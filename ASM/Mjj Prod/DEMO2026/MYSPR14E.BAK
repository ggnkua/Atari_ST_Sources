initcleartozerozero
	moveq #0,d0
	move.l codeeffliste,d4
	lea ptrlsteff,a2
	moveq #2-1,d7
xx4
	move.w #nbbob-1,d6
	move.l (a2)+,a3	
.clearall
	move.w d0,(a3)+
	move.l d4,(a3)+
	dbf d6,.clearall

	dbf d7,xx4
	rts


majangle
	lea ajoutangle,a0
	lea angles,a1
	moveq #1,d7
.loop
	move.w (a0)+,d0
	move.w (a1),d1
	add d0,d1
	and.w #511,d1
	move.w d1,(a1)+

	move.w (a0)+,d0
	move.w (a1),d1
	add d0,d1
	cmp.w #900,d1
	blt.s .1
	sub.w #900,d1
.1	move.w d1,(a1)+
	dbf d7,.loop

	moveq #1,d7
.loop2
	move.w (a0)+,d0
	move.w (a1),d1
	add d0,d1
	and.w #511,d1
	move.w d1,(a1)+

	move.w (a0)+,d0
	move.w (a1),d1
	add d0,d1
	cmp.w #900,d1
	blt.s .2
	sub.w #900,d1
.2	move.w d1,(a1)+
	dbf d7,.loop2

	rts

convsinus
	move.l sinx1,a1
	move.l sinx2,a2
	move.l sin512,a0
	move.w #511,d0
	move.w ptrconvX+2,d4
.loop
	moveq #0,d1
	move.w (a0)+,d1
	add.w #32767,d1

;	move.l d1,d2
	mulu #(160-8)*subpixel2,d1
;;	mulu #(159-8)*subpixel2,d2   ; 8 subpixel
	;asl #1,d1
	;asl #1,d2
	swap d1
	add.w #0*subpixel2,d1   ; additionner 5 pixel a x
;;	swap d2
; *10 = *8+*2 = *2(*4+1)

	add d1,d1
	move.w d1,d3
    add.w d3,d3 *4
    add.w d3,d3
    add d3,d1	; d1 = d1 * 10
;	and.w #-4,d1

;	and.w #-4,d2

;; 	add d2,d2
;;	move.w d2,d3
;;	add d3,d3
;; 	add d3,d3
;; 	add d3,d2

 	add d4,d1				; premiere table de sinus, on ajoute l'offset de convX
	move.w d1,(a1)+
;;	move.w d2,(a2)+
	dbf d0,.loop

	move.w #899,d0
	move.l sinx2,a1
	move.l sin900,a0
	
.loop2
	moveq #0,d1
	move.w (a0)+,d1
	add.w #32767,d1

	mulu #(159-8)*subpixel2,d1   ; 8 subpixel
	;asl #1,d1
	;asl #1,d2
	swap d1
;	add.w #5*subpixel2,d1   ; additionner 5 pixel a x
;;	swap d2
; *10 = *8+*2 = *2(*4+1)

	add d1,d1
	move.w d1,d3
    add.w d3,d3 *4
    add.w d3,d3
    add d3,d1	; d1 = d1 * 10
;	and.w #-4,d1

;	and.w #-4,d2

;; 	add d2,d2
;;	move.w d2,d3
;;	add d3,d3
;; 	add d3,d3
;; 	add d3,d2

 ;	add d4,d1				; premiere table de sinus, on ajoute l'offset de convX
	move.w d1,(a1)+
;;	move.w d2,(a2)+
	dbf d0,.loop2

	move.w ptrConvY+2,d4
	add.w #216*subpixel2*2,d4
	move.l siny1,a1
	;move.l siny2,a2
	move.l sin512,a0
	move.w #511,d0
.loopy
	moveq #0,d1
	move.w (a0)+,d1
	add.w #32767,d1
;;	move.l d1,d2
	mulu #(79-8)*subpixel2*2,d1
;;	mulu #(119-8)*subpixel2*2,d2
;	asl #1,d1
;	asl #1,d2
	swap d1
;;	swap d2
	and.w #-2,d1
;;	and.w #-2,d2
	add d4,d1			; ajoute l'offset segment
	move.w d1,(a1)+
	;;move.w d2,(a2)+
	dbf d0,.loopy

	;move.w ptrConvY+2,d4
	;add.w #216*subpixel2*2,d4
	move.l siny2,a1
	;move.l siny2,a2
	move.l sin900,a0
	move.w #900-1,d0
.loopy2
	moveq #0,d1
	move.w (a0)+,d1
	add.w #32767,d1
;;	move.l d1,d2
;;	mulu #(80-8)*subpixel2*2,d1
	mulu #(119-8)*subpixel2*2,d1
;	asl #1,d1
;	asl #1,d2
	swap d1
;;	swap d2
	and.w #-2,d1
;;	and.w #-2,d2
;;;	add d4,d1			; ajoute l'offset segment
	move.w d1,(a1)+
	;;move.w d2,(a2)+
.prout
	dbf d0,.loopy2

	
; createContigustable
;
; a0 = ram
; d0 = nombre d'element de la table sinus
; d1 = pas interne
; d2 = nombre de copie de valeurs
; a3 = table de sinus d'amplitude final
;
; pendant le fonctionnement:
; constante  d3,d4,d5 = pas interne,*2,*4
;
;
;

; retour:
; a0 = ram
; a1 = adresse table de d0 adresses  reftable pris a partir de la ram
;  

totoisback
	move.l parametreInternStep,a6		; le seul registre dispo
.automodif
	lea angles,a5
	move.w (a6)+,(a5)+	; cos
	move.w (a6)+,(a5)+	; cos
	move.w (a6)+,(a5)+	; sin
	move.w (a6)+,(a5)+	; sin


	lea ram3,a0
	move.w #512,d0
	move.w #nbbob,d2 ; nombre de copie de valeur
	move.w (a6)+,d1
	;move.w #512-13,d1		; pas interne 5 /512
	move.l sinx1,a3
	jsr createContigustable
.auto1	move.l a1,ptrref1

	move.w #900,d0
	move.w (a6)+,d1
	;move.w #14,d1
	move.w #nbbob,d2
	move.l sinx2,a3
	jsr createContigustable
.auto2	move.l a1,ptrref2

	move.w #512,d0
	move.w (a6)+,d1
	;move.w #512-16,d1
	move.w #nbbob,d2
	move.l siny1,a3
	jsr createContigustable
.auto3	move.l a1,ptrref3

	move.w #900,d0
	;	move.w #19,d1
	move.w (a6)+,d1	
	move.w #nbbob,d2
	move.l siny2,a3
	jsr createContigustable
.auto4	move.l a1,ptrref4


	lea ajoutangle,a5
	move.w (a6)+,(a5)+
	move.w (a6)+,(a5)+
	move.w (a6)+,(a5)+
	move.w (a6)+,(a5)+
;	lea angles,a5
;	move.w #128,(a5)+
;	move.w #128,(a5)+
;	move.w #0,(a5)+
;	move.w #0,(a5)

	move.l a6,parametreInternStep
	move.l (a6),d0
tstt	cmp.l #$31415926,d0
	bne.s .nolooop
	move.l #fct,d0
	move.l d0,parametreInternStep
.nolooop
	rts
