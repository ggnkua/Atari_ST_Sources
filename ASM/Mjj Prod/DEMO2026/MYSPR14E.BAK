fixfct:
; ajuste les valeurs 
; de chaque fonctionne de maniere a ce que ca soit compris 
; entre 0 et 511 ou entre 0 et 899

	move.l parametreInternStep,a0
	move.w #512,d3
	move.w #900,d4
.loop0
	moveq #5,d2
.loop1
	move.w (a0),d0
	move.w d3,d1
	bsr .changed0
	move.w d0,(a0)+
	move.w (a0),d0
	move.w d4,d1
	bsr .changed0
	move.w d0,(a0)+
	dbf d2,.loop1

	move.l (a0),d0
	cmp.l #$31415926,d0
	bne.s .loop0
	rts

.changed0
	tst d0
	bmi.s .1
.2	sub.w d1,d0
	bpl.s .2
	add.w d1,d0
	rts
.1 add.w d1,d0
   bmi.s .1
	rts



cossinm	macro
	dc.w 128,225,0,0
	endm

cossinv macro 
	dc.w 128+\1,225+\2,\3,\4
	endm
parametreInternStep	dc.l fct

fct
	cossinm
	dc.w 40,900-40,512-40,40
	dc.w 1,2,-2,-1

	cossinv 10,5,4,3
	dc.w 37,61,38,62
	dc.w 2,2,1,1

	cossinm
	dc.w 20,19,22,18
	dc.w +3,-1,1,-3
	cossinm
	dc.w 256+20,19,22,450+18
	dc.w 3,-1,2,-3

	cossinm
	dc.w 4,4,4,4
	dc.w 1,3,2,5 


	cossinm
	dc.w 18,3,18,4
	dc.W 1,2,-2,-1


	cossinm
	dc.w 20,33,20,33
	dc.w 2,2,2,2


	

	cossinm			; valeur classique cos sin cos sin
	dc.w 4,8,7,3		; pas entre les bobs
	dc.w -1,2,-3,4		; pas a chaque vbl


	cossinv 10,10,20,10
	dc.w 8,9,10,11
	dc.w 1,3,2,1

	cossinv 120,20,20,20		valeur de depart des cos et sin
	dc.w 13,-5,7,9			pas entre les bobs (ce que j'apellais pas interne sans pouvoir preciser)
	dc.w 4,1,2,3			pas a chaque vbl

	cossinv 30,30,10,30
	dc.w 4,20,3,10
	dc.w -3,-2,-7,4


	cossinv 120,10,-5,-7
	dc.w 14,6,24,6
	dc.w -1,2,-2,1
	cossinm
	dc.w 14,5,-4,9   1,-1,-1,1
	dc.w 3,2,1,-2

	cossinv 10,20,15,30
	dc.w 10,22,10,23
	dc.w 1,-1,2,1


	cossinv 0,-20,-30,-40
	dc.w -13,14,-16,11
	dc.w -1,2,-3,1	
  ; dc.w 3,4,7,6
	cossinm
	dc.w 4,11,-12,3
        dc.w 4,-3,6,1
	
	cossinm
	dc.w 10,-19,5,-15
	   dc.w 2,4,1,3
	cossinm
	dc.w 10,2,30,4
	   dc.w 1,4,-5,1
	cossinm
	  dc.w 5,15,10,-6
	   dc.w 1,5,-2,4
	cossinv 10,10,15,30	
	dc.w 50,-45,42,43
	dc.w 3,1,2,5
	cossinm
	dc.w 10,9,8,11
	dc.w -2,1,5,3

	cossinm
	dc.w 5,6,7,8
	dc.w 1,1,2,3

	cossinm
	dc.w 50,-59,-47,43
	dc.w 1,2,1,4
	
	cossinm
	dc.w 100,2,99,3
	dc.w 2,3,3,5
	
	cossinm
	dc.w 200,5,207,-6
	dc.w 1,4,-3,4

