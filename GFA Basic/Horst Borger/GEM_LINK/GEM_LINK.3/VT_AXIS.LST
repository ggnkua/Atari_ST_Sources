PROCEDURE vt_axis(handle%,xres%,yres%,xset%,yset%)
  ' set tablet exis resolution in lines
  '   setzt horizontale und vertikale Auflîsung des Graphiktabletts
  ' fÅr GRAPHIK-TABLETT
  DPOKE CONTRL+6,2
  DPOKE INTIN,xres%
  DPOKE INTIN+2,yres%
  ' die eingegebene Auflîsung in Zeilen
  @ein(82,handle%)
  *xset%=DPEEK(INTOUT)
  *yset%=DPEEK(INTOUT+2)
  ' gesetzte Auflîsung
RETURN
