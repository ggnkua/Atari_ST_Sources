PROCEDURE vsm_type(handle%,symbol%)
  ' set polymarker type
  '   bestimmt das Aussehen des Markertypes
  DPOKE INTIN,symbol%
  @vin(18,0,1,handle%)
  *set_type%=DPEEK(INTOUT)
  ' zurÅckgegeben wird Typ des Markers
  ' symbol und set_type kînnen folgende Formen darstellen :
  '   0 : kleines Fadenkreuz
  '   1 : Sternchen
  '   2 : kleines Rechteck
  '   3 : Andreaskreuz
  '   4 : Raute
RETURN
