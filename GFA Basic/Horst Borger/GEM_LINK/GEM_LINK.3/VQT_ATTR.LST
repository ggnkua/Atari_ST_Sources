PROCEDURE vqt_attributes(handle%)
  ' inquire current graphic text attributes
  '   erfragt die aktuellen Textattribute
  @vin(38,0,0,handle%)
  *font_id%=DPEEK(INTOUT)
  ' die aktuelle Fontnummer
  *font_color_index%=DPEEK(INTOUT+2)
  ' Farbindex fÅr Zeichenausgabe
  *text_rotation%=DPEEK(INTOUT+4)
  ' Textrotation in1/10 Grad
  *horizontal_len%=DPEEK(INTOUT+6)
  ' horizontale Textausrichtung
  *vertical_len%=DPEEK(INTOUT+8)
  ' vertikale Textausrichtung
  *write_mode%=DPEEK(INTOUT+10)
  ' Schreibmodus
  *char_width%=DPEEK(PTSOUT)
  ' Zeichenbreite
  *char_height%=DPEEK(PTSOUT+2)
  ' Zeichenhîhe
  *cell_width%=DPEEK(PTSOUT+4)
  ' Zeichenzellenbreite
  *cell_height%=DPEEK(PTSOUT+6)
  ' Zeichenzellenhîhe
RETURN
