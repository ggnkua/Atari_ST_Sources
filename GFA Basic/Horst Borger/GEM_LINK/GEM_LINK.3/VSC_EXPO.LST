PROCEDURE vsc_expose(handle%,state%)
  ' disable or enable film exposure for frame preview
  '   die Belichtung kann bei Kameras mit Preview-Mîglichkeit abgeschaltet
  '   werden
  ' fÅr POLAROID-PALETTE
  DPOKE CONTRL+6,1
  DPOKE INTIN,state%
  ' Belichtung ausschalten    0
  '            einschalten  <>0
  @ein(93,handle%)
RETURN
