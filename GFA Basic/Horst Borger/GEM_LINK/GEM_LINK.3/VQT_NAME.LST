PROCEDURE vqt_name(handle%,element_num%,nme)
  ' inquire face name and index
  DPOKE INTIN,element_num%
  ' Nummer des Zeichensatzes (1 bis max.Anzahl vefÅgbare Fonts)
  @vin(130,0,1,handle%)
  *index%=DPEEK(INTOUT)
  ' die Nummer des Zeichensatzes
  LOCAL i%
  i%=-1
  nme$=""
  REPEAT
    INC i%
    POKE *nme+i%,PEEK(INTOUT+i%)
    ' Nme$=Nme$+chr$(Dpeek(Intout+2*I%))
    ' In 'Nme$' wird der Name aus dem INTOUT-Feld gelesen
  UNTIL i%=32
RETURN
