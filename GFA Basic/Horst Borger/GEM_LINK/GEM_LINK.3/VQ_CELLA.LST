PROCEDURE vq_cellarray(handle%,pxyarray,row_length%,num_rows%,el_used%,rows_used%,status%,colarray)
  ' inquire cell array
  '   gibt Auskunft über die Definition dex Cell-Arrays NICHT auf allen Geräten
  '   verfügbar
  DPOKE CONTRL+14,row_length%
  ' Zeilenlänge im Array der Farbinizes
  DPOKE CONTRL+16,num_rows%
  ' Anzahl der Pixelzeilen
  @pxyarray(pxyarray,2)
  @vin(27,2,0,handle%)
  el_used%=DPEEK(CONTRL+18)
  ' Spaltenanzahl
  rows_used%=DPEEK(CONTRL+20)
  ' Anzahl benutzte Spalten im Array der Farbindizes
  status%=DPEEK(CONTRL+22)
  ' 0 -> kein Fehler
  ' 1 -> Fehler bei Index-Feststellen bei einigen Pixeln
  ' Im INTOUT-Block steht jetzt die Farbinfo für das Rechteck
RETURN
