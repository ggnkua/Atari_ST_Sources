PROCEDURE vq_mouse(handle%,pstatus%,x%,y%)
  ' sample mouse button status
  '   erfragt Mausinfo, Status linke Maustaste und Position des Graphik-
  '   Cursors
  @vin(124,0,0,handle%)
  *pstatus=DPEEK(INTOUT)
  ' gesetzte Bits :  0 linke / 1 rechte / >1 andere   Tasten
  *x%=DPEEK(PTSOUT)
  *y%=DPEEK(PTSOUT+2)
  ' die Position der Maus
RETURN
