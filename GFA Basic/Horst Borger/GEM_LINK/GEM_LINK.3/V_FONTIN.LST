PROCEDURE v_fontinit(handle%,font_hdr)
  ' init system font
  '   installiert angegebenen Zeichensatz als Systemzeichensatz, Pixelbreite
  '   konstant 8 + Motorola-Format
  '   ACHTUNG : KEINE OFFIZIELLE DOKUMENTATION !
  '             BENUTZUNG AUF EIGENE GEFAHR !!!!
  ' für BILDSCHIRM
  DPOKE CONTRL+6,2
  LPOKE INTIN,LPEEK(font_hdr)
  ' Ausnahmsweise, es muŞ noch überprüft werden, ob man den Font-hdr trennen
  ' muŞ
  @ein(102,handle%)
RETURN
