PROCEDURE vsl_type(handle%,style%)
  ' set polyline lien type
  '   w„hlt die Dartsellungsart von Linien aus (die ersten 6 sind von ATARI
  '   vorgegeben)
  DPOKE INTIN,style%
  '   0                      nix, was sonst
  '   1    ----------------  durchgehend
  '   2    ------------      langer Strich
  '   3    ---     ---       Punkte
  '   4    -------   ---     Strich Punkt
  '   5    --------          Strich
  '   6    ----   --  --     Strich Punkt Punkt
  '   7                      benutzerdefiniert
  @vin(15,0,1,handle%)
  *set_type%=DPEEK(INTOUT)
  ' ausgew„hlter Linientyp
RETURN
