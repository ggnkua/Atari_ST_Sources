PROCEDURE vsf_perimeter(handle%,per_vis%)
  ' set fill parameter visibility
  '   schaltet die automatische Umrahmung der Füllfläche ein ode aus
  DPOKE INTIN,per_vis%
  ' Flag für die Umrahmung  0  :  keine Umrahmung
  '                         1  :  mit Umrahmung
  @vin(104,0,1,handle%)
  *set_perimeter%=DPEEK(INTOUT)
  ' zurückgeben wird der tatsächlich ausgewählte Status
RETURN
