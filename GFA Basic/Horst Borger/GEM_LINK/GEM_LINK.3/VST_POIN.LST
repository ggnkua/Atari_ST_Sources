PROCEDURE vst_points(handle%,point%,char_width%,char_height%,cell_width%,cell_height%)
  ' set character height, points mode
  '   der Abstand zweier Basislinien wird bestimmt -> Zeichenzellengrîûe
  '   gemessen wird der Abstand in 1/72" (Druckerpunktgrîûe)
  DPOKE INTIN,point%
  @vin(107,0,1,handle%)
  *char_width%=DPEEK(PTSOUT)
  *char_height%=DPEEK(PTSOUT+2)
  *cell_width%=DPEEK(PTSOUT+4)
  *cell_height%=DPEEK(PTSOUT+6)
  *set_point%=DPEEK(INTOUT)
  ' zur¹ckgegeben wird die tats³chliche Zellengrîûe = Zeilenabstand
RETURN
