PROCEDURE v_justified(handle%,x%,y%,string,length%,word_flag%,char_flag%)
  ' GDP justified graphics text
  '   eine Zeichenkette wird in einer bestimmten Pixellänge ausggeben
  LOCAL i%
  i%=-1
  DPOKE PTSIN,x%
  DPOKE PTSIN+2,y%
  ' Anfangskoordinaten für den String
  DPOKE PTSIN+4,length%
  ' die Länge in x-Pixeln, auf die die Stringlänge gedehnt wird
  DPOKE PTSIN+6,0
  POKE INTIN,word_flag%
  ' ob zwischen Wörtern gedehnt wird
  POKE INTIN+2,char_flag
  ' ob zwischen Buchstaben gedehnt wird
  REPEAT
    ' dann mu× jedes Zeichen in den Eingabebereich gebracht werden
    INC i%
    POKE INTIN+4+i%,PEEK(string+i%)
  UNTIL PEEK(string+i%)=0
  @gin(2,2+i%,10,handle%)
RETURN
