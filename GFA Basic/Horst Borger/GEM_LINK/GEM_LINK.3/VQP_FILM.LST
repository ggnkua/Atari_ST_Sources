PROCEDURE vqp_filmname(handle%,index%,filmname)
  ' inquire camera film name
  '   Liefert zu einer Filmnummer den entsprechenden Namen (bis 24 Zeichen)
  '   bei Fehler kommt ein Nullstring zur…k
  DPOKE CONTRL+6,1
  DPOKE INTIN,index%
  @ein(92,handle%)
  LOCAL i%
  FOR i%=0 TO 23
    POKE (filmname+i%),PEEK(INTOUT+i%)
  NEXT i%
  ' der Filmname wird zur…kgegeben
RETURN
