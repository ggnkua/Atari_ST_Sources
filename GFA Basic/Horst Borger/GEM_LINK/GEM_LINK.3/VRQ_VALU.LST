PROCEDURE vrq_valuator(handle%,valuator_in%,valuator_out%,term%)
  ' input valuator, request mode
  '   ermitteln einer WertverÑnderung (Cursortasten) (NACH Tastendruck)
  ' NICHT implementiert im ROM
  DPOKE INTIN,valuator_in%
  ' Eingabewert
  @vin(29,0,1,handle%)
  *valuator_out%=DPEEK(INTOUT)
  ' RÅckgabewert, wenn er anders ist als der Eingabewert, hat sich was getan
  '   (tolle Logik, ne?)
  *term%=DPEEK(INTOUT+2)
  ' ASCII der auslîsenden Taste
RETURN
