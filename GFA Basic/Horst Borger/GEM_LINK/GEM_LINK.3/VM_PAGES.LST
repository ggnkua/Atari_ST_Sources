PROCEDURE vm_pagesize(handle%,page_width%,page_height%)
  ' physical page size
  '   setzt die Sietngrîûe in 1/10 mm
  ' f¹r METAFILE
  DPOKE CONTRL+6,3
  DPOKE INTIN,0
  ' Opcode f¹r VM_PAGESIZE
  DPOKE INTIN+2,page_width%
  DPOKE INTIN+4,page_height%
  ' die Seitengrîûe in 1/10 mm
  @ein(99,handle%)
RETURN
