PROCEDURE vsf_interior(handle%,style%)
  ' set fill interior index
  '   wählt den Fülltyp aus
  DPOKE INTIN,style%
  ' Fülltyp :  0  leer
  '            1  voll (einfarbig)
  '            2  Muster
  '            3  Schraffur
  '            4  frei definierbar
  @vin(23,0,1,handle%)
  *set_interior=DPEEK(INTOUT)
  ' ausgewählter Fülltyp
RETURN
