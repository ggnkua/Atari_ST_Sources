PROCEDURE vst_rotation(handle%,angle%)
  ' set character baseline vector
  '   der Winkel der Textausgabe wird gesetzt, in 1/10Grad. Der Bild-
  '   schirmtreiber kann's aber nur in 90Grad.
  DPOKE INTIN,angle%
  @vin(13,0,1,handle%)
  *set_angle%=DPEEK(INTOUT)
  ' zurÅckgegeben wird der wirkliche Winkel
RETURN
