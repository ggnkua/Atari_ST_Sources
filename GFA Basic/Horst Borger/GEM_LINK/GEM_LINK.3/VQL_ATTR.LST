PROCEDURE vql_attributes(handle%)
  ' inquire current polyline attributes
  '   erfragt die aktuellen Linienattribute
  @vin(35,0,0,handle%)
  *line_type%=DPEEK(INTOUT)
  *line_color_index%=DPEEK(INTOUT+2)
  *write_mode%=DPEEK(INTOUT+4)
  IF DPEEK(CONTRL+4)>3
    ' oder ob GDOS geladen ist (mit 'vq_gdos')
    *line_begstyle%=DPEEK(INTOUT+6)
    *line_endstyle%=dpee(INTOUT+8)
  ENDIF
  *line_width%=DPEEK(PTSOUT)
RETURN
