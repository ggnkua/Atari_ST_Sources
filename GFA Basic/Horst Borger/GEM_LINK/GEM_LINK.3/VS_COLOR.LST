PROCEDURE vs_color(handle%,index%,rgb_in%)
  LOCAL i%
  ' set color representation
  '   wählt die Farbintensität zu den einzelnen Farbregistern
  DPOKE INTIN,index%
  ' die ersten 16 Farben sind vom ATARI vorgegeben (kennt man ja), dort
  '   bitte NICHTS verändern
  FOR i%=0 TO 2
    ' 0 = Rot, 1 = Grün, 2 = Blau
    DPOKE INTIN+i%*2,DPEEK(rgb_in%+2*i%)
  NEXT i%
  @vin(14,0,4,handle%)
RETURN
