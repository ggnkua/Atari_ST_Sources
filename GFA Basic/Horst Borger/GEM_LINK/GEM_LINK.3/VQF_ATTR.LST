PROCEDURE vqf_attributes(handle%)
  ' inquire current fill area attributes
  '   erfragt die aktuellen FÅllattribute
  @vin(37,0,0,handle%)
  *fill_style%=DPEEK(INTOUT)
  '  das FÅllmuster
  *fill_colorindex%=DPEEK(INTOUT+2)
  ' Index der FÅllfarbe
  *style_index%=DPEEK(INTOUT+4)
  ' Musterindex
  *write_mode%=DPEEK(INTOUT+6)
  ' Schreibmodus
  *border_status%=DPEEK(INTOUT+8)
  ' Umrahmungsstatus
RETURN
