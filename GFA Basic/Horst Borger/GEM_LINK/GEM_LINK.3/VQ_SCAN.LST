PROCEDURE vq_scan(handle%,g_slice%,g_page%,a_slice%,a_page%,div_fac%)
  ' inquire printer scan
  '   Abfrage einiger Druckerparameter
  ' nur DRUCKER
  DPOKE CONTRL+8,5
  @ein(24,handle%)
  *g_slice%=DPEEK(INTOUT)
  ' Anzahl der Drucker-'slices' -> Teile einer ganzen Seite
  *g_page%=DPEEK(INTOUT+2)
  ' Pixelhîhe einer Scheibe
  *a_slice%=DPEEK(INTOUT+4)
  ' Pixelhîhe einer Textzeile
  *a_page%=DPEEK(INTOUT+6)
  ' Textzeilen pro Seite%
  *div_fac%=DPEEK(INTOUT+8)
  ' ggf. mÅssen die oben genannten Werte noch durch diesen Faktor geteilt werden
RETURN
