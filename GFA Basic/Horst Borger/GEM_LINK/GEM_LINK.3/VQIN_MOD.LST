PROCEDURE vqin_mode(handle%,dev_type%,input_mode%)
  ' inquire input mode
  '   ergibt den aktuellen EIngabemodus fЃr das zuletzt angew„hlte Eingabeger„t
  DPOKE INTIN,dev_type%
  ' Logisches Eingabeger„t     1 Positionseingabe (Maus)
  '                            2 Wertver„ndernde Eingabe (Cursor VORSICHT!!!)
  '                            3 ausw„hlende Eingabe (F-Tasten)
  '                            4 Zeichenketteneingabe (Tastatur)
  @vin(115,0,1,handle%)
  *input_mode%=DPEEK(INTOUT)
  ' Eingabemodus               1 Request
  '                            2 Sample
RETURN
