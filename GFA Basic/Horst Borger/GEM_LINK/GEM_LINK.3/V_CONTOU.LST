PROCEDURE v_contourfill(handle%,x%,y%,index%)
  ' contour fill
  '   füllt eine Fläche aus, die entweder durch den Bildschirmrand oder eine
  '   bestimmte Farbe begrenzt wird
  DPOKE PTSIN,x%
  DPOKE PTSIN+2,y%
  ' x/y ist der Startpunkt, von dem aus gefüllt wird
  DPOKE INTIN,index%
  ' index ist der Farbindex, mit der gefüllt wird
  @vin(103,1,1,handle%)
RETURN
