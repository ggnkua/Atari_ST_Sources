PROCEDURE vsc_form(handle%,pcur_form)
  ' set mouse form
  '   Graphik-Cursor (Maus) kann definiert werden
  FOR i%=0 TO 36
    POKE INTIN+i%,PEEK(pcur_form+i%)
  NEXT i%
  ' die Mausform muž in den INTIN-Berich gebacht werden
  ' Aufbau  : 0      realtives X des Aktionspunktes
  '           1      relatives Y des Aktionspunktes
  '           2      1 (reserviert)
  '           3      Hintergrundfarbe (0)
  '           4      Vordergrundfarbe (1)
  '           5 - 20 Hintergrundmaske
  '          21 - 36 Vordergrundmaske
  @vin(111,0,37,handle%)
RETURN
