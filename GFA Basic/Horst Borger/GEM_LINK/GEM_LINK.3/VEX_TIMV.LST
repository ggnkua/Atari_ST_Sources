PROCEDURE vex_timv(handle%,tim_addr,otim_addr,tim_conv%)
  ' exchange timer interrupt vector
  '   eine alte Interrupt-Adresse wird durch eine neue Adresse ersetzt
  '   DAS EIGENE PROGRAMM MUSS DIE ALTE ADRESSE SPEICHERN UND AM ENDE
  '   WIEDER HERSTELLEN, SONST RAPPELT'S
  LPOKE CONTRL+14,tim_addr
  ' Adresse der alten Interruptroutine
  LPOKE CONTRL+18,otim_addr
  ' Adresse der neuen Interruptroutine
  @vin(118,0,0,handle%)
  *otim_addr=LPEEK(CONTRL+18)
  *tim_conv%=DPEEK(INTOUT)
  ' Interruptintervall in Millisekunden
RETURN
