PROCEDURE vq_extprn(handle%,owflag%,intout,xmax%,ymax%)
  ' extended printer inquire function
  '   erweiterte Abfragefunktion der Standardparameter incl MATRIXdrucker
  DPOKE INTIN,owflag%
  '   0  : Standardparameter
  '   1  : erweiterte Parameter
  DPOKE PTSIN,xmax%
  DPOKE PTSIN+2,ymax%
  @vin(102,2,1,handle%)
  IF ow_flag%=0
    @opn
  ELSE
    @opn_ext
  ENDIF
RETURN
