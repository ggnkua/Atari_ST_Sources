PROCEDURE vst_height(handle%,height%,char_width%,char_height%,cell_width%,cell_height%)
  ' set character height, absolute mode
  '   setzt die absoluteZeichengr”˛e : von der Basislinie bis zur
  '   Zeichenzellenobergrenze
  DPOKE PTSIN,0
  DPOKE PTSIN+2,height%
  @vin(12,1,0,handle%)
  *char_width%=DPEEK(PTSOUT)
  *char_height%=DPEEK(PTSOUT+2)
  *cell_width%=DPEEK(PTSOUT+4)
  *cell_height%=DPEEK(PTSOUT+6)
  ' im Falle eines Proportionalzeichensatzes wird die gr”˛te Zeichen- und
  '   Zellenbreite ausgegeben
RETURN
