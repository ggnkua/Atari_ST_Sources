PROCEDURE v_curtext(handle%,string)
  ' output cursor adressable alpha text
  '   Zeichenkette an String wird an der aktuellen Cursorposition ausgegeben
  ' für BILDSCHIRM
  LOCAL i%
  i%=-1
  REPEAT
    ' jedes Zeichen muŞ in den Eingabebereich gebracht werden
    INC i%
    POKE INTIN+i%,PEEK(string+i%)
  UNTIL PEEK(string+i%)=0
  DPOKE CONTRL+6,i%
  @ein(12,handle%)
RETURN
