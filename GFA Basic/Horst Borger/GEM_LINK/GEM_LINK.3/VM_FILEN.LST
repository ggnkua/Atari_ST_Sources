PROCEDURE vm_filename(handle%,flename)
  ' change gem vdi filename
  '   ändert den Namen des GEM-Files von GEMFILE.GEM in *.GEM
  '   die Funktion wird nur direkt nach Öffnen der Workstation ausgeführt !!
  '   Pfadname kann mit angegeben sein; ein schon geöffnetes Metafile wird
  '   geschlossen
  ' für METAFILE
  LOCAL i%
  i%=-1
  REPEAT
    ' jedes Zeichen mu× in den Eingabebereich gebracht werden
    INC i%
    POKE INTIN+i%,PEEK(filename+i%)
  UNTIL PEEK(filename+i%)=0
  DPOKE INTIN+6,i%
  ' Filename darf max. 74 Zeichen incl. Pfadnamen und Endekennung 0 sein
  @ein(100,handle%)
RETURN
