PROCEDURE vsm_valuator(handle%,valuator_in%,valuator_out%,term%,status%)
  ' input valuator, sample mode
  '   eine Wertveränderung wird ermittelt
  ' NICHT implementiert im ROM
  DPOKE INTIN,valuator_in%
  ' Eingabeweert
  @vin(29,0,1,handle%)
  status%=PEEK(CONTRL+8)
  ' Status  :  0 keine Änderung
  '            1 Wertänderung
  '            2 Taste betätigt
  *valuator_out=DPEEK(INTOUT)
  ' Rückgabewert
  *term=DPEEK(INTOUT+2)
  ' ASCII der betätigten Taste
RETURN
