PROCEDURE vr_trnfm(handle%,pscr_mfdb,pdes_mfdb)
  ' transform form
  '   wandelt ein Raster vom geräteabhängigen Format in Standard oder
  '   umgekehrt
  LPOKE CONTRL+14,psrc_mfdb
  ' Adresse des Quellrasters
  LPOKE CONTRL+18,pdes_mfdb
  ' Adresse des Zielrasters
  '   die Adressen der Rasterblöcke müssen erst mal in den Adressbereich
  '   ge-lpoket werden
  @vin(110,0,0,handle%)
RETURN
