PROCEDURE vq_extnd(handle%,owflag%,intout)
  ' extended inquire function
  '   erweiterte Abfragefunktion der Standardparameter
  DPOKE INTIN,owflag%
  '   0  : Standardparameter
  '   1  : erweiterte Parameter
  @vin(102,0,1,handle%)
  IF ow_flag%=0
    @opn
  ELSE
    @opn_ext
  ENDIF
RETURN
