PROCEDURE vsf_udpat(handle%,pfill_pat%,planes%)
  ' ACHTUNG : in der Originaldokumentation stand Vsf_updat !
  LOCAL i%
  i%=-1
  ' set user-defined fill pattern
  '   hier wird das frei definierbare FÅllmuster festgelegt)
  '   [ s. vsf_interior(Handle%,4) ]
  DPOKE INTIN,planes%
  ' Anzahl der Farbebenen
  REPEAT
    ' die gesamten Farbebenen mÅssen in den INTIN-Bereich verschoben werden
    INC i%
    DPOKE INTIN+i%*2,PEEK(pfill_pat%+i%*2)
  UNTIL i%=planes%*16-1
  @vin(112,0,16*planes%,handle%)
RETURN
