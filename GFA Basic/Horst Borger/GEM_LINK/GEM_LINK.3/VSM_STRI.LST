PROCEDURE vsm_string(handle%,max_len%,echo_mode%,echo_xy,string)
  ' input string, sample mode
  '   Ausgabe eines Strings von der Tastatur, mit oder ohne Echo auf dem
  '   Ausgabegre³t (nicht auf allen mîglich)
  '   Abschluû des Strings mit RETURN oder mit Stringende oder durch einen
  '     nicht verf¹gbaren Wert (z.B. Steuerzeichen)
  DPOKE INTIN,max_length%
  DPOKE INTIN+2,echo_mode%
  ' Echo-Mode  :  0 aus / 1 ein (Textausgabe auf Monitor)
  @pxyarray(echo_xy,2)
  LOCAL i%
  i%=-1
  REPEAT
    ' dann muû jedes Zeichen nach INTOUT transportiert werden
    INC i%
    POKE INTOUT+i%,PEEK(string+i%)
  UNTIL PEEK(string+i%)=0 OR i%=max_len%-1
  POKE CONTRL+8,i%
  @vin(31,1,2,handle%)
  *status=DPEEK(INTOUT)
  ' 0   -> Ausgabe abgebrochen durch ung¹ltiges Zeichen
  ' >0  -> Stringl³nge
RETURN
