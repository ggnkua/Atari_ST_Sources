PROCEDURE vqt_extent(handle%,string,extent%)
  ' inquire text extent
  '   berechnet AusmaŞe des kleinsten Rechteckes, in das der String paŞt,
  '   auf den der entesprechende Zeiger zeigt, unter Berücksichtigung der
  '   Texteffekte
  LOCAL i%
  i%=-1
  REPEAT
    ' dann muŞ jedes Zeichen in den Eingabebereich gebracht werden
    INC i%
    POKE INTIN+i%,PEEK(string+i%)
  UNTIL PEEK(string+i%)=0
  @vin(116,0,i%,handle%)
  ' Extent% gibt die Adresse an, an die die Koordinaten abgelegt werden sollen
  '   hier werden sie aber direkt aus dem PTSOUT-Block geholt
  *x_liunt%=DPEEK(PTSOUT)
  *y_liunt%=DPEEK(PTSOUT+2)
  *x_reunt%=DPEEK(PTSOUT+4)
  *y_reunt%=DPEEK(PTSOUT+6)
  *x_reobe%=DPEEK(PTSOUT+8)
  *y_reobe%=DPEEK(PTSOUT+10)
  *x_liobe%=DPEEK(PTSOUT+12)
  *y_liobe%=DPEEK(PTSOUT+14)
  ' Die Koordinatenpaare der vier Ecken des einschlieŞenden Rechteckes
  '   beginnend links unten gegen der Uhrzeigersinn
RETURN
