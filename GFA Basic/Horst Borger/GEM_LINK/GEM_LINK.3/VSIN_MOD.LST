PROCEDURE vsin_mode(handle%,dev_type%,mode%)
  ' set input mode
  '   setzt den Eingabe-Modus eines EingabegerÑtes
  DPOKE INTIN,dev_type%
  ' Eingabeeinheit :  1  Maus (Positionseingabe)
  '                   2  Cursor (WertÑnderungs-Eingaben VORSICHT :
  '                              NICHT implementiert im ROM)
  '                      (SHIFT/ALTERNATE/CONTROL ???)
  '                   3  Funktionstasten (Auswahleingabe)
  '                   4  Tastatur (Stringeingaben)
  DPOKE INTIN+2,mode%
  ' Eingabe-Modus     1  Request (wartet auf Eingabe)
  '                   2  Sample (Abfrage des Zustandes oder Position)
  @vin(33,0,2,handle%)
  *set_mode%=DPEEK(INTOUT)
  ' zurÅckgegeben wird der Modus oder der Status des EingabegerÑtes
  ' TURBOWICHITG : lieber NICHT benutzen, es sei es werden das AES
  '                benutzt keine VDI-Eingebefunktionen. (Das tut es fast
  '                immer)
RETURN
