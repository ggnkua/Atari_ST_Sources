PROCEDURE vm_coords(handle%,x_lu%,y_lu%,x_ro%,y_ro%)
  ' coordinate window
  '   setzt das Koordinatensystem f〉 die Seite
  ' f〉 METAFILE
  DPOKE CONTRL+6,5
  DPOKE INTIN,1
  ' Opcode f〉 VM_COORDS
  DPOKE INTIN+2,x_lu%
  DPOKE INTIN+4,y_lu%
  DPOKE INTIN+6,x_ro%
  DPOKE INTIN+8,y_ro%
  @ein(99,handle%)
RETURN
