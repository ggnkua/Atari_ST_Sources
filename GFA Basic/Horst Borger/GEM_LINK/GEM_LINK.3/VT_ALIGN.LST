PROCEDURE vt_alignment(handle%,xoffset%,yoffset%)
  ' set tablet alignment
  '   setzt in einem Ausschnitt eines Graphiktabletts die Ausrichtung des
  '   Koordinatensystems
  ' fÅr GRAPHIK-TABLETT
  DPOKE CONTRL+6,2
  DPOKE INTIN,xoffset%
  DPOKE INTIN+2,yoffset%
  ' X- und Y-Abstand zum Koordinatenursprung
  @ein(85,handle%)
RETURN
