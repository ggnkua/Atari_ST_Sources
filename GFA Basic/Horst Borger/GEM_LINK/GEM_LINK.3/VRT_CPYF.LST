PROCEDURE vrt_cpyfm(handle%,wr_mode%,pxyarray,pscr_mfdb,pdes_mfdb,color_index1%,color_index2%)
  ' copy raster, transparent
  '   pixelweises Kopieren von Quell- in Zielraster, wobei die Farbwerte fest-
  '   gelegt werden, für die die Werte 0 und 1 angenommen werden sollen
  DPOKE INTOUT,0
  DPOKE INTIN,wr_mode%
  DPOKE INTIN+2,color_index1%
  ' die Farbe wird als 'weiŞ' angenommen
  DPOKE INTIN+4,color_index2%
  ' die Farbe wird als 'schwarz' angenommen
  @pxyarray(pxyarray,8)
  LPOKE CONTRL+14,psrc_mfdb
  ' Adresse des Quellrasters
  LPOKE CONTRL+18,pdes_mfdb
  ' Adresse des Zielrasters
  '   die Adressen der Rasterblöcke müssen erst mal in den Adressbereich
  '   ge-lpoket werden
  @vin(121,4,3,handle%)
  *fehler=DPEEK(INTOUT)
  ' wenn der Wert nicht 0 ist, war irgendetwas falsch
RETURN
