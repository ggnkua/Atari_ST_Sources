PROCEDURE vq_chcells(handle%,rows%,colums%)
  ' inquire addressable alpha charcter cells
  '   gibt die Anzahl der möglichen Zeilen + Spalten für den Cursor
  ' für BILDSCHIRM
  @ein(1,handle%)
  DPOKE (CONTRL+4),2
  *rows%=DPEEK(INTOUT)
  ' Anzahl der Zeilen
  *columns%=DPEEK(INTOUT+2)
  ' Zeilen + Spalten, wenn nicht adressierbar, dann kommt -1 zurück
RETURN
