PROCEDURE vst_load_fonts(handle%,select%)
  ' load fonts
  '   lädt zusätzliche Zeichensätze
  POKE INTIN,0
  '          ^ hier müŞte das 'select' hin, das ist aber immer reserviert = 0
  @vin(119,0,1,handle%)
  *more_fonts%=DPEEK(INTOUT)
  '   0  ->  keine weiteren Fonts verfügbar oder nachgefragter schon eingeladen
  '   >0 ->  Anzahl verfügbarer Zeichensätze
  ' WICHTIG :
  '   vorher mit vq_gdos nachfragen, ob das GDOS installiert ist, sonst gibt's
  '   einen Crash
RETURN
