PROCEDURE vm_palette(handle%,palette%)
  ' select palette
  '   Auswahl der Farbpalette auf einer IBM-CGA-Graphikkarte in mitterer
  '   Auflîsung
  ' nur IBM-CGA-GRAPHIKKARTE
  DPOKE CONTRL+6,1
  DPOKE INTIN,palette%
  ' Farbpalette  0 Rot/Gr¹n/Blau
  '              1 Cyan/Magenta/Weiû
  @ein(60,handle%)
  *set_palette%=DPEEK(INTOUT)
  ' die ausgew³hlte Palette
RETURN
