PROCEDURE vst_alignment(handle%,hor_in%,vert_in%,hor_out%,vert_out%)
  ' set graphic text alignment
  '   die horizontale und vertikale Ausrichtungeines Textes kann bestimmt werden
  '   Hoizontal 3 M”glichkeiten, Vertikal 6 M”glichkeiten
  DPOKE INTIN,hor_in%
  ' horizontale Ausrichtung :  1  links justiert
  '                            2  zentriert
  '                            3  rechts zentriert
  DPOKE INTIN+2,vert_in%
  ' vertikale Ausrichtung   :  0  Basislinie des Zeichens
  '                            1  Halblinie (Oberkante Kleinbuchstaben)
  '                            2  Zeichenoberkante
  '                            3  Zeichenzellenunterkante
  '                            4  Zeichenunterkante
  '                            5  Zeichenzellenoberkante
  @vin(39,0,2,handle%)
  *hor_out=DPEEK(INTOUT)
  *vert_out=DPEEK(INTOUT+2)
RETURN
