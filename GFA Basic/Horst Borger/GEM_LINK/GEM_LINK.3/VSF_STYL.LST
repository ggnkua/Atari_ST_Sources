PROCEDURE vsf_style(handle%,style_index%)
  ' set fill style index
  '   der Mustetyp zum F¹llindex wird ausgew³hlt
  DPOKE INTIN,style_index%
  ' bei F¹lltyp 0 wird alles weiû
  '             1 einfarbig in der angegebenen Farbe
  '             2 sind Muster
  '             3 Schraffuren
  '             4 frei definierbar
  ' f¹r die genauen Muster bitte Lteratur nachschlagen
  @vin(24,0,1,handle%)
  *set_style%=DPEEK(INTOUT)
  ' zur¹ckgegeben wird der gestzte F¹lltyp
RETURN
