PROCEDURE vt_resolution(handle%,xres%,yres%,xset%,yset%)
  ' set tablet axis resolution in lines/inch
  '   setzt horizontale und vertikale Auflîsung des Graphiktablets
  ' fÅr GRAPHIK-TABLETT
  DPOKE CONTRL+6,2
  DPOKE INTIN,xres%
  DPOKE INTIN+2,yres%
  ' die eingegebene Auflîsung
  @ein(81,handle%)
  *xset%=DPEEK(INTOUT)
  *yset%=DPEEK(INTOUT+2)
  ' gesetzte Auflîsung
RETURN
