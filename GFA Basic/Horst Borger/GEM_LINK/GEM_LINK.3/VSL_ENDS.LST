PROCEDURE vsl_ends(handle%,line_begstyle%,line_endstyle%)
  ' set polyline end styles
  '   Die Enden einer Linie oder Polylinie k”nnen in ihrem Aussehen bestimmt
  '   werden.
  DPOKE INTIN,line_begstyle%
  DPOKE INTIN+2,line_endstyle%
  ' die Linienenden k”nnen folgendes Aussehen haben
  '   0 : eckig
  '   1 : Pfeil
  '   2 : abgerundet
  @vin(108,0,2,handle%)
RETURN
