PROCEDURE vqm_attributes(handle%)
  ' inquire current polymarker attributes
  '   erfragt die aktuellen Markerattribute
  @vin(36,0,0,handle%)
  *marker_type%=DPEEK(INTOUT)
  *marker_color_index%=DPEEK(INTOUT+2)
  *write_mode%=DPEEK(INTOUT+4)
  IF DPEEK(CONTRL+4)>3
    ' oder ob GDOS geladen ist (mit 'vq_gdos')
    *marker_width%=DPEEK(PTSOUT)
  ENDIF
  *marker_height=DPEEK(PTSOUT+2)
RETURN
