PROCEDURE vs_mute(handle%,action%)
  ' set/clear tone muting flag
  '   setzt oder lîscht das Tonflag oder liefert dessen Status zurÅck
  ' fÅr BILDSCHIRM
  ' NICHT im Rom-Bildschirmtreiber implementiert
  DPOKE CONTRL+6,1
  DPOKE INTIN,action%
  ' was gemacht werden soll   -1 Status abfragen
  '                            0 Tonerzeugung ein
  '                            1 Tonerzeugung aus
  @ein(62,handle%)
  *status%=DPEEK(INTOUT)
  ' der aktuelle Status
RETURN
