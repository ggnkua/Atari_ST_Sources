PROCEDURE vro_cpyfm(handle%,write_mode%,pxyarray,psrc_mfdb,pdes_mfdb)
  ' copy raster, opaque
  '   kopiert von einem Quell- in ein Zielraster, wobei logische Verknüpf-
  '   ungen beachtet werden. Ist das Zielraster grö×er als das Ausgangsraster,
  '   so wird automatisch die Grö×e des Zielrasters genommen, bzw. nur der
  '   Pointer auf das Zielraster benutzt. Das Clipping wird nur auf dem
  '   Bildschirm ausgeführt !
  ' TURBOWICHTIG : Raster in Standardformat dürfen NICHT kopiert werden,
  '                zuerst müssen sie mit VDI110 (transform form) in das
  '                ATARI-Format gebracht werden. Steht im MFDB-Block
  '  die Struktur eines MFDB-Blockes :
  '  Adresse   Art  Var-Name   Bedeutung
  '  0-3       LONG fd_addr    Zeiger auf Rasterblock
  '  4+5       INT  fd_w       Pixelbreite des Rasterblockes
  '  6+7       INT  fd_h       Pixelhöhe
  '  8+9       INT  fd_wdw     WORD-Breite des Rasterblockes
  '  10+11     INT  fd_stand   0  :  geräteabhängig
  '                            1  :  STANDARDFORMAT
  '  12+13     INT  fd_nplanes Anzahl der Bildebenen
  '  14+15     INT  fd_res1    reserviert
  '  16+17     INT  fd_res2    reserviert
  '  18+19     INT  fd_res3    reserviert
  DPOKE INTOUT,0
  ' 'Rückgabewert' auf 0 setzen, damit man nachher eine Möglichkeit hat,
  '   festzustellen, ob was passiert ist
  DPOKE INTIN,write_mode%
  ' der Schreibmodus (0-15)
  '   0  0 (Ziel wird 'wei×')
  '   1  Start AND Ziel
  '   2  Start AND (NOT Ziel)
  '   3  Start
  '   4  (NOT Start) AND Ziel
  '   5  Ziel
  '   6  Start XOR Ziel
  '   7  Start OR Ziel
  '   8  NOT (Start OR Ziel)
  '   9  NOT (Start XOR Ziel)
  '  10  NOT Ziel
  '  11  Start OR (NOT Ziel)
  '  12  NOT Ziel
  '  13  (NOT Strt) OR Ziel
  '  14  NOT (Start AND Ziel)
  '  15  1 (Ziel wird 'schwarz')
  @pxyarray(pxyarray,8)
  LPOKE CONTRL+14,psrc_mfdb
  ' Adresse des Quellrasters
  LPOKE CONTRL+18,pdes_mfdb
  ' Adresse des Zielrasters
  '   die Adressen der Rasterblöcke müssen erst mal in den Adressbereich
  '   ge-lpoket werden
  @vin(109,4,1,handle%)
  ' keine Angabe über einen Rückgabewert, aber vorsichtshalber mal im
  '   INTOUT nachschauen, ob sich was getan hat
  *fehler%=DPEEK(INTOUT)
RETURN
