PROCEDURE vqt_width(handle%,character%,cell_width%,left_delta%,right_delta%)
  ' inquire charcter cell width
  '   berechnet die horizontalen Zeichenzellenwerte ohne BerÅcksichtigung der
  '   Texteffekte
  DPOKE INTIN,charcter%
  ' der ASCII-Wert des abzufragenden Zeichens
  @vin(117,0,1,handle%)
  *cell_width%=DPEEK(PTSOUT)
  ' Zeichenzellenbreite
  *left_delta%=DPEEK(PTSOUT+4)
  ' Abstand linker Zeichenzellenrand <-> linker Zeichenrand
  *right_delta%=DPEEK(PTSOUT+8)
  ' Abstand rechter Zeichenzellenrand <-> rechter Zeichenrand
RETURN
