PROCEDURE vq_key_s(handle%,pstatus%)
  ' sample keybnoard state information
  '   gibt Info über Status der Sondertasten zurück
  @vin(128,0,0,handle%)
  *pstatus=DPEEK(INTOUT)
  ' Jedes Bit zählt
  '   0x0001  K_RSHIFT rechte Shifttaste
  '   0x0002  K_LSHIFT linke Shifttaste
  '   0x0004  K_CTRL   Control
  '   0x0008  K_ALT    Alternate
RETURN
