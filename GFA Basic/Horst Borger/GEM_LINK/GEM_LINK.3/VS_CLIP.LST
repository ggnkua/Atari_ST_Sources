PROCEDURE vs_clip(handle%,clip_flag%,pxyarray)
  ' set clipping rectangle
  '   Arbeitsbereich wird festgelegt oder freigegeben
  '   ohne Clip-Rechteck, wird an den Bildschirmgrenzen NICHT geklippt
  POKE INTIN,clip_flag%
  ' das VDI mu× wissen, welche Variante gewünscht wird
  '   0  -> Arbeitsbereich clippen aus
  '   1  ->        %          %    ein
  @pxyarray(pxyarray,2)
  ' die Koordinaten der Punktepaare müssen ins PTSIN-Feld gebracht werden
  '  pxyarray ist die Adresse + Anzahl Kooedinatenpaare
  @vin(129,2,1,handle)
  pioff%=PTSIN
  ' zur Sicherheit PTSIN festhalten
RETURN
