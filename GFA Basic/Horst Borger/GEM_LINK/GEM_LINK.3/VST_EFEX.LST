PROCEDURE vst_efexts(handle%,effect%)
  ' set raphic text special effects
  '   wÑhlt verschiedene Textausgaben
  '   0x00  TF_NORMAL       normaler Text
  '   0x01  TF_THICKENED    Fettschrift
  '   0x02  TF_LIGHTENED    helle Schrift
  '   0x04  TF_SLANTED      kursive Schrift
  '   0x08  TF_UNDERLINED   unterstrichen
  '   0x10  TF_OUTLINED     umrandet + ausgehîhlt
  '   0x20  TF_SHADOWED     schattierte Schrift (beim ST nichtimplementiert)
  '   das sind Bitwerte,man kann also auch Kombinationen machen
  DPOKE INTIN,effect%
  @vin(106,0,1,handle%)
  *set_effect=DPEEK(INTOUT)
  ' der tatsÑchlich eingestellt Textstyle
RETURN
