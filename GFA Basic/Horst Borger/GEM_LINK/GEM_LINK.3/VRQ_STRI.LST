PROCEDURE vrq_string(handle%,max_len%,echo_mode%,echo_xy,string)
  ' input string, request mode
  '   Ausgabe eines Strings von der Tastatur, mit oder ohne Echo auf dem
  '   Ausgabegre„t (nicht auf allen m”glich)
  '   Abschluž des Strings mit RETURN oder mit Stringende
  DPOKE INTIN,max_length%
  DPOKE INTIN+2,echo_mode%
  ' Echo-Mode  :  0 aus / 1 ein (Textausgabe auf Monitor)
  @pxyarray(echo_xy,2)
  LOCAL i%
  i%=-1
  REPEAT
    ' dann muž jedes Zeichen nach INTOUT transportiert werden
    INC i%
    POKE INTOUT+i%,PEEK(string+i%)
  UNTIL PEEK(string+i%)=0 OR i%=max_len%-1
  POKE CONTRL+8,i%
  @vin(31,1,2,handle%)
RETURN
