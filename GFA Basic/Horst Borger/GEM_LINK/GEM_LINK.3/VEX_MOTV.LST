PROCEDURE vex_motv(handle%,pusrcode,psavcode)
  ' exchange mouse movement vector
  '   die Routine, die durch Mausbawegung angesteuert wird, wird geÑndert
  '   der Vektor der alten Mausroutine wird gerettet, die neue Routine
  '   ausgefÅhrt und die alte Adresse wieder hergestellt
  LPOKE CONTRL+14,pusrcode
  ' die Adresse der neuen Mausbewegungs-Routine
  LPOKE CONTRL+18,psavcode
  ' die Adresse der alten Mausbewegungs-Routine
  @vin(126,0,0,handle%)
  *psavcode=LPEEK(CONTRL+18)
RETURN
