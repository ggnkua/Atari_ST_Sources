PROCEDURE v_cellarray(handle%,pxyarray,row_length%,el_used%,num_rows%,wrt_mode%,colorarray)
  ' jetzt wird's kompliziert, weil die Funktion NICHT im ROM implementiert ist
  ' cell array
  '   Darstellung eines komplexen Farbbildschirm, jedes Pixel bekommt eine Farbe
  '   zugeordnet
  @pxyarray(pxyarray,2)
  @vin(10,2,row_length%*num_rows%,handle%)
RETURN
