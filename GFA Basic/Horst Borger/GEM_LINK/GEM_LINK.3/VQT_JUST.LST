PROCEDURE vqt_justified(handle%,x%,y%,string,length%,word_space%,char_space%,offsets)
  ' inquire justified graphics text
  '   frgat für jedes Zeichen einer Zeichenkete Offsets von einem Ausgangs-
  '   punkt ab
  v%=GEMDOS(48)
  ' Versionsabfrage
  LOCAL i%,j%
  IF (v% AND 255)>1
    ' FUNKTIONIERT ERST AB GEM GRÖSSER V.2 !!!!!!!!!!!!
    '  Die Abfrage lieber über _sysbase machen
    DPOKE INTIN,word_space%
    ' Flag für Wortzwischenräume     0  ohne
    '                               >0 mit Dehnung zwischen den Wörtern
    DPOKE INTIN+2,char_space%
    ' Flag für Zeichenzwischenräume  0  ohne
    '                                1  mit Dehnung zwischen den Buchstaben
    i%=-1
    REPEAT
      ' jedes Zeichen mu× in den Eingabebereich gebracht werden
      INC i%
      POKE INTIN+i%,PEEK(string+i%)
    UNTIL PEEK(string+i%)=0
    DPOKE PTSIN,x%
    DPOKE PTSIN+2,y%
    ' die Ausgangspunktkoordinaten
    DPOKE PTSIN+4,length%
    ' Textlänge in X-Pixeln
    @vin(132,3,2+i%,handle%)
    j%=-1
    REPEAT
      ' jeder Offset mu× in den Offsetbereich gebracht werden
      ' Der Offsetbereich ist doppelt so lang wie der String, da für jedes
      '   Zeichen zwei Werte zurückgegeben werden, deswegen wieder Dpeek/Dpoke
      INC j%
      DPOKE offset+j%,DPEEK(PTSOUT+j%)
    UNTIL j%=i%
  ENDIF
RETURN
