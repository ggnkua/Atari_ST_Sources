PROCEDURE v_gtext(handle%,x%,y%,string)
  LOCAL i%
  i%=-1
  ' text
  '   gibt Text-String an der Stelle x/y aus
  DPOKE PTSIN,x%
  DPOKE PTSIN+2,y%
  ' erst mal die Koordinaten festlegen
  REPEAT
    ' dann muž jedes Zeichen in den Eingabebereich gebracht werden
    INC i%
    POKE INTIN+i%,PEEK(string+i%)
  UNTIL PEEK(string+i%)=0
  @vin(8,1,i%,handle%)
RETURN
