PROCEDURE v_alpha_text(handle%,string)
  ' output alpha text
  '   gibt Textstring auf Drucker aus
  ' nur DRUCKER
  LOCAL i%
  i%=-1
  REPEAT
    ' jedes Zeichen mu× in den Eingabebereich gebracht werden
    INC i%
    POKE INTIN+i%,PEEK(string+i%)
  UNTIL PEEK(string+i%)=0
  ' im 'String' können auch Steuerzeichen enthalten sein. Folgende Zeichen
  '   generelle Druckerdefinitionen DC2 = ASCII 18
  '   DC2 0  Fettschrift AN
  '   DC2 1              AUS
  '   DC2 2  Kursivschrift AN
  '   DC2 3                AUS
  '   DC2 4  Unterstrichen AN
  '   DC2 5                AUS
  DPOKE CONTRL+6,i%
  ' im ATARI-ST-Profibuch steht für CONTRL[4] 5 Ausaben in INTOUT, es werden
  '   aber KEINE Rückgabevariablen genannt
  @ein(25,handle%)
RETURN
