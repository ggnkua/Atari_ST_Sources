PROCEDURE v_bit_image(handle%,filename,aspect%,x_scale%,y_scaele%,h_align%,v_align%,pxyarray)
  ' output bit image
  '   gibt eine Bilddatei im Bit-Image-Format auf Drucker aus
  ' nur DRUCKER
  DPOKE INTIN,aspect%
  ' AbbildungsmaŞstab  0 nicht
  '                    1 berücksichtigt (Kreise werden Kreise)
  DPOKE INTIN+2,x_scale%
  ' Skalierung der X-Achse  0 gebrochen
  '                         1 ganzzahlig
  DPOKE INTIN+4,y_scale%
  ' Skalierung der Y-Achse
  DPOKE INTIN+6,h_align%
  ' horizontale Ausrichtung 0 links
  '                         1 zenztriert
  '                         2 rechts
  DPOKE INTIN+8,v_align%
  ' vertikale Ausrichtung   0 oben
  '                         1 zentriert
  '                         2 unten
  LOCAL i%
  i%=-1
  REPEAT
    ' jedes Zeichen muŞ in den Eingabebereich gebracht werden
    INC i%
    POKE INTIN+i%+5,PEEK(filename+i%)
  UNTIL PEEK(filename+i%)=0
  DPOKE CONTRL+2,2
  DPOKE CONTRL+6,i%+5
  @ein(23,handle%)
RETURN
