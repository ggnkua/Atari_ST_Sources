PROCEDURE vsp_film(handle%,index%,lightness%)
  ' set camera film type and exposure time
  '   definiert den Filmtyp und die Entwicklungsdauer
  ' fÅr POLAROID-PALETTE
  DPOKE CONTRL+6,2
  DPOKE INTIN,index%
  ' Nummer des FIlmtypes ( -> vqp_filmname() )
  DPOKE INTIN+2,lightness%
  ' Belichtungszeit von  -3 halbe
  '                       0 normale
  '                 bis   3 doppelte
  @ein(91,handle%)
RETURN
