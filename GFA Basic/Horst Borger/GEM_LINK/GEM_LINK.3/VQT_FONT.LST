PROCEDURE vqt_fontinfo(handle%,asc_min%,asc_max%,distance%,maxwidth%,effects%)
  ' inquire current face information
  '   Auskunft über den aktuellen Zeichensatz, Ausgabe der gegenwärtigen Grö×e
  '   unter Berücksichtigung der Texteffekte
  @vin(131,0,0,handle%)
  *asc_min%=DPEEK(INTOUT)
  ' kleinster ASCII im Font
  *asc_max%=DPEEK(INTOUT+2)
  ' grö×ter ASCII im Font
  *maxwidth%=DPEEK(PTSOUT)
  ' maximale Zeichenzellenbreite OHNE Texteffekte
  *distance0%=DPEEK(PTSOUT+2)
  ' Untergrenze Zeichenzelle <-> Basislinie
  *distance1%=DPEEK(PTSOUT+6)
  ' Untergrenze Zeichenlänge (Überlängen) <-> Basislinie
  *distance2%=DPEEK(PTSOUT+10)
  ' Halblinie (Obergrenze Kleinbuchstaben) <-> Basislinie
  *distance3%=DPEEK(PTSOUT+14)
  ' Zeichenobergrenze <-> Basislinie
  *distance4%=DPEEK(PTSOUT+18)
  ' Zeichenzellenobergrenze <-> Basislinie
  *effects0%=DPEEK(PTSOUT+4)
  ' Betrag, um den die Zeichen bei Texteffekten breiter werden
  *effects1%=DPEEK(PTSOUT+8)
  ' linker Offset -> Betrag, um den die linke untere Ecke der Zeichenzelle
  '   weiter links steht als die linke Grenze der Basislinie
  *effects2%=DPEEK(PTSOUT+12)
  ' rechter Offset -> Betrag, um den die rechte obere Ecke der Zeichenzelle
  '   weiter rechts steht als die rechte Grenze der Basislinie
RETURN
