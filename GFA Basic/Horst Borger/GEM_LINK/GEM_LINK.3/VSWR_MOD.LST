PROCEDURE vswr_mode(handle%,mode%)
  ' set writing mode
  '   w„hlt Schreibmodus aus :  1  MD_REPLACE  ersetzen
  '                             2  MD_TRANS    transparent
  '                             3  MD_XOR      XOR
  '                             4  MD_ERASE    invers transparent
  DPOKE INTIN,mode%
  @vin(32,0,1,handle%)
  *set_mode%=DPEEK(INTOUT)
  ' ausgew„hlter Schreibmodus
RETURN
