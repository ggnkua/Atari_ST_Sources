PROCEDURE wind_calc(ctype%,ckind%,cinx%,ciny%,cinw%,cinh%,coutx%,couty%,coutw%,couth%)
  DPOKE GINTIN,ctype%
  DPOKE GINTIN+2,ckind%
  DPOKE GINTIN+4,cinx%
  DPOKE GINTIN+6,ciny%
  DPOKE GINTIN+8,cinw%
  DPOKE GINTIN+10,cinh%
  @ain(108,6,0)
  *coutx%=DPEEK(GINTOUT+2)
  *couty%=DPEEK(GINTOUT+4)
  *coutw%=DPEEK(GINTOUT+6)
  *couth%=DPEEK(GINTOUT+8)
RETURN
