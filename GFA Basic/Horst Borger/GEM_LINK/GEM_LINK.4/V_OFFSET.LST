PROCEDURE v_offset(handle%,offset%)
  ' set line offset
  '   setzt den Offset in Rasterzeilen zumBeginn des logischen Bildscirms
  '   ACHTUNG : KEINE OFFIZIELLE DOKUMENTATION !
  '             BENUTZUNG AUF EIGENE GEFAHR !!!!
  ' f〉 BILDSCHIRM
  DPOKE CONTRL+6,1
  DPOKE INTIN,offset%
  ' Pixelabstand f〉 logischen Bildschirm ab Oberkante wirklicher Bildschirm
  @ein(101,handle%)
RETURN
