PROCEDURE xgrf_2box(xg_2xc%,xg_2yc%,xg_2wc%,xg_2h%,xg_2corners%,xg_2cnt%,xg_2xsteps%,xg_2ystep%,xg_2double%)
  ' erst ab GEM 2.0
  DPOKE GINTIN,xg_2cnt%
  DPOKE GINTIN+2,xg_2xstep%
  DPOKE GINTIN+4,xg_2ystep%
  DPOKE GINTIN+6,xg_2double%
  DPOKE GINTIN+8,xg_2corners%
  DPOKE GINTIN+10,xg_2xc%
  DPOKE GINTIN+12,xg_2yc%
  DPOKE GINTIN+14,xg_2wc%
  DPOKE GINTIN+16,xg_2hc%
  @ain(131,9,0)
RETURN
