PROCEDURE v_updprn(handle%,prnbuf)
  ' update workstation printer
  '   ein eigener Puffer kann an den Drucker gesandt werden
  '   die Adresse des Puffers mu× RICHTIG in INTIN gepoket werden !!
  POKE INTIN,hword_prnbuf_adr
  POKE INTIN+1,lword_prnbuf_adr
  ' das high-Wort und das Low-Wort müsen auf jeden Fall in der Reihenfolge
  ' drin stehen
  @vin(5,1,1,handle%)
  *prn_status=PEEK(INTOUT)
  '  für ATARI Laser-Drucker SLM804
  '  0  no error
  '  2  not ready
  '  3  toner empty
  '  4  warmup
  '  5  no paper
  '  6  no drum
  '  7  jam input
  '  8  jam through
  '  9  jam output
  ' 10  cover open
  ' 11  malfunction : fuser
  ' 12  malfunction : imager
  ' 13  malfunction : motor
  ' 14  malfunction : video
  ' 16  system timeout
RETURN
