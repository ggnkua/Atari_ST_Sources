PROCEDURE v_write_meta(handle%,num_intin%,a_intin,num_ptsin%,a_ptsin)
  ' write metafile item
  '   schreibt Parameter in ein Metafile und wird abgespeichert mit einem
  '   vom Benutzer definieren Opcode (>100 zulÑssig, andere sind reserviert)
  ' fÅr METAFILE
  DPOKE CONTRL+2,num_ptsin%
  DPOKE CONTRL+6,num_intin%
  LOCAL i%
  FOR i%=0 TO num_ptsin%-1
    DPOKE INTIN+i%*2,DPEEK(a_intin+i%*2)
  NEXT i%
  ' die Integer-Werte werden in den INTIN-Block gelegt
  ' der erste Eintrag ist der vom Benutzer efinierte Opcode !!
  FOR i%=0 TO num_intin%
    DPOKE PTSIN+2*i%,DPEEK(a_ptsin+2*i%)
  NEXT i%
  ' der PTSIN-Block wird gesetzt
  @ein(99,handle%)
RETURN
