PROCEDURE xgrf_stepcalc(xg_storgw%,xg_storgh%,xg_stxc%,xg_styc%,xg_stw%,xg_sth%,xg_stpcx%,xg_stpcy%,xg_stpcnt%,xg_stpxstep%,xg,stpystep%)
  ' erst ab GEM 2.0
  DPOKE GINTIN,xg_storgw%
  DPOKE GINTIN+2,xg_storgh%
  DPOKE GINTIN+4,xg_stxc%
  DPOKE GINTIN+6,xg_styc%
  DPOKE GINTIN+8,xg_stw%
  DPOKE GINTIN+10,xg_sth%
  @ain(130,6,0)
  IF FN aes_ret>0
    *xg_stpcx%=DPEEK(GINTOUT+2)
    *xg_stpcy%=DPEEK(GINTOUT+4)
    *xg_stpcnt%=DPEEK(GINTOUT+6)
    *xg_stpxstep%=DPEEK(GINTOUT+8)
    *xg_stpystep%=DPEEK(GINTOUT+10)
  ENDIF
RETURN
