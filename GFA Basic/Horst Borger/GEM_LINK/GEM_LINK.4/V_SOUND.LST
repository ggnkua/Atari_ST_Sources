PROCEDURE v_sound(handle%,frequency%,duration%)
  ' generated specified tone
  '   erzeugt Ton mit der angegebenen LÑnge und Tonhîhe
  ' fÅr BILDSCHIRM
  ' NICHT im ROM-Bildschirmtreiber implementiert
  DPOKE CONTRL+6,2
  DPOKE INTIN,frequency%
  ' die Frequenz des zu erzeugenden Tones in Hertz
  DPOKE INTIN+2,duration%
  ' die Dauer des zu ereugenden Tones in Timer-Ticks
  @ein(61,handle%)
RETURN
