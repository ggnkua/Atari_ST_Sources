  txtrotation_flag%=DPEEK(INTOUT+72)
  fll_flag%=DPEEK(INTOUT+74)
  cellary_flag%=DPEEK(INTOUT+76)
  colr_cnt2%=DPEEK(INTOUT+78)
  gcursor_ctrl%=DPEEK(INTOUT+80)
  in_ctrl%=DPEEK(INTOUT+82)
  tast%=DPEEK(INTOUT+84)
  alpha_in%=DPEEK(INTOUT+86)
  in_out_type%=DPEEK(INTOUT+88)
  min_width%=DPEEK(PTSOUT)
  min_height%=DPEEK(PTSOUT+2)
  max_width%=DPEEK(PTSOUT+4)
