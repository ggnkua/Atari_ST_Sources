PROCEDURE graf_shrinkbox(sfinx%,sfiny%,sfinwidth%,sfinheight%,sstx%,ssty%,sstwidth%,sstheight%)
  DPOKE GINTIN,sfinx%
  DPOKE GINTIN+2,sfiny%
  DPOKE GINTIN+4,sfinwidth%
  DPOKE GINTIN+6,sfinheight%
  DPOKE GINTIN+8,sstx%
  DPOKE GINTIN+10,ssty%
  DPOKE GINTIN+12,sstwidth%
  DPOKE GINTIN+14,sstheight%
  @ain(74,8,0)
RETURN
