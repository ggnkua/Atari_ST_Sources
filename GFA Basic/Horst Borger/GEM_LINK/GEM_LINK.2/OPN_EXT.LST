PROCEDURE opn_ext
  *screen_type=PEEK(INTOUT)
  ' Bildschirmtyp   0  kein Bildschirm
  '                 1  getrennte Alpha-/Graphiktreiber + versch. Screens
  '                 2  getrennte Alpha-/Graphiktreiber + gleicher Screen
  '                 3  selber Treiber + versch. Screens
  '                 4  selber Treiber + gleicher Screen
  *backgr_color_cnt%=PEEK(INTOUT+1)
  ' Anzahl Hintergrundfarben
  *text_effect_cnt%=PEEK(INTOUT+2)
  ' Anzahl Texteffekte
  *zoom_flag%=PEEK(INTOUT+3)
  ' VergröŞerung    0 nicht möglich
  '                 1 möglich
  *planes_cnt%=PEEK(INTOUT+4)
  ' Anzahl Farbebenen
  *lookup_table_flag%=PEEK(INTOUT+5)
  ' Unterstützung des 'Lokup-Table'   0 nicht möglich
  '                                   1 möglich
  *op16pixel_cnt%=PEEK(INTOUT+6)
  ' Anzahl der 16er Pixelraster-Operationen
  *contour_fill_flag%=PEEK(INTOUT+7)
  ' Contourfill     0 nicht verfügbar
  '                 1 verfügbar
  *textrotation_flag%=PEEK(INTOUT+8)
  ' Textrotation    0 nicht möglich
  '                 1 in 90Grad-Schritten
  '                 2 beliebig
  *textmod_cnt%=PEEK(INTOUT+9)
  ' Anzahl Schreibmodi
  *max_inmod%=PEEK(INTOUT+10)
  ' höchster Grad der Eingabemodi     0 keine
  '                                   1 Request
  '                                   2 Sample
  *text_set_flag%=PEEK(INTOUT+11)
  ' Textausrichtungsflag              0 nicht verfügbar
  '                                   1 verfügbar
  *colorpen_flag%=PEEK(INTOUT+12)
  ' Farbstiftwechsel am Ausgabegerät  0 nicht möglich
  '                                   1 möglich
  *colorband_flag%=PEEK(INTOUT+13)
  ' Farbbandwechsel 0 nicht möglich
  '                 1 farbige Zeilen
  '                 2 farbige Zeilen und Rechtecke
  *pxy_cnt%=PEEK(INTOUT+14)
  ' maximale Anzahl Koordinatenpaare für 'Poly'-Funktionen
  ' -1 -> unbegrenzt
  *int_in_max%=PEEK(INTOUT+15)
  ' maximale GröŞe des INTIN-Arrays
  ' -1 -> unbegrenzt
  *mousekey_cnt%=PEEK(INTOUT+16)
  ' Anzahl Maustasten
  *linetype_flag%=PEEK(INTOUT+17)
  ' Linientypen für Linienbreite > 1Pixel
  '                 0 nicht möglich
  '                 1 möglich
  *texttype_line_cnt%=PEEK(INTOUT+18)
  ' Anzahl Schreibmodi für breite Linien
  *clip_flag%=PEEK(INTOUT+19)
  ' Clipping aus=0 / ein=1 ERST AB GEM 2.o
RETURN
