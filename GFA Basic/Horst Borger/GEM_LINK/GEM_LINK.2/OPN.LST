PROCEDURE opn
  ' das sind die ganzen Parameter, die beim Öffnen winer Workstation zurück-
  '   gegeben werden
  handle%=PEEK(INTIN)
  ' Gerätekennung
  lne_type%=PEEK(INTIN+1)
  ' Linientyp
  lne_color%=PEEK(INTIN+2)
  ' Linienfarbe
  marker_type%=PEEK(INTIN+3)
  ' Markertyp
  marker_color%=PEEK(INTIN+4)
  ' Markerfarbe
  font_no%=PEEK(INTIN+5)
  ' Font-ID
  txt_color%=PEEK(INTIN+6)
  ' Textfarbe
  fll_type%=PEEK(INTIN+7)
  ' Fülltyp
  fll_style_id%=PEEK(INTIN+8)
  ' Füllmuster-Index
  fll_style_color%=PEEK(INTIN+9)
  ' Füllmuster-Farbe
  koord_flag%=PEEK(INTIN+10)
  ' Koordinatenflag  : 0 -> NDC-Koordinaten
  '                    1 -> reserviert
  '                    2 -> RC-Koordinaten
  '
  x_raster_max%=DPEEK(INTOUT)
  ' maximale x-Pixel
  y_raster_max%=DPEEK(INTOUT+2)
  ' maximale y-Pixel
  skale%=DPEEK(INTOUT+4)
  ' Exaktheit der Skalierung : 0 -> genau
  '                            1 -> ungenau
  pixel_width%=DPEEK(INTOUT+6)
  ' Pixelbreite (f.Plotter) (x/1000)mm
  pixel_height%=DPEEK(INTOUT+8)
  ' Pixelhöhe (f.Plotter) (x/1000)mm
  fontheight_cnt%=DPEEK(INTOUT+10)
  ' Anzahl Schriftzeichenhöhen
  lnetype_cnt%=DPEEK(INTOUT+12)
  ' Anzahl Linientypen
  lnewidth_cnt%=DPEEK(INTOUT+14)
  ' Anzahl Linienbreiten
  markertype_cnt%=DPEEK(INTOUT+16)
  ' Anzahl Markertypen
  markerwidth_cnt%=DPEEK(INTOUT+18)
  ' Anzahl Markergrö×en
  font_cnt%=DPEEK(INTOUT+20)
  ' Anzahl Fonts
  style_cnt%=DPEEK(INTOUT+22)
  ' Anzahl Muster
  diag_cnt%=DPEEK(INTOUT+24)
  ' Anzahl Schraffuren
  colr_cnt%=DPEEK(INTOUT+26)
  ' Anzahl vordefinierte Farben
  gdp_cnt%=DPEEK(INTOUT+28)
  ' Anzahl Graphikgrundfunktionen
  ' intout15 bis intout24 stehen die unterstützten Graphikgrundfunktionen :
  '   Balken / Bogen / Kreisausschnitt / Kreis / Ellipse / elliptische Bogen /
  '   Ellipsensegment / abgerundetes Rechteck / ausgefülltes, abgerundetes
  '   Rechteck / justierter Graphiktext / am ENDE steht -1
  ' intout25 bis intout34 beinhaltet Liste möglicher Attribute der GDP :
  '   Linie / Marker / Text / ausgefüllter Bereich / kein Attribut (DPOKE!!!)
  colr_ok_flag%=DPEEK(INTOUT+70)
  ' Farbdarstellungsflag     0 -> nicht
  '                          1 -> verfügbar
  txtrotation_flag%=DPEEK(INTOUT+72)
  ' Textrotationsflag        0 -> nicht
  '                          1 -> verfügbar
  fll_flag%=DPEEK(INTOUT+74)
  ' Flächenfüllflag          0 -> nicht
  '                          1 -> verfügbar
  cellary_flag%=DPEEK(INTOUT+76)
  ' CELLARRAY                0 -> nicht
  '                          1 -> verfügbar
  colr_cnt2%=DPEEK(INTOUT+78)
  ' Anzahl verfügbare Farben (0-> >32767)
  gcursor_ctrl%=DPEEK(INTOUT+80)
  ' Graphik-Cursorkontrolle  1 -> Tastatur
  '                          2 -> Tastatur + Maus
  in_ctrl%=DPEEK(INTOUT+82)
  ' Eingabegerät für versch. Eingaben
  '                          1 -> Tastatur
  '                          2 -> anderes Gerät
  tast%=DPEEK(INTOUT+84)
  ' Auswahltasten            1 -> Funktionstasten
  '                          2 -> anderes Tastenfeld
  alpha_in%=DPEEK(INTOUT+86)
  ' alphanumerische Eingabe  1 -> Tastatur
  in_out_type%=DPEEK(INTOUT+88)
  ' Ein-/Ausgabegerät-Typ    0 -> nur Ausgabe
  '                          1 -> nur Eingabe
  '                          2 -> Ein-/Ausgabe
  '                          3 -> reserviert
  '                          4 -> Metafile
  '
  min_width%=DPEEK(PTSOUT)
  ' minimale Zeichenbreite
  min_height%=DPEEK(PTSOUT+2)
  ' minimale Zeichenhöhe
  max_width%=DPEEK(PTSOUT+4)
  ' maximale zeichenbreite
  max_height%=DPEEK(PTSOUT+6)
  ' maximale Zeichenhöhe
  min_columnwidth%=DPEEK(PTSOUT+8)
  ' minimale Zeilenbreite
  konst%=DPEEK(PTSOUT+10)
  ' immer 0
  max_columnwidth%=DPEEK(PTSOUT+12)
  ' maximale Zeilenbreite
  konst%=DPEEK(PTSOUT+14)
  ' immer 0
  min_mkwidth%=DPEEK(PTSOUT+16)
  ' minimale Markerbreite
  min_mkheight%=DPEEK(PTSOUT+18)
  ' minimale Markerhöhe
  max_mkwidth%=DPEEK(PTSOUT+20)
  ' maximale Markerbreite
  max_mkheight%=DPEEK(PTSOUT+22)
  ' maximale Markerhöhe
RETURN
