PROCEDURE graf_growbox(gstx%,gsty%,gstwidth%,gstheight%,gfinx%,gfiny%,gfinwidth%,gfinheight%)
  DPOKE GINTIN,gstx%
  DPOKE GINTIN+2,gsty%
  DPOKE GINTIN+4,gstwidth%
  DPOKE GINTIN+6,gstheight%
  DPOKE GINTIN+8,gfinx%
  DPOKE GINTIN+10,gfiny%
  DPOKE GINTIN+12,gfinwidth%
  DPOKE GINTIN+14,gfinheight%
  @ain(73,8,0)
RETURN
