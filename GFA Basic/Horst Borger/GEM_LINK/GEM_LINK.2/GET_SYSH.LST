PROCEDURE get_syshdr
  ' Block SYSHDR System Header
  sysbase%=LPEEK(&H4F2)
  ' da steht die Adresse für den Block SYSHDR drin, allerdings wei× ich nicht,
  ' ob die Adresse für TOS >1.2 gilt
  ' man mü×te, wenn nötig, die Adressen wissen, die Version abfragen und je nach
  ' Version dann 'sysbase%' ausrechnen
  '
  ' ab hier stimmt's wieder in allen Versionen (wenn 'sysbase%' richtig ist)
  os_entry%=DPEEK(sysbase%)
  ' Einsprungsadresse (BRAs !!)
  os_version%=DPEEK(sysbase%+2)
  ' OS-Version, beim ROM-TOS      $0100 -> 1.0 (1986)
  '                  Blitter-TOS  $0102 -> 1.2 (1987)
  os_start%=LPEEK(sysbase%+4)
  ' Startadresse des OS-Codes
  os_base%=LPEEK(sysbase%+8)
  ' Anfangsadresse des Betriebssystems
  os_membot%=LPEEK(sysbase%+12)
  ' Anfangsadresse des freien RAM
  os_shell%=LPEEK(sysbase%+16)
  ' Zeiger auf Default-Shell, normalerweise nicht benutzt
  os_magic%=LPEEK(sysbase%+20)
  ' Zeiger auf GEM-MAGIC-Variable, $87654321
  os_gendat%=LPEEK(sysbase%+24)
  ' Erstellungsdatum des TOS im BCD-Format, z.B. $02061986
  os_palmode%=DPEEK(sysbase%+28)
  ' 1 -> PAL-Mode, ansonsten NTSC-Mode
  os_gendatg%=DPEEK(sysbase%+30)
  ' Erstellungsdatum im GEMDOS-Format
  IF os_version%>&H101
    ' folgende Einträge gibt's erst ab TOS 1.2
    *root%=LPEEK(sysbase%+32)
    ' Zeiger auf 'mfl'-Liste des Gemdos
    ' -> BIOS(0)
    *kbshift%=LPEEK(sysbase%+36)
    ' Zeiger auf die Systemvariable, in der der Sondertastenstatus abgelegt wird
    r_un%=LPEEK(sysbase%+40)
    ' Zeiger auf eigenen PD-Block ( Process Describtion )
    ' damit ist die eigenen Basepage gemeint
    *p_resv%=Lpeek(sysbase%+44)
    ' z.Zt. nicht benutzt
  ENDIF
RETURN
