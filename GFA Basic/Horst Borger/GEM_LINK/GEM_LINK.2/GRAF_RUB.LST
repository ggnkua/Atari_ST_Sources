PROCEDURE graf_rubberbox(gr_rx%,gr_ry%,gr_rminwidth%,gr_rminheight%,gr_rlastwidth%,gr_rlastheight%)
  DPOKE GINTIN,gr_rx%
  DPOKE GINTIN+2,gr_ry%
  DPOKE GINTIN+4,gr_rminwidth%
  DPOKE GINTIN+6,gr_minheight%
  @ain(70,4,0)
  *gr_rlastwidth%=DPEEK(GINTOUT+2)
  *gr_rlastheight%=DPEEK(GINTOUT+4)
RETURN
