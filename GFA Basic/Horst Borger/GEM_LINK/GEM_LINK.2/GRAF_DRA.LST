PROCEDURE graf_dragbox(dwidth%,dheight%,dstarx%,dstarty%,dboundx%,dboundy%,dboundw%,dbondh%,dfinishx%,dfinishy%)
  DPOKE GINTIN,dwidth%
  DPOKE GINTIN+2,dheight%
  DPOKE GINTIN+4,dstartx%
  DPOKE GINTIN+6,dstarty%
  DPOKE GINTIN+8,dboundx%
  DPOKE GINTIN+10,dboundy%
  DPOKE GINTIN+12,dboundw%
  DPOKE GINTIN+14,dboundh%
  @ain(71,8,0)
  *dfinishx%=DPEEK(GINTOUT+2)
  *dfinishy%=DPEEK(GINTOUT+4)
RETURN
