PRINT "Code        ASCII SCAN Taste(n)"
kbshift:
DATA RSHIFT ,LSHIFT ,CONTROL ,ALTERNATE ,CAPSLOCK ,xxx
DO
  a%=BIOS(2,2)
  PRINT a%;
  PRINT TAB(12);a% MOD 65536;
  scan%=a% DIV 16777216
  PRINT TAB(18);a% DIV 65536 MOD 256;
  RESTORE kbshift
  PRINT TAB(23);
  FOR i%=0 TO 4
    READ kb$
    IF scan% AND 2^i%
      PRINT kb$;
    ENDIF
  NEXT i%
  PRINT CHR$(a% MOD 65536)
  EXIT IF a% MOD 256=27
LOOP
EDIT
