PROCEDURE get_keytbl(unshift%,shift%,capslock%)
  ' Block KEYTBL Key-Tables
  ' setzt und ermittelt die neuen Adressen f〉 Tastaturblocks
  ptr_keytbl%=@keytbl(unshift%,shift%,capslock%)
  ' die Adresse f〉 den KEYTBL holen
  unshift%=LPEEK(ptr_keytbl%)
  ' Adresse f〉 normale Tasten
  shift%=LPEEK(ptr_keytbl%+4)
  ' Adresse f〉 Tasten mit SHIFT
  capslock%=LPEEK(ptr_keytbl%+8)
  ' Adresse f〉 Tasten mit CAPSLOCK
RETURN
