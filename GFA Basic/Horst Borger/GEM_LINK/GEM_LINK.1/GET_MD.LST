PROCEDURE get_md(ptr_md%)
  ' Block MD Memory Describtion
  ' Diese Funktion muž rekursiv aufgebaut werden, damit sie sich durch alle
  ' freien oder benutzten Bl”cke durchhangeln und deren L„ngen jeweils addieren kann
  '   LOCAL m_link%,m_start%,m_length%,m_descr%
  m_link%=LPEEK(ptr_md%)
  '     Zeiger auf die n„chste MD
  m_start%=LPEEK(ptr_md%+4)
  '     Startadresse des Blockes
  m_length%=LPEEK(ptr_md%+8)
  '     L„nge des Blockes
  '   ADD m_ges%,m_length%
  '   der gesamtfreie Speicherplatz muž hochgez„hlt werden
  m_own%=LPEEK(ptr_md%+12)
  '     Zeiger auf MD-Beschreibung, angeblich Zeiger auf die eigene Basepage
  '   IF m_link%<>fst_ptr_md%
  '   wenn m_link% NICHT auf sich selber zeigt
  '   @get_md(m_link%)
  '   muž der n„chste MD-Block geladen werden
  '   ELSE
  '   PRINT m_ges%
  '   ENDIF
RETURN
