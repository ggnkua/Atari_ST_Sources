PROCEDURE evnt_multi(mf%,mbc%,mbm%,mbs%,m1f%,m1x%,m1y%,m1w%,m1h%,m2f%,m2x%,m2y%,m2w%,m2h%,mgpb%,mtl%,mth%,mox%,moy%,mob%,mos%,mkr%,mbr%)
  DPOKE GINTIN,mf%
  DPOKE GINTIN+2,mbc%
  DPOKE GINTIN+4,mbm%
  DPOKE GINTIN+6,mbs%
  DPOKE GINTIN+8,m1f%
  DPOKE GINTIN+10,m1x%
  DPOKE GINTIN+12,m1y%
  DPOKE GINTIN+14,m1w%
  DPOKE GINTIN+16,m1h%
  DPOKE GINTIN+18,m2f%
  DPOKE GINTIN+20,m2x%
  DPOKE GINTIN+22,m2y%
  DPOKE GINTIN+24,m2w%
  DPOKE GINTIN+26,m2h%
  DPOKE GINTIN+28,mtl%
  DPOKE GINTIN+30,mth%
  LPOKE ADDRIN,mgpb%
  @ain(25,16,1)
  *mox%=DPEEK(GINTOUT+2)
  *moy%=DPEEK(GINTOUT+4)
  *mob%=DPEEK(GINTOUT+6)
  *mos%=DPEEK(GINTOUT+8)
  *mkr%=DPEEK(GINTOUT+10)
  *mbr%=DPEEK(GINTOUT+12)
RETURN
