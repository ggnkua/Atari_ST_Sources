PROCEDURE get_dta(ptr_dta%)
  ' d_resvd[21]
  ' 21 Zeichen für's GEMDOS reserviert
  d_attrib%=PEEK(ptr_dta%+21)
  ' Datei-Attribut
  d_time%=DPEEK(ptr_dta%+22)
  ' Uhrzeit im GEMDOS-Format
  d_date%=DPEEK(ptr_dta%+24)
  ' Datum im GEMDOS-Format
  d_length%=LPEEK(ptr_dta%+26)
  ' Dateilänge
  ' d_filename[14]
  ' 14 Zeichen für den Filenamen OHNE Pfad
RETURN
