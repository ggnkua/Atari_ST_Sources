PROCEDURE get_bpb(dev%)
  ' Block BPB Bios Parameter Block
  ptr_bpb%=@getbpb(dev%)
  recsiz%=DPEEK(ptr_bpb%)
  '     Bytes pro Sektor
  CL_siz%=DPEEK(ptr_bpb%+2)
  '     Sektoren pro Cluster=Einheit
  CL_Sizb%=DPEEK(ptr_bpb%+4)
  '     Bytes pro Cluster
  rdlen%=DPEEK(ptr_bpb%+6)
  '     Directorylänge in Sektoren
  fsiz%=DPEEK(ptr_bpb%+8)
  '     FAT-Länge in Sektoren
  fatrec%=DPEEK(ptr_bpb%+10)
  '     Statsektor der zweiten FAT
  datrec%=DPEEK(ptr_bpb%+12)
  '     Startsektor der Daten
  numcl%=DPEEK(ptr_bpb%+14)
  '     Gesamtzahl Cluster
  bflags%=DPEEK(ptr_bpb%+16)
  '     Flag für FAT :
  '       0  12-Bit Verschlüsselung
  '       1  16 Bit Verschlüsselung
RETURN
