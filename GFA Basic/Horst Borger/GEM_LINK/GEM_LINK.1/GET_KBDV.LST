PROCEDURE get_kbdvbase
  kbdvbase%=@kbdvbase
  midivec%=LPEEK(kbdvbase%)
  ' Zeiger auf Routine, die die vom Midi-Port empfangenen Bytes in einen
  ' Buffer schreibt
  vkbderr%=LPEEK(kbdvbase%+4)
  ' Fehlerroutine, die beim šberlauf des Tastaturspeichers aufgerufen wird
  vmiderr%=LPEEK(kbdvbase%+8)
  ' Fehlerroutine, die beim šberlauf des Midi-Port-Buffers aufgerufen wird
  statvec%=LPEEK(kbdvbase%+12)
  mousevec%=LPEEK(kbdvbase%+16)
  clockvec%=LPEEK(kbdvbase%+20)
  joyvec%=LPEEK(kbdvbase%+24)
  ' verschiedene Zeiger af die entsprechenden Routinen, diese sollten mit
  ' einem RTS abgeschlossen sein und h„chstens 1 ms laufen
  midisys%=LPEEK(kbdvbase%+28)
  ikbdsys%=LPEEK(kbdvbase%+32)
  ' Routinen, die beim Eintreffen von Daten am entsprechenden Port aufge~
  ' rufen werden
RETURN
