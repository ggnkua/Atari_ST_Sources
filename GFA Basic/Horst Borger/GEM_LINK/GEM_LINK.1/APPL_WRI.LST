PROCEDURE appl_write(ap_wid%,ap_wlength%,ap_wpbuff%)
  ' schreibt eine bestimmte Anzahl von BYtes in einen Ereignispuffer
  DPOKE GINTIN,ap_wid%
  ' zu dieser Applikation wird die Nachricht geschickt
  DPOKE GINTIN+2,apwlength%
  ' so viele Bytes werden geschickt
  LPOKE ADDRIN,ap_wpbuff%
  ' von dem Puffer werden sie geholt
  @ain(12,2,1)
RETURN
