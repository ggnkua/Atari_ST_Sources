PROCEDURE evnt_button(ev_bclicks%,ev_bmask%,ev_bstate%,ev_bmx%,ev_bmy%,ev_bbutton%,ev_bkstate%)
  ' wartet auf eine Mausbetätigung
  DPOKE GINTIN,ev_bclicks%
  ' Anzahl der zu zählenden Tastendrücke bis zur Rückmeldung
  DPOKE GINTIN+2,ev_bmask%
  ' Maske für die gewünschte Masustaste  0 -> links
  '                                      1 -> rechts
  DPOKE GINTIN+4,ev_bstate%
  ' Maske für den gewünschten Status     0 -> links löst aus
  '                                      1 -> rechts löst aus
  @ain(21,3,0)
  *ev_bmx%=DPEEK(GINTOUT+2)
  ' X-Koordinate beim Auslösen
  *ev_bmy%=DPEEK(GINTOUT+4)
  ' Y-Koordinate beim Auslösen
  *ev_bbutton%=DPEEK(GINTOUT+6)
  ' Tastaturzustand beim Auslösen -> DEFFNs
  *ev_bkstate%=DPEEK(GINTOUT+8)
  ' Anzahl der aufgetretenen Mausdrücke
RETURN
