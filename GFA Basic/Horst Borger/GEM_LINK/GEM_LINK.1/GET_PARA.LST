PROCEDURE get_param_block
  ' Block PARAM
  topmode%=PEEK(mouse_param%)
  ' 0  Y=oberste Bildschirmpixelzeile
  ' 1  Y=unterste Bildschirmpixelzeile
  buttons%=PEEK(mouse_param%+1)
  ' 0x1  rechter Knopf seit letzter Abfrage gedrÅckt
  ' 0x2     %                               losgelassen
  ' 0x4  linker                             gedrÅckt
  ' 0x8     %                               losgelassen
  xparam%=PEEK(mouse_param%+2)
  yparam%=PEEK(mouse_param%+3)
  ' nach Modus verschieden, meist aber die DistanzbetrÑge seit der
  ' letzten Abfrage
  IF type%=2
    ' wenn die Maus im absoluten Modus gesetzt ist
    xmax%=DPEEK(mouse_param%+4)
    ymax%=DPEEK(mouse_param%+6)
    ' maximale Mausposition
    xinitial%=DPEEK(mouse_param%+8)
    yinitial%=DPEEK(mouse_param%+10)
    ' Anfangsposition der Maus
  ENDIF
RETURN
