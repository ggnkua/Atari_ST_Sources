PROCEDURE appl_tplay(ap_tpmem%,ap_tpnum%,ap_tpscale%)
  ' erlaubt das Abspielen einer Ereignisliste
  DPOKE GINTIN,ap_tpnum%
  ' Anzahl der Ereignisse
  DPOKE GINTIN+2,ap_tpscale%
  ' Geschwindigkeitsfaktor = ap_tpscale%/100
  LPOKE ADDRIN,ap_tpmem%
  ' Adresse, an der der Ereignispuffer liegt
  @ain(14,2,1)
  ' AES_RET muž immer 1 sein
RETURN
