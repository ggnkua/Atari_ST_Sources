PROCEDURE appl_bvset(ap_bvdisk%,ap_bvhard%)
  ' erst ab GEM 2.0
  ' setzt Informationen Åber angeschlossenen Laufwerke
  DPOKE GINTIN,ap_bvdisk%
  ' Bitvektor mit allen vorhandenen Laufwerken
  DPOKE GINTIN+2,ap_bvhard%
  ' Bitvektor mit allen Laufwerken, die als Harddisk anzusehen sind
  @ain(16,2,0)
RETURN
