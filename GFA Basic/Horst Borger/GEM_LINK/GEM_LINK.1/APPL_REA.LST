PROCEDURE appl_read(ap_rid%,ap_rlength%,ap_rpbuff%)
  ' liest eine bestimmte Anzahl Bytes aus einem Ereignispuffer
  DPOKE GINTIN,ap_rid%
  ' application-ID, aus deren Ereignispuffer gelesen werden soll (normaler~
  ' weise der eigene)
  DPOKE GINTIN+2,ap_rlength%
  ' Anzahl der zu empfangenden Bytes%
  LPOKE ADDRIN,ap_rpbuff%
  ' Anfangsadresse des Puffers, in dem die Bytes abgelegt werden sollen
  @ain(11,2,1)
RETURN
