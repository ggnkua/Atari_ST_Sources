PROCEDURE appl_find(ap_fpname%)
  ' findet die Applikationsnummer einer Applikation, deren Filename bekannt
  ' ist
  LPOKE ADDRIN,ap_fpname%
  ' der Zeiger auf den Filenamen, nach dem gesucht wird
  @ain(0,1)
  ' die gefundene ID steht jetzt in AES_RET, oder sie ist 0, dann gibt's nix
RETURN
