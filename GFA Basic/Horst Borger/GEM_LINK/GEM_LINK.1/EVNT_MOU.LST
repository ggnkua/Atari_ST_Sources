PROCEDURE evnt_mouse(ev_moflags%,ev_mox%,ev_moy%,ev_mowidth%,ev_moheight%,ev_momx%,ev_momy%,ev_mobutton%,ev_mokstate%)
  ' wartet, daž die Maus einen Bildschirmbereich verl„žt oder betritt
  DPOKE GINTIN,ev_moflags%
  ' Betreten=0, Verlassen=1 des Bildschirmrechteckes
  DPOKE GINTIN+2,ev_mox%
  DPOKE GINTIN+4,ev_moy%
  ' linke obere Ecke des Rechteckes
  DPOKE GINTIN+6,ev_mowidth%
  ' Breite
  DPOKE GINTIN+8,ev_moheight%
  ' und H”he des Rechteckes
  @ain(22,5,0)
  *ev_momx%=DPEEK(GINTOUT+2)
  *ev_momy%=DPEEK(GINTOUT+4)
  ' ausl”sende Mausposition
  *ev_mobutton%=DPEEK(GINTOUT+6)
  ' Tastenstatus beim Ausl”sen           0 -> linke Maustaste
  '                                      1 -> rechte Maustaste
  *ev_mokstate%=DPEEK(GINTOUT+8)
  ' Sondertastenstatus beim Ausl”sen
RETURN
