'
'       #################################################################
'       #                                                               #
'       #       GEM-DEMO-Programm ĮŠ PIDAT 1992                         #
'       #       Public Domain                                           #
'       #                                                               #
'       #       im Grunde genommen wird nur die Bildschirmauslösung     #
'       #       abgefragt, aber das klappt bei ALLEN Bildschirmen       #
'       #       die am ST/STE/TT hängen.                                #
'       #                                                               #
'       #################################################################
'
@appl_init                      ! eine AES-Funktion : initialisieren einer Applikation
gl_apid%=PEEK(INTOUT)           ! da hat Appl_init die Gerätekennung hinterlassen
IF gl_apid%<>-1                 ! wenn's keinen Fehler gegeben hat
  FOR i%=0 TO 9                 ! den Integer-Input-Block vorbereiten
    POKE INTIN+i%,1             ! die ersten 10 Plätze mit 1 belegen
  NEXT i%
  POKE INTIN+10,2               ! den 11. mit 2
  @graf_handle(*gl_wchar,*gl_hchar,*gl_wbox,*gl_hbox)
  '                             ! wieder 'ne AES-Funktion, liefert das Handle
  '                             ! der Bildschirm-Workstation
  handle%=PEEK(INTOUT)          ! wieder an der 1. Stelle des IntOut-Blockes
  POKE INTIN,handle%            ! an die 1. Stelle des IntIn-Blockes das Handle schreiben
  '
  @v_opnvwk(INTIN,*handle,INTOUT)
  '                             ! und jetzt können wir die Workstation aufmachen
  '
  '     #################################################################
  '     #                                                               #
  '     #         Hier kommt dann das eigene GEM-Programm rein          #
  '     #                                                               #
  '     #################################################################
  '
  PRINT x_raster%,y_raster%     ! Ausgabe der Koordinaten des Bildschirmes
  '
  @v_clsvwk(handle)             ! die Workstation mu× wieder geschlossen werden,
  '                             ! sonst kann's böse Überraschungen geben
ELSE
  PRINT "Hat nicht geklappt !!" ! Das hat's bei mir NIE gemacht, aber vorsichtshalber
ENDIF
VOID INP(2)                     ! die Anzeige soll man ja lesen können
EDIT
'
PROCEDURE v_opnvwk(intin,handle,intout)
  '                             ! die workstation wird geöffnet
  @vin(0,6,11,45)               ! den CONTRL-Block richtig initialisieren
  VDISYS 100                    ! dann kommt die VDI-Funktionsnummer dran
  '
  '  die Infos bekommt man zurück
  handle%=PEEK(INTIN)           ! Gerätekennung
  l_type%=PEEK(INTIN+1)         ! Linientyp
  l_color%=PEEK(INTIN+2)        ! Linienfarbe
  m_type%=PEEK(INTIN+3)         ! Markertyp
  m_color%=PEEK(INTIN+4)        ! Markerfarbe
  font_no%=PEEK(INTIN+5)        ! Font-Nummer
  t_color%=PEEK(INTIN+6)        ! Textfarbe
  f_type%=PEEK(INTIN+7)         ! Fülltyp
  fa_id%=PEEK(INTIN+8)          ! Füllmuster-Index
  fa_color%=PEEK(INTIN+9)       ! Füllmuster-Farbe
  xy_flag%=PEEK(INTIN+10)       ! Koordinatenflag  : 0 -> NDC-Koordinaten
  '                             !                    1 -> reserviert
  '                             !                    2 -> RC-Koordinaten
  '
  x_raster%=DPEEK(INTOUT)        ! maximale x-Pixel
  y_raster%=DPEEK(INTOUT+2)      ! maximale y-Pixel
  skale%=DPEEK(INTOUT+4)         ! Exaktheit der Skalierung : 0 -> genau
  '                                                           1 -> ungenau
  p_width%=DPEEK(INTOUT+6)       ! Pixelbreite (f.Plotter) (x/1000)mm
  p_height%=DPEEK(INTOUT+8)      ! Pixelhöhe (f.Plotter) (x/1000)mm
  fntheight_cnt%=DPEEK(INTOUT+10)! Anzahl Schriftzeichenhöhen
  ltype_cnt%=DPEEK(INTOUT+12)    ! Anzahl Linientypen
  lwidth_cnt%=DPEEK(INTOUT+14)   ! Anzahl Linienbreiten
  mtype_cnt%=DPEEK(INTOUT+16)    ! Anzahl Markertypen
  mwidth_cnt%=DPEEK(INTOUT+18)   ! Anzahl Markergrö×en
  font_cnt%=DPEEK(INTOUT+20)     ! Anzahl Fonts
  sgn_cnt%=DPEEK(INTOUT+22)      ! Anzahl Muster
  diag_cnt%=DPEEK(INTOUT+24)     ! Anzahl Schraffuren
  colr_cnt%=DPEEK(INTOUT+26)     ! Anzahl vordefinierte Farben
  gdp_cnt%=DPEEK(INTOUT+28)      ! Anzahl Graphikgrundfunktionen
  ' intout15 bis intout24 stehen die unterstützten Graphikgrundfunktionen :
  '   Balken / Bogen / Kreisausschnitt / Kreis / Ellipse / elliptische Bogen /
  '   Ellipsensegment / abgerundetes Rechteck / ausgefülltes, abgerundetes
  '   Rechteck / justierter Graphiktext / am ENDE steht -1
  ' intout25 bis intout34 beinhaltet Liste möglicher Attribute der GDP :
  '   Linie / Marker / Text / ausgefüllter Bereich / kein Attribut (DPOKE!!!)
  colr_ok%=DPEEK(INTOUT+70)      ! Farbdarstellungsflag 0 -> nicht
  '                                                     1 -> verfügbar
  txtrot_ok%=DPEEK(INTOUT+72)    ! Textrotationsflag    0 -> nicht
  '                                                     1 -> verfügbar
  fil_ok%=DPEEK(INTOUT+74)       ! Flächenfüllflag      0 -> nicht
  '                                                     1 -> verfügbar
  cellary_ok%=DPEEK(INTOUT+76)   ! CELLARRAY            0 -> nicht
  '                                                     1 -> verfügbar
  colr_cnt2%=DPEEK(INTOUT+78)    ! Anzahl verfügbare Farben (0-> >32767)
  gcurs_ctrl%=DPEEK(INTOUT+80)   ! Graphik-Cursorkontrolle  1 -> Tastatur
  '                                                         2 -> Tastatur + Maus
  in_ctrl%=DPEEK(INTOUT+82)      ! Eingabegerät für versch. Eingaben
  '                                                         1 -> Tastatur
  '                                                         2 -> anderes Gerät
  tast%=DPEEK(INTOUT+84)         ! Auswahltasten            1 -> Funktionstasten
  '                                                         2 -> anderes Tastenfeld
  alpha_in%=DPEEK(INTOUT+86)     ! alphanumerische Eingabe  1 -> Tastatur
  in_out_type%=DPEEK(INTOUT+88)  ! Ein-/Ausgabegerät-Typ    0 -> nur Ausgabe
  '                                                         1 -> nur Eingabe
  '                                                         2 -> Ein-/Ausgabe
  '                                                         3 -> reserviert
  '                                                         4 -> Metafile
  '
  min_w%=DPEEK(PTSOUT)           ! minimale Zeichenbreite
  min_h%=DPEEK(PTSOUT+2)         ! minimale Zeichenhöhe
  max_w%=DPEEK(PTSOUT+4)         ! maximale zeichenbreite
  max_h%=DPEEK(PTSOUT+6)         ! maximale Zeichenhöhe
  min_cw%=DPEEK(PTSOUT+8)        ! minimale Zeilenbreite
  konst%=DPEEK(PTSOUT+10)        ! immer 0
  max_cw%=DPEEK(PTSOUT+12)       ! maximale Zeilenbreite
  konst%=DPEEK(PTSOUT+14)        ! immer 0
  min_mw%=DPEEK(PTSOUT+16)       ! minimale Markerbreite
  min_mh%=DPEEK(PTSOUT+18)       ! minimale Markerhöhe
  max_mw%=DPEEK(PTSOUT+20)       ! maximale Markerbreite
  max_mh%=DPEEK(PTSOUT+22)       ! maximale Markerhöhe
RETURN
PROCEDURE v_clsvwk(handle)       ! Workstation schlie×en
  @vin(0,0,0,0)                  ! CONTRL
  VDISYS 101                     ! VDI-Funktionsnummer
RETURN
PROCEDURE vin(c2%,c4%,c6%,c8%)   ! CONTRL-Block richtig einstellen
  DPOKE CONTRL+2,c2%
  DPOKE CONTRL+4,c4%
  DPOKE CONTRL+6,c6%
  DPOKE CONTRL+8,c8%
RETURN
'
PROCEDURE appl_init              ! Applikation initialisieren
  @ain(0,1,0,0)                  ! GCONTRL-Block richtig einstellen
  GEMSYS 10                      ! AES-Funktionsnummer
RETURN
PROCEDURE graf_handle(hwchar%,hhchar%,wbox%,hbox%)
  '                              ! liefert Handle der Workstation
  @ain(0,5,0,0)                  ! GCONTRL setzen
  GEMSYS 77                      ! AES-Funktionsnummer
  *hwchar%=DPEEK(GINTOUT+2)      ! Breite und
  *hhchar%=DPEEK(GINTOUT+4)      !   Höhe eines Zeichens aus dem Systemzeichensatz
  *wbox%=DPEEK(GINTOUT+6)        ! Breite und Höhe
  *hbox%=DPEEK(GINTOUT+8)        !   eines Standardrechteckes, in das die Zeichen hineinpassen
RETURN
PROCEDURE ain(g2%,g4%,g6%,g8%)   ! der GCONTRL-Block wird gesetzt
  DPOKE GCONTRL+2,g2%
  DPOKE GCONTRL+4,g4%
  DPOKE GCONTRL+6,g6%
  DPOKE GCONTRL+8,g8%
RETURN
