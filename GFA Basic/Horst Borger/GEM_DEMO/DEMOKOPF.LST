'
'       #################################################################
'       #                                                               #
'       #       GEM-DEMO-Programm Ĺĺ PIDAT 1992                         #
'       #       fĀr GFA-BASIC 2.o    (auf 3.6 lĄuft's auch)             #
'       #       Public Domain                                           #
'       #                                                               #
'       #       im Grunde genommen wird nur die BildschirmauslĒsung     #
'       #       abgefragt, aber das klappt bei ALLEN Bildschirmen       #
'       #       die am ST/STE/TT hĄngen.                                #
'       #                                                               #
'       #################################################################
'
@appl_init
gl_apid%=PEEK(INTOUT)
IF gl_apid%<>-1
  FOR i%=0 TO 9
    POKE INTIN+i%,1
  NEXT i%
  POKE INTIN+10,2
  @graf_handle(*gl_wchar,*gl_hchar,*gl_wbox,*gl_hbox)
  handle%=PEEK(INTOUT)
  POKE INTIN,handle%
  @v_opnvwk(INTIN,*handle%,INTOUT)
  '
  '     #################################################################
  '     #                                                               #
  '     #         Hier kommt dann das eigene GEM-Programm rein          #
  '     #                                                               #
  '     #################################################################
  '
  PRINT x_raster%,y_raster%
  @v_clsvwk(handle%)
ELSE
  PRINT "Hat nicht geklappt !!"
ENDIF
VOID INP(2)
EDIT
Procedure V_opnvwk(Intin,Handle%,Intout)
  ' open virtual workstation
  '   Ēffnet virtuelle Workstation, nur fĀr Bildschirmtreiber
  @Vin(0,6,11,45,Handle%)
  Vdisys 100
  @Opn
Return
Procedure V_clsvwk(Handle%)
  ' close virtual workstation
  '   schlieět die virtuelle Workstation
  @Vin(0,0,0,0,Handle%)
  Vdisys 101
Return
Procedure Vin(G2%,G4%,G6%,G8%,Handle%)
  Dpoke Gcontrl+2,G2%
  Dpoke Gcontrl+4,G4%
  Dpoke Gcontrl+6,G6%
  Dpoke Gcontrl+8,G8%
  Dpoke Gcontrl+12,Handle%
Return
Procedure Opn
  ' das sind die ganzen Parameter, die beim ôffnen winer Workstation zurĀck-
  '   gegeben werden
  Handle%=Peek(Intin)
  ' GerĄtekennung
  Lne_type%=Peek(Intin+1)
  ' Linientyp
  Lne_color%=Peek(Intin+2)
  ' Linienfarbe
  Marker_type%=Peek(Intin+3)
  ' Markertyp
  Marker_color%=Peek(Intin+4)
  ' Markerfarbe
  Font_no%=Peek(Intin+5)
  ' Font-ID
  Txt_color%=Peek(Intin+6)
  ' Textfarbe
  Fll_type%=Peek(Intin+7)
  ' FĀlltyp
  Fll_style_id%=Peek(Intin+8)
  ' FĀllmuster-Index
  Fll_style_color%=Peek(Intin+9)
  ' FĀllmuster-Farbe
  Koord_flag%=Peek(Intin+10)
  ' Koordinatenflag  : 0 -> NDC-Koordinaten
  '                    1 -> reserviert
  '                    2 -> RC-Koordinaten
  '
  X_raster_max%=Dpeek(Intout)
  ' maximale x-Pixel
  Y_raster_max%=Dpeek(Intout+2)
  ' maximale y-Pixel
  Skale%=Dpeek(Intout+4)
  ' Exaktheit der Skalierung : 0 -> genau
  '                            1 -> ungenau
  Pixel_width%=Dpeek(Intout+6)
  ' Pixelbreite (f.Plotter) (x/1000)mm
  Pixel_height%=Dpeek(Intout+8)
  ' PixelhĒhe (f.Plotter) (x/1000)mm
  Fontheight_cnt%=Dpeek(Intout+10)
  ' Anzahl SchriftzeichenhĒhen
  Lnetype_cnt%=Dpeek(Intout+12)
  ' Anzahl Linientypen
  Lnewidth_cnt%=Dpeek(Intout+14)
  ' Anzahl Linienbreiten
  Markertype_cnt%=Dpeek(Intout+16)
  ' Anzahl Markertypen
  Markerwidth_cnt%=Dpeek(Intout+18)
  ' Anzahl MarkergrĒěen
  Font_cnt%=Dpeek(Intout+20)
  ' Anzahl Fonts
  Style_cnt%=Dpeek(Intout+22)
  ' Anzahl Muster
  Diag_cnt%=Dpeek(Intout+24)
  ' Anzahl Schraffuren
  Colr_cnt%=Dpeek(Intout+26)
  ' Anzahl vordefinierte Farben
  Gdp_cnt%=Dpeek(Intout+28)
  ' Anzahl Graphikgrundfunktionen
  ' intout15 bis intout24 stehen die unterstĀtzten Graphikgrundfunktionen :
  '   Balken / Bogen / Kreisausschnitt / Kreis / Ellipse / elliptische Bogen /
  '   Ellipsensegment / abgerundetes Rechteck / ausgefĀlltes, abgerundetes
  '   Rechteck / justierter Graphiktext / am ENDE steht -1
  ' intout25 bis intout34 beinhaltet Liste mĒglicher Attribute der GDP :
  '   Linie / Marker / Text / ausgefĀllter Bereich / kein Attribut (DPOKE!!!)
  Colr_ok_flag%=Dpeek(Intout+70)
  ' Farbdarstellungsflag     0 -> nicht
  '                          1 -> verfĀgbar
  Txtrotation_flag%=Dpeek(Intout+72)
  ' Textrotationsflag        0 -> nicht
  '                          1 -> verfĀgbar
  Fll_flag%=Dpeek(Intout+74)
  ' FlĄchenfĀllflag          0 -> nicht
  '                          1 -> verfĀgbar
  Cellary_flag%=Dpeek(Intout+76)
  ' CELLARRAY                0 -> nicht
  '                          1 -> verfĀgbar
  Colr_cnt2%=Dpeek(Intout+78)
  ' Anzahl verfĀgbare Farben (0-> >32767)
  Gcursor_ctrl%=Dpeek(Intout+80)
  ' Graphik-Cursorkontrolle  1 -> Tastatur
  '                          2 -> Tastatur + Maus
  In_ctrl%=Dpeek(Intout+82)
  ' EingabegerĄt fĀr versch. Eingaben
  '                          1 -> Tastatur
  '                          2 -> anderes GerĄt
  Tast%=Dpeek(Intout+84)
  ' Auswahltasten            1 -> Funktionstasten
  '                          2 -> anderes Tastenfeld
  Alpha_in%=Dpeek(Intout+86)
  ' alphanumerische Eingabe  1 -> Tastatur
  In_out_type%=Dpeek(Intout+88)
  ' Ein-/AusgabegerĄt-Typ    0 -> nur Ausgabe
  '                          1 -> nur Eingabe
  '                          2 -> Ein-/Ausgabe
  '                          3 -> reserviert
  '                          4 -> Metafile
  '
  Min_width%=Dpeek(Ptsout)
  ' minimale Zeichenbreite
  Min_height%=Dpeek(Ptsout+2)
  ' minimale ZeichenhĒhe
  Max_width%=Dpeek(Ptsout+4)
  ' maximale zeichenbreite
  Max_height%=Dpeek(Ptsout+6)
  ' maximale ZeichenhĒhe
  Min_columnwidth%=Dpeek(Ptsout+8)
  ' minimale Zeilenbreite
  Konst%=Dpeek(Ptsout+10)
  ' immer 0
  Max_columnwidth%=Dpeek(Ptsout+12)
  ' maximale Zeilenbreite
  Konst%=Dpeek(Ptsout+14)
  ' immer 0
  Min_mkwidth%=Dpeek(Ptsout+16)
  ' minimale Markerbreite
  Min_mkheight%=Dpeek(Ptsout+18)
  ' minimale MarkerhĒhe
  Max_mkwidth%=Dpeek(Ptsout+20)
  ' maximale Markerbreite
  Max_mkheight%=Dpeek(Ptsout+22)
  ' maximale MarkerhĒhe
Return
