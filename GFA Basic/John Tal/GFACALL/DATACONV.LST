Input "File To Convert To Data Statements";I_file$
Print
Input "OutPut File ";O_file$
Print
'
'
If Instr(O_file$,".")=0 Then
  O_file$=O_file$+".LST"
Endif
'
'
Open "R",#1,I_file$,1
Open "O",#2,O_file$
'
Field #1,1 As F1$
'
Max_dt%=28
Dt%=Max_dt%
'
Print At(1,10);"Working on byte ";
Print At(30,10);"/ ";Lof(#1)
While Loc(#1)<Lof(#1)
  '
  Get #1
  Print At(20,10);Loc(#1)
  If Dt%>=Max_dt% Then
    If Loc(#1)>1 Then
      Print #2
    Endif
    Print #2,"DATA ";
    Dt%=0
    Print #2,Str$(Asc(F1$));
    Dt%=Dt%+1
  Else
    If (Dt%<Max_dt%) And (Dt%<>0) Then
      Print #2,",";
    Endif
    Print #2,Str$(Asc(F1$));
    Dt%=Dt%+1
  Endif
  '
Wend
'
Print #2
Print #2,"REM  Total bytes in data statements = ";Lof(#1)
Close #1
Close #2
'
End
