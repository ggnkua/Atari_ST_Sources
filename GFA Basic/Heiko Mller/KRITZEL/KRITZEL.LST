' ****************************************************************************
'
PROCEDURE speicherplatz
  al$=" Speicherplatz| | RAM     : "+STR$(FRE(0))+" K| Diskette: "+STR$(DFREE(0))+" K"
  ALERT 0,al$,1," Aha ",dummy
  DEFMOUSE 3
RETURN
'
' ****************************************************************************
'
PROCEDURE gitter
  gitter!=TRUE
  ALERT 2,"     Gitterweite:      | | ",2,"  5 | 10 | 20 ",we
  weite=5
  IF we=2
    weite=10
  ENDIF
  IF we=3
    weite=20
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE schriftwahl   ! Nach dem Programm "DENISE" aus der "68000er"
  SGET undo$
  GRAPHMODE 1
  SGET merk$
  DEFFILL 1,0,0
  PRBOX 130,60,440,270
  FOR y%=70 TO 230 STEP 32
    PBOX 140,y%,240,y%+31
  NEXT y%
  PRBOX 275,230,315,260
  PRINT AT(21,6);"Normal"
  PRINT AT(21,8);"Fett"
  PRINT AT(21,10);"Hell"
  PRINT AT(21,12);"Kursiv"
  PRINT AT(21,14);"Unterstr."
  PRINT AT(21,16);"Umrandet"
  PRINT AT(37,16);"OK"
  REPEAT
    FOR a=8 TO 16 STEP 2
      PRINT AT(19,a);" "
    NEXT a
    IF s3>0
      FOR i=0 TO 4
        IF s3 AND 2^i
          PRINT AT(19,8+i*2);">"
        ENDIF
      NEXT i
    ENDIF
    GRAPHMODE 1
    FOR y%=70 TO 230 STEP 64
      PBOX 335,y%,430,y%+31
    NEXT y%
    PRINT AT(45,6);"gröŞer"
    PRINT AT(45,10);"kleiner"
    PRINT AT(45,14);"drehen"
    PBOX 245,70,330,190
    GRAPHMODE 2
    DEFTEXT 1,s3,wink,hoehe(ho)
    TEXT 285,110,"Aa"
    TEXT 285,145,"01"
    REPEAT
      MOUSE x%,y%,k%
      a$=INKEY$
    UNTIL k%=1 OR a$=CHR$(13)
    PAUSE 9
    IF x%>140 AND x%<240 AND y%>70 AND y%<262 AND k%=1
      IF y%<102
        s3=0
      ENDIF
      FOR i=0 TO 4
        IF y%>102+32*i AND y%<134+32*i
          IF s3 AND 2^i
            SUB s3,2^i
          ELSE
            ADD s3,2^i
          ENDIF
        ENDIF
      NEXT i
    ENDIF
    IF x%>335 AND x%<430 AND y%>70 AND y%<230 AND k%=1
      IF y%<102
        INC ho
        IF ho>4
          ho=4
        ENDIF
      ENDIF
      IF y%>134 AND y%<166
        SUB ho,1
        IF ho<0
          ho=0
        ENDIF
      ENDIF
      IF y%>198 AND y%<230
        ADD wink,900
        IF wink>2700
          wink=0
        ENDIF
      ENDIF
    ENDIF
  UNTIL x%>275 AND x%<315 AND y%>230 AND y%<260 OR a$=CHR$(13)
  DEFFILL 1,muster1,muster2
  DEFTEXT 1,s3,wink,hoehe(ho)
  SPUT merk$
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE schreiben       ! Nach dem Programm "DENISE" aus der "68000er"
  SGET undo$
  DEFMOUSE 1
  DEFTEXT farbe,s3,wink,hoehe(ho)
  SGET merk$
  GRAPHMODE 2
  DO
    MOUSE x%,y%,k%
    IF k%>1
      SPUT merk$
      schreib$=""
    ENDIF
    EXIT IF k%>1
    a$=""
    a$=INKEY$
    IF LEN(schreib$)
      HIDEM
    ELSE
      SHOWM
    ENDIF
    IF a$=CHR$(8)             ! Backspace
      IF LEN(schreib$)
        schreib$=LEFT$(schreib$,LEN(schreib$)-1)
        SPUT merk$
        TEXT xs,ys,schreib$
      ENDIF
    ELSE
      IF ASC(a$)>31
        schreib$=schreib$+a$
        TEXT xs,ys,schreib$
      ENDIF
    ENDIF
    IF x%<>xs OR y%<>ys AND LEN(schreib$)
      xs=x%
      ys=y%
      SPUT merk$
      TEXT xs,ys,schreib$
    ENDIF
    IF k%=1 AND LEN(schreib$)
      SPUT merk$
      TEXT xs,ys,schreib$
      SGET merk$
      schreib$=""
    ENDIF
    PAUSE 8
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE gummikreis
  COLOR 1
  DEFLINE 1,1,0,0
  REPEAT
    MOUSE x%,y%,k%
  UNTIL k%=1
  IF gitter!
    x%=INT((x%+weite/2)/weite)*weite
    y%=INT((y%+weite/2)/weite)*weite
  ENDIF
  GRAPHMODE 3
  PAUSE 10
  REPEAT
    MOUSE x1%,y1%,k%
    IF gitter!
      x1%=INT((x1%+weite/2)/weite)*weite
      y1%=INT((y1%+weite/2)/weite)*weite
    ENDIF
    radius=ABS(x1%-x%)
    CIRCLE x%,y%,radius
    PAUSE 2
    CIRCLE x%,y%,radius
  UNTIL k%<>1
  GRAPHMODE mode
  DEFLINE stil,breite,2,2
  DEFFILL 1,muster1,muster2
  COLOR farbe
RETURN
'
' ****************************************************************************
'
PROCEDURE kopieren
  DEFMOUSE 5
  SGET undo$
  REPEAT
    a$=INKEY$
    IF (LEN(a$)=2 AND ASC(RIGHT$(a$))=98)
      al$=" bitte erste Ecke festlegen, |  linke Maustaste festhalten |"
      al$=al$+" und die BlockgröŞe bestimmen| "
      ALERT 0,al$,1," OK ",dummy
    ENDIF
  UNTIL MOUSEK=1
  GOSUB gummikasten
  GET x%,y%,x1%,y1%,a$
  GRAPHMODE 1
  GOSUB box_schieben
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE testbild
  SGET undo$
  CLS
  GRAPHMODE 3
  DEFTEXT 1,16,0,32
  FOR i%=0 TO 639 STEP 4
    LINE 0,0,i%,399
    LINE 639,0,i%,399
  NEXT i%
  TEXT 250,100,"TESTBILD"
  SGET bild$
  GRAPHMODE mode
RETURN
'
' ****************************************************************************
'
PROCEDURE gummikasten
  COLOR 1
  DEFLINE 1,1,0,0
  REPEAT
    MOUSE x%,y%,k%
  UNTIL k%
  IF gitter!
    x%=INT((x%+weite/2)/weite)*weite
    y%=INT((y%+weite/2)/weite)*weite
  ENDIF
  GRAPHMODE 3
  PAUSE 10
  REPEAT
    MOUSE x1%,y1%,k%
    IF gitter!
      x1%=INT((x1%+weite/2)/weite)*weite
      y1%=INT((y1%+weite/2)/weite)*weite
    ENDIF
    BOX x%,y%,x1%,y1%
    PAUSE 2
    BOX x%,y%,x1%,y1%
  UNTIL k%<>1
  GRAPHMODE mode
  DEFLINE stil,breite,2,2
  DEFFILL 1,muster1,muster2
  COLOR farbe
  IF x1%>=640
    x1%=639
  ENDIF
  IF y1%>=400
    y1%=399
  ENDIF
  IF x1%<x%
    SWAP x1%,x%
  ENDIF
  IF y1%<y%
    SWAP y1%,y%
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE spiegeln     ! die nächsten Proceduren stammen alle aus
  '                      dem GFA-BASIC-Buch von F. Ostrowski
  DEFMOUSE 5
  SGET undo$
  DIM smfdb%(8),dmfdb%(8),p%(8)
  REPEAT
    a$=INKEY$
    IF (LEN(a$)=2 AND ASC(RIGHT$(a$))=98)
      al$=" bitte erste Ecke festlegen, |  linke Maustaste festhalten |"
      al$=al$+" und die BlockgröŞe bestimmen| "
      ALERT 0,al$,1," OK ",dummy
    ENDIF
  UNTIL MOUSEK=1
  GOSUB gummikasten
  GET x%,y%,x1%,y1%,a$
  @mirrorput(x%,y%,*a$)
  ERASE smfdb%()
  ERASE dmfdb%()
  ERASE p%()
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE mirrorput(x%,y%,s.%)
  IF DPEEK(s.%+4)>6      !nur wenn auch etwas da ist
    a%=LPEEK(s.%)
    b%=DPEEK(a%)
    h%=DPEEK(a%+2)
    smfdb%(0)=a%+6
    smfdb%(1)=(b%+16) AND &HFFF0
    smfdb%(2)=h%+1
    smfdb%(3)=smfdb%(1)/16
    smfdb%(5)=DPEEK(a%+4)
    dmfdb%(0)=XBIOS(3)
    dmfdb%(1)=640
    dmfdb%(2)=400
    dmfdb%(3)=40
    dmfdb%(5)=1
    ALERT 2,"Wie willst Du spiegeln?",0,"vertikal|horizont",antw
    ON antw GOSUB vertikal,horizontal
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE vertikal
  p%(1)=0
  p%(3)=h%
  p%(5)=y%
  p%(7)=y%+h%
  p%(8)=3
  p%(4)=x%+b%
  p%(6)=x%+b%
  FOR i%=0 TO b%
    p%(0)=i%
    p%(2)=i%
    BITBLT smfdb%(),dmfdb%(),p%()
    DEC p%(4)
    DEC p%(6)
  NEXT i%
RETURN
'
' ****************************************************************************
'
PROCEDURE horizontal
  p%(0)=0
  p%(2)=b%
  p%(4)=x%
  p%(6)=x%+b%
  p%(8)=3
  p%(5)=y%+h%
  p%(7)=y%+h%
  FOR i%=0 TO h%
    p%(1)=i%
    p%(3)=i%
    BITBLT smfdb%(),dmfdb%(),p%()
    DEC p%(5)
    DEC p%(7)
  NEXT i%
RETURN
'
' ****************************************************************************
'
PROCEDURE auf_diskette
  DEFMOUSE 5
  REPEAT
    a$=INKEY$
    IF (LEN(a$)=2 AND ASC(RIGHT$(a$))=98)
      al$=" bitte erste Ecke festlegen, |  linke Maustaste festhalten |"
      al$=al$+" und die BlockgröŞe bestimmen| "
      ALERT 0,al$,1," OK ",dummy
    ENDIF
  UNTIL MOUSEK=1
  GOSUB gummikasten
  GRAPHMODE 3
  DEFFILL 1,2,8                    ! schwarze Füllung
  PBOX x%,y%,x1%,y1%
  PAUSE 40
  PBOX x%,y%,x1%,y1%
  GET x%,y%,x1%,y1%,a$
  antw=1
  IF DFREE(0)<LEN(a$)
    REPEAT
      ALERT 0,"Nicht genug Platz|auf der Diskette!| |Willst Du etwas löschen?",1," ja |nein",antw
      IF antw=1
        GOSUB datei_loeschen
      ENDIF
    UNTIL DFREE(0)>LEN(a$) OR antw=2
  ENDIF
  IF antw=1
    FILESELECT "A:\BILDER\*.BLK","",name$
    IF LEN(name$)>0
      IF INSTR(name$,".")=0
        name$=name$+".BLK"
      ENDIF
      BSAVE name$,VARPTR(a$),LEN(a$)
      GRAPHMODE 1
    ENDIF
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE von_diskette
  SGET undo$
  a$=""
  FILESELECT "A:\BILDER\*.BLK","",name$
  IF EXIST(name$)                           ! Datei existiert?
    OPEN "I",#99,name$                      !  dann öffnen
    a$=SPACE$(LOF(#99))                     !  DateigröŞe ermitteln
    BLOAD name$,VARPTR(a$)                  !  Datei laden
    CLOSE #99                               !  Datei schlieŞen
    GOSUB box_schieben
  ENDIF
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE block_invert
  DEFMOUSE 5
  SGET undo$
  REPEAT
    a$=INKEY$
    IF (LEN(a$)=2 AND ASC(RIGHT$(a$))=98)
      al$=" bitte erste Ecke festlegen, |  linke Maustaste festhalten |"
      al$=al$+" und die BlockgröŞe bestimmen| "
      ALERT 0,al$,1," OK ",dummy
    ENDIF
  UNTIL MOUSEK=1
  GOSUB gummikasten
  GET x%,y%,x1%,y1%,a$
  GRAPHMODE 3
  DEFFILL 1,2,8
  PBOX x%,y%,x1%,y1%
  GRAPHMODE mode
  DEFFILL 1,muster1,muster2
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE box_schieben
  DIM bild%(32255/4)
  a%=XBIOS(3)
  b%=(VARPTR(bild%(0))+255) AND &HFFFF00
  SGET bild$
  DEFLINE 1,1,0,0
  REPEAT
    SWAP a%,b%
    VOID XBIOS(5,L:a%,L:b%,-1)
    SPUT bild$
    MOUSE x%,y%,k%
    IF gitter!
      x%=INT((x%+weite/2)/weite)*weite
      y%=INT((y%+weite/2)/weite)*weite
    ENDIF
    PUT x%,y%,a$
    IF k%=1
      SGET bild$
    ENDIF
    LINE x%,0,x%,399
    LINE 0,y%,639,y%
  UNTIL k%=2
  a%=MAX(a%,b%)
  VOID XBIOS(5,L:a%,L:a%,-1)
  ERASE bild%()
  SPUT bild$
RETURN
