' ****************************************************************************
'
PROCEDURE invert
  SGET undo$
  GRAPHMODE 3
  DEFFILL 1,1,1
  PBOX -1,-1,640,400
  GRAPHMODE 1
  DEFFILL 1,muster1,muster2
  SGET bild$
RETURN
