' *****************************************************************************
'
' M A L P R O G R A M M    " K R I T Z E L"
'
' programmiert von Heiko Müller, MozartstraŞe 17, 2905 Edewecht
'
' Das Programm darf mitsamt der Programmliste beliebig kopiert oder weiter-
' gegeben werden.
'
' Die Grundfunktionen dieses Programms kann jeder durch Ausprobieren kennen-
' lernen. Die meisten Funktionen lassen sich auŞer über das Menü auch durch
' eine Taste aufrufen (siehe dazu im Menü).
'
' Jede aufgerufene Funktion wird wieder verlassen durch Betätigung der rechten
' Maustaste.
'
' Nach Betätigung der rechten Maustaste können die zuletzt eingefügten Ände-
' rungen durch die Taste [Undo] wieder rückgängig gemacht werden.
'
' Viele Aktionen können sofort durch Betätigung der Taste [X] rückgängig
' gemacht werden.
'
' Mit der Taste [Help] können an vielen Stellen Hilfsbemerkungen abgerufen
' werden.
'
datum$="27.07.1988"                 ! letzes Bearbeitungsdatum
version$="02"                       ! Version-Nummer
'
' *****************************************************************************
'
SGET bild$
SGET undo$
GOSUB ueberschrift
GOSUB speicher_einrichten
CLS
GOSUB menue_einrichten
MENU menue$()
MENU OFF
GOSUB zustand_anzeigen
'
' *************************************** Hauptprogramm ***********************
'
ON MENU  GOSUB abfrage
ON MENU KEY GOSUB abfrage
DO
  ON MENU
LOOP
'
' ****************************************************************************
'
PROCEDURE menue_einrichten
  RESTORE
  FOR i=0 TO 100
    READ menue$(i)
    EXIT IF menue$(i)="***"
  NEXT i
  LET menue$(i)=""
  LET menue$(i+1)=""
  DATA Desk,  über dieses Programm,------------------------
  DATA 1,2,3,4,5,6,""
  DATA Diskette, Speicherplatz,---------------------
  DATA  Bild laden, Bild speichern, Datei löschen
  DATA ---------------------, Programmende,""
  DATA Bildschirm, ohne Menü   (O),----------------, invertieren (I)
  DATA  ausdrucken  (D),----------------, löschen   (Esc),""
  DATA Linien, Freihand            (F), Gerade              (G)
  DATA  Linienzug           (L), Strahlen            (*)
  DATA ------------------------, Linienwahl          (-), Zeichenfarbe ändern (Z),""
  DATA Werkzeug,  Radiergummi        (R),  Sprühdose          (S),  Mikroskop          (M)
  DATA ------------------------,  Ausfüllen          (A),  Füllmuster wählen  (Y)
  DATA   Graphikmodus       (.),------------------------,  Gitter             (#),""
  DATA Figuren,  Kreis               (F1),  Ellipse             (F2)
  DATA   regelmäŞiges N-Eck  (F3),  Rechteck kantig     (F4),  Rechteck abgerundet (F5)
  DATA   Vieleck             (F6)
  DATA ---------------------------,  Figuren ausfüllen  (F10)
  DATA ---------------------------,  Schriftwahl          (W)
  DATA ---------------------------,  Text schreiben       (T),""
  DATA Block, spiegeln, kopieren, invertieren,---------------
  DATA  auf Diskette, von Diskette,""
  DATA ***
RETURN
'
' ****************************************************************************
'
PROCEDURE abfrage
  MENU KILL
  SPUT bild$
  taste=INT(MENU(14)/256)
  ' ŞŞŞŞŞŞŞŞŞŞŞŞ
  ' PRINT AT(30,20);taste        ! Dies braucht man beim Verändern des Menüs
  ' ŞŞŞŞŞŞŞŞŞŞŞŞŞŞ               ! zum Ausprobieren der Tastencodes
  auswahl=MENU(0)
  REPEAT
  UNTIL MOUSEK=0
  IF auswahl=1
    GOSUB ueber
  ENDIF
  IF auswahl=11
    GOSUB speicherplatz
  ENDIF
  IF auswahl=13
    GOSUB laden
  ENDIF
  IF auswahl=14
    GOSUB speichern
  ENDIF
  IF auswahl=15
    GOSUB datei_loeschen
  ENDIF
  IF auswahl=17
    GOSUB schluss
  ENDIF
  IF auswahl=20 OR taste=24
    SPUT bild$
    REPEAT
      a=INP(2)
    UNTIL a
  ENDIF
  IF auswahl=22 OR taste=23
    GOSUB invert
  ENDIF
  IF auswahl=23 OR taste=32
    GOSUB ausdruck
  ENDIF
  IF auswahl=25 OR taste=1
    GOSUB loeschen
  ENDIF
  IF auswahl=28 OR taste=33
    GOSUB freihand
  ENDIF
  IF auswahl=29 OR taste=34
    GOSUB gerade
  ENDIF
  IF auswahl=30 OR taste=38
    GOSUB linienzug
  ENDIF
  IF auswahl=31 OR taste=102
    GOSUB strahlen
  ENDIF
  IF auswahl=33 OR taste=53
    GOSUB linienwahl
  ENDIF
  IF auswahl=34 OR taste=21
    GOSUB farbwahl
  ENDIF
  IF auswahl=37 OR taste=19
    GOSUB radiergummi
  ENDIF
  IF auswahl=38 OR taste=31
    GOSUB spruehdose
  ENDIF
  IF auswahl=39 OR taste=50
    GOSUB mikroskop
  ENDIF
  IF auswahl=41 OR taste=30
    GOSUB fuellen
  ENDIF
  IF auswahl=42 OR taste=44
    GOSUB musterwahl
  ENDIF
  IF auswahl=43 OR taste=52
    GOSUB moduswahl
  ENDIF
  IF auswahl=45 OR taste=41
    IF gitter!=FALSE
      GOSUB gitter
    ELSE
      gitter!=FALSE
    ENDIF
  ENDIF
  IF auswahl=48 OR taste=59
    GOSUB kreis
  ENDIF
  IF auswahl=49 OR taste=60
    GOSUB ellipse
  ENDIF
  IF auswahl=50 OR taste=61
    GOSUB n_ecken
  ENDIF
  IF auswahl=51 OR taste=62
    GOSUB kasten
  ENDIF
  IF auswahl=52 OR taste=63
    GOSUB rundkasten
  ENDIF
  IF auswahl=53 OR taste=64
    GOSUB vieleck
  ENDIF
  IF auswahl=55 OR taste=68
    IF figurfuellen!
      figurfuellen!=FALSE
    ELSE
      figurfuellen!=TRUE
    ENDIF
  ENDIF
  IF auswahl=57 OR taste=17
    GOSUB schriftwahl
    GOSUB schreiben
  ENDIF
  IF auswahl=59 OR taste=20
    IF taste=20 AND (BIOS(11,-1) AND 4)=4  ! Wenn Controltaste gehalten
      GOSUB testbild
    ELSE
      GOSUB schreiben
    ENDIF
  ENDIF
  IF auswahl=62
    GOSUB spiegeln
  ENDIF
  IF auswahl=63
    GOSUB kopieren
  ENDIF
  IF auswahl=64
    GOSUB block_invert
  ENDIF
  IF auswahl=66
    GOSUB auf_diskette
  ENDIF
  IF auswahl=67
    GOSUB von_diskette
  ENDIF
  IF taste=98                    !Help
    al$="Probier doch mal einfach aus, |was das Menü alles enthält! |"
    al$=al$+"An anderen Stellen gibt's mit |dieser Taste Hilfe.           "
    ALERT 1,al$,1," OK ",dummy
  ENDIF
  IF taste=97                    !Undo
    SPUT undo$
    bild$=undo$
  ENDIF
  MENU OFF
  MENU menue$()
  ON MENU  GOSUB abfrage
  ON MENU KEY GOSUB abfrage
  MENU 45,-gitter!
  MENU 55,-figurfuellen!
  DEFMOUSE 3
  SHOWM
  GOSUB zustand_anzeigen
RETURN
'
' ****************************************************************************
'
PROCEDURE speicher_einrichten
  DIM menue$(100)
  DIM wert(20),sektor(20),text$(20),prozent(20)
  DIM hoehe(4)
  RESTORE hoehe
  FOR a=0 TO 4
    READ hoehe(a)
  NEXT a
  hoehe:
  DATA 4,6,13,20,32
  muster1=2
  muster2=4
  DEFFILL 1,muster1,muster2 ! grau
  gitter!=FALSE ! aus
  farbe=1      ! schwarz
  farb$="S"
  figurfuellen!=FALSE
  DEFMOUSE 3
  mode=1
  modus$=" 1"
  SETCOLOR 0,1
  stil=1
  breite=1
  name$="bild"
  ho=2
  wink=0
RETURN
'
' ****************************************************************************
'
PROCEDURE ueberschrift
  DEFFILL 1,4,1
  PBOX 5,5,635,395
  DEFFILL 0,2,8
  PBOX 20,45,620,225
  DEFTEXT 1,16,0,32
  TEXT 25,75," * * * * * * * * * * * * * * "
  TEXT 25,110," K R I T Z E L"
  TEXT 25,145," * * * * * * * * * * * * * * "
  DEFTEXT 1,16,0,13
  TEXT 45,185,"ein  MALPROGRAMM "
  DEFTEXT 1,0,0,4
  TEXT 550,55,"Version "+version$
  TEXT 550,65,"vom"
  TEXT 550,75,datum$
  TEXT 45,215,"mit Druckeranpassung für Panasonic KXP1092"
  TEXT 420,215,"Leertaste oder rechte Maustaste"
  REPEAT
  UNTIL MOUSEK>1 OR INKEY$=" "
RETURN
'
' ****************************************************************************
'
PROCEDURE ueber
  GRAPHMODE 1
  SGET undo$
  CLS
  PRINT
  PRINT " Dieses Programm wurde in GfA-BASIC programmiert von"
  PRINT
  PRINT "     Heiko Müller, MozartstraŞe 17, 2905 Edewecht"
  PRINT
  PRINT " Das Programm darf mitsamt der Programmliste beliebig kopiert oder weiter-"
  PRINT " gegeben werden."
  PRINT
  PRINT
  PRINT " Die Grundfunktionen dieses Programms kann jeder durch Ausprobieren kennen-"
  PRINT " lernen. Die meisten Funktionen lassen sich auŞer über das Menü auch durch"
  PRINT " eine Taste aufrufen (siehe dazu im Menü)."
  PRINT
  PRINT " Jede aufgerufene Funktion wird wieder verlassen durch Betätigung der rechten"
  PRINT " Maustaste."
  PRINT
  PRINT " Nach Betätigung der rechten Maustaste können die zuletzt eingefügten Ände-"
  PRINT " rungen durch die Taste [Undo] wieder rückgängig gemacht werden."
  PRINT
  PRINT " Viele Aktionen können sofort durch Betätigung der Taste [X] rückgängig"
  PRINT " gemacht werden."
  PRINT
  PRINT " Mit der Taste [Help] können an vielen Stellen Hilfsbemerkungen abgerufen"
  PRINT " werden."
  REPEAT
  UNTIL MOUSEK>1 OR INKEY$<>""
  SPUT undo$
RETURN
'
' ****************************************************************************
'
PROCEDURE zustand_anzeigen
  GRAPHMODE 1
  DEFFILL 1,muster1,muster2
  PBOX 610,1,638,18
  COLOR 1
  DEFLINE stil,breite,0,0
  LINE 550,0,550,18
  DEFTEXT 1,0,0,6
  TEXT 575,10,farb$+modus$
RETURN
'
' ****************************************************************************
'
PROCEDURE schluss
  OUT 2,7
  ALERT 2,"      Willst Du wirklich | mit dem Malprogramm aufhören?",2," Ja | Nein ",a
  IF a=1
    SYSTEM
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE laden
  SGET undo$
  FILESELECT "A:\BILDER\*.MAL","",name$
  IF LEN(name$)>0
    IF EXIST(name$)
      BLOAD name$,XBIOS(2)
    ENDIF
  ENDIF
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE speichern
  antw=1
  IF DFREE(0)<32000
    REPEAT
      ALERT 0,"Nicht genug Platz|auf der Diskette!| |Willst Du etwas löschen?",1," ja |nein",antw
      IF antw=1
        GOSUB datei_loeschen
      ENDIF
    UNTIL DFREE(0)>32000 OR antw=2
  ENDIF
  IF antw=1
    FILESELECT "A:\BILDER\*.MAL","",name$
    IF LEN(name$)>0
      IF INSTR(name$,".")=0
        name$=name$+".MAL"
      ENDIF
      SPUT bild$
      HIDEM
      BSAVE name$,XBIOS(2),32000
    ENDIF
    DEFFILL 1,muster1,muster2
    GRAPHMODE 1
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE loeschen
  SGET undo$
  ALERT 2," Bild wirklich löschen ? ",1," Nein | Ja ",antw
  IF antw=2
    CLS
    SGET bild$
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE radiergummi
  DEFMOUSE 5
  SGET undo$
  REPEAT
    a$=INKEY$
    IF LEN(a$)=2 AND ASC(RIGHT$(a$))=98
      al$=" bitte erste Ecke festlegen, |linke Maustaste festhalten und|"
      al$=al$+"die RadiergummigröŞe bestimmen| "
      ALERT 0,al$,1," OK ",dummy
    ENDIF
  UNTIL MOUSEK=1
  GOSUB gummikasten
  rbreite=ABS(x%-x1%)
  rhoehe=ABS(y%-y1%)
  DEFLINE 1,1,2,2
  DEFFILL 0,1,0
  DO
    GRAPHMODE 3
    HIDEM
    REPEAT
      MOUSE x%,y%,k%
      BOX x%,y%,x%+rbreite,y%+rhoehe
      PAUSE 1
      BOX x%,y%,x%+rbreite,y%+rhoehe
      x$=INKEY$
    UNTIL k% OR x$="X" OR x$="x"
    IF x$="X" OR x$="x"
      SPUT merk$
    ENDIF
    SGET merk$
    WHILE k%=1
      GRAPHMODE 3
      BOX x%,y%,x%+rbreite,y%+rhoehe
      PAUSE 1
      BOX x%,y%,x%+rbreite,y%+rhoehe
      GRAPHMODE 1
      MOUSE x%,y%,k%
      PBOX x%,y%,x%+rbreite,y%+rhoehe
    WEND
    EXIT IF k%>1
  LOOP
  DEFLINE stil,breite,2,2
  GRAPHMODE mode
  DEFFILL 1,muster1,muster2
  COLOR farbe
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE ausdruck
  ant=2
  ALERT 2,"Bild wirklich ausdrucken? ",2,"  Ja  | Nein ",antw
  IF antw=1
    antw=0
    DO
      EXIT IF OUT?(0)
      ALERT 1,"Drucker einschalten !",2,"Abbruch| OK ",antw
      EXIT IF antw=1
    LOOP
    IF antw<>1
      OUT 4,18
      HIDEM
      LPRINT CHR$(28);"@";       ! Drucker initialisieren (NEC P2200)
      LPRINT
      GOSUB hardcopy
      OUT 4,8
    ENDIF
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE hardcopy      ! aus dem "GFA-BASIC-Buch von F. Ostrowski
  a$=SPACE$(400)
  ' g$="    "+CHR$(27)+"*"+CHR$(0)+CHR$(400)+CHR$(400/256)  !für NEC P2200
  g$="    "+CHR$(27)+"*"+CHR$(5)+CHR$(400)+CHR$(400/256)!für Panasonic KXP1092
  OPEN "",#99,"LST:"
  FOR i%=XBIOS(3) TO i%+79
    abbruch%=0
    x%=VARPTR(a$)
    FOR q%=i%+399*80 TO i% STEP -80
      POKE x%,PEEK(q%)
      INC x%
    NEXT q%
    FOR qq%=0 TO 2
      PRINT #99,g$;a$;CHR$(13);CHR$(27);"J";CHR$(1);
      IF INKEY$<>""
        OUT 4,8
        ALERT 2,"Ausdruck abbrechen?",1,"  ja  | nein ",abbruch%
      ENDIF
      EXIT IF abbruch%=1
    NEXT qq%
    PRINT #99,CHR$(27);"J";CHR$(21);
    EXIT IF abbruch%=1
  NEXT i%
  CLOSE #99
RETURN
'
' ****************************************************************************
'
PROCEDURE datei_loeschen
  FILESELECT "A:\BILDER\*.*","",name$
  IF LEN(name$)>0
    ALERT 3," Die Datei        | "+name$+"| löschen ?",1,"Nein| Ja ",antw
    IF antw=2
      KILL name$
    ENDIF
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE mikroskop      ! Nach dem Programm "DENISE" aus der "68000er"
  SGET undo$
  HIDEM
  DO
    DEFLINE 1,1,0,0
    GRAPHMODE 3
    REPEAT
      MOUSE x%,y%,k%
      IF x%>600
        x%=600
      ENDIF
      IF y%>360
        y%=360
      ENDIF
      BOX x%,y%,x%+39,y%+39
      PAUSE 3
      BOX x%,y%,x%+39,y%+39
      a$=INKEY$
      IF (LEN(a$)=2 AND ASC(RIGHT$(a$))=98)
        al$="bitte VergröŞerungsgebiet aus- |suchen, dann linke Maustaste |"
        al$=al$+" |Ausstieg mit rechter Maustaste"
        ALERT 0,al$,1," OK ",dummy
      ENDIF
    UNTIL k%
    IF k%>1
      GOTO lupe_ende
    ENDIF
    SGET merk$
    ausschnitt$=""
    IF x%>29 AND x%<550 AND y%>29 AND y%<350
      GET x%-30,y%-30,x%+69,y%+69,ausschnitt$
    ENDIF
    GET x%,y%,x%+39,y%+39,lupe$
    DEFFILL 1,1,1
    CLS
    ERASE lupe()
    DIM lupe(40,40)
    ARRAYFILL lupe(),0
    PUT 520,70,ausschnitt$
    BOX 549,99,590,140
    PUT 550,100,lupe$
    FOR a=0 TO 39
      FOR b=0 TO 39
        IF POINT(550+a,100+b)
          lupe(a,b)=1
          PBOX a*10,b*10,a*10+9,b*10+9
        ENDIF
      NEXT b
    NEXT a
    SHOWM
    GRAPHMODE 1
    DEFLINE 1,1,0,0
    BOX 549,99,590,140
    PBOX 400,0,410,399
    GRAPHMODE 3
    DEFMOUSE 0
    REPEAT
      REPEAT
        MOUSE x1%,y1%,k%
        a=INT(x1%/10)
        b=INT(y1%/10)
        PRINT AT(70,12);a'b'''
        IF a<40
          IF lupe(a,b)
            set=1
          ELSE
            set=0
          ENDIF
        ENDIF
      UNTIL k%
      IF k%=1 AND a<40
        GRAPHMODE 3
        WHILE MOUSEK=1
          MOUSE x1%,y1%,k%
          a=INT(x1%/10)
          b=INT(y1%/10)
          PRINT AT(70,12);a'b'''
          IF a<40
            IF set=lupe(a,b)
              PBOX a*10,b*10,9+a*10,9+b*10
              lupe(a,b)=ABS(lupe(a,b)-1)
              PLOT 550+a,100+b
            ENDIF
          ENDIF
        WEND
      ENDIF
    UNTIL k%>1
    GET 550,100,550+39,100+39,lupe$
    DEFFILL 1,muster1,muster2
    DEFLINE stil,breite,2,2
    SPUT merk$
    PUT x%,y%,lupe$
    lupe$=""
    ERASE lupe()
    PAUSE 15
    GRAPHMODE 1
    lupe_ende:
    GRAPHMODE 1
    EXIT IF MOUSEK=2
  LOOP
  DEFLINE stil,breite,2,2
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE musterwahl
  SGET sicher$
  DEFMOUSE 3
  musterdaten:
  DATA 2,1,2,2,2,3,2,4,2,5,2,6
  DATA 2,7,2,8,2,9,2,10,2,11,2,12
  DATA 2,13,2,14,2,15,2,16,2,17,2,18
  DATA 2,19,2,20,2,21,2,22,2,23,2,24
  DATA 3,1,3,2,3,3,3,4,3,5,3,6
  DATA 3,7,3,8,3,9,3,10,3,11,3,12,4,1,0,0,0,0
  RESTORE musterdaten
  GRAPHMODE 1
  FOR i%=0 TO 37
    READ muster1,muster2
    DEFFILL 1,muster1,muster2
    PBOX i%*16.8,50,i%*16.8+16.8,110
  NEXT i%
  REPEAT
    MOUSE x%,y%,k%
    x%=INT(x%/16.8)
  UNTIL k% AND y%>40 AND y%<110
  RESTORE musterdaten
  FOR i%=1 TO x%+1
    READ muster1,muster2
  NEXT i%
  DEFFILL 1,muster1,muster2
  PBOX 0,50,640,110
  PAUSE 10
  REPEAT
  UNTIL MOUSEK=0
  SPUT sicher$
  DEFMOUSE 0
RETURN
'
' ****************************************************************************
'
PROCEDURE moduswahl
  DEFLINE 1,1,0,0
  modus$=""
  DO
    GRAPHMODE 1
    DEFFILL 1,0,0
    PRBOX 180,30,460,205
    FOR i%=1 TO 4
      BOX 200,23+i%*32,440,55+i%*32
    NEXT i%
    PRINT AT(27,5);"Modus 1: überdecken"
    PRINT AT(27,7);"Modus 2: durchsichtig"
    PRINT AT(27,9);"Modus 3: X-Or"
    PRINT AT(27,11);"Modus 4: Invers transparent"
    DEFFILL 1,1,1
    GRAPHMODE 3
    PBOX 200,23+mode*32,440,55+mode*32
    EXIT IF modus$<>""
    DO
      MOUSE a,b,c
      a$=INKEY$
      EXIT IF (c=1 AND a>200 AND a<440 AND b>55 AND b<249) OR ASC(a$)=13
      EXIT IF VAL(a$)>0 AND VAL(a$)<5
    LOOP
    EXIT IF ASC(a$)=13 OR modus$<>""
    IF c=1 AND a>200 AND a<440 AND b>55 AND b<183
      mode=INT((b-23)/32)
      modus$=" "+STR$(mode)
    ENDIF
    IF VAL(a$)>0
      mode=VAL(a$)
      modus$=" "+STR$(mode)
    ENDIF
  LOOP
  PAUSE 50
  SPUT bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE fuellen
  SGET undo$
  DEFFILL 1,muster1,muster2
  DEFMOUSE 0
  DO
    REPEAT
      MOUSE x%,y%,k%
      x$=INKEY$
      IF x$="y" OR x$="Y"
        GOSUB musterwahl
        k%=0
      ENDIF
      IF (LEN(x$)=2 AND ASC(RIGHT$(x$))=98)
        al$="gefüllt wird mit dem Muster,|das in der Menüzeile oben |"
        al$=al$+"rechts zu sehen war.|Füllen mit linker Maustaste"
        ALERT 0,al$,1," OK ",dummy
        al$="Das Füllmuster kann mit der|Taste Y gewechselt werden.|"
        ALERT 0,al$,1," OK ",dummy
      ENDIF
    UNTIL k% OR x$="x" OR x$="X"
    EXIT IF k%>1
    IF x$="x" OR x$="X"
      SPUT merk$
    ENDIF
    SGET merk$
    IF k%=1
      FILL x%,y%
    ENDIF
    REPEAT
    UNTIL MOUSEK=0
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE spruehdose
  SGET undo$
  COLOR farbe
  DEFLINE 1,1,0,0
  HIDEM
  DO
    GRAPHMODE 3
    HIDEM
    REPEAT
      MOUSE x%,y%,k%
      BOX x%,y%,x%+20,y%+20
      PAUSE 1
      BOX x%,y%,x%+20,y%+20
      x$=INKEY$
    UNTIL k% OR x$="X" OR x$="x"
    IF x$="X" OR x$="x"
      SPUT merk$
    ENDIF
    SGET merk$
    EXIT IF k%>1
    GRAPHMODE 1
    WHILE k%=1
      MOUSE x%,y%,k%
      PLOT RANDOM(20)+x%,RANDOM(20)+y%
    WEND
    EXIT IF k%>1
  LOOP
  DEFLINE stil,breite,2,2
  GRAPHMODE 1
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE linienwahl       ! Nach dem Programm "DENISE" aus der "68000er"
  SGET undo$
  COLOR 1
  GRAPHMODE 1
  SGET merk$
  DEFFILL 1,2,1
  PRBOX 140,60,380,305
  DEFFILL 1,0,0
  FOR i=104 TO 168 STEP 32
    PBOX 150,i,220,i+31
  NEXT i
  PBOX 150,235,220,260
  PRINT AT(20,8);"Breite +"
  PRINT AT(20,10);"Breite -"
  PRINT AT(20,12);"  Stil"
  PRINT AT(20,16);" Fertig"
  DO
    DEFLINE stil,breite,2,2
    PBOX 270,103,330,245
    LINE 300,125,300,225
    REPEAT
      MOUSE x%,y%,k%
      a$=INKEY$
      IF (LEN(a$)=2 AND ASC(RIGHT$(a$))=98)
        al$="Hier werden die Linienart|bestimmt, die bei Linien oder|"
        al$=al$+"bei Figuren (z.B. Geraden) |benutzt wird."
        ALERT 0,al$,1," OK ",dummy
      ENDIF
    UNTIL k%=1 OR a$=CHR$(13)
    PAUSE 5
    EXIT IF a$=CHR$(13)
    IF x%>150 AND x%<220
      IF y%>104 AND y%<136
        breite=breite+2
        IF breite>40
          breite=40
        ENDIF
      ENDIF
      IF y%>136 AND y%<168
        breite=breite-2
        IF breite<1
          breite=1
        ENDIF
      ENDIF
      IF y%>168 AND y%<200
        REPEAT
        UNTIL MOUSEK=0
        breite=1
        INC stil
        IF stil>6
          stil=1
        ENDIF
      ENDIF
    ENDIF
    EXIT IF y%>235 AND y%<260
  LOOP
  SPUT merk$
  GRAPHMODE mode
  DEFLINE stil,breite,2,2
  DEFFILL 1,muster1,muster2
  COLOR farbe
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE farbwahl
  SGET undo$
  f$="weiŞ"
  IF farbe=1
    farbe=0
    farb$="W"
  ELSE
    farbe=1
    f$="Schwarz"
    farb$="S"
  ENDIF
  SGET merk$
  COLOR farbe
  DEFFILL farbe,2,8
  PRBOX 220,120,385,210
  PRINT AT(30,10);" Zeichenfarbe ist "
  PRINT AT(35,12);'f$'
  PAUSE 50
  SPUT merk$
  DEFFILL 1,muster1,muster2
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE freihand
  SGET undo$
  DEFLINE stil,breite,2,2
  COLOR 1
  DEFMOUSE 7
  DO
    GRAPHMODE mode
    IF mode=4
      GRAPHMODE 1
    ENDIF
    COLOR farbe
    REPEAT
      MOUSE x%,y%,k%
      x$=INKEY$
      IF (LEN(x$)=2 AND ASC(RIGHT$(x$))=98)
        al$="Zeichnen mit gedrückter linker|Maustaste  -  |"
        al$=al$+"Ausstieg mit rechter Maustaste|Löschen mit X"
        ALERT 0,al$,1," OK ",dummy
      ENDIF
    UNTIL k% OR x$="x" OR x$="X"
    IF x$="X" OR x$="x"
      SPUT merk$
    ENDIF
    EXIT IF k%>1
    SGET merk$
    PLOT MOUSEX,MOUSEY
    REPEAT
      MOUSE x%,y%,k%
      DRAW  TO x%,y%
    UNTIL k%<>1
    EXIT IF k%>1
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE gerade
  SGET undo$
  DEFMOUSE 7
  DO
    COLOR 1
    DEFLINE 1,1,0,0
    REPEAT
      MOUSE x%,y%,k%
      x$=INKEY$
    UNTIL k% OR x$="X" OR x$="x"
    IF x$="X" OR x$="x"
      SPUT merk$
    ENDIF
    IF gitter!
      x%=INT((x%+weite/2)/weite)*weite
      y%=INT((y%+weite/2)/weite)*weite
    ENDIF
    EXIT IF k%>1
    SGET merk$
    GRAPHMODE 3
    REPEAT
      MOUSE x1%,y1%,k%
      IF gitter!
        x1%=INT((x1%+weite/2)/weite)*weite
        y1%=INT((y1%+weite/2)/weite)*weite
      ENDIF
      LINE x%,y%,x1%,y1%
      PAUSE 2
      LINE x%,y%,x1%,y1%
    UNTIL k%=0 OR k%>1
    EXIT IF k%>1
    GRAPHMODE mode
    DEFLINE stil,breite,2,2
    COLOR farbe
    IF x$=""
      LINE x%,y%,x1%,y1%
      PAUSE 5
    ENDIF
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE linienzug
  SGET undo$
  DEFMOUSE 7
  REPEAT
    MOUSE x%,y%,k%
  UNTIL k%=1
  REPEAT
  UNTIL MOUSEK=0
  IF gitter!
    x%=INT((x%+weite/2)/weite)*weite
    y%=INT((y%+weite/2)/weite)*weite
  ENDIF
  REPEAT
    REPEAT
      COLOR 1
      DEFLINE 1,1,0,0
      GRAPHMODE 3
      MOUSE x1%,y1%,k%
      IF gitter!
        x1%=INT((x1%+weite/2)/weite)*weite
        y1%=INT((y1%+weite/2)/weite)*weite
      ENDIF
      LINE x%,y%,x1%,y1%
      PAUSE 3
      LINE x%,y%,x1%,y1%
    UNTIL k%
    REPEAT
      MOUSE a,b,c
    UNTIL c=0
    GRAPHMODE mode
    DEFLINE stil,breite,2,2
    COLOR farbe
    IF k%=1
      LINE x%,y%,x1%,y1%
    ENDIF
    x%=x1%
    y%=y1%
  UNTIL k%>1
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE strahlen
  SGET undo$
  DEFMOUSE 7
  DO
    COLOR 1
    REPEAT
      MOUSE x%,y%,k%
    UNTIL k%
    REPEAT
      MOUSE a,b,c
    UNTIL c=0
    EXIT IF k%>1
    REPEAT
      GRAPHMODE 3
      DEFLINE 1,1,0,0
      REPEAT
        MOUSE x1%,y1%,k%
        LINE x%,y%,x1%,y1%
        PAUSE 3
        LINE x%,y%,x1%,y1%
      UNTIL k%
      GRAPHMODE mode
      DEFLINE stil,breite,2,2
      COLOR farbe
      EXIT IF k%>1
      LINE x%,y%,x1%,y1%
      REPEAT
        MOUSE a,b,c
      UNTIL c=0
    UNTIL k%>1
    k%=0
    PAUSE 7.5
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE n_ecken    ! Nach dem Programm "DENISE" aus der "68000er"
  SGET undo$
  DEFMOUSE 7
  DEFLINE 1,1,0,0
  DEFFILL 1,0,0
  SGET merk$
  eckfrag:
  COLOR 1
  GRAPHMODE 1
  PRBOX 220,120,385,210
  num$=""
  PRINT AT(30,10);"Anzahl der Ecken :"
  PRINT AT(30,12);">_";
  DO
    a$=INKEY$
    IF ASC(a$)>47 AND ASC(a$)<58
      num$=num$+a$
      PRINT CHR$(8);a$;"_";
    ENDIF
    EXIT IF ASC(a$)=13 OR LEN(num$)=2
  LOOP
  eck=VAL(num$)
  IF eck<3
    GOTO eckfrag
  ENDIF
  PAUSE 30
  SPUT merk$
  DO
    DEFLINE 1,1,0,0
    REPEAT
      MOUSE x%,y%,k%
    UNTIL k%
    EXIT IF k%>1
    IF gitter!
      x%=INT((x%+weite/2)/weite)*weite
      y%=INT((y%+weite/2)/weite)*weite
    ENDIF
    PAUSE 10
    GRAPHMODE 3
    REPEAT
      MOUSE x1%,y1%,k%
      IF gitter!
        x1%=INT((x1%+weite/2)/weite)*weite
        y1%=INT((y1%+weite/2)/weite)*weite
      ENDIF
      dx=ABS(x1%-x%)
      CIRCLE x%,y%,dx
      PAUSE 3
      CIRCLE x%,y%,dx
    UNTIL k%=0 OR k%>1
    EXIT IF k%>1
    GRAPHMODE mode
    PLOT x%+dx,y%
    DEFLINE stil,breite,2,2
    DEFFILL 1,muster1,muster2
    GRAPHMODE mode
    COLOR farbe
    IF figurfuellen!=FALSE
      FOR i=0 TO 2*PI STEP (2*PI)/eck
        DRAW  TO x%+COS(i)*dx,y%+SIN(i)*dx
      NEXT i
      DRAW  TO x%+dx,y%
      DEFFILL 1,muster1,muster2
    ELSE
      DIM xecke(eck)
      DIM yecke(eck)
      xecke(0)=x%+dx
      yecke(0)=y%
      xecke(eck)=x%+dx
      yecke(eck)=y%
      FOR i=0 TO 2*PI STEP (2*PI)/eck
        xecke(INT(i/((2*PI)/eck)+0.5))=x%+COS(i)*dx
        yecke(INT(i/((2*PI)/eck)+0.5))=y%+SIN(i)*dx
      NEXT i
      POLYFILL eck,xecke(),yecke()
      ERASE xecke()
      ERASE yecke()
    ENDIF
    REPEAT
      MOUSE a,b,c
    UNTIL c=0
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE kreis
  SGET undo$
  DEFMOUSE 7
  DO
    COLOR 1
    DEFLINE 1,1,0,0
    REPEAT
      REPEAT
        MOUSE x%,y%,k%
        x$=INKEY$
      UNTIL k% OR x$>""
      IF x$="X" OR x$="x"
        SPUT merk$
      ENDIF
    UNTIL x$=""
    SGET merk$
    EXIT IF k%>1
    GOSUB gummikreis
    GRAPHMODE mode
    DEFLINE stil,breite,2,2
    DEFFILL 1,muster1,muster2
    COLOR farbe
    IF figurfuellen!
      PCIRCLE x%,y%,ABS(x1%-x%)
    ELSE
      CIRCLE x%,y%,ABS(x1%-x%)
    ENDIF
    PAUSE 5
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE kasten
  SGET undo$
  DEFMOUSE 7
  DO
    COLOR 1
    DEFLINE 1,1,0,0
    REPEAT
      MOUSE x%,y%,k%
    UNTIL k%
    EXIT IF k%>1
    GOSUB gummikasten
    EXIT IF k%>1
    GRAPHMODE mode
    DEFLINE stil,breite,2,2
    DEFFILL 1,muster1,muster2
    COLOR farbe
    IF figurfuellen!
      PBOX x%,y%,x1%,y1%
    ELSE
      BOX x%,y%,x1%,y1%
    ENDIF
    PAUSE 5
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE rundkasten
  SGET undo$
  DEFMOUSE 7
  DO
    COLOR 1
    DEFLINE 1,1,0,0
    REPEAT
      MOUSE x%,y%,k%
    UNTIL k%
    EXIT IF k%>1
    GOSUB gummikasten
    EXIT IF k%>1
    GRAPHMODE mode
    DEFLINE stil,breite,2,2
    DEFFILL 1,muster1,muster2
    COLOR farbe
    IF figurfuellen!
      PRBOX x%,y%,x1%,y1%
    ELSE
      RBOX x%,y%,x1%,y1%
    ENDIF
    PAUSE 5
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE ellipse
  SGET undo$
  DEFMOUSE 7
  DO
    COLOR 1
    DEFLINE 1,1,0,0
    REPEAT
      MOUSE x%,y%,k%
    UNTIL k%
    IF gitter!
      x%=INT((x%+weite/2)/weite)*weite
      y%=INT((y%+weite/2)/weite)*weite
    ENDIF
    EXIT IF k%>1
    GRAPHMODE 3
    PAUSE 10
    REPEAT
      MOUSE x1%,y1%,k%
      IF gitter!
        x1%=INT((x1%+weite/2)/weite)*weite
        y1%=INT((y1%+weite/2)/weite)*weite
      ENDIF
      ELLIPSE x%,y%,ABS(x1%-x%),ABS(y1%-y%)
      PAUSE 2
      ELLIPSE x%,y%,ABS(x1%-x%),ABS(y1%-y%)
    UNTIL k%<>1
    EXIT IF k%>1
    GRAPHMODE mode
    DEFLINE stil,breite,2,2
    DEFFILL 1,muster1,muster2
    COLOR farbe
    IF figurfuellen!
      PELLIPSE x%,y%,ABS(x1%-x%),ABS(y1%-y%)
    ELSE
      ELLIPSE x%,y%,ABS(x1%-x%),ABS(y1%-y%)
    ENDIF
    PAUSE 5
  LOOP
  SGET bild$
RETURN
'
' ****************************************************************************
'
PROCEDURE vieleck
  SGET undo$
  DEFMOUSE 5
  DO
    ERASE x%()
    ERASE y%()
    DIM x%(100),y%(100)
    FOR i%=1 TO 100
      IF i%=1
        DO
          MOUSE x%(1),y%(1),k%
          IF gitter!
            x%(1)=INT((x%(1)+weite/2)/weite)*weite
            y%(1)=INT((y%(1)+weite/2)/weite)*weite
          ENDIF
          a$=INKEY$
          EXIT IF ASC(a$)=13 OR k%
        LOOP
        INC i%
      ENDIF
      EXIT IF ASC(a$)=13 OR k%>1
      GRAPHMODE 3
      DEFLINE 1,1,0,0
      REPEAT
        MOUSE x%(i%),y%(i%),k%
        IF gitter!
          x%(i%)=INT((x%(i%)+weite/2)/weite)*weite
          y%(i%)=INT((y%(i%)+weite/2)/weite)*weite
        ENDIF
        LINE x%(i%-1),y%(i%-1),x%(i%),y%(i%)
        PAUSE 5
        LINE x%(i%-1),y%(i%-1),x%(i%),y%(i%)
      UNTIL k%
      GRAPHMODE 3
      EXIT IF k%>1
      LINE x%(i%-1),y%(i%-1),x%(i%),y%(i%)
      REPEAT
      UNTIL MOUSEK=0
    NEXT i%
    REPEAT
    UNTIL MOUSEK=0
    GRAPHMODE mode
    x%(0)=x%(i%-1)
    y%(0)=y%(i%-1)
    DEFLINE stil,breite,2,2
    COLOR farbe
    IF NOT figurfuellen!
      POLYLINE i%,x%(),y%()
    ELSE
      DEFFILL 1,muster1,muster2
      POLYFILL i%,x%(),y%()
    ENDIF
    ERASE x%()
    ERASE y%()
    REPEAT
      MOUSE x%,y%,k%
      x$=INKEY$
    UNTIL k% OR x$="x" OR x$="X"
    IF x$="X" OR x$="x"
      SPUT merk$
    ENDIF
    EXIT IF k%>1
    SGET merk$
  LOOP
  SGET bild$
RETURN
