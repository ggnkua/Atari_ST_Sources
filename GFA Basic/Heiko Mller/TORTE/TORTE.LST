' *****************************************************************************
'
' T O R T E N D I A G R A M M
'
' Mit diesem Programm werden Tortendiagramme produziert. Man gibt dazu
' der Reihe nach die Zahlen ein - beginnend mit der kleinsten Zahl. Das
' Progamm errechnet die zugehörigen Prozentwerte und zeichnet das Diagramm.
' Es ist möglich, Kommentare in die Zeichnung einzublenden.
'
' Die Diagramm lassen sich z.B. mit SNAPSHOT einfangen und dann in
' WORDPLUS-Texte einbauen.
'
' programmiert von Heiko Müller, Mozartsta×e 17, 2905 Edewecht
'
' zuletzt bearbeitet am 24.8.1988
'
' *****************************************************************************
'
meld$="T O R T E N D I A G R A M M E | |"
meld$=meld$+" ein Public-Domain-Programm|        aus Edewecht"
ALERT 0,meld$,1," aha ",a
'
DIM wert(20),prozent(20),sektor(20),text$(20)
'
DIM menue$(20)
'
FOR i=0 TO 20
  READ menue$(i)
  EXIT IF menue$(i)="***"
NEXT i
menue$(i)=""
menue$(i+1)=""
'   M E N U E L E I S T E
DATA Desk  , Info
DATA --------------------
DATA 1,2,3,4,5,6,""
DATA  Auswahl, Diagramm anlegen, Diagramm ausdrucken
DATA ---------------------, Programmende,""
DATA ***
'
MENU menue$()
MENU 12,2
'
ON MENU  GOSUB menue
DO
  ON MENU
LOOP
'
' ---- M E N U E ----------------------------------------
'
PROCEDURE menue
  MENU KILL
  IF menue$(MENU(0))=" Info"
    meld$="T O R T E N D I A G R A M M E |programmiert in GFA-BASIC  |"
    meld$=meld$+"       von Heiko Müller|Mozartstra×e 17, 2905 Edewecht"
    ALERT 0,meld$,1," OK ",a
  ENDIF
  IF menue$(MENU(0))=" Diagramm anlegen"
    GOSUB torte
  ENDIF
  IF menue$(MENU(0))=" Diagramm ausdrucken"
    GOSUB ausdruck
  ENDIF
  IF menue$(MENU(0))=" Programmende"
    EDIT
  ENDIF
  SHOWM
  MENU menue$()
  IF bild$=""
    MENU 12,2
  ENDIF
  MENU OFF
  ON MENU  GOSUB menue
RETURN
'
'
PROCEDURE torte
  CLS
  DEFTEXT 1,0,0,13
  DEFLINE 1,1,0,0
  SGET sicher$                   ! Bildschirminhalt sichern
  GRAPHMODE 1
  DEFFILL 0,2,8
  PBOX 140,85,500,165
  BOX 140,85,500,165
  TEXT 200,110,"T O R T E N D I A G R A M M"
  LINE 140,120,500,120
  '
  REPEAT
    PRINT AT(22,9);"Wieviele Tortenstücke? (maximal 20)  ";
    FORM INPUT 2,n$
    n=VAL(n$)
    IF n>20 OR n<0
      OUT 2,7
    ENDIF
  UNTIL n<21 AND n>0
  '
  text!=FALSE
  ALERT 0,"Soll Text eingeblendet werden?",1," nein |  ja  ",antw
  IF antw=2
    text!=TRUE
  ENDIF
  '
  IF text!
    groesse=6
    ALERT 0,"Klein- oder Normalschrift?",1," klein |normal ",antw
    IF antw=2
      groesse=13
    ENDIF
    prozent!=TRUE
    ALERT 0,"Sollen Prozentsätze|eingeblendet werden?",1,"  ja  | nein ",antw
    IF antw=2
      prozent!=FALSE
    ENDIF
  ENDIF
  '
  CLS
  PRINT
  PRINT "  Bitte die einzelnen Werte mit [Return] eingeben (die kleinsten zuerst)"
  PRINT
  PRINT "  Nr.  Wert             ";
  IF text!
    PRINT "Text dazu (max. 15 Zeichen)"
  ENDIF
  PRINT
  FOR s=1 TO n
    PRINT AT(2,s+4);
    PRINT USING "###",s;
    PRINT ":";
  NEXT s
  FOR s=1 TO n
    PRINT CHR$(27);"e"                  ! Cursor einschalten
    w$=""
    DO
      PRINT AT(8,s+4);w$';
      PRINT CHR$(27);"D";               ! Cursor um ein Zeichen nach links
      REPEAT
        i$=INKEY$
      UNTIL i$<>""
      EXIT IF ASC(i$)=13 AND VAL(w$)>=0
      IF ASC(i$)=8 AND LEN(w$)
        w$=LEFT$(w$,LEN(w$)-1)
      ELSE
        IF INSTR("0123456789.",i$)>0
          w$=w$+i$
        ELSE
          OUT 2,7
        ENDIF
      ENDIF
    LOOP
    wert(s)=VAL(w$)
    IF w$=""
      PRINT "0"
    ENDIF
    PRINT CHR$(27);"f"                   ! Cursor ausschalten
    IF text!
      PRINT AT(25,s+4);
      FORM INPUT 15,text$(s)
    ENDIF
  NEXT s
  ' Prozentverteilung ermitteln:
  sum=0
  FOR i=1 TO n
    sum=sum+wert(i)
  NEXT i
  IF sum=0
    ALERT 0,"so eine bescheuerte Eingabe!!| |    (insgesamt Null??)| ",1,"au weia",dummy
  ELSE
    CLS
    FOR i=1 TO n
      prozent(i)=wert(i)*100/sum
      sektor(i)=prozent(i)*36              ! 1% entspricht 36 * 1/10 Grad
    NEXT i
    '
    SPUT sicher$                           ! alten Bildschirminhalt zurück
    '
    '     Kreis und Muster zeichnen
    '
    al$="  Mauspfeil auf gewünschten|         Mittelpunkt,| dann linke Maustaste halten|"
    al$=al$+" und die Kreisgrö×e bestimmen| "
    ALERT 0,al$,1,"  OK  |Abbruch",antw
    IF antw=1
      GOSUB gummikreis
      start=900
      GRAPHMODE 1
      FOR i=1 TO n
        schluss=start+sektor(i)
        DEFFILL 1,2,i
        IF prozent(i)<2          ! Da nicht beliebig kleine Sektoren gezeichnet
          ausgleich=50           ! werden können, werden ganz kleine Sektoren zu
        ELSE                     ! gro× dargestellt. Durch Überdecken vom nächsten
          ausgleich=0            ! Sektor wird der Winkel wieder richtig.
        ENDIF
        PCIRCLE x,y,radius,start,schluss+ausgleich
        start=schluss
      NEXT i
      CIRCLE x,y,radius
      '
      IF text!
        '              die Texte werden in die Kreissektoren geschrieben:
        '
        DEFTEXT 1,0,0,groesse
        '
        '
        richtung=900                              ! Startwinkel in 1/10 Grad
        PRINT AT(1,22);
        FOR i=1 TO n
          richtung=richtung+sektor(i)/2
          gradrichtung=richtung/10                ! Textrichtung in Grad
          bogenrichtung=gradrichtung*PI/180       ! Textrichtung in Bogenma×
          textx=x+(radius-10)*COS(bogenrichtung)
          texty=y-(radius-10)*SIN(bogenrichtung)
          '
          IF prozent!
            text$(i)=text$(i)+" ("+STR$(INT(prozent(i)+0.5))+"%)"
          ENDIF
          '
          IF textx<x
            textx=textx-8*LEN(text$(i))           ! Text nach links rücken
          ENDIF
          IF textx<1
            textx=1
          ENDIF
          IF textx>640-(LEN(text$(i))*8)
            textx=640-(LEN(text$(i))*8)
          ENDIF
          '
          TEXT textx,texty,text$(i)               ! Text schreiben
          '
          richtung=richtung+sektor(i)/2
        NEXT i
      ENDIF
    ENDIF
    HIDEM
    SGET bild$
    REPEAT
    UNTIL MOUSEK>1 OR INKEY$=" "
    MENU 12,3
  ENDIF
RETURN
'
' ****************************************************************************
'
PROCEDURE gummikreis
  COLOR 1
  DEFLINE 1,1,0,0
  REPEAT
    MOUSE x,y,k
  UNTIL k=1
  GRAPHMODE 3
  PAUSE 10
  REPEAT
    MOUSE x1,y1,k
    radius=ABS(x1-x)
    CIRCLE x,y,radius
    PAUSE 2
    CIRCLE x,y,radius
  UNTIL k<>1
  GRAPHMODE 1
RETURN
'
' ****************************************************************************
'
PROCEDURE hardcopy    ! Aus dem GFA-BASIC-Buch von F. Ostrowski (S. 73 ff)
  '
  ok=2
  DO                  ! zuerst testen, ob der Drucker eingeschaltet ist
    EXIT IF OUT?(0)
    ALERT 1,"Drucker einschalten !",2,"Abbruch| OK ",ok
    EXIT IF ok=1
  LOOP
  '
  IF ok<>1
    a$=SPACE$(400)
    '
    ' so funktioniert es beim Panasonic KXP1092:
    g$="    "+CHR$(27)+"*"+CHR$(5)+CHR$(400)+CHR$(400/256)
    ' so beim NEC P2200 (allerdings nicht besonders schön):
    ' g$="    "+CHR$(27)+"*"+CHR$(0)+CHR$(400)+CHR$(400/256)
    '
    OPEN "",#99,"LST:"
    FOR s%=XBIOS(3) TO s%+79
      abbruch%=0
      x%=VARPTR(a$)
      FOR q%=s%+399*80 TO s% STEP -80
        POKE x%,PEEK(q%)
        INC x%
      NEXT q%
      FOR qq%=0 TO 2
        PRINT #99,g$;a$;CHR$(13);CHR$(27);"J";CHR$(1);
        IF INKEY$<>""
          ALERT 0,"Ausdruck abbrechen?",2," ja |nein",abbruch%
        ENDIF
        EXIT IF abbruch%=1
      NEXT qq%
      PRINT #99,CHR$(27);"J";CHR$(24-qq%);
      EXIT IF abbruch%=1
    NEXT s%
    CLOSE #99
  ENDIF
RETURN
'
PROCEDURE ausdruck
  ALERT 0,"wirklich ausdrucken?",1,"nein| ja ",antw
  IF antw=2
    CLS
    HIDEM
    SPUT bild$
    GOSUB hardcopy
  ENDIF
RETURN
