'
' *****************************************************************************
'
'        SPIELESAMMLUNG
'
' programmiert von Heiko Müller, Mozartstra×e 17, 2905 Edewecht
'
' Auch ohne gro×e Bildschirmaktionen kann man Spa× am Spielen haben. Diese
' Spiele waren ursprünglich für den Taschencomputer SHARP PC 1260 programmiert.
' Ihre Umsetzung für den ATARI ST ist noch genauso reizvoll wie die "Taschen-
' spiele", die ihnen zugrundeliegen. Sie lassen sich übrigens auch als Unter-
' programme in ernsthafte Programme einbauen - damit man sich damit zwischen-
' durch mal von seiner Arbeit entspannen kann.
'
' letzte Bearbeitung am 20.6.1988
'
' ****************************************************************************
'
al$=" S P I E L E S A M M L U N G|  programmiert in GFA-BASIC"
al$=al$+" |       von Heiko Müller|Mozartstra×e 17, 2905 Edewecht"
ALERT 0,al$,1," aha ",antw
DO
  '
  GOSUB titelbild
  '
  SHOWM
  REPEAT
    MOUSE x,y,k
    i$=INKEY$
  UNTIL (k AND x>200 AND x<440 AND y>100 AND y<220) OR (VAL(i$)>0 AND VAL(i$)<7)
  IF k
    auswahl=INT((y-100)/20)+1
  ELSE
    auswahl=VAL(i$)
  ENDIF
  CLS
  HIDEM
  ON auswahl GOSUB sterne,tippen,wortrate,telefon,merken,schluss
LOOP
'
' *****************************************************************************
'
PROCEDURE titelbild
  '
  DEFTEXT 1,16,0,32
  TEXT 40,60,"* S P I E L E S A M M L U N G *"
  DEFTEXT 1,0,0,13
  '
  FOR i%=100 TO 200 STEP 20          ! Kästen zur Programmwahl zeichnen
    BOX 200,i%,440,i%+20
  NEXT i%
  '
  TEXT 215,115,"1     Das Sternespiel"
  TEXT 215,135,"2     Tippübung"
  TEXT 215,155,"3     Wortratespiel"
  TEXT 215,175,"4     Telefonnummer"
  TEXT 215,195,"5     Zahlenmerken"
  TEXT 215,215,"6     Programmende"
  '
  PRINT AT(12,23);"Bitte gewünschtes Programm mit Maus oder Taste auswählen"
RETURN
'
' *****************************************************************************
'
PROCEDURE sterne
  REPEAT
    DEFTEXT 1,16,0,13
    TEXT 18,25,"Das 4-Sterne-Spiel"
    DEFTEXT 1,0,0,6
    TEXT 400,25,"( * = Ende )"
    PRINT AT(3,4);"Es soll eine vierstellige Zahl geraten werden (alle Ziffern verschieden)"
    PRINT
    PRINT "  + = richtige Ziffer an falscher Stelle"
    PRINT "  * = richtige Ziffer an richtiger Stelle"
    '
    DIM a$(4)                    ! Ratestring zusammenstellen
    a$(1)=STR$(RANDOM(10))
    x$=a$(1)
    FOR i%=2 TO 4
      REPEAT
        ungleich!=TRUE
        a$(i%)=STR$(RANDOM(10))
        FOR t=1 TO i%-1
          IF a$(i%)=a$(t)
            ungleich!=FALSE
          ENDIF
        NEXT t
      UNTIL ungleich!
      x$=x$+a$(i%)
    NEXT i%
    '
    versuch%=0
    PRINT AT(1,8)
    REPEAT
      INC versuch%
      PRINT USING "###",versuch%;
      PRINT ". Rateversuch: ";
      xx=CRSCOL                         ! x-Position des Cursors merken
      yy=CRSLIN                         ! y-Position  "      "     "
      r$=""
      PRINT CHR$(27)+"e";             ! Cursor einschalten
      REPEAT
        REPEAT
          i$=INKEY$
          EXIT IF i$="*"
        UNTIL (ASC(i$)>47 AND ASC(i$)<58) OR ASC(i$)=8    ! Ziffer oder Backspace
        EXIT IF i$="*"
        r$=r$+i$
        IF ASC(i$)=8 AND LEN(r$)>1         ! falsche Eingaben löschen
          r$=LEFT$(r$,LEN(r$)-2)
          PRINT AT(xx,yy);"    ";
        ENDIF
        PRINT AT(xx,yy);r$;
      UNTIL LEN(r$)=4
      EXIT IF i$="*"
      kreuz%=0
      stern%=0
      FOR i%=1 TO 4
        IF MID$(r$,i%,1)=a$(i%)
          INC stern%
          DEC kreuz%
        ENDIF
        FOR t=1 TO 4
          IF MID$(r$,t,1)=a$(i%)
            INC kreuz%
          ENDIF
        NEXT t
      NEXT i%
      PRINT AT(xx+6,yy);
      i%=0
      WHILE i%<stern%
        INC i%
        PRINT "*";
      WEND
      PRINT '
      i%=0
      WHILE i%<kreuz%
        INC i%
        PRINT "+";
      WEND
      PRINT
    UNTIL r$=x$
    PRINT CHR$(27)+"f";             ! Cursor ausschalten
    IF r$=x$
      GOSUB dreiklang_rauf
    ELSE
      PRINT
      PRINT "  leider abgebrochen ..."
      PRINT
      PRINT "  Die Zahl hie×"'x$
    ENDIF
    PRINT
    PRINT "  nochmal ?   (J/N);"
    ERASE a$()
    DO
      a$=INKEY$
      EXIT IF a$="J" OR a$="N" OR a$="j" OR a$="n"
    LOOP
    CLS
  UNTIL a$="N" OR a$="n"
RETURN
'
' *****************************************************************************
'
PROCEDURE tippen
  DEFTEXT 1,16,0,13
  TEXT 20,20,"Tippübung"
  DEFTEXT 1,0,0,6
  TEXT 400,25,"( * = Ende )"
  PRINT AT(3,4);"Die gro×en angezeigten Buchstaben sollen möglichst schnell getippt werden."
  PRINT
  DEFTEXT 1,16,0,32
  PRINT AT(3,7);"Mit der Leertaste geht's los."
  REPEAT
  UNTIL INKEY$=" "
  PRINT AT(3,7);"                             "
  REPEAT
    zeit=1000
    treffer=0
    BOX 280,252,340,274
    DO
      PRINT AT(35,8);treffer'"Treffer"
      x=RANDOM(26)+68
      IF x=91
        x=142
      ENDIF
      IF x=92 OR x=93
        x=x+61
      ENDIF
      x$=CHR$(x)
      TEXT 300,200,x$
      REPEAT
        a$=INKEY$
        a$=UPPER$(a$)
        DEC zeit
        PRINT AT(38,17);zeit;'
        EXIT IF zeit<1 OR a$="*"
        PAUSE 1
      UNTIL a$=x$
      INC treffer
      EXIT IF zeit<1 OR a$="*"
    LOOP
    EXIT IF a$="*"
    GOSUB gong
    PRINT AT(4,22);"nochmal ?  (J/N)"
    REPEAT
      a$=INKEY$
    UNTIL a$="J" OR a$="N" OR a$="j" OR a$="n"
    CLS
  UNTIL a$="N" OR a$="n"
  CLS
RETURN
'
' *****************************************************************************
'
PROCEDURE wortrate
  DEFTEXT 1,16,0,13
  TEXT 18,25,"Das Wortratespiel"
  DEFTEXT 1,0,0,6
  TEXT 400,25,"( * = Ende )"
  PRINT AT(4,4);"Dies ist das altbekannte ""Galgenspiel"":"
  PRINT AT(4,5);"Vorgegebene Wörter müssen buchstabenweise geraten werden."
  PRINT AT(4,6);"Richtige Buchstaben werden an allen Stellen eingesetzt."
  PRINT AT(4,8);"Willst Du selbst Wörter eingeben?  (J/N)"
  selbst!=FALSE
  DO
    a$=INKEY$
    a$=UPPER$(a$)
    IF a$="J"
      selbst!=TRUE
    ENDIF
    EXIT IF a$="J" OR a$="N"
  LOOP
  PRINT AT(4,4);SPACE$(60)
  PRINT AT(4,5);SPACE$(60)
  PRINT AT(4,6);SPACE$(60)
  PRINT AT(4,8);SPACE$(60)
  REPEAT
    IF selbst!
      REPEAT
        PRINT AT(4,5);
        FORM INPUT 60,x$
      UNTIL LEN(x$)>0
      x$=UPPER$(x$)
      PRINT AT(4,5);"                                                            "
    ELSE
      RESTORE ratewoerter
      FOR i%=1 TO RANDOM(100)
        READ x$
      NEXT i%
    ENDIF
    l=LEN(x$)
    n=l
    f=6
    PRINT AT(4,12);"6 5 4 3 2 1 0"
    ERASE a$()
    ERASE r$()
    DIM a$(l),r$(l)
    PRINT AT(4,6);
    FOR i%=1 TO l
      a$(i%)=MID$(x$,i%,1)
      r$(i%)="_"
      PAUSE 5
      PRINT r$(i%);
    NEXT i%
    PRINT
    DO
      PRINT AT(4,6);
      REPEAT
        a$=INKEY$
      UNTIL a$>""
      REPEAT
      UNTIL INKEY$=""
      EXIT IF a$="*"
      a$=UPPER$(a$)
      falsch!=TRUE
      FOR i%=1 TO l
        IF a$=a$(i%)
          falsch!=FALSE
          IF r$(i%)="_"
            DEC n
          ENDIF
          r$(i%)=a$
        ENDIF
        PRINT r$(i%);
      NEXT i%
      PRINT
      IF falsch!
        OUT 2,7
        DEC f
        PRINT AT(14-2*f,12);"  "
        IF f<0
          PRINT AT(4,15);"Schade - das war zu oft daneben!"
          PRINT
          PRINT "   Das Wort hei×t ";x$
          n=0
        ENDIF
      ENDIF
      EXIT IF n=0
    LOOP
    EXIT IF a$="*"
    IF NOT falsch!
      GOSUB dreiklang_runter
    ENDIF
    PRINT AT(4,19);"nochmal ?   (J/N)"
    REPEAT
      a$=INKEY$
    UNTIL a$="N" OR a$="n" OR a$="J" OR a$="j"
    CLS
    '
    DEFTEXT 1,16,0,13               ! Bei Wiederholung wird Titel noch einmal
    TEXT 18,25,"Das Wortratespiel"  ! geschrieben
    DEFTEXT 1,0,0,6
    TEXT 400,25,"( * = Ende )"
    '
  UNTIL a$="N" OR a$="n"
  CLS
  ratewoerter:
  DATA DISKETTE,MARKTPLATZ,COMPUTER,PHYSIK,LATERNENPFAHL
  DATA PENNBRUDER,MONITOR,TASTATUR,FUNKAUSSTELLUNG,RADIATOR
  DATA PROGRAMM,BUTTERKÄSE,LORELEI,MEGABYTE,PUZZLE
  DATA SCHACHSPIELER,GENTECHNIKER,CHEMIELEHRER,ENDLOSPAPIER,REGELSCHALTER
  DATA VERTÄFELUNG,LEGOSTEIN,KLAPPSTUHL,MARSCHRICHTUNG,ALPHABET
  DATA KLEMMBUCHSE,FENSTERSCHEIBE,DREHSTUHL,PECHVOGEL,PSYCHIATER
  DATA BABYWINDEL,PAMPERSKARTON,SOMMERWETTER,MILCHGLAS,CASSETTENRECORDER
  DATA SCHWEINCHEN,SCHWEINELENDE,UNANSTÄNDIG,PAPIERKORB,REALSCHULE
  DATA ENTENFAHRER,SCHIEBEDACH,GLATZKOPF,KAMMER,RAMDISK
  DATA WALKMAN,KABELSALAT,TISCHBEIN,UHRENRADIO,PFÖTCHEN
  DATA GFA-BASIC,ROTKÄPPCHEN,PAPRIKASALAT,NÜSSE,CARABINIERI
  DATA SCHNITTLAUCH,LIPPENSTIFT,FLOHZIRKUS,ERSATZREIFEN,LEUKOPLAST
  DATA KALORIEN,VITAMIN,SPUTNIK,DORSCHLEBERPASTETE,KRABBE
  DATA LACHS,LEBERTRAN,MANDOLINE,MANDARINE,KOKOSNÜSSE
  DATA AQUARIUM,PFEFFERKUCHEN,VASELINE,VANILLE,EISCREME
  DATA GEFLÜGEL,PROZEDUR,SCHRECKSEKUNDE,HIRSCHSCHWANZ,GESÖFF
  DATA DIVISION,GESPRÄCH,DEZEMBER,NÄHKÄSTCHEN,MÖBEL
  DATA MÜRRISCH,FRÖHLICH,TRÄLLERN,SYSTEM,ANTIQUITÄTEN
  DATA GEOGRAPHIE,KOMPLEX,SOPRANXYLOPHON,KONVERSATION,GYMNASIUM
  DATA POTPOURRI,ZIVILISATION,FLOPPYDISK,MAUSBUTTON,BABYSPECK
  ERASE a$()
  ERASE r$()
RETURN
'
' *****************************************************************************
'
PROCEDURE telefon
  DIM z$(35)
  REPEAT
    DEFTEXT 1,16,0,13
    TEXT 18,25,"Telefonnummer"
    PRINT AT(3,4);"Die gezeigte Ziffernfolge soll noch einmal eingegeben werden."
    PRINT
    PRINT "  Wenn man das ohne Fehler geschafft hat, erscheint dieselbe Reihe mit"
    PRINT "  einer Ziffer mehr. Das geht theoretisch so weiter, bis zu 35 Ziffern..."
    PRINT
    PRINT "  Mit der Leertaste geht's los."
    REPEAT
    UNTIL INKEY$=" "
    '
    schluss%=0
    falsch!=FALSE
    BOX 10,220,630,245
    DO
      INC schluss%
      EXIT IF schluss%>35
      z$(schluss%)=STR$(RANDOM(10))          ! Zufallszahl als String
      PRINT AT(3,15);SPACE$(75)              ! Reihe löschen
      PRINT AT(3,15);
      PAUSE 30
      FOR i%=1 TO schluss%
        PRINT z$(i%)';
        PAUSE 30
      NEXT i%
      PRINT AT(3,15);SPACE$(75)              ! Reihe löschen
      PRINT AT(3,15);
      FOR i%=1 TO schluss%
        REPEAT
          i$=INKEY$
        UNTIL ASC(i$)>47 AND ASC(i$)<58       ! nur weiter, wenn Ziffer getippt
        IF i$<>z$(i%)
          falsch!=TRUE
        ENDIF
        EXIT IF falsch!
        PRINT i$';
      NEXT i%
      EXIT IF falsch!
      PAUSE 30
    LOOP
    GOSUB gong
    PRINT AT(3,15);
    FOR i%=1 TO schluss%
      PRINT z$(i%)';
    NEXT i%
    PRINT AT(3,18);
    PRINT "Zusammenbruch bei ";schluss%;" Ziffern"
    PRINT AT(3,20);
    PRINT "nochmal ?   (J/N)"
    DO
      a$=INKEY$
      EXIT IF a$="J" OR a$="N" OR a$="j" OR a$="n"
    LOOP
    CLS
  UNTIL a$="N" OR a$="n"
  ERASE z$()
RETURN
'
' *****************************************************************************
'
PROCEDURE merken
  falsch!=FALSE
  DEFTEXT 1,16,0,13
  TEXT 20,20,"Zahlenmerken"
  DEFTEXT 1,0,0,6
  PRINT AT(3,4);"Die gezeigte Zahl soll noch einmal eingegeben werden."
  PRINT
  PRINT "  Wenn man das ohne Fehler geschafft hat, erscheint eine neue Zahl, die"
  PRINT "  aber kürzere Zeit zu sehen ist. Nach 10 dreistelligen Zahlen folgen dann"
  PRINT "  10 vierstellige usw. bis man es nicht mehr schafft."
  PRINT
  '
  REPEAT
    DEFFILL 0,2,8                    ! Füllfarbe wei×
    PBOX 260,250,360,275             ! gefüllte Kiste
    BOX 260,250,360,275              ! Rand dazu
    PRINT AT(3,10);"Mit der Leertaste geht's los."
    REPEAT
    UNTIL INKEY$=" "
    PRINT AT(3,10);SPACE$(30)
    laenge%=2
    treffer=0
    falsch!=FALSE
    REPEAT
      INC laenge%
      pause=14*laenge%
      FOR i%=1 TO 10
        x$=""
        FOR j%=1 TO laenge%
          x$=x$+STR$(RANDOM(10))          ! Zufallszahl aufbauen
        NEXT j%
        INC treffer
        PRINT AT(30,17);treffer'
        PRINT AT(40-laenge%/2,17);x$
        SUB pause,laenge%
        PAUSE pause
        '
        DEFFILL 0,2,8                    ! Füllfarbe wei×
        PBOX 260,250,360,275             ! gefüllte Kiste über Zahl
        BOX 260,250,360,275              ! Rand dazu
        PRINT AT(40-laenge%/2,17);
        FOR j%=1 TO laenge%
          v$=MID$(x$,j%,1)
          REPEAT
            i$=INKEY$
          UNTIL ASC(i$)>47 AND ASC(i$)<58       ! nur weiter, wenn Ziffer getippt
          PRINT i$;
          IF i$<>v$
            falsch!=TRUE
          ENDIF
          EXIT IF i$<>v$
        NEXT j%
        '
        EXIT IF i$<>v$
        PAUSE 30
      NEXT i%
    UNTIL falsch!
    GOSUB gong
    PRINT AT(40-laenge%/2,17);x$
    PRINT AT(4,22);"nochmal ?  (J/N)"
    REPEAT
      a$=INKEY$
    UNTIL a$="J" OR a$="N" OR a$="j" OR a$="n"
    PRINT AT(30,17);"  "
    PRINT AT(4,22);"                "
  UNTIL a$="N" OR a$="n"
  CLS
RETURN
'
' *****************************************************************************
'
PROCEDURE schluss
  ALERT 2," Willst Du wirklich aufhören?",1,"  ja  | nein ",antw
  IF antw=1
    EDIT
  ENDIF
RETURN
'
' *****************************************************************************
'
PROCEDURE dreiklang_rauf
  SOUND 1,15,1,4,5
  SOUND 1,15,5,4,5
  SOUND 1,15,8,4,5
  FOR i%=15 DOWNTO 0
    SOUND 1,i%,1,5,4
  NEXT i%
RETURN
'
PROCEDURE dreiklang_runter
  SOUND 1,15,1,5,5
  SOUND 1,15,8,4,5
  SOUND 1,15,5,4,5
  FOR i%=15 DOWNTO 0
    SOUND 1,i%,1,4,4
  NEXT i%
RETURN
'
PROCEDURE gong
  FOR i%=15 DOWNTO 0
    SOUND 1,i%,1,4,4
  NEXT i%
RETURN
'
