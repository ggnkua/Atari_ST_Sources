Procedure Hardcopy_2
  Dim Bit1%(640),Bit%(1920,2)
  For Y%=0 To 49
    Arrayfill Bit1%(),0
    Arrayfill Bit%(),0
    For X%=0 To 39
      For Yy%=0 To 7
        P%=Dpeek(Xbios(3)+(Y%*640)+(Yy%*80)+(X%*2))
        If P%<>0
          If P%=65535
            For Xx%=0 To 15
              Bit1%((X%*16)+Xx%)=Bit1%((X%*16)+Xx%) Or 2^(7-Yy%)
            Next Xx%
          Else
            For Xx%=0 To 15
              If (P% And 2^(15-Xx%))<>0
                Bit1%((X%*16)+Xx%)=Bit1%((X%*16)+Xx%) Or 2^(7-Yy%)
              Endif
            Next Xx%
          Endif
        Endif
      Next Yy%
    Next X%
    Lprint Chr$(27);"3";Chr$(0);                      ! set line spacing off
    Lprint Chr$(27);"*";Chr$(3);Chr$(128);Chr$(7);Chr$(Bit1%(0));
    For I%=0 To 638
      Lprint Chr$(Bit1%(I%) And Bit1%(I%+1));
      Lprint Chr$(Bit1%(I%) And Bit1%(I%+1));Chr$(Bit1%(I%+1));
    Next I%
    Lprint Chr$(0);Chr$(0)
    For C%=0 To 7
      For I%=0 To 639
        If Peek(Xbios(3)+Int(I%/8)+(C%*80)+((Y%*8)*80))<>0
          If Point(I%,C%+(Y%*8))
            If Point(I%,(Y%*8)+C%+1)
              Bit%(I%*3,1)=Bit%(I%*3,1) Or 2^(7-C%)
              Bit%(I%*3,2)=Bit%(I%*3,2) Or 2^(7-C%)
              Q%=1
            Else
              Q%=0
            Endif
            If Point(I%-1,(Y%*8)+C%+1) And Q%=1 And Point(I%-1,(Y%*8)+C%)
              Bit%((I%*3)-1,1)=Bit%((I%*3)-1,1) Or 2^(7-C%)
              Bit%((I%*3)-2,2)=Bit%((I%*3)-2,2) Or 2^(7-C%)
            Else
              If Point(I%-1,(Y%*8)+C%+1) And Q%=0 And Point(I%-1,(Y%*8)+C%)=0
                Bit%((I%*3)-1,1)=Bit%((I%*3)-1,1) Or 2^(7-C%)
                Bit%((I%*3)-2,2)=Bit%((I%*3)-2,2) Or 2^(7-C%)
              Endif
            Endif
            If Point(I%+1,(Y%*8)+C%+1) And Q%=0 And Point(I%+1,(Y%*8)+C%)=0
              Bit%((I%*3)+1,1)=Bit%((I%*3)+1,1) Or 2^(7-C%)
              Bit%((I%*3)+2,2)=Bit%((I%*3)+2,2) Or 2^(7-C%)
            Else
              If Point(I%+1,(Y%*8)+C%+1) And Q%=1 And Point(I%+1,(Y%*8)+C%)
                Bit%((I%*3)+1,1)=Bit%((I%*3)+1,1) Or 2^(7-C%)
                Bit%((I%*3)+2,2)=Bit%((I%*3)+2,2) Or 2^(7-C%)
              Endif
            Endif
          Endif
        Else
          I%=I%+7
        Endif
      Next I%
    Next C%
    Lprint Chr$(27);"J";Chr$(1);            ! one time 1/216 line spacing
    Lprint Chr$(27);"*";Chr$(3);Chr$(128);Chr$(7);
    For I%=0 To 1919
      Lprint Chr$(Bit%(I%,1));
    Next I%
    Lprint
    Lprint Chr$(27);"J";Chr$(1);
    Lprint Chr$(27);"*";Chr$(3);Chr$(128);Chr$(7);
    For I%=0 To 1919
      Lprint Chr$(Bit%(I%,2));
    Next I%
    Lprint
    Lprint Chr$(27);"J";Chr$(22);           ! one time 21/216 inch line spacing
  Next Y%
  Lprint Chr$(27);Chr$(2)                   ! normal line spacing
Return
