' ********************************************
' Name         : Mousestepping
' Autor        : Andreas Walthes
' Sprache      : GFA-BASIC
' Level        : 2
' Beschreibung : Beschleunigung des Mauspfeils
'                (ErhĒhung der Schrittweite)
'                innerhalb einer Hauptschleife
' ********************************************
@Mouse.stepping(4)
Procedure Mouse.stepping(D%)
  Mouse Xx%,Yy%,K%
  Print At(1,1);"Steps:"
  Print At(10,1);D%+1
  Do
    Mouse X%,Y%,K%
    If X%<>Xx% Or Yy%<>Y%
      Add X%,(X%-Xx%)*D%
      Add Y%,(Y%-Yy%)*D%
      If X%>639
        X%=639
      Endif
      If X%<0
        X%=0
      Endif
      If Y%>399
        Y%=399
      Endif
      If Y%<0
        Y%=0
      Endif
      Dpoke 9952,X%
      Dpoke 9954,Y%
      Xx%=X%
      Yy%=Y%
      If K%
        Plot X%,Y%
      Endif
    Endif
    I$=Inkey$
    If I$="-" And D%>0
      Dec D%
      Print At(1,1);D%+1
      Pause 5
    Endif
    If I$="+" And D%<15
      Inc D%
      Print At(1,1);D%+1
      Pause 5
    Endif
  Loop
Return
