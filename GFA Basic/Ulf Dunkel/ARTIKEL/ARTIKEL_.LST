' -----------------------------------------------------------------------------
' ARTIKEL_.LST
' I:  12.12.88
' U:  06.02.89
' PROGRAMM VON   Ulf Dunkel, Haselünner Str. 4, D-4573 Löningen, TEL 05432/4306
' -----------------------------------------------------------------------------
' Programm zum Verwalten von Lieferanten + Artikeln; ergibt ein Feld von max.
' l_max% Lieferanten, mit jeweils 3-stelliger Nummer + max. 35 Buchstaben Text
' sowie ein Feld von max. a_max% Artikeln, mit jeweils max. 35 Buchstaben
' Text sowie einem Extender von mind. einer 3-stelligen Zahl (Lieferant-Nr.).
' -----------------------------------------------------------------------------
' Voreinstellungen für das ganze System
' -----------------------------------------------------------------------------
IF XBIOS(4)<>2                                  !Falsche Auflösung eingestellt?
  ALERT 3,"|Dieses Programm läuft |nur im Monochrom-Modus!",1,"Sorry!",dum!
  END                                           !***** später SYSTEM *****
ENDIF                                           !Ansonsten kann's losgehen!
OPTION BASE 1                                   !Klare Verhältnisse im DIM.
DEFTEXT 1,0,0,13                                !Normale Schriftgrö×e gilt.
a_dat$="ARTIKEL_.DAT"                           !Einige der o.g. Variablen
a_max%=5000                                     !einstellen, denn es gilt:
abc$="ABCDEFGHIJKLMNOPQRSTUVWXYZ×ÄÖÜ,;.()/"     !Voreinstellungen, z.B.
bing_on!=TRUE                                   !Alarm bei ALERT-Boxen ON,
funk$="Funktion abbrechen?"                     !und div. Einstellungen schon
j_n$="   Ja   |  Nein  "                        !am Anfang machen,
l_dat$="LIEFERER.DAT"                           !innerhalb der
l_max%=999                                      !verschiedenen Procedures
leer$=SPACE$(50)                                !findet man
ok$="   OK   "                                  !sie schwerer wieder.
v%=-1                                           !(Bedeutung der Variablen:
p$="ARTIKEL_.GFA"                               !siehe PROC globale_variablen)
@genug_speicher_da                              !Platz zum Abspeichern da?
' -----------------------------------------------------------------------------
' Menu aufbauen + Programm-Hauptschleife
' -----------------------------------------------------------------------------
DIM mess%(3),menu$(54)                          !Message-Buffer einrichten.
menu|=0                                         !Menu-Lese-Zähler auf NULL;
REPEAT                                          !Pulldown-Daten einlesen
  INC menu|                                     !+ Zähler raufsetzen, bis
  READ menu$(menu|)                             !keine Menu-Daten
UNTIL menu$(menu|)="Datei_Ende"                 !mehr da sind.
menu$(menu|)=""                                 !Letzter Menu-Wert ist NULL.
MENU menu$()                                    !Menu am Bildschirm aufbauen,
DEFTEXT 1,1,0,4                                 !mit Titel-Spezialeintrag
TEXT 19,7,"Artikel"                             !(Programm-Name)
DEFTEXT 1,0                                     !+
TEXT 19,14,CHR$(14)+CHR$(15)+"+Info"            !Atari-Symbol als DESK.
DEFTEXT 1,0,0,13                                !Schrift wieder normal.
OPENW 0                                         !Oberste Zeile schützen.
OPENW 4,0,0                                     !Ein Vollfenster öffnen.
@laden                                          !Was gibt's an Dateien?
@datum                                          !Datum einstellen!
@a_clock                                        !Uhr anschalten
EVERY 200 GOSUB a_clock                         !+ alle 2 Sekunden zeigen.
ON MENU GOSUB menuauswertung                    !Menu-Auswertungs-Befehle.
ON MENU MESSAGE GOSUB sauber                    !(auch für Accessories).
ON BREAK CONT                                   !System-Break OFF.
ON ERROR GOSUB fehler_abfangen                  !Fehler-Abfang-Routine.
DO                                              !Haupt-Schleife =
  ON MENU                                       !Menu-Abfrage
LOOP !UNTIL MOUSEK=3                            !Opt.: STOP mit beiden Tasten!
' -----------------------------------------------------------------------------
' Es folgen die Unterprogramme
' -----------------------------------------------------------------------------
PROCEDURE a_aendern
  LOCAL a1_hi&,a2$,x&,y&,z&
  ' ---------------------------------------------------------------------------
  a_aendern_nochmal:                            !Hier geht's los:
  @bing
  ALERT 0,funk$,1,j_n$,but|                     !Abbrechen?
  IF but|=2                                     !Noch nicht beenden!
    a$=""                                       !Suchstring auf NULL
    PRINT AT(15,4);"Bitte den gewünschten Artikel eingeben:";
    @kasten_sauber(5,9,5)
    LOCATE 15,5
    FORM INPUT (35),a$                          !Gib den gewünschten Art ein.
    @blanks_weg_u_upper(a$)                     !Natürlich ohne Leerzeichen.
    IF dum!                                     !Bleibt nicht's über:
      GOTO a_aendern_nochmal                    !Nochmal von vorn.
    ENDIF
    @a_schon_drin_pruefen(a$)                   !Gibt's den gesuchten schon?
    IF a_ex! OR a_si!                           !Ja, exakt oder ähnlich.
      PRINT AT(15,4);leer$;
      PRINT AT(15,4);"Der ist gespeichert als:";!Zeig ihn,
      IF LEN(a_fld$(a_hi&))>50                  !wenn er zu lang ist,
        PRINT AT(15,5);LEFT$(a_fld$(a_hi&),47)+"...";!verkürzt,
      ELSE                                      !ansonsten
        PRINT AT(15,5);a_fld$(a_hi&)            !in voller Länge an.
      ENDIF
      a1_hi&=a_hi&
      a1$=a_fld$(a1_hi&)
      @bing
      PRINT AT(15,6);"Bitte eingeben, wie er geändert lauten soll:"
      LOCATE 15,7
      FORM INPUT (35),a2$
      @blanks_weg_u_upper(a2$)
      IF dum!
        GOTO a_aendern_nochmal
      ENDIF
      @a_schon_drin_pruefen(a2$)
      IF a_ex! OR a_si!
        PRINT AT(15,8);"Der ist auch schon vorhanden! - Funktions-Abbruch!"
        txt$="Bitte erst entscheiden,|welcher Artikel bleiben soll.|Nach"
        txt$=txt$+" Übernahme der Lieferanten|diese Funktion neu aufrufen."
        @bing
        ALERT 1,txt$,1,ok$,dum!
      ELSE
        @bing
        ALERT 0,"Artikel wie gewünscht |ändern?",2,j_n$,but|
        IF but|=2                               !Der soll nicht aendern!
          GOTO a_aendern_nochmal                !Nochmal von vorn.
        ELSE                                    !Genau der soll aendern!
          @bing
          ALERT 0,"| Wirklich ändern?",2,j_n$,but|!Wirklich?
          IF but|=2                             !Nö -
            GOTO a_aendern_nochmal              !Nochmal von vorn.
          ENDIF
        ENDIF
        lang|=LEN(a1$)
        FOR x&=lang| DOWNTO 1
          IF INSTR(abc$,MID$(a1$,x&,1))
            rand|=x&
            EXIT IF x&>1
          ENDIF
        NEXT x&
        IF rand|=0
          a_fld$(a1_hi&)=a2$
        ELSE
          a1$=RIGHT$(a1$,lang|-rand|)
          a_fld$(a1_hi&)=a2$+a1$
          @kasten_sauber(6,7,6)
          PRINT AT(15,6);"Wird zu:"
          IF LEN(a_fld$(a1_hi&))>79
            a_fld$(a1_hi&)=LEFT$(a_fld$(a1_hi&),lang|-3)
            PRINT AT(15,7);LEFT$(a_fld$(a1_hi&),30)+"..."
          ELSE
            PRINT AT(15,7);a_fld$(a1_hi&)
          ENDIF
        ENDIF
        @info("Ich sortiere ",a_dat$)
        QSORT a_fld$()
        @info("  Ich ändere ",a_dat$)           !speichere sie im
        v%=-1
        @dat_store(a_ok!,v%,a_dat$,a_fld$())    !neuen, kleineren Feld.
      ENDIF
    ELSE                                        !Den haben wir noch nicht!
      PRINT AT(15,7);"Der gesuchte Artikel ist nicht gespeichert!"
      GOTO a_aendern_nochmal                    !Nochmal von vorn.
    ENDIF
  ENDIF
  a_aendern_ende:
  a_ex!=FALSE                                   !Flags zurück
  a_si!=FALSE                                   !und String-Sucher
  a$=""                                         !auf NULL.
RETURN
PROCEDURE a_clock
  ACLIP 1,575,1,639,15                          !Reserviere Menu-Platz für Uhr
  ATEXT 575,1,2,TIME$                           !Zeige die Uhr-Zeit oben rechts
RETURN
PROCEDURE a_eingeben(VAR l$)
  LOCAL a$,a_ch&,a_da&,a_ex!,a_hi&,a_si!,l_da!,lang|,such|,x&,y&,z&
  ' ---------------------------------------------------------------------------
  @kasten(200,26,"Artikel-Eingabe")             !@@@ Info-Kasten
  lang|=INT(40-((LEN(l$)+4)/2))*8               !Text einmitten
  TEXT lang|,43,"für "+l$                       !und anzeigen.
  lang|=0                                       !Div. Variablen
  a_ch&=0                                       !zurück-
  a_neu$=""                                     !stellen.
  a_eingeben_nochmal:                           !Hierher, wenn schon vorhanden.
  a$=""                                         !Input-String auf NULL
  a_ex!=FALSE                                   !Such-Flags
  a_si!=FALSE                                   !auf NULL
  a_da&=0                                       !+ Pointer
  a_hi&=0                                       !auf NULL.
  l_da!=FALSE                                   !Lieferer-Flag zurückstellen!
  such|=0                                       !Such-Pointer dito.
  ' ---------------------------------------------------------------------------
  IF a%=0                                       !Ist schon was da?
    a_neu%=0                                    !Zähler für Neue auf NULL.
    PRINT AT(15,4);"Keine Artikel gespeichert!";!@@@
    a_ok!=TRUE                                  !Artikel-System-Flag TRUE
  ENDIF
  @bing
  ALERT 0,funk$,2,j_n$,but|                     !Abbrechen?
  IF but|=1                                     !Abbrechen, also
    GOTO a_eingeben_schluss                     !ab dafür!
  ENDIF                                         !Weitermachen, also
  @kasten_sauber(5,9,5)                         !Info-Kasten säubern.
  ' ---------------------------------------------------------------------------
  IF a%=a_max%                                  !Max. Artikelzahl erreicht?
    IF l%=l_max%                                !Max. Lieferer-Zahl erreicht?
      MENU 20,2                                 !"Lieferant + Artikel" OFF
      GOTO a_eingeben_voll                      !Ab dafür!
    ENDIF
  ENDIF
  ' ---------------------------------------------------------------------------
  PRINT AT(15,4);"Bitte den Artikel in der Einzahl eingeben:"; !Info-Meldung
  LOCATE 15,5
  FORM INPUT (35),a$                            !Max. Länge evtl. in Variable.
  @blanks_weg_u_upper(a$)
  IF dum!                                       !Nichts eingegeben?
    GOTO a_eingeben_nochmal                     !Dann nochmal von vorn!
  ENDIF
  ' ---------------------------------------------------------------------------
  IF a%>0                                       !Wenn schon Artikel da sind,
    @a_schon_drin_pruefen(a$)                   !prüfe:
    IF a_ex! OR a_si!                           !Einer ist ähnlich oder gleich:
      PRINT AT(15,5);"Der ist schon gespeichert als:";!@@@
      IF LEN(a_fld$(a_hi&))>50                  !String zu lang für Anzeige:
        PRINT AT(15,6);LEFT$(a_fld$(a_hi&),47)+"..."  !Zeig ihn verkürzt.
      ELSE                                      !Sonst
        PRINT AT(15,6);a_fld$(a_hi&);           !zeig ihn ganz.
      ENDIF
      @bing
      ALERT 2,"Artikel wie gespeichert |übernehmen?",1,j_n$,but|
      IF but|=2                                 !Artikel ist ähnlich,
        IF a_ex!=FALSE                          !aber nicht der Gleiche.
          IF INSTR("0123456789",MID$(a_fld$(a_hi&),LEN(a$)+1,1))<>1
            PRINT AT(15,7);"Die Artikel sind unterschiedlich!";
            PRINT AT(15,8);a$;                  !Zeig den Unterschied.
            @bing
            ALERT 2,"So wie neu eingegeben|übernehmen?",1,j_n$,but|
            IF but|=2                           !Den Neuen nicht übernehmen.
              a_ok!=TRUE                        !Artikel-System-Flag setzen.
              GOTO a_eingeben_nochmal           !Nochmal von vorn.
            ELSE                                !Den Neuen übernehmen:
              GOTO a_eingeben_neu               !Mach weiter.
            ENDIF
          ENDIF
        ELSE                                    !Die Artikel
          a_si!=TRUE                            !sind gleich.
        ENDIF
        a_ok!=TRUE                              !Artikel-System-Flag setzen.
        GOTO a_eingeben_nochmal                 !Den nächsten bitte.
      ELSE                                      !Prüfe ob Liefer-Nr.
        lang|=LEN(a_fld$(a_hi&))                !schon vorhanden.
        FOR x&=lang| DOWNTO 1                   !Such durch den ganzen String:
          a$=MID$(a_fld$(a_hi&),x&,1)           !a$ wird gesucht.
          IF INSTR(abc$,a$)                     !a$ ist enthalten im Lieferant
            such|=x&+1                          !und der Pointer wird gesetzt.
            EXIT IF x&>1                        !Raus
          ENDIF                                 !-
        NEXT x&                                 !oder weiter.
        FOR x&=such| TO lang| STEP 3            !Zähle die
          IF MID$(a_fld$(a_hi&),x&,3)=l_n$      !Lieferanten dieses Artikels:
            l_da!=TRUE                          !Flag setzen
          ENDIF                                 !oder
        NEXT x&                                 !nächsten prüfen.
      ENDIF
      IF l_da!=TRUE                             !Wenn einer da ist,
        t$="Der Lieferant ist für |diesen Artikel schon|gespeichert!"
        @bing
        ALERT 3,t$,1,ok$,dum!                   !sag es.
        a_ok!=TRUE                              !Artikel-System-Flag setzen.
      ELSE                                      !Wenn keiner da ist:
        t$="Dieser Artikel ist neu|für den Lieferanten!|So übernehmen?"
        @bing
        ALERT 2,t$,1,j_n$,but|                  !sag es auch.
        IF but|=2                               !Den will er nicht,
          a_ok!=TRUE                            !System-Flag setzen.
          GOTO a_eingeben_nochmal               !Nochmal von vorn.
        ENDIF                                   !Den will er doch:
        IF LEN(a_fld$(a_hi&))>77                !Artikel-String zu lang?
          t$="Es sind schon genug|Lieferanten für diesen"
          t$=t$+"|Artikel gespeichert!"
          @bing
          ALERT 3,t$,1,ok$,dum!                 !Ja, sag es.
          a_ok!=TRUE                            !System-Flag setzen.
          GOTO a_eingeben_nochmal               !Nochmal von vorn.
        ENDIF                                   !Nicht zu lang:
        PRINT AT(15,5);leer$                    !Zeig
        PRINT AT(15,5);"Wird zu:";              !den neuen
        IF LEN(a_fld$(a_hi&))>50                !Artikel verkürzt
          PRINT AT(15,6);LEFT$(a_fld$(a_hi&),44)+"..."+l_n$; !oder
        ELSE                                    !zeige ihn in seiner
          PRINT AT(15,6);a_fld$(a_hi&)+l_n$;    !ganzen Länge.
        ENDIF
        a_fld$(a_hi&)=a_fld$(a_hi&)+l_n$        !Pack ihn ins Artikel-Feld.
        INC a_ch&                               !Zähler hochsetzen
        a_ok!=TRUE                              !und System-Flag setzen.
      ENDIF                                     !Schleife fertig,
      GOTO a_eingeben_nochmal                   !nochmal von vorn.
    ELSE IF a_si!=FALSE AND a_ex!=FALSE         !Nicht in Datei, sondern
      IF INSTR(a_neu$,a$)                       !bei den neu Eingegebenen:
        @bing
        ALERT 1,"|Der Artikel ist schon |bei den neu Eingegebenen!",1,ok$,dum!
        GOTO a_eingeben_nochmal                 !Also nochmal von vorn.
      ENDIF
    ELSE IF a_neu%>=a_max%                      !Max. Artikelzahl erreicht!
      a_eingeben_voll:
      t$="Achtung! Es sind|"+STR$(a_max%)+" Artikel|gespeichert!"
      t$=t$+"|Mehr geht nicht!"
      @bing
      ALERT 3,t$,1,ok$,dum!                     !Ja, sag es.
      MENU 20,2                                 !"Lieferant + Artikel"  OFF
      a_ok!=TRUE                                !System-Flag setzen.
      GOTO a_eingeben_schluss                   !Ab dafür!
    ENDIF
    ' -------------------------------------------------------------------------
    a_eingeben_neu:                             !Hierhin bei neuem Artikel:
    @bing
    ALERT 2,"Dieser Artikel ist neu!|So übernehmen?",1,j_n$,but|
    IF but|=2                                   !Der will den Neuen nicht!
      a_ok!=TRUE                                !System-Flag setzen.
      GOTO a_eingeben_nochmal                   !Nochmal von vorn.
    ELSE                                        !Der will den Neuen doch!
      t$="Ist der Artikel in der |Einzahl eingegeben?"
      @bing
      ALERT 2,t$,1,j_n$,but|                    !Ist er im Singular?
      IF but|=2                                 !Nö -
        a_ok!=TRUE                              !System-Flag setzen.
        GOTO a_eingeben_nochmal                 !Nochmal von vorn.
      ENDIF                                     !Ist im Singular
    ENDIF                                       !und ist erwünscht.
    a$=a$+l_n$+"|"                              !Baue den neuen zusammen.
    a_neu$=a_neu$+a$                            !Baue a_neu$ zusammen.
    @kasten_sauber(5,9,6)                       !Info-Kasten säubern.
    PRINT a$;                                   !Zeige den neuen.
    GOTO a_eingeben_nochmal                     !Nochmal von vorn.
  ELSE                                          !Es sind noch keine Art. da!
    t$="Der erste Artikel! |Soll er so gespeichert |werden?"
    @bing
    ALERT 2,t$,1,j_n$,but|                      !Der erste Artikel
    IF but|=2                                   !soll nicht genommen werden,
      GOTO a_eingeben_nochmal                   !also nochmal von vorn.
    ELSE                                        !Er soll doch genommen werden.
      t$="Ist der Artikel in der |Einzahl eingegeben?"
      @bing
      ALERT 2,t$,1,j_n$,but|                    !Ist er im Singular?
      IF but|=2                                 !Nö -
        GOTO a_eingeben_nochmal                 !also ab dafür.
      ENDIF
    ENDIF                                       !Ist im Singular.
    @a_menu_on                                  !Entspr. Menu-Punkte ON
    a$=a$+l_n$                                  !Artikel bauen.
    PRINT AT(15,6);a$;                          !Zeig, wie er gespeichert wird.
    a%=1                                        !Der erste Artikel!
    a_neu%=a%                                   !Zähler mit raufsetzen.
    ERASE a_fld$()                              !Feld (a_max%) löschen.
    DIM a_fld$(a_neu%)                          !Baue das Art-Feld neu,
    @info("    Ich baue ",a_dat$)               !zeig die Info dafür.
    a_fld$(a_neu%)=a$                           !Benenne Feldinhalt
    @dat_store(a_ok!,v%,a_dat$,a_fld$())        !+ speicher alles ab.
  ENDIF                                         !Das war's.
  GOTO a_eingeben_nochmal                       !Nochmal von vorn beginnen!
  ' ---------------------------------------------------------------------------
  a_eingeben_schluss:                           !Ende der Artikel-Eingabe +
  IF a_ch&>0                                    !Wenn Artikel geändert wurden:
    PRINT AT(15,8);a_ch&'"Artikel mit Lieferanten-Erweiterung.";
    @info("  Ich ändere ",a_dat$)               !sag's auch
    @dat_store(a_ok!,v%,a_dat$,a_fld$())        !und speicher alles ab.
  ENDIF
  IF a_neu$<>""                                 !Wenn neue Artikel dabei sind,
    FOR x&=1 TO LEN(a_neu$)                     !finde heraus anhand "|",
      IF INSTR(MID$(a_neu$,x&,1),"|")           !wieviele es sind
        INC a_neu%                              !+ erhöhe auch a_neu%.
      ENDIF
    NEXT x&
    ERASE a_fld$()                              !Weg mit dem alten Feld +
    DIM a_fld$(a_neu%)                          !baue ein grö×eres neues.
    @info("    Ich lese ",a_dat$)               !Zeig die Info und
    @dat_recall(a_ok!,a_dat$,a_fld$())          !lies die Datei ein.
    FOR x&=a%+1 TO a_neu%                       !Nimm den a_neu$-String
      IF a_hi&=0                                !auseinander + weise
        a_hi&=1                                 !jedem neuen Feld-Teil einen
      ELSE                                      !neuen Artikel zu.
        a_hi&=INSTR(a_hi&+1,a_neu$,"|")+1       !Auch die neu hinzugekommenen
      ENDIF                                     !Artikel zuweisen.
      a_da&=INSTR(a_hi&+1,a_neu$,"|")           !a_neu$-Pointer (a_da&) setzen.
      a_fld$(x&)=MID$(a_neu$,a_hi&,a_da&-a_hi&) !Dies ist ein neuer Feld-Teil.
    NEXT x&
    @info("Ich sortiere ",a_dat$)               !Info zeigen,
    QSORT a_fld$()                              !sortieren +
    @info("  Ich ändere ",a_dat$)               !nochmal Info zeigen
    @dat_store(a_ok!,v%,a_dat$,a_fld$())        !+ alles abspeichern.
    a%=a_neu%                                   !Nun Gesamt-Artikelzahl rauf.
  ENDIF
  PRINT AT(15,9);leer$;                         !Kasten sauber halten.
RETURN
PROCEDURE a_info
  t$="ARTIKEL_ ist ein Verwaltungs- |Programm für Lieferanten und  |Artikel."
  t$=t$+" (c) Ulf Dunkel 1989 |(Version 1.01 -- 06.02.1989)"
  @bing
  ALERT 0,t$,1,ok$,dum!
RETURN
PROCEDURE a_menu_off
  a%=0
  a_neu%=0
  a_ok!=FALSE
  MENU 23,2                                     !  1  Artikel ändern        OFF
  MENU 24,2                                     !  1  Artikel raus          OFF
  MENU 27,2                                     !Lieferant für Artikel raus OFF
  MENU 30,2                                     !Alle Artikel (A-Z)         OFF
  MENU 31,2                                     !Alle Artikel (Z-A)         OFF
  MENU 32,2                                     !Div. Artikel (von-bis)     OFF
  MENU 34,2                                     !  1  Artikel               OFF
RETURN
PROCEDURE a_menu_on
  a_ok!=TRUE
  MENU 23,3                                     !  1  Artikel ändern        ON
  MENU 24,3                                     !  1  Artikel raus          ON
  MENU 27,3                                     !Lieferant für Artikel raus ON
  MENU 30,3                                     !Alle Artikel (A-Z)         ON
  MENU 31,3                                     !Alle Artikel (Z-A)         ON
  MENU 32,3                                     !Div. Artikel (von-bis)     ON
  MENU 34,3                                     !  1  Artikel               ON
RETURN
PROCEDURE a_raus
  LOCAL x&,y&,z&
  ' ---------------------------------------------------------------------------
  a_raus_nochmal:                               !Hier geht's los:
  @bing
  ALERT 0,funk$,1,j_n$,but|                     !Abbrechen?
  IF but|=2                                     !Noch nicht beenden!
    a$=""                                       !Suchstring auf NULL
    PRINT AT(15,4);"Bitte den gewünschten Artikel eingeben:";
    @kasten_sauber(5,9,5)
    FORM INPUT (35),a$                          !Gib den gewünschten Art ein.
    @blanks_weg_u_upper(a$)                     !Natürlich ohne Leerzeichen.
    IF dum!                                     !Bleibt nicht's über:
      GOTO a_raus_nochmal                       !Nochmal von vorn.
    ENDIF
    @a_schon_drin_pruefen(a$)                   !ibt's den gesuchten schon?
    IF a_ex! OR a_si!                           !Ja, exakt oder ähnlich.
      PRINT AT(15,7);"Der ist gespeichert als:";!Zeig ihn,
      IF LEN(a_fld$(a_hi&))>50                  !wenn er zu lang ist,
        PRINT AT(15,8);LEFT$(a_fld$(a_hi&),47)+"...";!verkürzt,
      ELSE                                      !ansonsten
        PRINT AT(15,8);a_fld$(a_hi&)            !in voller Länge an.
      ENDIF
      @bing
      ALERT 0,"Artikel wie gespeichert  |löschen?",2,j_n$,but|
      IF but|=2                                 !Der soll nicht raus!
        GOTO a_raus_nochmal                     !Nochmal von vorn.
      ELSE                                      !Genau der soll raus!
        @bing
        ALERT 0,"| Wirklich löschen?",2,j_n$,but| !Wirklich?
        IF but|=2                               !Nö -
          GOTO a_raus_nochmal                   !Nochmal von vorn.
        ENDIF
      ENDIF
      PRINT AT(15,9);"Wird gelöscht!";
      IF a_hi&=1 AND a_neu%>1                   !Doch, der Erste soll raus!
        v%=a_neu%-1                             !So viele bleiben über:
        FOR x&=1 TO a_neu%-1                    !Gib den übrigen
          a_fld$(x&)=a_fld$(x&+1)               !eine neue Feld-Nummer
        NEXT x&                                 !und
        @info("  Ich ändere ",a_dat$)           !speichere sie im
        @dat_store(a_ok!,v%,a_dat$,a_fld$())    !neuen, kleineren Feld.
      ELSE IF a_hi&=a_neu%                      !Der letzte kommt raus!
        @info("  Ich ändere ",a_dat$)           !Speichere den Rest, ohne
        @dat_store(a_ok!,v%,a_dat$,a_fld$())    !vorher umzusortieren.
      ELSE                                      !Irgendeiner kommt raus.
        FOR x&=a_hi& TO a_neu%-1                !Sortiere den Rest
          a_fld$(x&)=a_fld$(x&+1)               !in neue Felder
        NEXT x&                                 !und
        @info("  Ich ändere ",a_dat$)           !speichere den Rest
        @dat_store(a_ok!,v%,a_dat$,a_fld$())    !neu ab.
      ENDIF
      v%=-1                                     !STORE-Feldgrö×e = Gesamtgrö×e
      ERASE a_fld$()                            !Lösch das alte Feld im RAM.
      DEC a_neu%                                !Neu-Artikel-Zähler eins runter.
      a%=a_neu%                                 !Artikel-Zähler dito.
      IF a_neu%>0                               !Immer noch Artikel da:
        DIM a_fld$(a_neu%)                      !Neues Feld bauen
        @info("    Ich lade ",a_dat$)           !+ die neue, kleinere Datei
        @dat_recall(a_ok!,a_dat$,a_fld$())      !da reinlesen.
      ELSE                                      !Keine Artikel mehr über:
        @a_menu_off                             !Alle entspr. Menus OFF
        KILL a_dat$                             !und den Datei-Stamm killen.
      ENDIF
    ELSE                                        !Den haben wir noch nicht!
      PRINT AT(15,7);"Der gesuchte Artikel ist nicht gespeichert!"
      GOTO a_raus_nochmal                       !Nochmal von vorn.
    ENDIF
  ENDIF
  a_ex!=FALSE                                   !Flags zurück
  a_si!=FALSE                                   !und String-Sucher
  a$=""                                         !auf NULL.
RETURN
PROCEDURE a_schon_drin_pruefen(VAR a$)
  a_hi&=0                                       !div. Pointer
  a_ex!=FALSE                                   !auf NULL
  a_si!=FALSE                                   !stellen.
  FOR x&=a_neu% DOWNTO 1                        !Rückwärts alle Artikel
    IF INSTR(a_fld$(x&),a$)                     !nach a$ absuchen.
      FOR y&=LEN(a_fld$(x&)) DOWNTO 1           !Gefunden, dann den absuchen:
        z&=0                                    !Pointer z& auf NULL.
        IF INSTR(abc$,MID$(a_fld$(x&),y&,1))    !Suche
          z&=y&                                 !den Rand des Artikel-Namens
          EXIT IF z&>0                          !und geh dann raus.
        ENDIF
      NEXT y&
      IF LEFT$(a_fld$(x&),z&)=a$                !Wenn linker Rand identisch mit
        a_hi&=x&                                !a$, dann ist's der Gleiche.
        a_ex!=TRUE                              !Exakt-Flag TRUE setzen.
        EXIT IF a_hi&>0
      ENDIF
      EXIT IF a_ex!                             !und raus!
      a_hi&=x&                                  !Ansonsten ist der Artikel
      a_si!=TRUE                                !nur ähnlich (simile!).
    ENDIF
    EXIT IF a_ex!                               !Raus hier.
  NEXT x&
RETURN
PROCEDURE a_von_bis_zeigen
  LOCAL bis$,von$
  ' ---------------------------------------------------------------------------
  @info_weg
  HIDEM                                         !Maus weg
  @sauber                                       !Bildschirm sauber
  @kasten(106,32,"Artikel (von...bis) zeigen")  !Info-Box
  @von_bis_fragen("Artikel","zeigen",a_neu%)
  @sauber
  zl%=0
  DEFTEXT 1,0,0,6                               !Kleine Listing-Schrift
  IF a_neu%<39                                  !Nur ein Bildschirm voll?
    FOR x&=1 TO a_neu%                          !Ja -
      PRINT TAB(1);a_fld$(x&)                   !zeig ihn ganz
    NEXT x&                                     !+ das war es auch schon!
  ELSE                                          !Oder mehr als 40 Artikel?
    FOR x&=1 TO a_neu%                          !Dann such alle gewünschten
      IF LEFT$(a_fld$(x&))>=von$ AND LEFT$(a_fld$(x&))<=bis$    !raus +
        INC zl%                                 !zähl mit, wie viele es sind.
      ENDIF
    NEXT x&
    DIM von_bis_fld$(zl%)                       !Bau ein Feld für diese Art.
    zl&=1
    FOR x&=1 TO a_neu%
      IF LEFT$(a_fld$(x&))>=von$ AND LEFT$(a_fld$(x&))<=bis$    !raus
        von_bis_fld$(zl&)=a_fld$(x&)
        INC zl&
      ENDIF
    NEXT x&
    IF zl%<=39
      PRINT
      PRINT
      FOR x&=1 TO zl%
        PRINT TAB(1);von_bis_fld$(x&)
      NEXT x&
    ELSE
      @listing(1,"Artikel von "+von$+" bis "+bis$,zl%,zl%,von_bis_fld$())
    ENDIF
  ENDIF
  DEFTEXT 1,0,0,13
  DEFMOUSE 0
  SHOWM
  ERASE von_bis_fld$()                          !Feld wieder weg
RETURN
PROCEDURE a_zeigen
  LOCAL a&,l_nr|,lang|,rand|,x&,y&,l_su&
  ' ---------------------------------------------------------------------------
  l_hi&=0
  l_nr|=0
  a$=""                                         !Input-String +
  a&=0                                          !Pointer auf NULL.
  nochmal_suchen:                               !Hierhin, wenn Input = Mist.
  IF l_fuer_a_raus!=TRUE
    @kasten(112,32,"Lieferant für Artikel raus")
    PRINT AT(15,4);"Artikel (zum Lieferant Entfernen) eingeben:";
  ELSE
    @kasten(208,32,"Artikel suchen")
    PRINT AT(15,4);"Gewünschten Artikel eingeben:";
  ENDIF
  LOCATE 15,5
  FORM INPUT (35),a$                            !Gib den Gesuchten ein.
  @blanks_weg_u_upper(a$)
  IF dum!                                       !Nix eingeben gibt's nicht!
    GOTO nochmal_suchen                         !Nochmal von vorn beginnen.
  ENDIF
  @a_schon_drin_pruefen(a$)
  IF a_ex! OR a_si!                             !Wenn einer drin ist:
    @bing
    PRINT AT(15,6);"Der ist gespeichert als:";
    IF LEN(a_fld$(a_hi&))>50
      PRINT AT(15,7);LEFT$(a_fld$(a_hi&),47)+"...";
    ELSE
      PRINT AT(15,7);a_fld$(a_hi&);             !zeig ihn.
    ENDIF
  ELSE IF a_hi&=0                               !Wenn keiner drin ist:
    PRINT AT(15,6);"Der gesuchte Artikel ist so noch nicht gespeichert!";
    PRINT AT(15,7);"Eventuell anders suchen!";
    GOTO a_zeigen_ende                          !Ab dafür!
  ENDIF
  a$=a_fld$(a_hi&)                              !Das ist der gesuchte Artikel.
  lang|=LEN(a$)                                 !So lang ist der String.
  FOR x&=lang| DOWNTO 1                         !Such den Rand des Art.-Textes:
    aa$=MID$(a$,x&,1)
    IF INSTR(abc$,aa$)
      rand|=x&                                  !Hier Ende des Artikelnamens.
      EXIT IF x&>1                              !Schlu× mit der Suche.
    ENDIF
  NEXT x&
  IF lang|>rand|                                !Steht was hinter dem Namen?
    l_nr|=(lang|-rand|) DIV 3                   !Ja: die Lieferanten!
  ENDIF
  ERASE su$()                                   !Sicher ist sicher!
  IF l_nr|>0                                    !Wenn Lieferanten da sind:
    DIM su$(l_nr|)
    QSORT l_fld$()                              !Sortiere die Lieferanten (1-x)
    x&=1
    FOR y&=rand|+1 TO lang| STEP 3
      su$(x&)=l_fld$(VAL(MID$(a$,y&,3)))
      INC x&
    NEXT y&
    QSORT su$()
    PRINT AT(15,9);LEFT$(a$,lang|-(lang|-rand|));!Zeige den gefundenen Artikel
    DEFTEXT 1,0,0,6
    LOCATE 1,20
    FOR x&=1 TO l_nr|                           !+ schön alphabetisch sortiert
      PRINT TAB(14);su$(x&)                     !die Lieferanten dazu.
    NEXT x&
  ENDIF
  DEFTEXT 1,0,0,13                              !Schrift wieder normal.
  IF l_fuer_a_raus!=TRUE AND l_nr|>0            !Wenn Lieferanten da sind:
    @kasten_sauber(4,6,4)
    PRINT AT(15,9);leer$;
    PRINT AT(15,4);"Bitte Lieferanten-Nummer nennen, die raus soll:"';
    FORM INPUT (3),nr$
    l_su&=VAL(nr$)
    IF l_su&>0 AND l_su&<=l%                    !Kein Mist eingegeben.
      IF l_su&<10                               !Auf 3 Stellen formatieren.
        nr$="00"+STR$(l_su&)
      ELSE IF l_su&<100
        nr$="0"+STR$(l_su&)
      ELSE IF l_su&<1000
        nr$=STR$(l_su&)
      ENDIF
      FOR x&=1 TO l_nr|                         !Lieferant schon da?
        IF INSTR(su$(x&),nr$)                   !Ja, hier bei x&.
          l_hi&=x&                              !Pointer setzen.
        ENDIF
      NEXT x&
    ENDIF
    IF l_hi&>0                                  !Lieferanten-Nummer gefunden
      FOR x&=rand| TO lang| STEP 3
        IF INSTR(a$,nr$)
          hier|=INSTR(a$,nr$)
        ENDIF
      NEXT x&
      a$=LEFT$(a$,hier|-1)+RIGHT$(a$,lang|-(hier|+2))
      a_fld$(a_hi&)=a$
      PRINT AT(15,6);"Wird zu:"
      PRINT AT(15,7);leer$
      PRINT AT(15,7);a$
      @info("  Ich ändere ",a_dat$)
      @dat_store(a_ok!,a_neu%,a_dat$,a_fld$())
    ELSE
      @bing
      PRINT AT(15,9);"Der Lieferant ist für den Artikel nicht gespeichert!"
    ENDIF
  ELSE IF l_fuer_a_raus!=TRUE
    PRINT AT(15,9);"Der Artikel ist zur Zeit ohne Lieferanten!"
  ENDIF
  a_zeigen_ende:
  ERASE su$()                                   !Weg mit dem Suchfeld.
  a$=""
  a_si!=FALSE
  a_ex!=FALSE
RETURN
PROCEDURE ausdruck
  @sauber
  ausdruck_nochmal:
  IF OUT?(0)=0                                  !Drucker OFF
    @bing
    ALERT 3,"|Drucker nicht bereit!",2,"Abbruch| Weiter ",but|
    IF but|=2                                   !Nochmal versuchen.
      GOTO ausdruck_nochmal
    ENDIF
  ELSE                                          !Drucker ist ON
    @bing
    ALERT 2,"|Listing ausdrucken?",3,"Artikel|Lieferer|Abbruch",but|
    SELECT but|                                 !Es soll gedruckt werden:
    CASE 1                                      !eine Artikel-Liste;
      @kasten(200,32,"Artikel drucken")
      @von_bis_fragen("Artikel","drucke",a_neu%)
      @kasten_sauber(5,8,5)
      @von_bis_feld_bauen(a_neu%,a_fld$())
      IF zl%>0
        z%=0
        LPRINT "Artikel-Liste von "+von$+" bis "+bis$+", gedruckt am "+DATE$
        LPRINT STRING$(80,"-")
        PRINT AT(15,9);"Abbruch mit beiden Maus-Tasten!"
        EVERY 50 GOSUB ausdruck_artikel
        REPEAT
          PRINT AT(15,5);"Ich drucke den Artikel:"
        UNTIL MOUSEK=3 OR z%=-10
        ERASE von_bis_fld$()
      ELSE
        PRINT AT(15,9);"Kein Artikel in diesem Bereich vorhanden!"
      ENDIF
    CASE 2                                      !eine Lieferanten-Liste;
      @kasten(168,32,"Lieferanten drucken")
      @von_bis_fragen("Lieferanten","drucke",l_neu%)
      @kasten_sauber(5,8,5)
      @von_bis_feld_bauen(l_neu%,l_fld$())
      IF zl%>0
        z%=0
        LPRINT "Lieferanten-Liste von "+von$+" bis "+bis$+", gedruckt am ";
        LPRINT DATE$
        LPRINT STRING$(80,"-")
        PRINT AT(15,9);"Abbruch mit beiden Maus-Tasten!"
        EVERY 50 GOSUB ausdruck_lieferant
        REPEAT
          PRINT AT(15,5);"Ich drucke den Lieferant:"
        UNTIL MOUSEK=3 OR z%=-10
        ERASE von_bis_fld$()
      ELSE
        PRINT AT(15,9);"Kein Lieferant in diesem Bereich vorhanden!"
      ENDIF
    CASE 3                                      !nichts.
      GOTO ausdruck_ende
    ENDSELECT
    EVERY STOP                                  !Interrupt-Druckroutine OFF
    DEFMOUSE 0                                  !Maus wieder normal.
    IF MOUSEK=3                                 !Ist Abbruch erfolgt?
      PRINT AT(15,9);leer$;                     !Ja -
      PRINT AT(15,9);"Ausdruck abgebrochen!"    !dann sag es auch.
      LPRINT CHR$(13)                           !Drucker in Warte-Position
      LPRINT                                    !setzen.
    ELSE IF z%=-10                              !Ist Listing fertig gedruckt?
      PRINT AT(15,9);leer$;                     !Ja -
      PRINT AT(15,9);"Listing fertig gedruckt!" !dann sag es auch.
    ENDIF
  ENDIF
  ausdruck_ende:                                !Fertig.
RETURN
PROCEDURE ausdruck_artikel
  INC z%
  IF z%+1<zl%                                   !Es sind noch Artikel da:
    PRINT AT(15,7);leer$;
    IF LEN(von_bis_fld$(z%))>25
      PRINT AT(15,7);LEFT$(von_bis_fld$(z%),20)
    ELSE
      PRINT AT(15,7);von_bis_fld$(z%);          !Zeig den Artikel an.
    ENDIF
    LPRINT von_bis_fld$(z%)                     !Drucke ihn aus.
  ELSE
    z%=-10                                      !Liste fertig.
    LPRINT CHR$(13)                             !Drucker in Warte-Position
    LPRINT                                      !setzen.
  ENDIF                                         !Fertig.
RETURN
PROCEDURE ausdruck_lieferant
  INC z%
  IF z%+1<zl%                                   !Es sind noch Lieferanten da.
    PRINT AT(15,7);leer$;
    PRINT AT(15,7);von_bis_fld$(z%);            !Zeig sie an.
    LPRINT von_bis_fld$(z%)+SPACE$(40-LEN(von_bis_fld$(z%)));!Drucke sie.
  ELSE
    z%=-10                                      !Liste ist fertig.
    LPRINT CHR$(13)                             !Drucker in Warte-Position
    LPRINT                                      !setzen.
  ENDIF                                         !Fertig.
RETURN
PROCEDURE bing
  IF bing_on!=TRUE
    PRINT CHR$(7)
  ENDIF
RETURN
PROCEDURE blanks_weg_u_upper(VAR a$)
  FOR x&=1 TO LEN(a$)                           !Leerzeichen links löschen!
    IF LEFT$(a$,1)=" "
      a$=RIGHT$(a$,LEN(a$)-1)
    ENDIF
  NEXT x&
  a$=UPPER$(a$)                                 !Keine kleinen Buchstaben!
  IF a$=""
    t$="|Nur  <RETURN>  ohne |eine Texteingabe ist |nicht erlaubt!"
    @bing
    ALERT 3,t$,1,ok$,dum!
  ELSE
    dum!=FALSE
  ENDIF
RETURN
PROCEDURE breite_richtig(VAR zahl&,feld$())
  IF LEN(feld$(zahl&))=80
    PRINT TAB(tab&);feld$(zahl&);
  ELSE
    PRINT TAB(tab&);feld$(zahl&)
  ENDIF
RETURN
PROCEDURE dat_recall(VAR ok!,dat$,feld$())
  OPEN "i",#1,dat$                              !öffne die Datei,
  RECALL #1,feld$(),-1,n                        !speichere den neuen Artikel
  CLOSE #1                                      !+ schlie×e die Datei.
  ok!=TRUE                                      !(Art- oder Lief-)Flag setzen!
  DEFMOUSE 0                                    !Fertig.
  @info_weg
RETURN
PROCEDURE dat_store(VAR ok!,vol%,dat$,feld$())
  OPEN "o",#1,dat$                              !öffne die Datei,
  STORE #1,feld$(),vol%                         !speichere den neuen Artikel
  CLOSE #1                                      !+ schlie×e die Datei.
  ok!=TRUE                                      !Artikel-Flag setzen!
  DEFMOUSE 0                                    !Fertig.
  @info_weg
RETURN
PROCEDURE datum
  LOCAL d$,zeit$
  IF VAL(RIGHT$(DATE$,4))>=1989 AND datum_menu!=FALSE
    GOTO datum_ende
  ENDIF
  ' ---------------------------------------------------------------------------
  ' Routine von der GFA-PD Nr. 45 zum Eingeben der Systemdaten,
  ' macht das Programm etwas unabhängiger vom CONTROLL.ACC.
  ' ---------------------------------------------------------------------------
  anfang:
  DEFFILL 1,2,4
  PBOX 0,0,639,399
  DEFFILL 1,2,8
  PBOX 219,64,419,84
  DEFFILL 1,0,0
  PBOX 215,60,415,80
  TEXT 240,75,"Datum   -   Eingabe"
  PBOX 237,158,402,243
  PBOX 240,161,399,240
  d$=DATE$
  PRINT AT(34,12);d$
  PRINT AT(34,13);
  FORM INPUT 10,d$
  SETTIME "",d$
  @bing
  ALERT 0,DATE$+" | | |Datum korrekt ?",1,j_n$,but|
  IF but|=2
    GOTO anfang
  ENDIF
  zeit:
  DEFFILL 1,2,8
  PBOX 219,64,419,84
  DEFFILL 1,0,0
  PBOX 215,60,415,80
  TEXT 248,75,"Zeit   -   Eingabe"
  PBOX 237,158,402,243
  PBOX 240,161,399,240
  TIME$=TIME$
  PRINT AT(34,12);TIME$
  PRINT AT(34,13);
  FORM INPUT 10,zeit$
  SETTIME zeit$,""
  @bing
  ALERT 0,TIME$+" | | |Zeit  korrekt ?",1,j_n$,but|
  IF but|=2
    GOTO zeit
  ENDIF
  @sauber
  datum_ende:
  datum_menu!=FALSE
RETURN
PROCEDURE dump
  @sauber
  PRINT "GLOBALE Werte:----------------------"
  PRINT "a%      ="'a%
  PRINT "a_dat$  ="'a_dat$
  PRINT "a_max%  ="'a_max%
  PRINT "a_neu%  ="'a_neu%
  PRINT "abc$    ="'abc$
  PRINT "bing_on!="'bing_on!
  PRINT "j_n$    ="'j_n$
  PRINT "l%      ="'l%
  PRINT "l_dat$  ="'l_dat$
  PRINT "l_max%  ="'l_max%
  PRINT "l_neu%  ="'l_neu%
  PRINT "menu|   ="'menu|
  PRINT "n#      ="'n
  PRINT "ok$     ="'ok$
  PRINT "p$      ="'p$
  PRINT "v%      ="'v%
  PRINT "GLOBALE Flags:----------------------"
  PRINT "a_ok!  ="'a_ok!
  PRINT "but|   ="'but|
  PRINT "dum!   ="'dum!
  PRINT "l_ok!  ="'l_ok!
  PRINT "nur_l! ="'nur_l!;
RETURN
PROCEDURE ende
  t$="Heute ist erst der  |"+DATE$+", "
  t$=t$+TIME$+" Uhr.| |Keine Lust mehr?"
  @bing
  ALERT 2,t$,2,"Schlu×!|Weiter!",but|
  IF but|=1
    ' RESERVE                                   !Speicher-Reserven freigeben!
    OPTION BASE 0                               !Brav alles zurückstellen!
    LPOKE XBIOS(14,1)+6,0                       !Tastatur-Puffer löschen!
    CLEAR                                       !Alle Felder + Variablen NULL
    END !SYSTEM                                 !***** Programm-Ende *****
  ENDIF                                         !später ersetzen durch: SYSTEM
RETURN
PROCEDURE fehler_abfangen
  ON ERROR GOSUB fehler_abfangen
  t$="|Achtung, ein Fehler!|--> Nummer "+STR$(ERR)+"|Er bedeutet:"
  ALERT 3,t$,1,ok$,dum!
  ~FORM_ALERT(1,ERR$(ERR))
  IF NOT FATAL
    RESUME NEXT
  ENDIF
RETURN
PROCEDURE genug_speicher_da
  LOCAL a_pl%,d_fr%,d_mi%,l_pl%,p_lg%,ram%
  ' a_pl% = Benötigter Platz der Artikel-Datei
  ' d_fr% = Echt freier Speicher auf der Diskette
  ' d_mi% = Benötigter Disk-Speicherplatz (incl. a_pl% + l_pl%)
  ' l_pl% = Benötigter Platz der Lieferanten-Datei
  ' p_lg% = Programm-Länge dieses Programms
  ' ram%  = Freier RAM-Speicher im Computer
  ' ---------------------------------------------------------------------------
  genug_speicher_da_nochmal:
  OPEN "i",#1,p$                                !Öffne Programm-File,
  p_lg%=LOF(#1)                                 !lies Programm-Länge
  CLOSE #1                                      !+ schlie×e Programm-File.
  l_pl%=l_max%*(35+3+2)+1000                    !Platz für LIEFERER.DAT
  a_pl%=a_max%*(80+2)+1000                      !Platz für ARTIKEL_.DAT
  d_mi%=l_pl%+a_pl%+p_lg%                       !Mindest-DISK-Platzbedarf
  ram%=FRE()                                    !RAM-Speicher
  d_fr%=DFREE(1)                                !freier DISK-Speicherplatz
  d_fr%=d_fr%+l_pl%+a_pl%                       !Benötigter DISK-Speicherplatz
  ' ---------------------------------------------------------------------------
  IF ram%<d_mi%                                 !RAM zu klein?
    t$="|Achtung! Der RAM-Speicher|im Computer ist zu klein!"
    @bing
    ALERT 3,t$,1,ok$,dum!
    t$="Das Programm wird gleich |gestoppt. Bitte prüfen Sie |vor "
    t$=t$+"einem Neustart, welche|Nebenprogramme noch laufen!"
    @bing
    ALERT 3,t$,1,ok$,dum!
    t$="Löschen Sie vor dem nächsten |Neustart zum Beispiel einige|"
    t$=t$+"Accessories oder Programme |aus dem AUTO-Ordner."
    @bing
    ALERT 1,t$,1,ok$,dum!
    RESERVE                                     !Evtl. Reserven freigeben!
    END                                         !***** Programm-Ende *****
    ' -------------------------------------------------------------------------
  ELSE IF d_fr%<d_mi%                           !DISK-Speicher zu klein?
    unbedingt_loeschen!=TRUE
    @bing
    ALERT 3,"|Achtung! Ihre Diskette |hat zu wenig Platz. ",1,ok$,dum!
    t$="Bitte prüfen Sie mit <Löschen>|im Menu 'Datei', was neben|"
    t$=t$+a_dat$+", "+l_dat$+" und |"
    t$=t$+p$+" noch existiert."
    @bing
    ALERT 3,t$,1,ok$,dum!
    @loeschen                                   !Erstmal eine Datei loeschen.
    GOTO genug_speicher_da_nochmal              !Nachsehen, ob das ausreicht.
  ENDIF
  unbedingt_loeschen!=FALSE
RETURN
PROCEDURE globale_variablen
  ' GLOBALE Variablen:
  ' a%       = Anzahl der Artikel auf Disk (entspricht n#)
  ' a_dat$   = Name der Artikel-Datei (Default = ARTIKEL_.DAT)
  ' a_fld$() = Datei-Feld aller Artikel, max. a_max%
  ' a_max%   = Max. Anzahl der Artikel (später speicherabhängig formulieren!)
  ' a_neu%   = Zähler für neue Artikel, üblicherweise a%+1
  ' a_ok!    = Flag für Zugriffe auf die Artikel-Datei
  ' abc$     = "ABCDEFGHIJKLMNOPQRSTUVWXYZ×ÄÖÜ, "
  ' bing_on! = Status, ob Alert-Boxen mit einem Bing oder stumm erscheinen
  ' but|     = Rückgabe-Wert von mehreren Alert-Buttons
  ' dum!     = Ignorier-Wert bei nur einem Alert-Button
  ' funk$    = "Funktion abbrechen?"
  ' j_n$     " Wähl-Button-Text bei zwei Buttons "   Ja   |  Nein  "
  ' l%       = Anzahl der Lieferanten auf Disk (entspricht n#)
  ' l_dat$   = Name der Lieferanten-Datei (Default= LIEFERER.DAT)
  ' l_fld$() = Datei-Feld aller Lieferanten, max. l_max%
  ' l_max%   = Max. Anzahl der Lieferanten (später evtl. mal > 999)
  ' l_n$     = auf 3 Stellen formatierte Lieferanten-Nummer
  ' l_neu%   = Zähler für neue Lieferanten, üblicherweise l%+1
  ' l_ok!    = Flag für Zugriffe auf die Lieferanten-Datei
  ' leer$    = Info-Anzeige-Überschreiber (SPACE$(50)
  ' menu|    = Wert einer Pulldown-Menu-Aktion
  ' menu$()  = Feld für Pulldown-Menu-Aktivitäten
  ' mess%()  = Feld für Accessory-Meldungen etc.
  ' n#       = Rückgabe-Wert von RECALL (siehe auch v%)
  ' nur_l!   = Flag für Zugriff auf Eingabe-Procedure von "Nur Lieferant" aus.
  ' ok$      = Button-Text "   OK   "
  ' p$       = Name des Programms (ARTIKEL_.WAS bzw. comp. ARTIKEL_.PRG)
  ' t$       = String für Alert-Boxen
  ' txt$     = Ergänzung zu t$ (meist eine Lade-Info)
  ' v%       = Übergabe-Wert der Datei-Grö×en für Unterprogramme (meist -1)
RETURN
PROCEDURE hilfe_zeigen(ze1$,ze2$,ze3$,ze4$,ze5$)
  DEFMOUSE 2                                    !Flei×ig:
  TEXT 25,310,ze1$                              !Zeige die
  TEXT 25,325,ze2$                              !max. fünf
  TEXT 25,340,ze3$                              !Zeilen
  TEXT 25,355,ze4$                              !Informations-Text
  TEXT 25,370,ze5$                              !an +
  DO                                            !warte auf
  LOOP UNTIL MOUSEK                             !Maustasten-Druck.
  @sauber                                       !Bildschirm löschen.
  DEFMOUSE 0                                    !Fertig!
  mk&=MOUSEK                                    !Maus-Control OFF mit Zuweisen
RETURN
PROCEDURE hilfe
  DEFFILL 1,2,8                                 !Mit schwarzer Farbe
  PBOX 15,300,633,378                           !versetzten Kasten malen;
  DEFFILL 1,0,0                                 !mit wei×er Farbe
  PBOX 11,296,629,374                           !wei×en Kasten malen.
  SELECT m|                                     !Welches Menu wurde gewählt?
    ' CASE 0                                    !MENUTITEL "Artikel Desk+Info"
  CASE 1                                        !Programm-Info
    z1$="Dieses Programm verwaltet Lieferanten und denen zugeordnete Artikel."
    z2$="Nach einer komfortablen Eingabe der Artikel für einen bestimmten"
    z3$="Lieferanten sind umfassende Such-Möglichkeiten gegeben. Es können"
    z4$="sowohl die Lieferanten als auch die Artikel verändert, erweitert oder"
    z5$="wieder gelöscht werden. Alle Eingaben werden automatisch gespeichert."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
    ' CASE 9 ------------------------------------------------------------------
    ' CASE 10                                   !MENUTITEL "Datei"
  CASE 11                                       !-Laden
  CASE 12                                       !-Speichern
  CASE 13                                       !-Prüfen
  CASE 14 !-------------------------------------!@@@ Trennstrich
  CASE 15                                       !Löschen
    z1$="LÖSCHEN bewirkt, da× die in der gleich erscheinenden Auswahl-Box"
    z2$="angewählten Dateien unwiederbringlich gelöscht werden. Vorher wird"
    z3$="eine Sicherheits-Abfrage gestellt, die nicht umgangen werden kann."
    z4$="Zum Programm gehörende Dateien können - selbstverständlich - nicht"
    z5$="gelöscht werden. Fehleingaben werden berücksichtigt."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 16 !-------------------------------------!@@@ Trennstrich
  CASE 17                                       !Ende
    z1$="ENDE ist die einzige legitime Möglichkeit, aus diesem Programm wieder"
    z2$="auszusteigen. - Nach einer Sicherheits-Abfrage wird es beendet und"
    z3$="der GFA-BASIC-Interpreter oder RUN-ONLY-Interpreter wieder aktiviert."
    z4$="(optional: der GEM-Desktop wieder dargestellt.)"
    z5$="Dieses Programm ist nicht resetsicher!"
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
    ' CASE 18 -----------------------------------------------------------------
    ' CASE 19                                   !MENUTITEL "Eingabe"
  CASE 20                                       !Lieferant + Artikel
    z1$="LIEFERANT + ARTIKEL: Hier können Sie in einer Endlos-Schleife Artikel"
    z2$="für bestimmte Lieferanten eingeben. Erst wählen Sie einen Lieferanten"
    z3$="aus, dann geben Sie beliebig viele Artikel für ihn ein. Sie werden"
    z4$="vom Programm auf Fehler, schon vorhandene Lieferanten, Artikel etc."
    z5$="hingewiesen und durch diese Funktion geleitet."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 21                                       !Nur die Lieferanten
    z1$="NUR DIE LIEFERANTEN: Hier können Sie beliebig viele Lieferanten"
    z2$="eingeben, bis die vom Programm erlaubte max. Anzahl erreicht ist."
    z3$="Das Programm leitet Sie durch die Funktion und kontrolliert, ob ein"
    z4$="Lieferant schon vorhanden ist (auf Diskette) bzw. beim jetzigen"
    z5$="Benutzen dieser Funktion schon mal eingegeben wurde."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 22 !-------------------------------------!@@@ Trennstrich
  CASE 23                                       !1 Artikel ändern
    z1$="1 ARTIKEL ÄNDERN: Wenn Sie einen Artikel umbenennen möchten, z. B."
    z2$="weil er falsch eingegeben wurde, benutzen Sie diese Funktion. Es wird"
    z3$="selbstverständlich überprüft, ob der neue Artikel-Name auch schon"
    z4$="existiert. - Ansonsten leitet die Funktion Ihre Eingaben selbständig."
    z5$=""
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 24                                       !1 Artikel raus
    z1$="1 ARTIKEL RAUS: Falls ein Artikel nicht mehr im Programm ist, falsch"
    z2$="eingegeben wurde oder er aus sonstigen Gründen nicht mehr in der Datei"
    z3$="bleiben soll, wählen Sie ihn bitte mit dieser Funktion an. Nach der"
    z4$="obligatorischen Sicherheits-Abfrage wird er unwiederuflich gelöscht."
    z5$="(Natürlich kann er durch Neueingabe wieder aufgenommen werden!)"
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 26                                       !1 Lieferant ändern
    z1$="1 LIEFERANT ÄNDERN: Soll die Anschrift eines Lieferanten geändert"
    z2$="werden oder gar der alte Lieferant durch einen Neuen ersetzt werden,"
    z3$="so suchen Sie ihn bitte mit dieser Funktion aus. Alte Lieferanten"
    z4$="können Sie mühelos neu eingeben. Neue Lieferanten ersetzen den alten"
    z5$="und löschen die Lieferanten-Nummer bei den Artikeln ersatzlos."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 27                                       !Lieferant für Artikel raus
    z1$="LIEFERANT FÜR ARTIKEL RAUS: Wenn ein Lieferant einen Artikel nicht"
    z2$="mehr liefert oder aus sonstigen Gründen für einen bestimmten Artikel"
    z3$="gelöscht werden soll, wählen Sie ihn bitte mit dieser Funktion aus."
    z4$="Das Programm hilft ihnen bei der richtigen Auswahl und Lösch-Funktion."
    z5$="(Durch Neueingabe kann er wieder für den Artikel aufgenommen werden!)"
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
    ' CASE 28 -----------------------------------------------------------------
    ' CASE 29                                   !MENUTITEL "Ausgabe"
  CASE 30,31                                    !Alle Artikel (A-Z,Z-A)
    z1$="ALLE ARTIKEL: Hier werden - je nach Wahl - alle Artikel alphabetisch"
    z2$="sortiert angezeigt, von A - Z, oder rückwärts von Z - A."
    z3$="Dabei werden hinter jedem Artikel die für ihn gespeicherten"
    z4$="Lieferanten-Nummern mit angezeigt. Max. Länge eines Artikels ="
    z5$="35 Buchstaben und mind. 15 Lieferanten(-Nummern)."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 32                                       !Div. Artikel (von-bis)
    z1$="DIV. ARTIKEL: Wenn Sie nur einige Artikel aufgelistet sehen möchten,"
    z2$="geben Sie hier bitte Anfangs- und End-Buchstaben ein. Das Programm"
    z3$="sucht selbständig die entsprechenden Artikel und zeigt sie"
    z4$="alphabetisch sortiert. Selbstverständlich können Sie nach oben oder"
    z5$="unten blättern, wenn mehr als eine Seite voll Artikel gefunden werden."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 33 !-------------------------------------!@@@ Trennstrich
  CASE 34                                       !1 Artikel
    z1$="1 ARTIKEL: Hier geben Sie bitte den gewünschten Artikel ein. Sollten"
    z2$="Sie ihn nicht gleich finden, geben Sie nur Teile des Artikel-Namens"
    z3$="ein. Evtl. helfen Ihnen auch die Funktionen ALLE + DIV. ARTIKEL."
    z4$="Generell sollten Sie Artikel nicht zu lang umschreiben und nur die"
    z5$="Einzahl des Artikels verwenden."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 35 !-------------------------------------!@@@ Trennstrich
  CASE 36 TO 39                                 !Alle Lief (1-x,x-1,A-Z,Z-A)
    z1$="ALLE LIEFERANTEN: Hier werden - je nach Wahl - alle Lieferanten"
    z2$="sortiert angezeigt, von A - Z, von Z - A oder nach der Nummer von"
    z3$="001 bis zum neuesten Lieferanten bzw. rückwärts bis 001."
    z4$="Max. Länge eines Lieferanten = 3-stellige Nummer + 35 Buchstaben."
    z5$="(Die Nummer wird vom Programm automatisch vergeben!)"
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 40 !-------------------------------------!@@@ Trennstrich
  CASE 41,42                                    !1 Lieferant(Nr.,Name)
    z1$="1 LIEFERANT: Geben Sie - je nach Wahl - die Nummer oder den Namen des"
    z2$="gesuchten Lieferanten ein. Die Nummer kann nach Belieben bis 3-stellig"
    z3$="sein, der Name sollte nicht zu lang sein ('MEIER, HAMBURG' lä×t sich"
    z4$="schon z.B. mit 'mei' finden. - Wenn ein Lieferant nach Ihren Angaben"
    z5$="gespeichert ist, wird der volle Name und Ort ausgegeben."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 43 !-------------------------------------!@@@ Trennstrich
  CASE 44                                       !Ausdruck
    z1$="AUSDRUCK: Diese Funktion steuert Ihren angeschlossenen Drucker an."
    z2$="Dabei werden (momentan) nur Listings der gespeicherten Artikel- und"
    z3$="Lieferanten-Datei ausgedruckt."
    z4$="Der Ausdruck läuft als Interrupt und kann durch Drücken beider"
    z5$="Maus-Tasten gleichzeitig abgebrochen werden."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
    ' CASE 45 -----------------------------------------------------------------
    ' CASE 46                                   !MENUTITEL "Service"
  CASE 47                                       !Hilfe
    z1$="HILFE: Wenn vor diesem Menu-Punkt ein Häkchen steht (durch Anwählen),"
    z2$="so wird vor jedem Benutzen eines beliebigen Pulldown-Menupunktes ein"
    z3$="Hilfe-Text am unteren Bildschirm-Rand angezeigt."
    z4$="Durch Drücken einer Maustaste können Sie mit dem Programm fortfahren."
    z5$="HILFE abschalten: durch nochmaliges Anwählen dieses Punktes."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 48                                       !Datum
    z1$="DATUM: Sollte Ihr Rechner keine Batterie-gepufferte Uhr besitzen, so"
    z2$="prüft das Programm bei jedem Start, ob das System-Datum vor 1989 liegt"
    z3$="und bittet Sie automatisch, das Datum zu aktualisieren. - Sollten Sie"
    z4$="aus persönlichen Gründen das Datum nochmals verstellen wollen, wählen"
    z5$="Sie bitte diesen Punkt an."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 49                                       !Speicher
    z1$="SPEICHER: Dieser Informations-Service gibt die freien Bytes sowohl"
    z2$="in Ihrem Rechner als auch auf der in Laufwerk A: befindlichen Diskette"
    z3$="aus. Diese Funktion kann dienlich sein, um freien Speicher für die"
    z4$="immer grö×er werdenden Dateien zu schaffen. Arbeiten Sie dann auch"
    z5$="mit der Funktion LÖSCHEN im Menutitel DATEI zusammen."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 50                                       !Zeige DUMP
    z1$="ZEIGE DUMP: Diese Funktion ist während der Programm-Entwicklung"
    z2$="recht hilfreich gewesen und für Anwender des Programms wohl nur in"
    z3$="Ausnahme-Fällen von Bedeutung."
    z4$=""
    z5$=""
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 51                                       !Alarm AUS
    z1$="ALARM AUS: Wenn vor diesem Menu-Punkt ein Häkchen steht, erscheinen"
    z2$="sämtliche Warn-Boxen ohne das oft lästige Alarm-Bimmeln. "
    z3$="Alarm wieder aktivieren: durch nochmaliges Anwählen des Menupunktes."
    z4$="Die Warn-Boxen haben 1 - 3 Buttons, die durch Drücken mit der Maus"
    z5$="oder (fett umrandete) durch <RETURN> bzw. <ENTER> gewählt werden."
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
  CASE 52                                       !Anzeige weg
    z1$="ANZEIGE WEG: Diese Funktion löscht den gesamten Bildschirm."
    z2$="Das ist manchmal nötig, da nicht alle Funktionen des Programms nach"
    z3$="Beendigung den Bildschirm aufräumen."
    z4$=""
    z5$=""
    @hilfe_zeigen(z1$,z2$,z3$,z4$,z5$)
    ' CASE 53 -----------------------------------------------------------------
  ENDSELECT
RETURN
PROCEDURE info(txt$,dat$)
  CLOSEW 0
  TEXT 440,14,txt$+dat$
  OPENW 0
  DEFMOUSE 2
RETURN
PROCEDURE info_weg
  CLOSEW 0                                      !Info-Zeile beschreibbar
  TEXT 440,14,SPACE$(25)                        !Lösche die o.g. Info
  OPENW 0                                       !Info-Zeile wieder geschützt
RETURN
PROCEDURE info_zeigen
  PRINT
  PRINT
  PRINT AT(5,46);"Weiter mit ("'
  OUT 5,2                                       !Pfeil runter (ASCII 2)
  PRINT " ), wieder rauf mit ("'
  OUT 5,1                                       !Pfeil rauf   (ASCII 1)
  PRINT " ), Ende mit ( ESC )."
RETURN
PROCEDURE kasten(x&,y&,info$)
  @sauber
  DEFTEXT 1,1,0,32                              !Dicke fette Schrift
  TEXT x&,y&,info$                              !Überschrift für Kasten
  DEFTEXT 1,0,0,13                              !Schrift wieder normal
  DEFFILL 1,2,8                                 !Schwarze Farbe
  PBOX 104,50,533,150                           !Schwarze Hintergrund-Box
  DEFFILL 0                                     !Farbe Wei×
  PBOX 100,46,529,146                           !Wei×e Vordergrund-Box
  BOX 100,46,529,146                            !Rahmen um die wei×e Box
RETURN
PROCEDURE kasten_sauber(von&,bis&,loc&)
  FOR x&=von& TO bis&                           !lösche die Kasten-Texte
    PRINT AT(15,x&);leer$;
  NEXT x&
  LOCATE 15,loc&
RETURN
PROCEDURE l_finden
  LOCAL l_su&,l_su$,nr$
  ' ---------------------------------------------------------------------------
  l_hi&=0
  PRINT AT(15,4);"Lieferanten gespeichert:"'l%;
  ' ---------------------------------------------------------------------------
  IF finde_l_name!=TRUE                         !Nach Name suchen:
    l_finden_nochmal:
    PRINT AT(15,5);"Bitte gesuchten Lieferanten-Namen eingeben:"
    LOCATE 15,6
    FORM INPUT (35),l_su$
    @blanks_weg_u_upper(l_su$)
    IF dum!=TRUE                                !Kein Input?
      GOTO l_finden_nochmal                     !Nochmal von vorn!
    ENDIF
    FOR x&=1 TO l%                              !Lieferant schon da?
      IF INSTR(l_fld$(x&),l_su$)                !Ja, hier bei x&.
        l_hi&=x&                                !Pointer setzen.
      ENDIF
    NEXT x&
    ' -------------------------------------------------------------------------
  ELSE                                          !Nach Nummer suchen:
    PRINT AT(15,5);"Bitte gesuchte Lieferanten-Nummer eingeben:"'
    FORM INPUT (3),nr$
    l_su&=VAL(nr$)
    IF l_su&>0 AND l_su&<=l%                    !Kein Mist eingegeben.
      IF l_su&<10                               !Auf 3 Stellen formatieren.
        nr$="00"+STR$(l_su&)
      ELSE IF l_su&<100
        nr$="0"+STR$(l_su&)
      ELSE IF l_su&<1000
        nr$=STR$(l_su&)
      ENDIF
      FOR x&=1 TO l%                            !Lieferant schon da?
        IF INSTR(l_fld$(x&),nr$)                !Ja, hier bei x&.
          l_hi&=x&                              !Pointer setzen.
        ENDIF
      NEXT x&
    ENDIF
  ENDIF
  ' ---------------------------------------------------------------------------
  IF l_hi&>0                                    !Wenn Lieferant gefunden,
    PRINT AT(15,4);"Der Lieferant ist gespeichert als:";
    PRINT AT(15,5);leer$;
    PRINT AT(15,5);l_fld$(l_hi&);               !zeig ihn.
    dum!=FALSE                                  !
  ELSE                                          !Wenn nicht,
    @bing                                       !ab dafür!
    ALERT 1,"|Diesen Lieferanten |kenne ich nicht! ",1,ok$,dum!
    @sauber
  ENDIF
  l_name!=FALSE
RETURN
PROCEDURE l_aendern
  LOCAL a$,aa$,l_hi&,lang|,rand|,x&,xx&,y&,z&
  ' ---------------------------------------------------------------------------
  l_hi&=0
  @kasten(176,32,"Lieferanten ändern")
  @l_finden
  IF dum!=FALSE
    l_aendern_nochmal:
    l_n$=LEFT$(l_fld$(l_hi&),3)
    @bing
    ALERT 2,"|Diesen Lieferanten ändern?",2,j_n$,but|
    IF but|=1
      PRINT AT(15,6);"Bitte neuen Lieferanten-Namen eingeben";
      LOCATE 15,7
      FORM INPUT (35),l$
      @blanks_weg_u_upper(l$)
      IF dum!
        GOTO l_aendern_nochmal
      ENDIF
      t$="|Den gespeicherten Lieferanten|korrigieren oder gegen einen|"
      t$=t$+"NEUEN Lieferanten austauschen?"
      @bing
      ALERT 2,t$,2," NEUER! |Der Alte",but|
      l_fld$(l_hi&)=l_n$+l$                       !NEUEN Lieferer Speichern.
      @kasten_sauber(6,7,6)
      IF but|=2                                   !Der Alte!
        PRINT "Der alte Lieferant hei×t korrigiert:";
        PRINT AT(15,7);l_fld$(l_hi&);
      ELSE
        PRINT "Der neue Lieferant hei×t:";
        PRINT AT(15,7);l_fld$(l_hi&);
        IF a_ok!                                  !Neuer!
          PRINT AT(15,8);"Bewirkte Artikel-Änderung:";
          LOCATE 1,13
          xx&=0                                   !Zähler auf NULL
          FOR y&=1 TO a_neu%                      !Sieh bei allen Art. nach:
            a$=a_fld$(y&)                         !A$= zu prüfender Artikel.
            lang|=LEN(a$)                         !So lang ist der String.
            FOR x&=lang| DOWNTO 1                 !Suche Anfang der Codes:
              aa$=MID$(a$,x&,1)                   !aa$ = Prüfstelle im String
              IF INSTR(abc$,aa$)                  !Ist aa$ ein Buchstabe?
                rand|=x&+1                        !Dann -> Lieferanten-Codes.
                EXIT IF x&>1                      !Also Suche abbrechen
              ENDIF
            NEXT x&
            IF x&>0                               !Wenn ein Artikel existiert
              FOR z&=rand| TO lang| STEP 3
                IF MID$(a$,z&,3)=l_n$
                  INC xx&
                  IF xx&>12                       !Seite voll?
                    LOCATE 1,13                   !Dann oben
                    PRINT CHR$(27)+"M";           !den ersten löschen
                    LOCATE 1,24                   !+ unten weitermachen.
                  ENDIF
                  a$=LEFT$(a$,z&-1)+RIGHT$(a$,lang|-(z&+2))
                  PRINT "->"'a$                   !Zeig den Geänderten.
                  a_fld$(y&)=a$                   !Nimm neuen Artikel-String
                  PAUSE 25                        !Sonst alles zu schnell weg.
                ENDIF
              NEXT z&
            ENDIF
          NEXT y&
          IF xx&=0
            PRINT AT(15,8);leer$;
            PRINT AT(15,8);"Keine Artikel-Änderung!";
          ELSE
            @info("Ich sortiere ",a_dat$)
            QSORT a_fld$()
            @info("  Ich ändere ",a_dat$)
            @dat_store(a_ok!,v%,a_dat$,a_fld$())
          ENDIF
          a_ok!=TRUE
        ENDIF
      ENDIF
      @info("  Ich ändere ",l_dat$)
      v%=-1
      @dat_store(l_ok!,v%,l_dat$,l_fld$())
    ELSE
      @sauber
    ENDIF
  ELSE
    @sauber
  ENDIF
RETURN
PROCEDURE l_menu_off
  l%=0
  l_neu%=0
  l_ok!=FALSE
  MENU 26,2                                     !1 Lieferant ändern         OFF
  MENU 27,2                                     !Lieferant für Artikel raus OFF
  MENU 36,2                                     !Alle Lieferanten (1-x)     OFF
  MENU 37,2                                     !Alle Lieferanten (x-1)     OFF
  MENU 38,2                                     !Alle Lieferanten (A-Z)     OFF
  MENU 39,2                                     !Alle Lieferanten (Z-A)     OFF
  MENU 41,2                                     !  1  Lieferant  ( Nr.)     OFF
  MENU 42,2                                     !  1  Lieferant  (Name)     OFF
RETURN
PROCEDURE l_menu_on
  MENU 26,3                                     !1 Lieferant ändern         ON
  MENU 27,3                                     !Lieferant für Artikel raus ON
  MENU 36,3                                     !Alle Lieferanten (1-x)     ON
  MENU 37,3                                     !Alle Lieferanten (x-1)     ON
  MENU 38,3                                     !Alle Lieferanten (A-Z)     ON
  MENU 39,3                                     !Alle Lieferanten (Z-A)     ON
  MENU 41,3                                     !  1  Lieferant  ( Nr.)     ON
  MENU 42,3                                     !  1  Lieferant  (Name)     ON
RETURN
PROCEDURE l_speichern
  LOCAL l_da&,l_hi&
  ' ---------------------------------------------------------------------------
  IF l_neu%=l_max% AND a_neu%=a_max%            !Alles voll?
    MENU 20,2                                   !"Lieferant + Artikel" OFF
    GOTO l_speichern_ende                       !+ ab dafür.
    ' -------------------------------------------------------------------------
  ELSE IF l_neu=l_max%                          !Lieferanten-Datei voll?
    MENU 21,2                                   !"Nur Lieferanten" OFF
    ' -------------------------------------------------------------------------
  ELSE IF l_neu%=l%                             !Kein neuer hinzugekommen?
    PRINT AT(15,7);"Keine Lieferanten dazugekommen.";!@@@ Sag es
    GOTO l_speichern_ende                       !+ ab dafür.
  ENDIF
  ' ---------------------------------------------------------------------------
  IF l_neu%>l%                                  !Es sind Neue Lieferer da!
    PRINT AT(15,8);"Ich sortiere"'l_neu%'"Lieferanten.";
    ERASE l_fld$()                              !Vorhandenes Feld löschen
    DIM l_fld$(l_neu%)                          !+ Feld für alles bauen.
    IF EXIST(l_dat$)                            !Falls schon welche da waren,
      @info("    Ich lese ",l_dat$)
      @dat_recall(l_ok!,l_dat$,l_fld$())
    ENDIF
    FOR x%=l%+1 TO l_neu%                       !Alte + Neue sortieren:
      IF l_hi&=0
        l_hi&=1
      ELSE
        l_hi&=INSTR(l_hi&+1,neu$,"|")+1
      ENDIF
      l_da&=INSTR(l_hi&+1,neu$,"|")             !neu$-Pointer2 (lda&) setzen.
      l_fld$(x%)=MID$(neu$,l_hi&,l_da&-l_hi&)   !Dies ist ein neuer Feld-Teil.
    NEXT x%
    QSORT l_fld$() OFFSET 3                     !Sortieren (ohne Nummer)!
    @info("  Ich ändere ",l_dat$)
    @dat_store(l_ok!,v%,l_dat$,l_fld$())
    PRINT AT(15,4);"Anzahl gespeichert:"'l_neu%;!Zeige, wieviel da sind.
    PRINT AT(15,8);leer$;
  ENDIF
  l_speichern_ende:                             !Ab dafür? Hier hin.
  l%=l_neu%                                     !Gleiche Werte einstellen.
RETURN
PROCEDURE l_u_a_eingeben
  LOCAL l$,l_da!,l_da&,neu$,x&
  ' ---------------------------------------------------------------------------
  neu$=""                                       !Alles zurücksetzen.
  l$=""
  l_neu%=l%
  ' ---------------------------------------------------------------------------
  l_u_a_eingeben_nochmal:
  @kasten(168,32,"Lieferanten-Eingabe")
  PRINT AT(15,4);"Anzahl gespeichert:"'l_neu%;  !Zeige, wieviel da sind.
  l_ok!=TRUE                                    !Auf jeden Fall!
  @kasten_sauber(5,9,5)
  @bing
  ALERT 0,funk$,2,j_n$,but|                     !Abbrechen?
  IF but|=1
    GOTO l_u_a_eingeben_ende
  ENDIF
  IF l%=l_max%                                  !Max. Lieferer-Zahl erreicht:
    @bing
    MENU 21,2                                   !"Nur Lieferant" inaktivieren
    IF nur_l!                                   !Nur Lieferanten-Eingabe?
      GOTO l_voll                               !Ab dafür!
    ENDIF
  ENDIF
  ' ---------------------------------------------------------------------------
  PRINT AT(15,4);leer$
  IF l%=l_max%                                  !Max.-Zahl Lieferanten da?
    PRINT AT(15,4);"Gesuchten Lieferant eingeben:"'; !@@@ Info-Meldung
  ELSE IF l%<l_max%                             !Sonst normal fragen:
    PRINT AT(15,4);"Lieferant eingeben:"';      !@@@ Info-Meldung
  ENDIF
  LOCATE 15,5
  FORM INPUT (35),l$                            !Max. Länge evtl. in Variable.
  @blanks_weg_u_upper(l$)
  IF dum!
    GOTO l_u_a_eingeben_nochmal                 !Nochmal versuchen.
  ENDIF
  ' -------------------------------------------------------------------------
  l_da!=FALSE                                   !Flag erstmal zurückstellen."
  l_da&=0                                       !Pointer dito.
  IF l%>0                                       !Wenn ldat$ existiert:
    FOR x&=l% DOWNTO 1                          !Prüfe, ob schon vorhanden:
      IF INSTR(l_fld$(x&),l$)                   !Jawoll!
        l_da!=TRUE                              !Flag setzen."
        l_da&=x&                                !Merke, welcher.
      ENDIF
    NEXT x&
  ENDIF
  ' ---------------------------------------------------------------------------
  IF l_da!                                      !Wenn Lieferant auf Diskette:
    @bing
    PRINT AT(15,6);"Der ist schon gespeichert als:";!Ist schon auf Diskette.
    PRINT AT(15,7);l_fld$(l_da&);               !Zeige Nr. + Lieferant.
    l$=l_fld$(l_da&)                            !Nimm ihn auseinander: Name
    l_n$=LEFT$(l_fld$(l_da&),3)                 !+ Nummer merken.
    ' -------------------------------------------------------------------------
  ELSE IF INSTR(neu$,l$)                        !Er ist bei den Neuen.
    @bing
    l_da!=TRUE                                  !Flag setzen."
    PRINT AT(15,6);"Der ist schon gespeichert als:";!Ist schon im neu$-String.
    l_da&=INSTR(neu$,"|")                       !lda&=neu$-Pointer
    PRINT AT(15,7);MID$(neu$,INSTR(neu$,l$)-3,l_da&-1);!Zeige Nr. + Lieferant.
    l$=MID$(neu$,INSTR(neu$,l$)-3,l_da&-1)
    l_n$=LEFT$(MID$(neu$,INSTR(neu$,l$)-3,l_da&-1),3)
  ENDIF
  l_da&=0                                       !Pointer mu× zurück auf NULL!
  ' ---------------------------------------------------------------------------
  IF l_da!                                      !Wenn vorhanden: Behalten?
    @bing
    ALERT 2,"So übernehmen?",1,j_n$,but|
    IF but|=2                                   !Nein, also
      GOTO l_u_a_eingeben_nochmal               !nochmal neu eingeben.
    ENDIF                                       !Behalten, also weiter.
    ' -------------------------------------------------------------------------
  ELSE                                          !Wenn es ein Neuer ist,
    PRINT AT(15,7);l$;                          !zeige ihn + mach
    @bing
    ALERT 2,"Der Lieferant ist neu! |So übernehmen?",1,j_n$,but|
    IF but|=2                                   !Nicht übernehmen,
      GOTO l_u_a_eingeben_nochmal               !also nochmal von vorn.
    ENDIF                                       !Übernehmen, also
    IF l_neu%<l_max%
      INC l_neu%                                !Lief.-Nr. erhöhen.
    ENDIF
    IF l_neu%=1                                 !Der erste Lieferant?
      @l_menu_on                                !Menu ON.
    ENDIF
    IF l_neu%<10                                !Auf 3 Stellen formatieren.
      l_n$="00"+STR$(l_neu%)
    ELSE IF l_neu%<100
      l_n$="0"+STR$(l_neu%)
    ELSE IF l_neu%<=l_max%
      l_n$=STR$(l_neu%)
    ELSE IF l_neu%>l_max%                       !Liefereranzahl > als erlaubt?
      l_voll:
      t$="Mehr als "+STR$(l_max%)+"|Lieferanten gibt's|momentan nicht!"
      @bing
      ALERT 3,t$,1,ok$,dum!
      GOTO l_u_a_eingeben_ende
    ENDIF
    l$=l_n$+l$
    PRINT AT(15,7);l$;                          !+ zeigen, dann
    l$=l$+"|"                                   !zusammenfügen mit Trennstrich
    neu$=neu$+l$                                !+ in neu$-String nehmen.
  ENDIF
  ' ---------------------------------------------------------------------------
  nur_a_eingeben:                               !Wenn max. Lieferer-Zahl!
  IF nur_l!=FALSE                               !Läuft die Pulldown-Routine:
    @a_eingeben(l$)                             !"Lieferant + Artikel"?
  ENDIF                                         !sonst nur
  GOTO l_u_a_eingeben_nochmal
  l_u_a_eingeben_ende:
  @l_speichern                                  !alle Lieferanten speichern.
  nur_l!=FALSE                                  !Flag auf jeden Fall zurück.
RETURN
PROCEDURE laden
  IF EXIST(l_dat$)                              !Wenn schon Lieferanten da:
    DIM l_fld$(l_max%)                          !Baue das Maximal-Feld für sie,
    @info("    Ich lese ",l_dat$)
    @dat_recall(l_ok!,l_dat$,l_fld$())
    l%=n                                        !Stelle die Anzahl der Lieferer
    l_neu%=l%                                   !+ den Zähler für Neue ein.
    ERASE l_fld$()                              !+ wieder weg mit dem Feld.
    DIM l_fld$(l%)                              !Bau es neu in richtiger Grö×e:
    @info("    Ich lade ",l_dat$)
    @dat_recall(l_ok!,l_dat$,l_fld$())
    @l_menu_on
    ' -------------------------------------------------------------------------
  ELSE                                          !Wenn keine da sind:
    @bing
    ALERT 3,"|Ich finde keine|"+l_dat$+"!",1,ok$,dum!
    @l_menu_off                                 !Mach das entspr. Menu OFF.
  ENDIF
  ' ---------------------------------------------------------------------------
  IF EXIST(a_dat$)                              !Wenn schon Artikel da sind:
    DIM a_fld$(a_max%)
    @info("    Ich lese ",a_dat$)
    @dat_recall(a_ok!,a_dat$,a_fld$())
    a%=n                                        !Stelle die Anzahl der Artikel
    a_neu%=a%                                   !+ den Zähler für Neue ein.
    ERASE a_fld$()                              !Weg mit dem zu gro×en Feld.
    DIM a_fld$(a%)                              !Bau es neu in richtiger Grö×e:
    @info("    Ich lade ",a_dat$)
    @dat_recall(a_ok!,a_dat$,a_fld$())
    @a_menu_on                                  !Artikel-Menus ON
    ' -------------------------------------------------------------------------
  ELSE                                          !Wenn keine da sind:
    @bing
    ALERT 3,"|Ich finde keine |"+a_dat$+"!",1,ok$,dum!
    @a_menu_off                                 !Mach das entspr. Menu OFF.
  ENDIF
  ' ---------------------------------------------------------------------------
  IF l_neu%=l_max% AND a_neu%=a_max%            !Alles voll?
    MENU 20,2                                   !"Lieferant + Artikel" OFF
    MENU 21,2                                   !"Nur Lieferant"       OFF
  ELSE IF l_neu%=l_max%
    MENU 21,2                                   !"Nur Lieferant"       OFF
  ENDIF
RETURN
PROCEDURE listing(tab&,daten$,VAR neu%,max%,feld$())
  LOCAL a|,x&,y&,z&
  ' ---------------------------------------------------------------------------
  @info_weg
  @sauber
  HIDEM                                         !Weg mit der Maus!
  DEFTEXT 1,0,0,6                               !Schmale Schrift einstellen.
  a|=0                                          !Tastenpointer (a|) NULL
  PRINT AT(tab&,2);daten$+" gespeichert:"'neu%  !Info-Meldung: Soviele!
  PRINT
  IF neu%<40
    FOR x&=1 TO neu%
      @breite_richtig(x&,feld$())
    NEXT x&
    GOTO alle_zeigen_ende
  ELSE
    FOR x&=1 TO 40                              !Zeig die ersten 40.
      @breite_richtig(x&,feld$())
    NEXT x&
    @info_zeigen
    REPEAT
      alle_zeigen_nochmal:
      t$=INKEY$                                 !Warte auf Tastendruck
      a|=ASC(t$) OR CVI(t$)                     !Umformen für SELECT
      SELECT a|
      CASE 72                                   !<PFEIL RAUF> gedrückt:
        IF neu%<=40                             !Sind wir schon beim letzten?
          GOTO alle_zeigen_ende
        ELSE IF neu%<=max%
          IF x&>neu%
            y&=neu%
          ELSE
            y&=x&
          ENDIF
        ENDIF
        IF x&<=1
          GOTO alle_zeigen_ende                 !Ja, ab dafür!
        ELSE IF x&-40<1                         !Sind wir schon beim letzten?
          y&=41
        ENDIF
        PRINT
        FOR x&=y& DOWNTO y&-40                  !Rückwärts zeigen
          @breite_richtig(x&,feld$())
        NEXT x&
        @info_zeigen
        IF y&<=0
          y&=1
        ENDIF
        GOTO alle_zeigen_nochmal
      CASE 27                                   !<ESC> gedrückt:
        GOTO alle_zeigen_ende
      CASE 80                                   !<PFEIL RUNTER> gedrückt:
        IF x&>=neu%                             !Sind wir schon beim letzten?
          GOTO alle_zeigen_ende
        ENDIF
        IF neu%<=40                             !Sind wir bei den ersten 40?
          y&=1
        ENDIF
        IF x&=0
          x&=1
        ENDIF
        IF x&+40>neu% OR y&+40>neu%
          y&=neu%-40
        ELSE
          y&=x&
        ENDIF
        PRINT
        FOR x&=y& TO y&+40
          @breite_richtig(x&,feld$())
        NEXT x&
        @info_zeigen
        GOTO alle_zeigen_nochmal
      ENDSELECT
    UNTIL a|=27 OR x&=neu%
  ENDIF
  alle_zeigen_ende:
  IF neu%>40
    PRINT AT(1,2);SPACE$(80);
  ENDIF
  PRINT AT(1,46);SPACE$(80);
  DEFMOUSE 0
  SHOWM
  DEFTEXT 1,0,0,13                              !Normale Schrift einstellen.
RETURN
PROCEDURE loeschen
  LOCAL name$                                   !name$ = Gewünschte Datei
  DEFTEXT 1,9,0,32                              !Dicke, fette Warnschrift ON
  @bing
  @sauber
  PRINT AT(8,1);"Löschen von der Diskette !"    !@@@ Warnung! Warnung!
  DEFTEXT 1,0,0,13                              !Wieder normale Schrift.
  DEFMOUSE 2                                    !Flei×ig...
  loeschen_nochmal:
  FILESELECT "A:\*.*","",name$                  !Wünsch Dir was...
  ' ---------------------------------------------------------------------------
  IF name$="" OR RIGHT$(name$)="\"              !Nix gewünscht?
    @bing
    ALERT 0,funk$,1,j_n$,but|                   !Abbrechen?
    IF but|=1 AND unbedingt_loeschen!           !Du mu×t aber was löschen!
      @bing
      ALERT 1,"Es mu× aber etwas|gelöscht werden!",1,ok$,dum!
      GOTO loeschen_nochmal                     !Also nochmal.
    ELSE IF but|=2
      GOTO loeschen_nochmal                     !Egal, nochmal.
    ENDIF
    ' -------------------------------------------------------------------------
  ELSE IF EXIST(name$)                          !Aha! Es wurde was gewünscht:
    name$=RIGHT$(name$,(LEN(name$)-INSTR(name$,"\")))   !Was denn?
    IF name$=l_dat$ OR name$=a_dat$ OR name$=p$ !Eine der Programm-Dateien!
      @bing
      ALERT 3,"Diese Datei darf nicht|gelöscht werden!",1,ok$,dum!
    ELSE                                        !Eine erlaubte Datei.
      @bing                             !1. Sicherheits-Abfrage
      ALERT 2,"|Wollen Sie |"+name$+"|wirklich löschen?",2,j_n$,but|
      IF but|=1                                 !2. Sicherheits-Abfrage
        t$="|Sind Sie ganz sicher,da× Sie |"+name$
        t$=t$+"|wirklich löschen wollen?"
        @bing
        ALERT 3,t$,2,j_n$,but|
        IF but|=1                               !Nu reicht's!
          DEFMOUSE 2                            !Flei×ig...
          KILL name$                            !Rien ne va plus!
        ELSE IF unbedingt_loeschen!             !Oder: Fragen befolgt, aber es
          GOTO loeschen_nochmal                 !mu×te was gelöscht werden
        ENDIF
      ELSE IF unbedingt_loeschen!               !wegen zu kleinem DISK-Speicher
        GOTO loeschen_nochmal                   !Ab nach oben + löschen!
      ENDIF
    ENDIF
    ' -------------------------------------------------------------------------
  ELSE                                          !Da wünscht sich einer Quatsch!
    @bing
    ALERT 1,"|Dieses File kann ich|nicht löschen!",1,ok$,dum!
    IF unbedingt_loeschen!                      !Auch der mu× was löschen!
      GOTO loeschen_nochmal                     !Ab nach oben!
    ENDIF
  ENDIF                                         !Sonst:
  @sauber
  DEFMOUSE 0                                    !Fertig.
RETURN
PROCEDURE menuauswertung
  ' Es empfiehlt sich beim Programmieren ohne ein RCS, die Menu-Titel in diesem
  ' Procedure in einer lückenlosen Reihenfolge zu benennen. Nach Fertigstellung
  ' des Programms können die Zeilen mit DELETE-Marke (@@@) gelöscht werden.
  ' ---------------------------------------------------------------------------
  MENU OFF                                      !Menu totstellen
  m|=MENU(0)                                    !Werte zuweisen
  IF hilfe!=TRUE ! AND m|<>47
    @hilfe
  ENDIF
  SELECT m|                                     !+ befolgen:
  CASE 0                                        !@@@ Menu-Anfang DESK
    ' Menu-Anfang DESK--------------------------
  CASE 1                                        !ARTIKEL_-Programm-Info
    @a_info
  CASE 2                                        !@@@ Default-Trennstrich
    ' ------------------------------------------
  CASE 3 TO 8                                   !@@@ Accessories
    ' ------------------------------------------
  CASE 9                                        !@@@ Menu-Ende DESK
    ' Menu-Ende DESK----------------------------
  CASE 10                                       !@@@ Menu-Anfang DATEI
    ' Menu-Anfang DATEI-------------------------
  CASE 11                                       !Laden
    ' laden
  CASE 12                                       !Speichern
    ' @dat_store("text",ok!,vol%,dat$,feld$())
  CASE 13                                       !- verify
    ' -pruefe
  CASE 14                                       !@@@ Trennstrich
    ' ------------------------------------------
  CASE 15                                       !löschen
    @loeschen
  CASE 16                                       !@@@ Trennstrich
    ' ------------------------------------------
  CASE 17                                       !Ende (des Programms)
    @ende
  CASE 18                                       !@@@ Menu-Ende DATEI
    ' Menu-Ende DATEI---------------------------
  CASE 19                                       !@@@ Menu-Anfang EINGABE
    ' Menu-Anfang EINGABE-----------------------
  CASE 20                                       !Lieferant + Artikel
    nur_l!=FALSE
    @l_u_a_eingeben
  CASE 21                                       !Nur die Lieferanten
    nur_l!=TRUE
    @l_u_a_eingeben
  CASE 22                                       !@@@ Trennstrich
    ' ------------------------------------------
  CASE 23                                       !1 Artikel ändern
    @kasten(208,32,"Artikel ändern")
    @a_aendern
  CASE 24                                       !1 Artikel raus
    @kasten(224,32,"Artikel raus")
    @a_raus
  CASE 25                                       !@@@ Trennstrich
    ' ------------------------------------------
  CASE 26                                       !1 Lieferanten ändern
    finde_l_name!=FALSE
    @l_aendern
  CASE 27                                       !Lieferant für Artikel raus
    l_fuer_a_raus!=TRUE
    @a_zeigen
  CASE 28                                       !@@@ Menu-Ende EINGABE
    ' Menu-Ende EINGABE-------------------------
  CASE 29                                       !@@@ Menu-Anfang AUSGABE
    ' Menu-Anfang AUSGABE-----------------------
  CASE 30                                       !Alle Artikel (A-Z)
    @info("Ich sortiere ",a_dat$)
    QSORT a_fld$(+)
    @listing(1,"Artikel",a_neu%,a_max%,a_fld$())
  CASE 31                                       !Alle Artikel (Z-A)
    @info("Ich sortiere ",a_dat$)
    QSORT a_fld$(-)
    @listing(1,"Artikel",a_neu%,a_max%,a_fld$())
  CASE 32                                       !Div. Artikel (von-bis)
    @info("Ich sortiere ",a_dat$)
    QSORT a_fld$(+)
    @a_von_bis_zeigen
  CASE 33                                       !@@@ Trennstrich
    ' ------------------------------------------
  CASE 34                                       ! 1   Artikel
    l_fuer_a_raus!=FALSE
    @a_zeigen
  CASE 35                                       !@@@ Trennstrich
    ' ------------------------------------------
  CASE 36                                       !Alle Lieferanten (1-x)
    @info("Ich sortiere ",l_dat$)
    QSORT l_fld$(+)
    @listing(22,"Lieferanten",l_neu%,l_max%,l_fld$())
  CASE 37                                       !Alle Lieferanten (x-1)
    @info("Ich sortiere ",l_dat$)
    QSORT l_fld$(-)
    @listing(22,"Lieferanten",l_neu%,l_max%,l_fld$())
  CASE 38                                       !Alle Lieferanten (A-Z)
    @info("Ich sortiere ",l_dat$)
    QSORT l_fld$(+) OFFSET 3
    @listing(22,"Lieferanten",l_neu%,l_max%,l_fld$())
  CASE 39                                       !Alle Lieferanten (Z-A)
    @info("Ich sortiere ",l_dat$)
    QSORT l_fld$(-) OFFSET 3
    @listing(22,"Lieferanten",l_neu%,l_max%,l_fld$())
  CASE 40                                       !@@@ Trennstrich
    ' ------------------------------------------
  CASE 41                                       ! 1   Lieferant (Nr.)
    finde_l_name!=FALSE
    @kasten(104,32,"Lieferant (nach Nr.) zeigen")
    @l_finden
  CASE 42                                       ! 1   Lieferant (Name)
    finde_l_name!=TRUE
    @kasten(192,32,"Lieferant finden")
    @l_finden
  CASE 43                                       !@@@ Trennstrich
    ' ------------------------------------------
  CASE 44                                       !Ausdruck
    @ausdruck
  CASE 45                                       !@@@ Menu-Ende AUSGABE
    ' Menu-Ende AUSGABE-------------------------
  CASE 46                                       !@@@ Menu-Anfang SERVICE
    ' Menu-Anfang SERVICE-----------------------
  CASE 47                                       !Hilfe
    IF hilfe!=FALSE
      hilfe!=TRUE
      MENU 47,1                                 !Häkchen setzen
    ELSE
      hilfe!=FALSE
      MENU 47,0                                 !Menu sauber
      MENU 47,3                                 !Menu wählbar
    ENDIF
  CASE 48                                       !Datum
    datum_menu!=TRUE
    @datum
  CASE 49                                       !Speicherplatz zeigen
    @speicher
  CASE 50                                       !Dump zeigen
    @dump
  CASE 51                                       !Alarm (AN/AUS)
    IF bing_on!=FALSE
      bing_on!=TRUE
      MENU 51,0                                 !"Alarm" CLEAN
      MENU 51,3                                 !"Alarm" ON
    ELSE
      bing_on!=FALSE
      MENU 51,1                                 !"Alarm" ON mit Häkchen
    ENDIF
  CASE 52                                       !Bildschirm sauber
    @sauber
  ENDSELECT
RETURN
PROCEDURE sauber
  CLS
RETURN
PROCEDURE speicher
  DEFMOUSE 2                                    !Flei×ig...
  t$="Freier Speicher| |auf Diskette: "+STR$(DFREE(1))+" Bytes "
  t$=t$+"|RAM-Speicher: "+STR$(FRE())+" Bytes "
  @bing
  DEFMOUSE 0                                    !Fertig.
  @bing
  ALERT 1,t$,1,ok$,dum!
RETURN
PROCEDURE von_bis_feld_bauen(VAR neu%,fld$())
  zl%=0                                         !Zähler auf NULL
  DEFMOUSE 2                                    !Flei×ig...
  ERASE von_bis_fld$()                          !Sicher ist sicher!
  FOR x&=1 TO neu%                              !Such alle durch:
    IF neu%=a_neu%                              !bei Artikeln den 1. Buchstaben
      IF LEFT$(fld$(x&))>=von$ AND LEFT$(fld$(x&))<=bis$  !raus +
        INC zl%                                 !zähl mit, wie viele es sind.
      ENDIF
    ELSE IF neu%=l_neu%                         !bei Lieferern den 3. Buchst.
      IF MID$(fld$(x&),4)>=von$ AND MID$(fld$(x&),4)<=bis$
        INC zl%                                 !zähl mit, wie viele es sind.
      ENDIF
    ENDIF
  NEXT x&
  IF zl%>0
    DIM von_bis_fld$(zl%)                       !Bau ein Feld für diese Art:
    zl%=1
    FOR x&=1 TO neu%
      IF neu%=a_neu%                            !nämlich ein Artikel-Feld;
        IF LEFT$(fld$(x&))>=von$ AND LEFT$(fld$(x&))<=bis$  !raus
          von_bis_fld$(zl%)=fld$(x&)
          INC zl%
        ENDIF
      ELSE IF neu%=l_neu%                       !oder ein Lieferanten-Feld.
        IF MID$(fld$(x&),4)>=von$ AND MID$(fld$(x&),4)<=bis$
          von_bis_fld$(zl%)=fld$(x&)
          INC zl%
        ENDIF
      ENDIF
    NEXT x&
  ENDIF
RETURN
PROCEDURE von_bis_fragen(was$,was_tun$,VAR neu%)
  PRINT AT(15,4);was$+" gespeichert:   ";neu%;  !Info-Zeile
  nochmal_von:
  PRINT AT(15,6);leer$
  PRINT AT(15,6);"Bitte "+was_tun$+" von... ";
  FORM INPUT (1),von$
  von$=UPPER$(von$)
  IF von$<CHR$(65) OR von$>CHR$(90)             !Nur Buchstaben gelten!
    GOTO nochmal_von
  ENDIF
  nochmal_bis:
  PRINT AT(15,7);leer$
  PRINT AT(28,7);"bis... ";
  FORM INPUT (1),bis$
  bis$=UPPER$(bis$)
  IF bis$<CHR$(65) OR bis$>CHR$(90)             !Nur Buchstaben gelten!
    GOTO nochmal_bis
  ELSE IF bis$<von$                             !bis$ mu× grö×er sein als von$
    t$="Der erste Buchstabe|soll kleiner sein als|der zweite Buchstabe!"
    ALERT 1,t$,1,ok$,dum!
    GOTO nochmal_von
  ENDIF
RETURN
' -----------------------------------------------------------------------------
' Pulldown-Menu-Datei
' -----------------------------------------------------------------------------
' 1. Menu-Titel (DESK)
DATA     ,  Programm-Info,--------------------
DATA acc1,acc2,acc3,acc4,acc5,acc6,
' 2. Menu-Titel (DATEI)
DATA Datei,-Laden,-Speichern,-Prüfen,-----------, Löschen,-----------, Ende,
' 3. Menu-Titel (EINGABE)
DATA Eingabe, Lieferanten + Artikel , Nur die Lieferanten
DATA ----------------------------, 1 Artikel ändern, 1 Artikel raus
DATA ----------------------------, 1 Lieferant ändern
DATA  Lieferant für Artikel raus,
' 4. Menu-Titel (AUSGABE)
DATA Ausgabe, Alle Artikel ( A - Z ), Alle Artikel ( Z - A )
DATA  Div. Artikel (von-bis),------------------------,   1  Artikel
DATA ------------------------, Alle Lieferanten (1-x), Alle Lieferanten (x-1)
DATA  Alle Lieferanten (A-Z), Alle Lieferanten (Z-A),------------------------
DATA    1  Lieferant  ( Nr.),   1  Lieferant  (Name),------------------------
DATA  Ausdruck,
' 5. Menu-Titel (SERVICE)
DATA Service ,  Hilfe,  Datum,  Speicher,  Zeige DUMP,  Alarm AUS
DATA   Anzeige weg ,Datei_Ende
