' example of  for/next loop with nested goto's in and out of loop
' in GFA Basic using the structured conditional While
'
True=-1
False=0
'
' the loop's continuation depends on these two GLOBAL variables
Maybe_exit=True
Something=False
'
' loop continues While Working (=TRUE), Working affected by above two vars
Working=True
' Cnt% will substitute in place of a FOR Cnt% = x1 To x2  var
Cnt%=0
'
While Working
  Inc Cnt%
  Print "Working.. Cnt% = ";Cnt%
  If Maybe_exit Then
    @Check_exit
  Endif
  ' perhaps code after the check would not be appropriate to execute if the
  ' working condition were not true, so check Working at this time
  If Working Then
    ' code...
    If Cnt%>=100 Then
      Working=False
    Endif
  Endif
Wend
'
' code...
'
End
'
'
Procedure Check_exit
  If Something Then
    Working=False
  Endif
Return
