GOSUB initialize
FILESELECT "d:\data\pictures\*.tny","",file$
GOSUB tiny_load(file$,canvas$)
SPUT canvas$
a=INP(2)
GOSUB done
REM ***** The code
> PROCEDURE tiny_load(path$,VAR screen$)
  DEFMOUSE 2
  screen$=SPACE$(32000)
  OPEN "I",#1,path$
  picres=INP(#1)+1
  IF picres>3             ! color rotation
    RELSEEK #1,4          ! just ignore it
    SUB picres,3
  ENDIF
  palette$=INPUT$(32,#1)
  @set_palette(V:palette$)
  num_cb=CVI(INPUT$(2,#1))
  num_dw=CVI(INPUT$(2,#1))
  ERASE cb|(),dw&(),screen&()
  DIM cb|(num_cb+1)               !reserve some space
  DIM dw&(num_dw+1)               !+1 for option base 0...
  DIM screen&(16001)
  BGET #1,V:cb|(1),num_cb
  BGET #1,V:dw&(1),num_dw*2
  CLOSE #1
  c_counter=1
  d_counter=1
  s_counter=1
  fc=100/num_cb
  REPEAT
    '    PRINT AT(1,1);ROUND(prc#);"%   "          !percent done
    x=cb|(c_counter)
    IF x>128
      x=x-256
    ENDIF
    IF x<0
      BMOVE V:dw&(d_counter),V:screen&(s_counter),2*x*(-1)  !take -x from data
      SHOWM
      INC c_counter               ! took 1 control byte
      ADD d_counter,-1*x          ! took -x data words
      ADD s_counter,-1*x          ! -x 'unique words'
      ADD prc#,fc
    ELSE IF x>1
      FOR c=0 TO x-1              ! loop to repeat data word
        screen&(s_counter+c)=dw&(d_counter)
      NEXT c
      INC c_counter               ! took one control byte
      INC d_counter               ! repeated one data word
      ADD s_counter,x             ! repeated x times
      ADD prc#,fc
    ELSE IF x=0
      rp=CVI(CHR$(cb|(c_counter+1))+CHR$(cb|(c_counter+2))) !repeat rp times
      FOR c=0 TO rp-1             ! loop to repeat data word
        screen&(s_counter+c)=dw&(d_counter)
      NEXT c
      ADD c_counter,3             ! x=0, plus one word
      INC d_counter               ! repeated 1 data word
      ADD s_counter,rp            ! repeated rp times
      ADD prc#,fc*3
    ELSE IF x=1
      un=CVI(CHR$(cb|(c_counter+1))+CHR$(cb|(c_counter+2))) ! get unique
      BMOVE V:dw&(d_counter),V:screen&(s_counter),2*un  !take -x from data
      SHOWM
      REM ** a sequence of BMOVES if greater than 32000?
      ADD c_counter,3             ! x=0, plus one word
      ADD d_counter,un            ! used un times
      ADD s_counter,un            ! used un times
      ADD prc#,fc*3
    ENDIF
  UNTIL c_counter>num_cb
  REM *** now sort this junk
  oc=0
  counter=0
  occ=0
  column_c=0
  adr=V:screen$
  FOR i=1 TO 16000
    WORD{adr+counter}=screen&(i)
    ADD counter,160
    IF i/200=INT(i/200)
      ADD column_c,4
      counter=column_c*2
      '      PRINT AT(1,1);ROUND(i/16000,2)*100;"%     "      !percent done
    ENDIF
    IF i/4000=INT(i/4000)
      ADD oc,2
      INC occ
      counter=oc
      column_c=occ
    ENDIF
  NEXT i
  DEFMOUSE 0
RETURN
REM ***** end of code
> PROCEDURE initialize
  DEFINT "a-z"
  DEFFLT "f"
  @get_palette(orig_palette$)
RETURN
> PROCEDURE done
  set_palette(V:orig_palette$)
RETURN
> PROCEDURE get_palette(VAR palette$)
  palette$=""
  FOR i=0 TO 15
    palette$=palette$+MKI$(XBIOS(7,i,-1))
  NEXT i
RETURN
> PROCEDURE set_palette(adr)
  ~XBIOS(6,L:adr)
RETURN
