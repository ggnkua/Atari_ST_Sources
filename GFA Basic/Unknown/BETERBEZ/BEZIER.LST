' This first routine is built for code simplicity but is only moderatly fast
' because all the calculations are done on the fly.
' The curve vector point calculation can be placed into a lookup table for
' speedier execution. (Try version 2, below)
' Merge the bezier procedure into your source code and call it with the command:
' @bezier(50,100,100,25,150,175,200,100)
'
' Version 2 can be tried by renaming the procedure call to:
' @fastbezier(50,100,100,25,150,175,200,100). This one is almost twice as fast
'
' GFA verion 3.07 or above supports bezier curves with it's "CURVE" command,
' but doesn't allow one to access the individual calculated curve points
' for your own use. For instance you can draw polyfilled shapes with curved
' sections by storing all the vector points in an array and then calling
' POLYFILL n,x(),y() with n being the number of points.
'
' The slower version **********************************
'
@def_bezarray
time1=TIMER
@bezier(50,100,100,25,150,175,200,100)
time2=TIMER
PRINT "This curve took ";(time2-time1)/200;" seconds to execute."
'
PROCEDURE bezier(x0&,y0&,x1&,y1&,x2&,y2&,x3&,y3&)
  PLOT x0&,y0&            !plot the first point
  FOR t=0 TO 1 STEP 0.05  !smaller steps result in more points. Try 0.01
    '
    x&=((1-t)*(1-t)*(1-t)*x0&)+(3*t*(1-t)*(1-t)*x1&)+(3*(t*t)*(1-t)*x2&)+((t*t*t)*x3&)
    y&=((1-t)*(1-t)*(1-t)*y0&)+(3*t*(1-t)*(1-t)*y1&)+(3*(t*t)*(1-t)*y2&)+((t*t*t)*y3&)
    '
    DRAW  TO x&,y&        !draw to the calculated point
  NEXT t
  DRAW  TO x3&,y3&        !finish off by plotting the final point
RETURN
'
' The faster version **********************************
'
PROCEDURE def_bezarray
  DIM t(3,19)                   !
  i&=0                          !
  FOR t=0 TO 1 STEP 0.05        !
    t(0,i&)=(1-t)*(1-t)*(1-t)   !
    t(1,i&)=3*t*(1-t)*(1-t)     !
    t(2,i&)=3*(t*t)*(1-t)       ! array for bezier curve lookup table
    t(3,i&)=t*t*t               !
    INC i&                      !
  NEXT t                        !
RETURN                          !
'
PROCEDURE fastbezier(x0&,y0&,x1&,y1&,x2&,y2&,x3&,y3&)
  PLOT x0&,y0&
  FOR i&=0 TO 19
    x&=(t(0,i&)*x0&)+(t(1,i&)*x1&)+(t(2,i&)*x2&)+(t(3,i&)*x3&)
    y&=(t(0,i&)*y0&)+(t(1,i&)*y1&)+(t(2,i&)*y2&)+(t(3,i&)*y3&)
    DRAW  TO x&,y&
  NEXT i&
  DRAW  TO x3&,y3&
RETURN
