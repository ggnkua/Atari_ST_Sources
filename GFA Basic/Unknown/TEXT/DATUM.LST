' DATUM (ErklÑrung)
' Diese beiden Routinen wurden geschrieben um
' eine Datums- und Zeit- Eingabe von GFA-Basic
' Programmen zu ermîglichen.
' Die Eingabe kann gekÅrzt erfolgen, fÅr
' Datum (T.M.JJ)   z.B:   1.1.88     und fÅr
' Zeit  (hh:mm)    z.b:    08:08
'
' |"""""""""""""""""|
' |  DATUM.BAS      |
' |_________________|
@datum
@zeit
EDIT
PROCEDURE datum
  anfang:
  DEFFILL 1,2,4
  PBOX 0,0,639,399
  DEFFILL 1,2,8
  PBOX 217,62,417,82
  DEFFILL 1,0,0
  PBOX 216,61,416,81
  PRINT AT(30,5);"  Datums  -  Eingabe "
  PBOX 237,158,402,259
  PBOX 240,161,399,256
  d$=DATE$
  PRINT AT(34,12);d$
  PRINT AT(34,13);
  FORM INPUT 10,d$
  SETTIME "",d$
  ALERT 0,DATE$+"|  |Datum korrekt ?",1," JA | NEIN ",back%
  IF back%=2
    GOTO anfang
  ENDIF
RETURN
PROCEDURE zeit
  zeit:
  DEFFILL 1,2,8
  PBOX 217,62,417,82
  DEFFILL 1,0,0
  PBOX 216,61,416,81
  PRINT AT(30,5);"  Zeit   -   Eingabe "
  PBOX 237,158,402,259
  PBOX 240,161,399,256
  t$=TIME$
  PRINT AT(34,12);t$
  PRINT AT(34,13);
  FORM INPUT 10,t$
  SETTIME t$,""
  ALERT 0,TIME$+"|  |Zeit  korrekt ?",1," JA | NEIN ",back%
  IF back%=2
    GOTO zeit
  ENDIF
RETURN
