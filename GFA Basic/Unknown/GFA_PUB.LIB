Dim Bild%(32255/4)    ! Bereich resevieren fuer Phy. Bildschirmadresse
'
Procedure Vscr_init   ! Virtuellen Bildschirm Initialisieren
  Adr_log%=Xbios(3)
  Adr_phy%=(Varptr(Bild%(0))+255) And &HFFFF00
  Sget Scr$
Return
'
Procedure Switch_scr  ! Umschalten zwischen Phy. und Log. Bildschirm
  Swap Adr_log%,Adr_phy%
  Void Xbios(5,L:Adr_log%,L:Adr_phy%,-1)
  Sput Scr$
Return
'
Procedure Vscr_clear  ! Aufhebung des Virtuellen Bildschirms
  High%=Max(Adr_log%,Adr_phy%)
  Void Xbios(5,L:High%,L:High%,-1)
  Sput Scr$
Return
'
Procedure Disp_cross  ! Anzeige von Koordinatenkreuz
  Line Mousex,16,Mousex,399
  Line 0,Mousey,639,Mousey
Return
'
'
'
'
Procedure Inverse
  Graphmode 3
  For Pos%=0 To 399
    Line 0,Pos%,639,Pos%
  Next Pos%
Return
'
Procedure Rotate_180
  Dim Screen$(32000/4)
  For Pos%=0 To 399
    Get 0,Pos%,639,Pos%,Screen$(Pos%)
  Next Pos%
  For Pos%=0 To 399
    Put 0,Pos%,Screen$(399-Pos%)
  Next Pos%
  Erase Screen$()
Return
'
