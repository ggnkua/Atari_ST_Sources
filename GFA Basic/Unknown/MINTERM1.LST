Rem This is a simple terminal program in GFA BASIC       ! Terminalprogramm
A$="Select baud rate:"                                   ! Minimal-Version
Alert 0,A$,2,"300|1200|9600",B                           ! Weitere Information
If B=1 Then                                              ! GFA-Buch s. 146 ff
  C=9                                                    ! und XMODEM.LST
Endif                                                    ! in der GFA-Mailbox
If B=2 Then
  C=7
Endif
If B=3 Then
  C=1
Endif
A=Xbios(15,C,1,-1,-1,-1,-1)       ! Legt die Baudrate fest
Print Chr$(27);"e";  ! Cursor einschalten
Do
  If Inp?(1)      ! Fragt, ob ein Byte an der Seriellen Schnittstelle anliegt
    X%=Inp(1)       ! Liest Byte ein
    Out 2,X%        ! Bildschirmausgabe
  Endif           !
  If Inp?(2)      ! Fragt, ob eine Taste gedrueckt ist
    X%=Inp(2)       ! Liest ein Byte von Tastatur
    Out 1,X%        ! Ausgabe an RS 232
  Endif
Loop
