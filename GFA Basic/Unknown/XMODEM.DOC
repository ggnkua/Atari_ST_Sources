'
'
'                     XModem-Unterprogramm (Testversion)
'
'
'
'        Aufrufendes Programm
'
Deffill 1,2,4
Pbox 0,0,639,399
'
Do
  Fileselect "C:\*.*","DOWNLOAD.XMD",File$
  Exit If File$=""
  ' Test des Strings
  Clr Posi%
  While Instr(Posi%,File$,"\")
    Inc Posi%
  Wend
  '
  If Posi%<Len(File$)
    Gosub Xmod_reci(File$)
    Edit
  Endif
Loop
Edit
'
'        Unterprogramm zum XModemdownload  (Was sonst?)
'
Procedure Xmod_reci(File$)
  '
  ' Variablen definieren
  '
  On Break Gosub Xmod_abbruch
  Graphmode 1
  '
  Local Backup$,Steuer$,Sicher$,Aus$,X%,Y%,Z%,Posi%
  Local Break!,Blocknr%,Byte%,Check%,Dat%,Qsum1%,Qsum2%,Start%,To%,Try%,Block$
  '
  Clr Backup$,Steuer$,Sicher$,Aus$,X%,Y%,Z%,Posi%
  Clr Break!,Blocknr%,Byte%,Check%,Dat%,Qsum1%,Qsum2%,Start%,To%,Try%,Block$
  '
  Restore Xmod_daten
  Do
    Read Z%
    Exit If Z%>255
    Steuer$=Steuer$+Chr$(Z%)
  Loop
  Read X%,Y%
  '
  ' File erîffnen
  '
  If Exist(File$)                  ! Wenn vorhanden alte Datei als Backup retten
    Backup$=Left$(File$,Len(File$)-4)+".BAK"
    If Backup$<>File$
      If Exist(Backup$)
        Kill Backup$
      Endif
      Name File$ As Backup$
    Else
      Kill File$                   ! Backupdatei gewÑhlt
    Endif
  Endif
  '
  Open "o",#1,File$
  '
  ' Bildschirmteil sichern und Textausgabe
  '
  While Instr(Posi%,File$,"\")    ! Pfad wird vom Filenamen abgetrennt
    Inc Posi%
  Wend
  Aus$=Mid$(File$,Posi%)
  '
  Get X%*8-81,Y%*16-41,X%*8+185,Y%*16+137,Sicher$
  Deffill 0,0,0
  Pbox X%*8-80,Y%*16-40,X%*8+184,Y%*16+136
  Box X%*8-80,Y%*16-40,X%*8+184,Y%*16+136  ! innerer Rahmen
  Box X%*8-81,Y%*16-41,X%*8+185,Y%*16+137
  Print At(X%,Y%);"XModem-Download"
  Print At(X%-2,Y%+2);"File: ";Aus$
  Print At(X%-5,Y%+4);"öbertragene Bytes:      0"
  Print At(X%-5,Y%+5);"Empfangene Blîcke:      0"
  Print At(X%-5,Y%+6);"Versuch Nr.:            0"
  Print At(X%-5,Y%+7);"Fehlversuche :          0"
  '
  ' Endlich gehts' los
  '
  Break!=False
  Blocknr%=1
  Try%=1
  Gosub Xmod_clear
  Repeat
    Out (1),21                         ! Datenblock anfordern
    Pause 50
  Until Inp?(1)
  '
  Repeat
    '
    ' Datenblockkopf empfangen
    '
    While Inp?(1)=0                    ! Auf Startzeichen warten
    Wend
    Start%=Inp(1)
    If Start%=1                        ! Startzeichen erhalten ?
      '
      While Inp?(1)=0                  ! Blocknummer abwarten
      Wend
      Check%=Inp(1)
      '
      While Inp?(1)=0                  ! Blockkompliment abwarten
      Wend
      Check%=Check%+Inp(1)
      '
      ' Datenblock empfangen
      '
      For Byte%=0 To 127
        While Inp?(1)=0
          Inc To%
        Wend
        Exit If To%>128
        Clr To%
        Dat%=Inp(1)
        Qsum1%=Qsum1%+Dat%
        Block$=Block$+Chr$(Dat%)
      Next Byte%
      While Inp?(1)=0
      Wend
      Qsum2%=Inp(1)
      Qsum1%=Qsum1% And 255
      '
      ' Vertrauen ist gut. Jetzt kommt die ...
      '
      If Qsum1%=Qsum2% And Check%=255 ! Alles richtig Åbertragen ?
        Print #1,Block$;
        Clr Block$,Qsum1%
        Print At(X%+14,Y%+4);Using "######",Blocknr%*128
        Print At(X%+16,Y%+5);Using "####",Blocknr%
        Print At(X%+18,Y%+6);Using "##",Try%
        Try%=1
        Inc Blocknr%
        Out (1),6                     ! An Gegenstelle: Alles OK
      Else
        '
        ' Fehlerhafter Block
        '
        Inc Fehler%
        Clr Block$,Qsum1%,To%
        Print At(X%+18,Y%+6);Using "##",Try%
        Print At(X%+17,Y%+7);Using "###",Fehler%
        Inc Try%
        Gosub Xmod_clear
        Out (1),21                    ! An Gegenstelle: Den Block nochmal bitte
      Endif
    Else
      ' Kein Startzeichen
      If Instr(Steuer$,Chr$(Start%))
        On Instr(Steuer$,Chr$(Start%))-1 Gosub Xmod_ende,Dummy,D,Xmod_cancel
        Break!=True
        Out (1),6
      Else
        Out (1),21
      Endif
    Endif
  Until Break!
  '
  ' Ende
  '
  Close #1
  Graphmode 2
  Put X%*8-81,Y%*16-41,Sicher$
Return
'
'
'
Procedure Xmod_clear
  Repeat
    While Inp?(1)
      Void Inp(1)
    Wend
    Pause 10
  Until Inp?(1)=0
Return
'
'
'
Procedure Xmod_ende
Return
'
'
'
Procedure Xmod_cancel
Return
'
'
'
Procedure Xmod_abbruch
  Local Z%
  Close #1
  For Z%=0 To 2
    Out (1),24
  Next Z%
  Edit
Return
'
'
'
Xmod_daten:
' Steuerzeichen
Data 1,4,6,21,24,256
' Ausgabeposition
Data 56,3
'
'
'
'   Anmerkung: Dieses ist wie im Programmanfang vermerkt ein Testprogramm
'   und somit zur Weiterentwicklung gedacht (Sonst hÑttet ich die ganzen
'   Rem's einfach rausgeschmissen). Das Programm sollte aber ausreichen um
'   Dateien per XModem bequem zu empfangen. Fehlerfreiheit kann ich natÅrlich
'   nicht garantieren. Deshalb interessieren mich selbstverstÑndlich alle bei
'   der Benutzung auftreten Stîrungen. Also seit bitte so freundlich und infor-
'   miert mich Åber aufgetretene Bugs (am besten sogar nach deren Besei-
'   tigung !!!). Alle Hinweise, Tips, und VerbesserungsvorschlÑge bitte an:
'
'                                                        Echo (in dieser Box)
'
'           Bis dann
'
'
'
xit If File$=""
  ' Test des Strings
  Clr Posi%
  While In