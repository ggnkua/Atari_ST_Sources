Procedure Form_center(Tree.%,X.%,Y.%,B.%,H.%)
  Lpoke Addrin,Tree.%
  Gemsys 54
  *X.%=Dpeek(Tree.%+16)-3
  *Y.%=Dpeek(Tree.%+18)-3
  *B.%=Dpeek(Tree.%+20)+6
  *H.%=Dpeek(Tree.%+22)+6
Return
'
Procedure Dial_init
  Void Fre(0)
  Erase Rette$()
  Dim Rette$(3)
  Rette_handle%=-1
Return
'
Procedure Form_dial(F%,X%,Y%,B%,H%,Xb%,Yb%,Bb%,Hb%)
  If F%=0 And Rette_handle%<3
    Inc Rette_handle%
    Get Xb%,Yb%,Xb%+Bb%,Yb%+Hb%,Rette$(Rette_handle%)
  Else
    If F%=3
      Put Xb%,Yb%,Rette$(Rette_handle%)
      Dec Rette_handle%
    Else
      Dpoke Gintin,F%
      Dpoke Gintin+2,X%
      Dpoke Gintin+4,Y%
      Dpoke Gintin+6,B%
      Dpoke Gintin+8,H%
      Dpoke Gintin+10,Xb%
      Dpoke Gintin+12,Yb%
      Dpoke Gintin+14,Bb%
      Dpoke Gintin+16,Hb%
      Gemsys 51
    Endif
  Endif
Return
