'
'
'
Openw 0
'
'
'
'
'
'
'
'
A%=1
'
On Menu Key Gosub Key
Do
  On Menu
  Gosub Zahleneingabe(10,10,A%)
  ' Der Procedure müssen folgende Werte übergeben werden:
  ' XPOSITION, YPOSITION, eine Zahl die an der Cursorposition erscheinen soll
  A%=Abs(Int(Eingabe))
Loop
End
'
'
'
'
'
'
'
'
Procedure Key
  ' DIESE PROCEDURE WERTET DIE TASTATUREINGABE AUS
  Local A%,B%
  Key%=Menu(14)
  A%=Key% And 255
  ' = ASCII CODE
  B%=(Key% And 65280)/256
  ' = SCAN CODE
  If A%=0
    Key%=B%
  Else
    Key%=A%
  Endif
Return
'
'
'
'
'
'
'
'
Procedure Zahleneingabe(X%,Y%,C)
  '
  ' HIER WERDEN ZAHLEN BIS ZU EINER LÄNGE VON C% (HIER 15 STELLEN) EINGEGEBEN
  ' ALLE EINGABEN WERDEN AUTOMATISCH AUF 2 STELLEN HINTER DEM KOMMA
  ' GERUNDET
  ' DIE RUNDUNG KANN ABER AUCH WEGGELASSEN ODER AUF MEHRERE STELLEN ERWEITERT
  ' WERDEN
  ' DIE EINGABE VON + - * / u. .(=komma) WIRD ANGENOMMEN UND ES WERDEN VOM
  ' PROGRAMM SOFORT DIE RECHENANWEISUNGEN DURCHGEFÜHRT
  '
  Local A,B,A%,C%,D%,E%,Aa%,Ab%,A$,B$,C$
  '
  ' A und B = HILFSVARIABLEN ZUM RECHNEN
  ' AA% U AB% = HILFSVARIABLEN ZUR RECHENZEICHENEINGABE
  ' A% = ZULETZT GEDRÜCKTE TASTE
  ' C% = MAXIMALE ANZAHLLÄNGE FÜR ZAHL
  ' E% = CURSORPOSITION RELATIV ZUR X-KOORDINATE
  ' D% = ANZAHL EINGEGEBENER ZEICHEN
  ' X% = XPOSITION AN DER DIE ZAHL AUSGEGEBEN WIRD
  ' Y% = DTO. FÜR YPOSITION
  ' A$= EINGEGEBENE ZAHL ( + RECHENZEICHEN)
  ' B$ und C$ = HILFSVARIABLEN ZUR EINGABE
  ' C = DER WERT DIESER VARIABLEN WIRD DER PROCEDURE ÜBERGEBEN. DIE PROC.
  ' ZEIGT DIESE ZAHL AM ANFANG AN DER GEWÜNSCHTEN POSITION AN UND RECHNET MIT
  ' IHR WEITER
  '
  A=0
  B=0
  Aa%=0
  Ab%=0
  A%=0
  C%=15
  A$=Str$(C)
  E%=Len(A$)
  D%=E%
  B$=""
  C$=""
  '
  Print At(X%,Y%);C
  Do
    '
    '
    Do
      '
      On Menu
      Graphmode 3
      Vsync
      Box ((X%+E%)*8)-8,(Y%*8)-7,((X%+E%)*8)-1,(Y%*8)
      Graphmode 1
      Print At(X%+E%,Y%);
      ' HIER WIRD DER UNGEWÖHNLICHE CURSOR GEZEICHNET
      '
      If Key%<>0
        ' WENN EINE TASTE GEDRÜCKT WURDE
        A%=Key%
        Key%=0
      Endif
      '
      Exit If A%<>0
    Loop
    '
    Graphmode 3
    Vsync
    Box ((X%+E%)*8)-8,(Y%*8)-7,((X%+E%)*8)-1,(Y%*8)
    Graphmode 1
    ' NOCHMALS DER CURSOR
    Print At(X%,Y%);Space$(C%+2)
    Print At(X%,Y%);A$;" "
    ' AUSGABE DES EINGEGEBENEN ZEICHENS
    '
    If D%>0
      ' WENN SCHON EIN ZEICHEN VORHANDEN IST - D%= ANZAHL VON ZEICHEN
      If A%=75
        ' = CURSOR LINKS
        Dec E%
        If E%<0
          E%=0
        Endif
        ' E%= STELLUNG DES CURSORS - XPOS
        Print At(X%+E%,Y%);
        ' CURSORSTELLUNG = X%+E%
      Endif
      If A%=72 Or A%=71
        ' = CURSOR OBEN ODER HOME
        E%=0
        Print At(X%,Y%);
      Endif
      If A%=8
        ' BACKSPACE TASTE
        If E%>0
          B$=Left$(A$,E%-1)
          ' WENN LINKS VOM CURSOR NOCH EIN ZEICHEN STEHT
          ' 1. LINKES ZEICHEN LOESCHEN
          A$=B$+Mid$(A$,E%+1,C%)
          ' = STRING WIEDER ZUSAMMENSETZEN
          Print At(X%,Y%);Space$(C%+2)
          Print At(X%,Y%);A$
          ' STRING AUSGEBEN
          Dec D%
          If D%<0
            D%=0
          Endif
          Dec E%
          If E%<0
            E%=0
          Endif
        Endif
        Print At(X%+E%,Y%);
        ' EINGEGEBENE ZEICHEN UND CURSORSTELLUNG VERMINDERN
      Endif
    Endif
    If Len(A$)>E%
      ' WENN RECHTS VOM CURSOR NOCH EIN ZEICHEN STEHT
      If A%=127
        ' = DELET
        If E%>=0
          B$=Left$(A$,E%)
        Else
          B$=""
        Endif
        ' 1 RECHTS VOM CURSOR STEHENDES ZEICHEN LOESCHEN
        A$=B$+Mid$(A$,E%+2,D%)
        ' STRING WIEDER ZUSAMMENHAENGEN
        Dec D%
        If D%<0
          D%=0
        Endif
        ' EINGEGEBENE ZEICHEN -1
        Print At(X%,Y%);Space$(C%+2)
        Print At(X%,Y%);A$
        Print At(X%+E%,Y%);
      Endif
      If A%=80
        ' = CURSOR UNTEN
        E%=D%
        ' CURSORPOSITION = ENDE DER EINGABE
        Print At(X%+E%,Y%);
      Endif
      If A%=77
        ' = CURSOR RECHTS
        Inc E%
        If E%>D%
          E%=D%
        Endif
        ' CURSORPOSITION +1
        Print At(X%+E%,Y%);
      Endif
    Endif
    '
    '
    If A%>47 And A%<58 Or A%=46
      ' EINGABE IST EINE ZAHL
      If A$=""
        Print At(X%,Y%);Space$(C%+2)
        Print At(X%,Y%);
        ' ERGEBNIS AN DER POSITION ANZEIGEN AU×ER WENN EINE NEUE ZAHL
        ' EINGEGEBEN WIRD
      Endif
      If D%<C%
        ' WENN EINGABE NOCH MINDESTENS EIN ZEICHEN ZU KURZ WAR
        B$=Mid$(A$,E%+1,D%)
        ' = STRING RECHTS VON CURSOR UND ZEICHEN UNTER CURSOR
        C$=Left$(A$,E%)
        ' = STRING LINKS VOM CURSOR
        A$=C$+Chr$(A%)+B$
        B$=""
        C$=""
        Inc E%
        Inc D%
        If D%>C%
          D%=C%
          E%=C%
        Endif
        ' CURSORPOSITION UND ANZAHL DER ZEICHEN +1
        Print At(X%,Y%);Space$(C%+2)
        Print At(X%,Y%);A$
        ' CURSOR AUF NEUE SPALTE SETZEN
        Print At(X%+E%,Y%);
      Endif
    Endif
    '
    If A%=97
      ' UNDO = ALLE ZEICHEN LÖSCHEN
      Print At(X%,Y%);Space$(C%+2)
      Print At(X%,Y%);
      A=0
      B=0
      Aa%=0
      Ab%=0
      A%=0
      B$=""
      C$=""
      D%=0
      E%=0
      A$=""
    Endif
    '
    If A%=42 Or A%=43 Or A%=45 Or A%=47 Or A%=61 Or A%=13
      ' DIE EINGABE WAR EINES DER FOLGENDEN ZEICHEN: + - * / = oder ENTER
      Aa%=A%
      A=Val(A$)
      '
      If Ab%<>0
        ' ES WURDE SCHON 2X EIN RECHENZEICHEN EINGEGEBEN
        If Ab%=61 Or Ab%=13
          ' = = ODER ENTER
          A=B
        Endif
        If Ab%=43
          ' = +
          B=B+A
        Endif
        If Ab%=45
          ' = -
          B=B-A
        Endif
        If Ab%=42
          ' = *
          B=B*A
        Endif
        If Ab%=47
          ' = /
          If A=0
            ' DIVISION DURCH NULL LIEFERT DAS ERGEBNIS " 0 "
            B=0
            A%=0
            B$=""
            C$=""
            D%=0
            E%=0
            A$="0"
          Else
            B=B/A
          Endif
        Endif
        Print At(X%,Y%);Space$(C%+2)
        Print At(X%,Y%);B
        '
        Ab%=0
        Swap Aa%,Ab%
        A$=Str$(B)
      Else
        Swap A,B
        Swap Aa%,Ab%
      Endif
      D%=0
      E%=0
      B$=""
      C$=""
    Endif
    '
    If Ab%=13
      ' = ENTER
      Eingabe=(Int(B*100+0.5))/100
      ' HIER WIRD DAS ERGEBNIS AUF 2 STELLEN GERUNDET
      ' WENN EIN ANDERES ZAHLENFORMAT GEWÜNSCHT WIRD, KANN DAS HIER
      ' BERÜCKSICHTIGT WERDEN
      '
      If A$=""
        ' WENN KEINE EINGABE GEMACHT WURDE => DIE VORGEGEBENE ZAHL WIRD
        ' ÜBERNOMMEN ( = C )
        Eingabe=C
      Endif
      '
      If Eingabe>2147483647 Or Eingabe<-2147483648
        ' IST KEINE INTEGERZAHL
        ' WENN ALS ERGEBNIS EINE REALZAHL GEWÜNSCHT WIRD KANN DIES AUCH
        ' WEGGELASSEN WERDEN
        Eingabe=0
      Endif
      '
      Print At(X%,Y%);Space$(C%+2)
      Print At(X%,Y%);Eingabe
      '
    Endif
    Exit If Ab%=13
    ' WENN RETURN GEDRÜCKT WURDE
    '
    A%=0
  Loop
Return
