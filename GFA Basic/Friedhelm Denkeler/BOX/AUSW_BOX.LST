' --------------------------Dimensionierungen---------------------------
Dim M$(17)                        !Für Menüleiste
Dim Spalte%(40),Zeile%(40)        !Für Ausgabebox erforderlich
Dim Text$(40),Laenge%(40),F$(20)  !Für Ausgabebox erforderlich
' ------------------------Aufbau Menüleiste-----------------------------
For I%=0 To 17
  Read M$(I%)
Next I%
Menu M$()                  !Menüleiste wird dargestellt und aktiviert
Openw 0                    !Bildschirm ohne Menüleiste ist damit Fenster
Cls
For I%=0 To 85
  Print "TEST-Hintergrund     ";  !Nur zu Testzwecken
Next I%
On Menu  Gosub Menueauswahl
Do
  On Menu
Loop
Data DESK,  Programm-Info,---------------------,1,2,3,4,5,6,""
Data DATEI, Daten speichern,-----------------, Programmende,""
Data SONSTIGES, Informationen, Test,""
' ----------------------------------------------------------------------
Procedure Menueauswahl
  M=Menu(0)
  On M-0 Gosub Programm_info
  On M-10 Gosub Daten_speichern,D,Programmende,D,D,Informationen,Test
  Menu Off                        !Negative Titel werden wieder normal.
Return
Procedure D                       !Dummy
Return
' -----------------Anwendungsbeispiele Nr. 1 bis 4----------------------
Procedure Programm_info           !Anwendung der Ausgabebox Beispiel 1
  Restore Label_ausgabebox_info_daten
  For I%=0 To 8                           !Daten der Ausgabebox über DATA
    Read Spalte%(I%),Zeile%(I%),Text$(I%) !einlesen. Dies ist sinnvoll, bei
  Next I%                                 !Eingabebox mit mehr als 2 Zeilen.
  Label_ausgabebox_info_daten:
  Data 1,1,"BEISPIELPROGRAMM FÜR AUSGABEBOX ",8,3,"Version De 1.0",14,5,"von",7,6
  Data "Friedhelm Denkeler",3,7,"1000 Berlin 44, Ilsenhof 15",2,9
  Data "Das Programm wurde geschrieben ",5,10,"in GFA-BASIC Version 2.0"
  Data 3,12,"(c) Friedhelm Denkeler 1988",12,13,"Mausklick"
  @Ausgabebox(8,183,70,1,-1,-1)   !Ausgabebox aufrufen mit Übergabeparametern
Return
' ----------------------------------------------------------------------
Procedure Daten_speichern         !Anwendung der Ausgabebox Beispiel 2
  Spalte%(0)=13                           !Daten der Ausgabebox einlesen.
  Zeile%(0)=0                             !Hier direkt (ohne DATA-Zeilen)
  Let Text$(0)="DATEN SPEICHERN           "
  @Ausgabebox(0,164,27,1,0,0)
  Fileselect "*.*","TEST.DAT",Datei$
  Put X_pos%,Y_pos%,Screen$       !Bildrestaurierung
Return
' ----------------------------------------------------------------------
Procedure Informationen           !Anwendung der Ausgabebox Beispiel 3
  Restore Label_informationen_daten
  For I%=0 To 4
    Read Spalte%(I%),Zeile%(I%),Text$(I%)
  Next I%
  Let Text$(0)="Datum                  : "+Date$
  Let Text$(1)="Zeit                   : "+Left$(Time$,2)+" Uhr "+Mid$(Time$,4,2)
  Let Text$(2)="Hauptspeicher Computer : "+Str$(Fre(0))+" Bytes frei"
  Let Text$(3)="Diskette in Laufwerk A : "+Str$(Dfree(0))+" Bytes frei"
  Label_informationen_daten:
  Data 0,0,"",0,1,"",0,2,"",0,3,"",17,4,"Mausclick"
  @Ausgabebox(4,150,150,1,-1,-1)
Return
' ----------------------------------------------------------------------
Procedure Test                    !Anwendung der Ausgabebox Beispiel 4
  Spalte%(0)=1                    !1 Zeile beginnt bei Spalte 2
  Spalte%(1)=0                    !2 Zeile beginnt bei Spalte 1
  Zeile%(0)=0                     !1 Zeile
  Zeile%(1)=1                     !2 Zeile
  Let Text$(0)="Diese Box  verschwindet nach 7 Sekunden. "  !Text 1 Zeile
  Let Text$(1)=" Der Bildhintergrund wird dabei gerettet. " !Text 2 Zeile
  @Ausgabebox(1,250,250,1,0,0)
  Pause 350
  Put X_pos%,Y_pos%,Screen$       !Bildrestaurierung
Return
' -----------------------------Ausgabebox--------------------------------
Procedure Ausgabebox(Feldanzahl%,X_position%,Y_position%,Flag%,Klein!,Warte!)
  Local Breite%,Hoehe%,I%,Mx%,My%
  Breite%=8                       !Breite Rahmen
  Hoehe%=16                       !Höhe Rahmen/ Zeilenabstand
  Dim T.x%(Feldanzahl%),T.y%(Feldanzahl%)
  For I%=0 To Feldanzahl%
    T.x%(I%)=X_position%+Breite%*(Spalte%(I%)+Len(Text$(I%)))
    T.y%(I%)=Y_position%+Hoehe%*Zeile%(I%)
    Mx%=Max(Mx%,T.x%(I%)+Breite%)
    My%=Max(My%,T.y%(I%))
  Next I%
  X_pos%=X_position%-8            !Rettung in globale Variable
  Y_pos%=Y_position%-8-Hoehe%
  If Flag%                        !Rettet Bildhintergrund
    Get X_pos%,Y_pos%,Mx%+8,My%+8+60,Screen$
  Endif
  Deffill 1,0                     !Doppelrahmen zeichnen
  Pbox X_position%-8,Y_position%-8-Hoehe%,Mx%-1,My%+8 !Au×enrahmen zeichnen
  Box X_position%-5,Y_position%-5-Hoehe%,Mx%-4,My%+5  !Innenrahmen zeichnen
  For I%=0 To Feldanzahl%         !Zeilen der Ausgabebox schreiben
    If I%=Feldanzahl% And Klein!=-1
      Deftext 1,0,0,4             !letzte Zeile Kleinschrift
    Endif
    Text X_position%+Spalte%(I%)*Breite%,Y_position%+Zeile%(I%)*Hoehe%,Text$(I%)
  Next I%
  If Warte!=-1                    !Ausgabebox verschwindet erst nach
    Repeat                        !Mausklick oder Betätigung einer Taste
    Until Len(Inkey$) Or Mousek
    Put X_pos%,Y_pos%,Screen$     !Bildrestaurierung
  Endif
  Deftext 1,0,0,13                !Textdarstellung wird wieder normal
  Erase T.x%()                    !erforderlich für nächsten Aufruf
  Erase T.y%()
Return
' ----------------------------------------------------------------------
Procedure Programmende
  Edit
Return
' ----------------------------Ende--------------------------------------
