' ****************************************************************************
' *                    Program:  Verbose listing of an ARC file              *
' * Ported to GFA Basic 3.0 by:  Chris Carpinello                            *
' *                       Date:  September 31, 1989                          *
' ****************************************************************************
' * This code is public domain.  It may be freely distributed.  Feel free to *
' * use this code in your own programs.  I did this in GFA Basic for the     *
' * simple reason that I don't know how to program in "C", but needed this   *
' * routine for a project of mine.                                           *
' ****************************************************************************
' * BBS Ploy: (Give it a call - it's only 2 weeks old, and looking for users *
' * \/\/orld of \/\/onder  *  (804) 422-6265  *  1200/2400 Baud  *  100 Megs *
' *  FoReM 2.3  *  15 Online Games  *  Over 800 Textfiles online * FNet #226 *
' *            Looking for sysops to F-Net with (will call LD)               *
' ****************************************************************************
'
PROCEDURE verbose(file$)
  LOCAL a%,b%,c%,g%,l%,l1%,tot%,x%,y%,y1%,bf$,crc$,temp$,sf$,tot$
  ON ERROR GOSUB nonarc
  CLOSE #1
  OPEN "I",#1,file$
  z%=0
  l1%=0
  y%=0
  y1%=0
  tot%=0
  PRINT CHR$(27)+"E"
  PRINT "   Name        Length   Storage    SF   Size Now  CRC     Date      Time"
  PRINT "============  ========  ========  ====  ========  ==== ========== ========"
  b1:
  SEEK #1,l1%
  bf$=STRING$(30,0)
  BGET #1,VARPTR(bf$),30
  @f_length(16,17,18,f%)
  l1%=l1%+29+f%
  IF l1%>=LOF(#1) THEN
    nonarc:
    IF ASC(MID$(bf$,1,1))<>26 THEN
      PRINT "A file in "+file$+"has a bad header"
    ENDIF
    GOTO a3
  ENDIF
  a1:
  IF ASC(MID$(bf$,1,1))<>26 OR NOT ASC(MID$(bf$,2,1))<>26 THEN
    GOTO nonarc
  ENDIF
  temp$="            "
  FOR b%=1 TO 12
    MID$(temp$,b%,1)=MID$(bf$,2+b%,1)
    IF ASC(MID$(temp$,b%,1))<45 OR ASC(MID$(temp$,b%,1))>122 THEN
      FOR g%=b% TO 12
        MID$(temp$,g%,1)=" "
      NEXT g%
      b%=13
    ENDIF
  NEXT b%
  INC tot%
  crc$="0000"
  MID$(crc$,1,2)=HEX$(ASC(MID$(bf$,25,1)))
  MID$(crc$,3,2)=HEX$(ASC(MID$(bf$,24,1)))
  @str_time(ASC(MID$(bf$,22,1))+ASC(MID$(bf$,23,1))*256)
  @str_date(ASC(MID$(bf$,20,1))+ASC(MID$(bf$,21,1))*256)
  @f_length(16,17,18,f%)
  nam$="       "
  MID$(nam$,7-LEN(STR$(f%)),LEN(STR$(f%)))=STR$(f%)
  ADD y1%,f%
  IF y1%>LOF(#1) THEN
    DEC tot%
    GOTO a3
  ENDIF
  @f_length(26,27,28,f%)
  dsc$="       "
  MID$(dsc$,7-LEN(STR$(f%)),LEN(STR$(f%)))=STR$(f%)
  ADD y%,f%
  x%=ASC(MID$(bf$,2,1))
  IF x%=0 AND c%=0 AND f%=0 THEN
    DEC tot%
    GOTO a3
  ENDIF
  type$="Unknown "
  SELECT x%
  CASE 2
    type$="Stored  "
  CASE 1,3
    type$="Packed  "
  CASE 4
    type$="Squeezed"
  CASE 5,6,7,8
    type$="Crunched"
  CASE 9
    type$="Squashed"
  ENDSELECT
  a4:
  @f_sf(VAL(nam$),VAL(dsc$),sf$)
  PRINT temp$+"    "+dsc$+" "+type$+"   "+sf$+"    "+nam$+" "+crc$+" "+sdate$+" "+stime$
  IF l1%<LOF(#1) THEN
    GOTO b1
  ENDIF
  a3:
  @f_sf(y1%,y%,sf$)
  tot$="    "       ! Max of 9999 files in ARC
  y$="       "       ! Max of 9,999,999 uncompressed bytes in ARC
  y1$=y$
  MID$(tot$,1,LEN(STR$(tot%)))=STR$(tot%)
  MID$(y$,7-LEN(STR$(y%)),LEN(STR$(y%)))=STR$(y%)
  MID$(y1$,7-LEN(STR$(y1%)),LEN(STR$(y1%)))=STR$(y1%)
  PRINT "============  ========  ========  ====  ========  ==== ========== ========"
  PRINT "Total:  "+tot$+"    "+y$+"            "+sf$+"    "+y1$
  PRINT
  CLOSE #1
RETURN
' *****************************************************************************
PROCEDURE f_length(aa%,bb%,cc%,VAR f%) ! Finds file length
  f%=ASC(MID$(bf$,aa%,1))+ASC(MID$(bf$,bb%,1))*256+ASC(MID$(bf$,cc%,1))*65536
RETURN
' *****************************************************************************
PROCEDURE f_sf(dd1%,dd%,VAR sf$) ! Finds percentage of compression
  IF dd%=0 OR dd1%=0         ! Checks for 0 file length
    sf%=0
  ELSE
    sf%=INT(100*(dd1%/dd%))
    sf%=SUB(100,sf%)
  ENDIF
  sf$="  %"
  MID$(sf$,3-LEN(STR$(sf%)),LEN(STR$(sf%)))=STR$(sf%)
RETURN
' *****************************************************************************
' * Converts 2 byte date value 'date' to a string ('sdate') in the format     *
' * MM/DD/YY                                                                  *
' *****************************************************************************
PROCEDURE str_date(date%)
  LOCAL day%,month%,year%
  day%=date% AND 31
  month%=(date%/2^5) AND 15
  year%=(date%/2^9) AND 127
  sdate$=""
  IF month%<10
    sdate$=sdate$+"0"
  ENDIF
  sdate$=sdate$+STR$(month%)+"-"
  IF (day%<10)
    sdate$=sdate$+"0"
  ENDIF
  sdate$=sdate$+STR$(day%)+"-19"+STR$(year%+80)
RETURN
' *****************************************************************************
' * Converts the 2 byte time value 'time' to a string 'sdate' in the format   *
' * HH:MM am                                                                  *
' *****************************************************************************
PROCEDURE str_time(time%)
  LOCAL sec%,min%,hour%,hdigit%
  sec%=time% AND 31
  min%=(time%/2^5) AND 63
  hour%=(time%/2^11) AND 31
  hdigit%=hour%
  IF hour%=0
    hdigit%=12
  ENDIF
  IF hdigit%>12
    hdigit%=hdigit%-12
  ENDIF
  stime$=""
  IF hdigit%<10
    stime$=" "
  ENDIF
  stime$=stime$+STR$(hdigit%)+":"
  IF min%<10
    stime$=stime$+"0"
  ENDIF
  stime$=stime$+STR$(min%)+" "
  IF hour%>=12
    stime$=stime$+"pm"
  ELSE
    stime$=stime$+"am"
  ENDIF
RETURN
