' ****************************************************************************
' *                     Program:  Verbose listing of an ARC file v1.1        *
' * Written in GFA Basic 3.0 by:  Chris Carpinello                           *
' *                        Date:  September 30, 1989                         *
' *                Last Updated:  February 6, 1990                           *
' ****************************************************************************
' * This code is 'freeware'.  It may be freely distributed.  Feel free to    *
' * use this code in your own programs.  If you use any of this code in a    *
' * 'commercial' program, I ask that I recieve a registered copy of it.      *
' ****************************************************************************
' *           Compu$pend: 73520,2117
' *                GEnie: C.CARPINELLO
' *          (SysOp) BBS: (804) 422-6265 (14.4k HST/100 Megs)
' * FoReM ST (FNet) Node: 226
' ****************************************************************************
'
' ARC Header Format
' Courtesy of Raymond Clay and his ARCHIVE Header Format file
'             Bob Puff for supplying the original ARC header format file
' 1 byte
' 1 byte - Method of Compression
' variable - filename
' 1 byte
' 4 bytes - Compressed size (HEX) (Crunched, Squashed, Sqeeezed, Stored, etc.)
' 2 bytes - File Date (MSDOS)
' 2 bytes - File Time (MSDOS)
' 2 bytes - CRC check (16-bit)
' 4 bytes - Uncompressed size (HEX)
'
FILESELECT "\*.ARC","",file$
IF file$<>""
  @verbose(file$)
ENDIF
PROCEDURE verbose(file$)
  LOCAL a%,b%,c%,g%,l%,l1%,tot%,x%,y%,y1%,bf$,crc$,temp$,sf$,tot$
  ON ERROR GOSUB nonarc
  CLOSE #1
  OPEN "I",#1,file$
  z%=0
  l1%=0
  y%=0
  y1%=0
  tot%=0
  lof%=LOF(#1)
  PRINT CHR$(27)+"E"
  PRINT file$
  PRINT
  PRINT "   Name        Length   Storage    SF   Size Now  CRC     Date      Time"
  PRINT "============  ========  ========  ====  ========  ==== ========== ========"
  b1:
  SEEK #1,l1%
  IF l1%+30>lof%
    GOTO a3
  ENDIF
  bf$=STRING$(30,0)
  BGET #1,VARPTR(bf$),30
  '
  @f_length(16,17,18,19,f%)                ! Compressed size returned in f%
  '
  l1%=l1%+29+f%
  IF l1%>=lof% THEN
    nonarc:
    IF ASC(MID$(bf$,1,1))<>26 THEN
      PRINT "A file in "+file$+"has a bad header"
    ENDIF
    GOTO a3
  ENDIF
  a1:
  IF ASC(MID$(bf$,1,1))<>26 OR NOT ASC(MID$(bf$,2,1))<>26 THEN
    GOTO nonarc
  ENDIF
  temp$=SPACE$(12)
  FOR b%=1 TO 12
    MID$(temp$,b%,1)=MID$(bf$,2+b%,1)
    IF ASC(MID$(temp$,b%,1))<45 OR ASC(MID$(temp$,b%,1))>122 THEN
      FOR g%=b% TO 12
        MID$(temp$,g%,1)=" "
      NEXT g%
      b%=13
    ENDIF
  NEXT b%
  INC tot%
  crc$="0000"
  MID$(crc$,1,2)=HEX$(ASC(MID$(bf$,25,1)))                 ! CRC, 16-bit
  MID$(crc$,3,2)=HEX$(ASC(MID$(bf$,24,1)))
  @str_time(ASC(MID$(bf$,22,1))+ASC(MID$(bf$,23,1))*256)   ! Time
  @str_date(ASC(MID$(bf$,20,1))+ASC(MID$(bf$,21,1))*256)   ! Date
  '
  nam$=SPACE$(8)
  MID$(nam$,8-LEN(STR$(f%)),LEN(STR$(f%)))=STR$(f%) ! Spacing for compressed size
  ADD y1%,f%
  IF y1%>lof% THEN
    DEC tot%
    GOTO a3
  ENDIF
  '
  @f_length(26,27,28,29,f%)           ! Uncompressed size
  dsc$=SPACE$(8)
  MID$(dsc$,8-LEN(STR$(f%)),LEN(STR$(f%)))=STR$(f%) ! Spacing justification
  '
  ADD y%,f%
  x%=ASC(MID$(bf$,2,1))               ! Compression Method
  IF x%=0 AND c%=0 AND f%=0 THEN
    DEC tot%
    GOTO a3
  ENDIF
  type$="Unknown "
  SELECT x%
  CASE 0,2
    type$="Stored  "
  CASE 1,3
    type$="Packed  "
  CASE 4
    type$="Squeezed"
  CASE 5,6,7,8
    type$="Crunched"
  CASE 9
    type$="Squashed"
  ENDSELECT
  a4:
  @f_sf(VAL(nam$),VAL(dsc$),sf$)
  PRINT temp$+"   "+dsc$+" "+type$+"   "+sf$+"   "+nam$+" "+crc$+" "+sdate$+" "+stime$
  IF l1%<lof% THEN
    GOTO b1
  ENDIF
  a3:
  @f_sf(y1%,y%,sf$)
  tot$=SPACE$(4)     ! Max of 9999 files in ARC
  y$=SPACE$(8)       ! Max of 99,999,999 uncompressed bytes in ARC
  y1$=y$             ! Max of 99,999,999 compressed bytes in ARC
  MID$(tot$,1,LEN(STR$(tot%)))=STR$(tot%)              ! Space justification
  MID$(y$,9-LEN(STR$(y%)),LEN(STR$(y%)))=STR$(y%)      ! To make it
  MID$(y1$,9-LEN(STR$(y1%)),LEN(STR$(y1%)))=STR$(y1%)  ! Look nice
  PRINT "============  ========  ========  ====  ========  ==== ========== ========"
  PRINT "Total: "+tot$+"   "+y$+"             "+sf$+"  "+y1$
  PRINT
  CLOSE #1
RETURN
' *****************************************************************************
PROCEDURE f_length(aa%,bb%,cc%,dd%,VAR f%) ! Finds file length
  f%=ASC(MID$(bf$,aa%,1))+ASC(MID$(bf$,bb%,1))*256+ASC(MID$(bf$,cc%,1))*65536+ASC(MID$(bf$,dd%,1))*16777216
RETURN
' *****************************************************************************
PROCEDURE f_sf(dd1%,dd%,VAR sf$) ! Finds percentage of compression
  IF dd%=0 OR dd1%=0         ! Checks for 0 file length
    sf%=0
  ELSE
    sf%=INT(100*(dd1%/dd%))
    sf%=SUB(100,sf%)
  ENDIF
  sf$="  %"
  MID$(sf$,3-LEN(STR$(sf%)),LEN(STR$(sf%)))=STR$(sf%)
RETURN
' *****************************************************************************
' * Converts 2 byte date value 'date' to a string ('sdate') in the format     *
' * MM/DD/YYYY                                                                *
' *****************************************************************************
PROCEDURE str_date(date%)
  LOCAL day%,month%,year%
  day%=date% AND 31
  month%=(date%/2^5) AND 15
  year%=(date%/2^9) AND 127
  sdate$=""
  IF month%<10
    sdate$=sdate$+"0"
  ENDIF
  sdate$=sdate$+STR$(month%)+"-"
  IF (day%<10)
    sdate$=sdate$+"0"
  ENDIF
  sdate$=sdate$+STR$(day%)+"-19"+STR$(year%+80)
RETURN
' *****************************************************************************
' * Converts the 2 byte time value 'time' to a string 'sdate' in the format   *
' * HH:MM am                                                                  *
' *****************************************************************************
PROCEDURE str_time(time%)
  LOCAL sec%,min%,hour%,hdigit%
  sec%=time% AND 31
  min%=(time%/2^5) AND 63
  hour%=(time%/2^11) AND 31
  hdigit%=hour%
  IF hour%=0
    hdigit%=12
  ENDIF
  IF hdigit%>12
    hdigit%=hdigit%-12
  ENDIF
  stime$=""
  IF hdigit%<10
    stime$=" "
  ENDIF
  stime$=stime$+STR$(hdigit%)+":"
  IF min%<10
    stime$=stime$+"0"
  ENDIF
  stime$=stime$+STR$(min%)+" "
  IF hour%>=12
    stime$=stime$+"pm"
  ELSE
    stime$=stime$+"am"
  ENDIF
RETURN
