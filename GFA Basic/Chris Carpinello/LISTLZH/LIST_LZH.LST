' ****************************************************************************
' *                        Program:  Verbose listing of an LZH file v1.0     *
' * Programmed in GFA Basic 3.0 by:  Chris Carpinello                        *
' *                           Date:  February 6, 1990                        *
' ****************************************************************************
' * This code is 'freeware'.  It may be freely distributed, but not sold.    *
' * Feel free to use this code in your own programs.  All I ask, if you use  *
' * any of my code, is to send me a registered copy of your completed prg.   *
' ****************************************************************************
' *           Compu$pend: 73520,2117                                         *
' *                GEnie: C.CARPINELLO                                       *
' *          (SysOp) BBS: (804) 422-6265 (14.4k HST/100 Megs)                *
' * FoReM ST (FNet) Node: 226                                                *
' ****************************************************************************
'
' LHARC Header Format
' Courtesy of: Bill Miller, _Club Rat_, Toronto
'              Raymond Clay
'
' 1 byte   - DB  - header size (from thrid byte)
' 1 byte   - DB  - header checksum (starts at third byte, not null terminated
' 5 bytes  - ASC - compression method:
'                     -lh0-   STORED (No Compression)
'                     -lh1-   LZW, 4k buffer, Huffman for upper 6 bits of pos
'                     -lz4-   LZW, Arithmetic Encoding
'                     -lz5-   LZW, Arithmetic Encoding
' 4 bytes  - HEX - length of compressed data (DOS Format)
' 4 bytes  - HEX - length of uncompressed data (DOS Format)
' 2 bytes  - DW  - file date (DOS Format)
' 2 bytes  - DW  - file time (DOS Format)
' 2 bytes  - DW  - file attributes (bit encoded: read only, hidden, system, etc.)
' 1 byte   - DB  - length of filename
' variable - DS  - filename
' 2 bytes  - DW  - Cycle Redundancy Check (CRC) 16-bit
'
' variable - comment (length of comment = header size - filename length - 22)
'
FILESELECT "\*.LZH","",file$
IF file$<>""
  @verbose(file$)
ENDIF
PROCEDURE verbose(file$)
  LOCAL a%,b%,c%,g%,hdr%,l%,l1%,lof%,tot%,x%,y%,y1%,z%,eof!,bf$,crc$,temp$,sf$,tot$
  ON ERROR GOSUB nonarc
  CLOSE #1
  OPEN "I",#1,file$
  lof%=LOF(#1)
  bf$=STRING$(291,0)             ! Storage for header buffer
  '                                36 hdr + 255 for comment
  hdr%=0
  z%=0
  l1%=0
  y%=0
  y1%=0
  tot%=0
  eof!=FALSE
  PRINT CHR$(27)+"E"             ! Same as CLS
  PRINT file$
  PRINT
  PRINT "   Name        Length   Storage    SF   Size Now  CRC     Date      Time"
  PRINT "============  ========  ========  ====  ========  ==== ========== ========"
  b1:
  SEEK #1,l1%
  BGET #1,VARPTR(bf$),291
  hdr%=ASC(MID$(bf$,1,1)) !      ! Length of the header file
  h%=ASC(MID$(bf$,2,1))          ! Chksum of remaining bytes
  @f_length(8,9,10,11,f%)        ! Compressed file size
  l1%=l1%+hdr%+f%+2              ! 2 for the 16-bit CRC following the header
  IF l1%+1>=lof%
    eof!=TRUE
  ENDIF
  '
  nam$=SPACE$(8)
  MID$(nam$,8-LEN(STR$(f%)),LEN(STR$(f%)))=STR$(f%) ! Total compressed bytes
  '
  fl%=ASC(MID$(bf$,22,1))        ! Length of filename
  temp$=MID$(bf$,23,fl%)         ! Filename, fl% chars long
  '
  comment%=hdr%-fl%-22           ! Comment length
  IF comment%>0                  ! Is there a comment?
    comment$=MID$(bf$,24+fl%+1,comment%)   ! Yes, if comment% is > 0
  ENDIF
  '
  temp$=temp$+SPACE$(12-fl%)     ! So all filenames are 12 char when printed
  '
  INC tot%                       ! Total number of files in archive
  crc$="0000"
  MID$(crc$,1,2)=HEX$(ASC(MID$(bf$,24+fl%,1)))
  MID$(crc$,3,2)=HEX$(ASC(MID$(bf$,23+fl%,1)))
  @str_time(ASC(MID$(bf$,16,1))+ASC(MID$(bf$,17,1))*256)
  @str_date(ASC(MID$(bf$,18,1))+ASC(MID$(bf$,19,1))*256)
  ADD y1%,f%
  '
  @f_length(12,13,14,15,f%)      ! Uncompressed size of file
  dsc$=SPACE$(8)
  MID$(dsc$,8-LEN(STR$(f%)),LEN(STR$(f%)))=STR$(f%) ! Total uncompressed bytes
  ADD y%,f%
  type$=MID$(bf$,3,5)
  @f_sf(VAL(nam$),VAL(dsc$),sf$)
  PRINT temp$+"   "+dsc$+"   "+type$+"    "+sf$+"   "+nam$+" "+crc$+" "+sdate$+" "+stime$
  IF comment%<>0                       ! Print comment below file info,
    PRINT "*> ";comment$               ! if it exists.
  ENDIF
  IF eof!
    GOTO a3
  ENDIF
  IF l1%<LOF(#1) THEN
    GOTO b1
  ENDIF
  a3:
  @f_sf(y1%,y%,sf$)
  tot$=SPACE$(4)            ! Max of 9999 files in ARC
  y$=SPACE$(8)              ! Max of 99,999,999 uncompressed bytes in archive
  y1$=y$                    ! Max of 99,999,999 compressed bytes in archive
  MID$(tot$,1,LEN(STR$(tot%)))=STR$(tot%)              ! Space justification
  MID$(y$,9-LEN(STR$(y%)),LEN(STR$(y%)))=STR$(y%)      ! to make it
  MID$(y1$,9-LEN(STR$(y1%)),LEN(STR$(y1%)))=STR$(y1%)  ! look 'nice'
  PRINT "============  ========  ========  ====  ========  ==== ========== ========"
  PRINT "Total: "+tot$+"   "+y$+"             "+sf$+"  "+y1$
  PRINT
  CLOSE #1
RETURN
' *****************************************************************************
PROCEDURE nonarc ! In case of a bad header
  PRINT
  PRINT file$;" has a bad header. Unable to continue."
  END
RETURN
' *****************************************************************************
PROCEDURE f_length(aa%,bb%,cc%,dd%,VAR lof%) ! Finds file length
  lof%=ASC(MID$(bf$,aa%,1))+ASC(MID$(bf$,bb%,1))*256+ASC(MID$(bf$,cc%,1))*65536+ASC(MID$(bf$,dd%,1))*16777216
RETURN
' *****************************************************************************
PROCEDURE f_sf(dd1%,dd%,VAR sf$) ! Finds percentage of compression
  IF dd%=0 OR dd1%=0             ! Checks for 0 file length
    sf%=0
  ELSE
    sf%=INT(100*(dd1%/dd%))
    sf%=100-sf%
  ENDIF
  sf$="  %"
  MID$(sf$,3-LEN(STR$(sf%)),LEN(STR$(sf%)))=STR$(sf%)
RETURN
' *****************************************************************************
' * Converts 2 byte date value 'date' to a string ('sdate') in the format     *
' * MM/DD/YYYY                                                                *
' *****************************************************************************
PROCEDURE str_date(date%)
  LOCAL day%,month%,year%
  day%=date% AND 31
  month%=(date%/2^5) AND 15
  year%=(date%/2^9) AND 127
  sdate$=""
  IF month%<10
    sdate$=sdate$+"0"
  ENDIF
  sdate$=sdate$+STR$(month%)+"-"
  IF (day%<10)
    sdate$=sdate$+"0"
  ENDIF
  sdate$=sdate$+STR$(day%)+"-19"+STR$(year%+80)
RETURN
' *****************************************************************************
' * Converts the 2 byte time value 'time' to a string 'sdate' in the format   *
' * HH:MM xx                                                                  *
' *****************************************************************************
PROCEDURE str_time(time%)
  LOCAL sec%,min%,hour%,hdigit%
  sec%=time% AND 31
  min%=(time%/2^5) AND 63
  hour%=(time%/2^11) AND 31
  hdigit%=hour%
  IF hour%=0
    hdigit%=12
  ENDIF
  IF hdigit%>12
    hdigit%=hdigit%-12
  ENDIF
  stime$=""
  IF hdigit%<10
    stime$=" "
  ENDIF
  stime$=stime$+STR$(hdigit%)+":"
  IF min%<10
    stime$=stime$+"0"
  ENDIF
  stime$=stime$+STR$(min%)+" "
  IF hour%>=12
    stime$=stime$+"pm"
  ELSE
    stime$=stime$+"am"
  ENDIF
RETURN
