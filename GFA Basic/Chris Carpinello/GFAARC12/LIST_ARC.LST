' ****************************************************************************
' *                     Program:  Verbose listing of an ARC file v1.2        *
' * Written in GFA Basic 3.0 by:  Chris Carpinello                           *
' *                        Date:  September 30, 1989                         *
' *                Last Updated:  April 15, 1990                             *
' *                       Notes:  Supports ARC v6.02 subdirectories          *
' *                  Copyrights:  [/MinuteMan Software/] 1989,1990           *
' ****************************************************************************
' * This code is 'freeware'.  It may be freely distributed.  Feel free to    *
' * use this code in your own programs.  If you use any of this code in a    *
' * 'commercial' program, I ask that I receive a registered copy of it.      *
' ****************************************************************************
' *           Compu$pend: 73520,2117                                         *
' *                GEnie: C.CARPINELLO                                       *
' *          (SysOp) BBS: (804) 422-6265 (USR 9600 HST/100 Megs)             *
' * FoReM ST (FNet) Node: 226                                                *
' ****************************************************************************
'
' ARC Header Format
' Courtesy of:       Raymond Clay and his ARCHIVE Header Format file
'                    Bob Puff for supplying the original ARC header format file
'                    Larry Novak from Floppy Wizard BBS (also updater of DCopy)
'
' 1 byte   - Always $1A
' 1 byte   - Method of Compression/Subdirectory Byte
'            $00 - End of ARC file
'            $02 - Stored
'            $03 - Packed
'            $04 - Squeezed
'            $08 - Crunched
'            $09 - Squashed
'            $1E - Subdirectory name
'            $1F - End of subdirectory
' 12 bytes - Filename, padded with nuls
' 1 byte   - Nul byte
' 4 bytes  - Compressed size (HEX) (Crunched, Squashed, Sqeeezed, Stored, etc.)
' 2 bytes  - File Date (MSDOS)
' 2 bytes  - File Time (MSDOS)
' 2 bytes  - CRC check (16-bit)
' 4 bytes  - Uncompressed size (HEX)
'
FILESELECT "\*.ARC","",file$
IF file$<>""
  @verbose(file$)
ENDIF
'
PROCEDURE verbose(file$)
  LOCAL b%,crc1%,crc2%,info%,l1%,tot%,y%,y1%,bf$,crc$,folder$,temp$,sf$,tot$
  ON ERROR GOSUB nonarc
  CLOSE #1
  OPEN "I",#1,file$
  y%=0
  y1%=0
  tot%=0
  lof%=LOF(#1)
  PRINT CHR$(27)+"E"
  PRINT file$
  PRINT
  PRINT "   Name        Length  Storage   SF  Size Now CRC   Date     Time   Folder"
  PRINT "============  ======== ======== ==== ======== ==== ======== ======= ============";
  read_hdr:
  SEEK #1,l1%
  '
  arc1$=STRING$(2,0)                  ! First 2 bytes of header field
  BGET #1,VARPTR(arc1$),2
  '
  info%=ASC(MID$(arc1$,2,1))          ! Compression Method/end of ARC/dir info
  '
  IF ASC(MID$(arc1$,2,1))=0           ! Check if end of ARC file
    GOTO totals                       ! if so, print out results
  ENDIF
  '
  IF ASC(MID$(arc1$,2,1))=&H1F        ! Check if end of subdirectory
    folder$=""                        ! if so, then increment file pointer
    l1%=l1%+2                         ! by 2 and read in next 2 header bytes
    GOTO read_hdr
  ENDIF
  '
  bf$=STRING$(28,0)                        ! Remaining 28 bytes of header
  BGET #1,VARPTR(bf$),28
  '
  temp$=SPACE$(12)                         ! space for filename
  FOR b%=1 TO 12
    IF ASC(MID$(bf$,b%,1))<>0              ! Check for nuls
      MID$(temp$,b%,1)=MID$(bf$,b%,1)
    ELSE
      b%=13
    ENDIF
  NEXT b%
  '
  IF info%=&H1E                            ! Check if start of subdirectory
    l1%=l1%+29                             ! Increment file pointer by 29
    folder$=temp$                          ! Save folder name
    GOTO read_hdr
  ENDIF
  '
  @f_length(14,15,16,17,f%)                ! Compressed size returned in f%
  '
  l1%=l1%+29+f%
  a1:
  type$="Unknown "
  SELECT info%
  CASE 0,2
    type$="Stored  "
  CASE 1,3
    type$="Packed  "
  CASE 4
    type$="Squeezed"
  CASE 5,6,7,8
    type$="Crunched"
  CASE 9
    type$="Squashed"
  ENDSELECT
  INC tot%
  '
  crc$=""
  crc1%=ASC(MID$(bf$,23,1))                 ! CRC, 16-bit
  IF crc1%<15
    crc$=crc$+"0"
  ENDIF
  crc$=crc$+HEX$(crc1%)
  '
  crc2%=ASC(MID$(bf$,22,1))
  IF crc2%<15
    crc$=crc$+"0"
  ENDIF
  crc$=crc$+HEX$(crc2%)
  @str_time(ASC(MID$(bf$,22,1))+ASC(MID$(bf$,21,1))*256)   ! Time
  @str_date(ASC(MID$(bf$,20,1))+ASC(MID$(bf$,19,1))*256)   ! Date
  '
  nam$=SPACE$(8)
  MID$(nam$,8-LEN(STR$(f%)),LEN(STR$(f%)))=STR$(f%) ! Spacing for compressed size
  ADD y1%,f%
  IF y1%>lof% THEN
    DEC tot%
    GOTO totals
  ENDIF
  '
  @f_length(24,25,26,27,f%)           ! Uncompressed size
  dsc$=SPACE$(8)
  MID$(dsc$,8-LEN(STR$(f%)),LEN(STR$(f%)))=STR$(f%) ! Spacing justification
  '
  ADD y%,f%
  a4:
  @f_sf(VAL(nam$),VAL(dsc$),sf$)
  PRINT temp$+"   "+dsc$+""+type$+"  "+sf$+"  "+nam$+""+crc$+" "+sdate$+" "+stime$+" ";
  IF LEN(folder$)=12
    PRINT folder$;
  ELSE
    PRINT folder$
  ENDIF
  GOTO read_hdr
  '
  nonarc:
  IF ASC(MID$(arc1$,1,1))<>&H1A THEN
    PRINT "A file in "+file$+"has a bad header"
  ENDIF
  '
  totals:
  @f_sf(y1%,y%,sf$)
  tot$=SPACE$(4)     ! Max of 9999 files in ARC
  y$=SPACE$(8)       ! Max of 99,999,999 uncompressed bytes in ARC
  y1$=y$             ! Max of 99,999,999 compressed bytes in ARC
  MID$(tot$,1,LEN(STR$(tot%)))=STR$(tot%)              ! Space justification
  MID$(y$,9-LEN(STR$(y%)),LEN(STR$(y%)))=STR$(y%)      ! To make it
  MID$(y1$,9-LEN(STR$(y1%)),LEN(STR$(y1%)))=STR$(y1%)  ! Look nice
  PRINT "============  ======== ======== ==== ======== ==== ======== ======= ============";
  PRINT "Total: "+tot$+"   "+y$+"           "+sf$+" "+y1$
  PRINT
  CLOSE #1
RETURN
' *****************************************************************************
> PROCEDURE f_length(aa%,bb%,cc%,dd%,VAR f%) ! Finds file length
  f%=ASC(MID$(bf$,aa%,1))+ASC(MID$(bf$,bb%,1))*256+ASC(MID$(bf$,cc%,1))*65536+ASC(MID$(bf$,dd%,1))*16777216
RETURN
' *****************************************************************************
> PROCEDURE f_sf(dd1%,dd%,VAR sf$) ! Finds percentage of compression
  IF dd%=0 OR dd1%=0         ! Checks for 0 file length
    sf%=0
  ELSE
    sf%=INT(100*(dd1%/dd%))
    sf%=SUB(100,sf%)
  ENDIF
  sf$="  %"
  MID$(sf$,3-LEN(STR$(sf%)),LEN(STR$(sf%)))=STR$(sf%)
RETURN
' *****************************************************************************
' * Converts 2 byte date value 'date' to a string ('sdate') in the format     *
' * MM/DD/YYYY                                                                *
' *****************************************************************************
> PROCEDURE str_date(date%)
  LOCAL day%,month%,year%
  day%=date% AND 31
  month%=(date%/2^5) AND 15
  year%=(date%/2^9) AND 127
  sdate$=""
  IF month%<10
    sdate$=sdate$+"0"
  ENDIF
  sdate$=sdate$+STR$(month%)+"-"
  IF (day%<10)
    sdate$=sdate$+"0"
  ENDIF
  sdate$=sdate$+STR$(day%)+"-"+STR$(year%+80)
RETURN
' *****************************************************************************
' * Converts the 2 byte time value 'time' to a string 'sdate' in the format   *
' * HH:MM am                                                                  *
' *****************************************************************************
> PROCEDURE str_time(time%)
  LOCAL sec%,min%,hour%,hdigit%
  sec%=time% AND 31
  min%=(time%/2^5) AND 63
  hour%=(time%/2^11) AND 31
  hdigit%=hour%
  IF hour%=0
    hdigit%=12
  ENDIF
  IF hdigit%>12
    hdigit%=hdigit%-12
  ENDIF
  stime$=""
  IF hdigit%<10
    stime$=" "
  ENDIF
  stime$=stime$+STR$(hdigit%)+":"
  IF min%<10
    stime$=stime$+"0"
  ENDIF
  stime$=stime$+STR$(min%)
  IF hour%>=12
    stime$=stime$+"pm"
  ELSE
    stime$=stime$+"am"
  ENDIF
RETURN
