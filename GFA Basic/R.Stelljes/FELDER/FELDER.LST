' ------------------------------------------------
' Funktionsmodul: FELDER.GFA
'       Sprache : GFA 3.07 ST
'       Autor   : R.Stelljes, 2964 Wiesmoor
'       Erstellt: Dezember 1989
' ------------------------------------------------
' Beispiel zur Anwendung
' ------------------------------------------------
Data Exit,ACC,PRG,TOS,TTP,TXT,BAS,GFA,LST,SRC,ASM
Data PAS,LIB,PI1,PI2,PI3,PIC,PAC,IMG
Data *
Defint "A-Z"                 ! Nur Integer
Dim Extender$(100)           !
Deffill 1,2,4                ! Hintergrund
Pbox 1,1,638,398             ! für Kurzdemo
Clr I                        ! aufbauen
Do                           !
  Read Da$                   !
  Exit if Da$="*"            ! Einlesen
  Extender$(I)=Da$           ! der Feldinhalte
  Inc I                      !
Loop                         !
Anz_eintr=I                  ! Anzahl der Einträge
Do                           !
  X$=Extender$(@Felder(Anz_eintr,*Extender$()))
  Exit if Index=0            ! Abbruch?
  If Index<Anz_eintr         ! Nur wenn gültig
    Alert 0,"Feldinhalt: >"+X$+"<",1,"Toll",Button
  Endif                      !
Loop                         !
Edit                         ! Demo-Ende
' ------------------------------------------------
Function Felder(N,Ptr)
  Local B,Cx,Cy,X,Y,Xx,Yy,X1,X2,Y1,Y2,Nmax
  Local Fbr,Fho,Sp,Ze,I,Mx,My,Hintergrund$
  Swap *Ptr,Temp$()          ! Übernahme des Array
  Deffill 1,0,0              ! Hintergrund weiss
  Deftext 1,0,0,13           ! Buchstaben gro×
  Boundary 1                 ! Boxumrandung an
  Graphmode 1                ! Replace Modus
  Cx=Crscol                  ! Printpos merken
  Cy=Crslin                  ! "
  Nmax=Dim?(Temp$())-1       ! Obergrenze
  ' ---------
  N=Min(N+1,Nmax)            ! Anzahl < Dim()
  N=Max(1,Abs(N))            ! Anzahl > 0
  B=4                        ! Eintraglänge
  Fbr=(B+2)*8                ! Feldbreite
  Fho=16                     ! Feldhöhe festlegen
  Ze=Sqr(N)*1.6              ! Br/Hö Verhältnis
  Sp=N/Ze+1                  ! Anzahl Spalten
  Ho=Ze*Fho                  ! Gesamthöhe in Pixel
  Br=Sp*Fbr                  ! Gesamtbreite  "
  X1=320-Br/2                ! Linker Rand
  X2=X1+Br+8                 ! Rechter Rand
  Y1=((100-Ho/2)/Fho)*Fho    ! Oberkante
  Y2=Y1+Ho                   ! Unterkante
  ' ----------
  Get X1-2-8,Y1-2-8,X2+2,Y2+2+8,Hintergrund$
  Pbox X1-2-8,Y1-2-8,X2+2,Y2+2+8 ! Feldumrandung
  Pbox X1-8,Y1-8,X2,Y2+8         ! mit Randleiste
  For I=0 To N                   !
    Xx=X1+8+(I Div Ze)*8*(B+2)   ! Texte in Felder
    Yy=Y1-2+Fho+(I Mod Ze)*Fho   ! eintragen
    Text Xx,Yy,Left$(Temp$(I),B) !
  Next I                     !
  Deffill 1,2,8              ! Schwarrrzzzz
  Graphmode 3                ! durchsichtig
  Boundary 0                 ! Umrandung aus
  Do                         !
    Mx=Int((Mousex-X1)/Fbr)*Fbr ! Feldposition merken
    My=Int((Mousey-Y1)/Fho)*Fho ! "
    Xx=Max(Min(Mx+X1,X1+Fbr*(Sp-1)),X1)
    Yy=Max(Min(My+Y1,Y1+Fho*(Ze-1)),Y1)
    Index=Min((Xx-X1)/Fbr*Ze+(Yy-Y1)/Fho,Nmax)
    Pbox Xx,Yy,Xx+Fbr,Yy+Fho ! Feld invertieren
    Do                       !
      Exit if Int((Mousex-X1)/Fbr)*Fbr<>Mx
      Exit if Int((Mousey-Y1)/Fho)*Fho<>My
      Exit if Mousek         !
    Loop                     !
    Pbox Xx,Yy,Xx+Fbr,Yy+Fho ! Invers aus
    Exit if (Mousek=1 And Index<=Anz_eintr)
    If Mousek=2 And Index<=Anz_eintr And Index>0
      If Index=Anz_eintr     ! Falls Erweiterung
        Inc Anz_eintr        ! ... mitzählen
      Endif                  !
      Ediere                 ! Feld edieren
    Endif                    !
  Loop                       !
  Swap *Ptr,Temp$()          ! Normalzustand
  While Mousek               ! Klickbremse
  Wend                       !
  Boundary 1                 ! Aufräumen
  Put X1-2-8,Y1-2-8,Hintergrund$
  Clr Hintergrund$           ! Platz machen
  Void Fre(0)                !
  Print At(Cx,Cy);           ! Cursor platzieren
  Return Index               ! Wertübergabe
Endfunc                      !
' ------------------------------------------------
Procedure Ediere
  Local Merk$,Xp,Yp,Z,S
  ' Hier kann natürlich eine beliebige
  ' Ediermöglichkeit aufgerufen werden
  Graphmode 1
  Deffill 1,0,0
  Boundary 1
  Len=Len(Temp$(Index))+8
  Z=23
  S=(80-Len)/2
  Xp=(S-1)*8-8
  Yp=(Z-1)*16-8
  Get Xp,Yp,Xp+(Len+4)*8,Yp+30,Merk$
  Pbox Xp,Yp,Xp+(Len+4)*8,Yp+30
  Pbox Xp+2,Yp+2,Xp+(Len+4)*8-2,Yp+30-2
  Print At(S,Z);
  Repeat
  Until Inkey$=""
  Form input Len As Temp$(Index)
  Put Xp,Yp,Merk$
  Xx=X1+8+(Index Div Ze)*8*(B+2)
  Yy=Y1-2+Fho+(Index Mod Ze)*Fho
  Text Xx,Yy,Left$(Temp$(Index),B)+" "
  Graphmode 3
  Boundary 0
  Deffill 1,2,8
Return
' ------------------------------------------------
