> PROCEDURE xget(x1&,y1&,x2&,y2&,VAR adr%)
LOCAL width&,height&,width_in_words&,bitplanes&
'
' GET mit VDI-Routinen 'nachgebaut'
' von Stefan Münch
'
' Es ist zu beachten :
'
' xget() alloziert Speicher in der benoetigten
' Laenge ab der Adresse adr% mittels MALLOC().
' Dieser mu×, wenn man den herauskopierten Bildschirm-
' ausschnitt nicht mehr braucht, mittels VOID MFREE(adr%)
' freigegeben werden.
'
' Beispiel :
' xget(10,10,100,100,adr%)
' xput(120,120,adr%
' xput(200,200,adr%)
' VOID MFREE(adr%)
'
' Wer's perfekt will, ueberprueft natuerlich, ob MFREE geklappt
' hat.
'
' Die mit Stern (*) gekennzeichneten Zeilen aktivieren,
' wenn man psrmfdb% etc. nicht global definiert und reserviert
' hat, oder man Aufrufe 'verschachteln' moechte (wovon ich
' der Les- und Wartbarkeit wegen ABRATE) !!!
'
' Diese Prozedur greift auf folgende Prozeduren zu :
' make_zero_mfdb()
' make_mfdb()
' make_xyarray()
' vro_cpyfm()
'
' Diese Prozedur greift auf folgende Funktionen zu :
' xwork_out
'
' sowie ueber diese auf andere
'
'
' LOCAL psrcmfdb%,pdesmfdb%,pxyarray%                     ! *
' psrcmfdb%=MALLOC(56)                                    ! *
' pdesmfdb%=psrcmfdb%+20                                  ! *
' pxyarray%=pdesmfdb%+20                                  ! *
'
width&=SUB(x2&,x1&)
INC width&
'
height&=SUB(y2&,y1&)
INC height&
'
width_in_words&=DIV(ADD(width&,15),16)
'
bitplanes&=@xwork_out(4)
'
adr%=MALLOC(ADD(6,MUL(MUL(MUL(width_in_words&,4),height&),bitplanes&)))
'
make_zero_mfdb(psrcmfdb%)
make_mfdb(pdesmfdb%,ADD(adr%,6),width&,height&,width_in_words&,0,bitplanes&)
make_xyarray(pxyarray%,x1&,y1&,x2&,y2&,0,0,SUB(width&,1),SUB(height&,1))
'
vro_cpyfm(V~H,3,pxyarray%,psrcmfdb%,pdesmfdb%)
'
DEC width&
WORD{adr%}=width&
DEC height&
WORD{ADD(adr%,2)}=height&
WORD{ADD(adr%,4)}=bitplanes&
'
' VOID MFREE(psrcmfdb%)                                  ! *
RETURN
'
> PROCEDURE xput(x1&,y1&,adr%)
xputm(x1&,y1&,adr%,3)
RETURN
> PROCEDURE xputm(x1&,y1&,adr%,modus&)
LOCAL height&,width_in_words&,bitplanes&,x2&,y2&
'
' PUT mit VDI-Routinen 'nachgebaut'
' von Stefan Muench
'
' Siehe Anmerkungen zu xget() !!!
'
' LOCAL psrcmfdb%,pdesmfdb%,pxyarray%                     ! *
' psrcmfdb%=MALLOC(56)                                    ! *
' pdesmfdb%=psrcmfdb%+20                                  ! *
' pxyarray%=pdesmfdb%+20                                  ! *
'
width&=WORD{adr%}
INC width&
'
x2&=ADD(x1&,width&)
DEC x2&
'
height&=WORD{ADD(adr%,2)}
INC height&
'
y2&=ADD(y1&,height&)
DEC y2&
'
width_in_words&=DIV(ADD(width&,15),16)
'
bitplanes&=WORD{ADD(adr%,4)}
'
make_zero_mfdb(pdesmfdb%)
make_mfdb(psrcmfdb%,ADD(adr%,6),width&,height&,width_in_words&,0,bitplanes&)
make_xyarray(pxyarray%,0,0,SUB(width&,1),SUB(height&,1),x1&,y1&,x2&,y2&)
'
vro_cpyfm(V~H,modus&,pxyarray%,psrcmfdb%,pdesmfdb%)
'
' VOID MFREE(psrcmfdb%)                                  ! *
RETURN
'
> PROCEDURE make_mfdb(pmfdb%,fd_addr%,fd_w&,fd_h&,fd_width&,fd_stand&,fd_planes&)
LONG{pmfdb%}=fd_addr%
WORD{ADD(pmfdb%,4)}=fd_w&
WORD{ADD(pmfdb%,6)}=fd_h&
WORD{ADD(pmfdb%,8)}=fd_width&
WORD{ADD(pmfdb%,10)}=fd_stand&
WORD{ADD(pmfdb%,12)}=fd_planes&
WORD{ADD(pmfdb%,14)}=0         ! fd_r1
WORD{ADD(pmfdb%,16)}=0         ! fd_r2
WORD{ADD(pmfdb%,18)}=0         ! fd_r3
RETURN
> PROCEDURE make_zero_mfdb(pmfdb%)
LONG{pmfdb%}=0
LONG{ADD(pmfdb%,4)}=0
LONG{ADD(pmfdb%,8)}=0
LONG{ADD(pmfdb%,12)}=0
LONG{ADD(pmfdb%,16)}=0
RETURN
'
> PROCEDURE make_xyarray(pxyarray%,xq0&,yq0&,xq1&,yq1&,xz0&,yz0&,xz1&,yz1&)
WORD{pxyarray%}=xq0&
WORD{ADD(pxyarray%,2)}=yq0&
WORD{ADD(pxyarray%,4)}=xq1&
WORD{ADD(pxyarray%,6)}=yq1&
WORD{ADD(pxyarray%,8)}=xz0&
WORD{ADD(pxyarray%,10)}=yz0&
WORD{ADD(pxyarray%,12)}=xz1&
WORD{ADD(pxyarray%,14)}=yz1&
RETURN
'
> PROCEDURE vro_cpyfm(handle&,wr_mode&,pxyarray%,psrcmfdb%,pdesmfdb%)
CONTRL(0)=109
CONTRL(1)=4
CONTRL(2)=0
CONTRL(3)=1
CONTRL(4)=0
CONTRL(6)=handle&
LONG{ADD(CONTRL,14)}=psrcmfdb%
LONG{ADD(CONTRL,18)}=pdesmfdb%
INTIN(0)=wr_mode&
BMOVE pxyarray%,PTSIN,16
VDISYS
RETURN
> PROCEDURE vrt_cpyfm(handle&,wr_mode&,pxyarray%,psrcmfdb%,pdesmfdb%,color_index%)
CONTRL(0)=121
CONTRL(1)=4
CONTRL(2)=0
CONTRL(3)=3
CONTRL(4)=0
CONTRL(6)=handle&
LONG{ADD(CONTRL,14)}=psrcmfdb%
LONG{ADD(CONTRL,18)}=pdesmfdb%
INTIN(0)=wr_mode&
INTIN(1)=DIV(color_index%,256)
INTIN(2)=MOD(color_index%,256)
BMOVE pxyarray%,PTSIN,16
VDISYS
RETURN
'
> FUNCTION xwork_out(parameter&)
CONTRL(0)=102
CONTRL(1)=0
CONTRL(2)=6
CONTRL(3)=1
CONTRL(4)=45
CONTRL(6)=V~H
INTIN(0)=1
VDISYS
IF parameter&<45
RETURN INTOUT(parameter&)
ELSE
RETURN PTSOUT(parameter&)
ENDIF
ENDFUNC
