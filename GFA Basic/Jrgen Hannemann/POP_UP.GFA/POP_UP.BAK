az%=60
h_az%=10
DIM m$(az%),m_b%(az%),m_h%(az%),hm$(h_az%)
@menu_read
DO
  IF MOUSEK=2
    @on_menu
    @on_menu_gosub_auswahl
  ENDIF
LOOP
' ------------------------------------
> PROCEDURE on_menu
  LOCAL hm$,mz%,hx%,hy%
  DEFMOUSE 3
  DEFTEXT 1,0
  COLOR 1
  mbb%=(hm_b%+4)*8
  mx%=MOUSEX-mbb%+16
  @menu_xy
  my%=MOUSEY-8
  @menu_xy
  mb%=mx%+mbb%
  @menu_xy
  mhh%=m_max%*16
  mh%=my%+mhh%
  @menu_xy
  hx%=mx%
  hy%=my%
  GET hx%,hy%,mb%+10,mh%+5,hm$
  @menu_draw
  CLR i%,z%,zz%
  GRAPHMODE 3
  PBOX mx%,my%+zz%*16,mx%+(hm_b%+4)*8,my%+zz%*16+16
  REPEAT
    m$=hm$(i%)
    TEXT mx%+16,my%+13+i%*16,m$
    INC i%
  UNTIL i%=m_h%(nr%)
  REPEAT
  UNTIL MOUSEK=0
  m_enu!=FALSE
  head!=TRUE
  REPEAT
    @menu_get(hm_b%,4)
    mz%=z%
    IF m_enu!=TRUE AND mk%=1
      head!=FALSE
      @pop_up_menu(mz%)
    ENDIF
  UNTIL (mk% AND m_enu!=FALSE) OR obj%>0
  PUT hx%,hy%,hm$
RETURN
> PROCEDURE menu_xy
  IF mb%>639-11
    mx%=639-mbb%-12
    mb%=mx%+mbb%
  ENDIF
  IF mh%>399
    my%=399-mhh%-8
    mh%=my%+mhh%
  ENDIF
  IF mx%<0
    mx%=1
  ENDIF
  IF my%-8<0
    my%=1
  ENDIF
RETURN
> PROCEDURE menu_get(br%,bx%)
  LOCAL x%,y%
  MOUSE x%,y%,mk%
  m_enu!=FALSE
  IF x%>mx% AND x%<mb% AND y%>my% AND y%<mh%
    z%=(y%-my%) DIV 16
    m_enu!=TRUE
    IF z%<>zz%
      m1$=LEFT$(m$(m_add%+z%+1),1)
      IF (m$(m_add%+z%+1)="--" OR m1$="-") AND head!=FALSE
        enable!=TRUE
      ELSE
        GRAPHMODE 3
        PBOX mx%,my%+z%*16,mx%+(br%+bx%)*8,my%+z%*16+16
        PBOX mx%,my%+zz%*16,mx%+(br%+bx%)*8,my%+zz%*16+16
        GRAPHMODE 1
        zz%=z%
      ENDIF
    ENDIF
  ENDIF
RETURN
> PROCEDURE pop_up_menu(nr%)
  mbb%=(m_b%(nr%)+2)*8
  mx%=MOUSEX-8
  @menu_xy
  my%=MOUSEY-8
  @menu_xy
  mb%=mx%+mbb%
  @menu_xy
  IF nr%=0
    m_add%=0
    mh%=my%+16
    mhh%=16
  ELSE
    CLR i%
    FOR il%=0 TO nr%-1
      ADD i%,m_h%(il%)+1
    NEXT il%
    m_add%=i%
    mhh%=m_h%(nr%)*16-16
    mh%=my%+mhh%
  ENDIF
  @menu_xy
  GET mx%,my%,mb%+10,mh%+5,pm$
  @menu_draw
  CLR i%
  REPEAT
    m$=m$(i%+m_add%+1)
    IF m$="--" OR LEFT$(m$,1)="-" OR (nr%=0 AND i%>1)
      DEFTEXT 1,2
    ELSE
      DEFTEXT 1,0
    ENDIF
    IF LEFT$(m$,2)="--" AND RIGHT$(m$,2)="--"
      IF MID$(m$,LEN(m$)/2,1)="-"
        m$=STRING$(m_b%(nr%)+2,"-")
      ENDIF
    ELSE
      IF LEFT$(m$,2)="- "
        m$=" "+MID$(m$,2)
      ENDIF
    ENDIF
    TEXT mx%,my%+13+i%*16,m$
    INC i%
  UNTIL i%=m_h%(nr%) OR (nr%=0 AND i%=1)
  CLR i%,z%,zz%
  GRAPHMODE 3
  PBOX mx%,my%+zz%*16,mx%+mbb%,my%+zz%*16+16
  REPEAT
  UNTIL MOUSEK=0
  REPEAT
    REPEAT
      enable!=FALSE
      @menu_get(m_b%(nr%),2)
      obj%=m_add%+z%+1
    UNTIL ((mk%=1 AND m_enu!=TRUE) OR (mk% AND m_enu!=FALSE) AND enable!=FALSE)
    PUT mx%,my%,pm$
  UNTIL enable!=FALSE
  IF (mk% AND m_enu!=FALSE)
    CLR obj%
  ENDIF
RETURN
> PROCEDURE menu_draw
  GRAPHMODE 1
  DEFFILL 1,2,8
  PBOX mx%+4,my%+4,mb%+4,mh%+4
  BOX mx%+4,my%+4,mb%+4,mh%+4
  GRAPHMODE 2
  DEFFILL 0
  PBOX mx%,my%,mb%,mh%
  BOX mx%,my%,mb%,mh%
RETURN
> PROCEDURE menu(a%,b%)
  LOCAL a$
  IF b%=0 OR b%=3
    a$=" "
  ENDIF
  IF b%=1
    a$=CHR$(8)
  ENDIF
  IF b%=2
    a$="-"
  ENDIF
  MID$(m$(a%),1)=a$
RETURN
> PROCEDURE menu_read
  LOCAL breit%,q$,i%,ii%
  CLR i%,ii%,m_max%
  DO
    READ q$
    EXIT IF q$="***"
    breit%=LEN(q$)
    IF ii%=0
      hm$(m_max%)=q$
      IF hm_b%<breit%
        hm_b%=breit%
      ENDIF
      CLR breit%
    ENDIF
    INC ii%
    m$(i%)=q$
    IF q$=""
      m_h%(m_max%)=ii%-1
      INC m_max%
      CLR ii%
    ENDIF
    IF m_b%(m_max%)<breit%
      m_b%(m_max%)=breit%
    ENDIF
    INC i%
  LOOP
  m$(i%)=""
  m$(i%+1)=""
RETURN
> PROCEDURE on_menu_gosub_auswahl
  PRINT AT(1,2);SPACE$(80)
  IF obj%<>0
    PRINT AT(1,2);"     MENš -  [ Nr"'obj%'"]   [";m$(obj%)'" ]   wurde angew„hlt !"
  ELSE
    PRINT AT(13,2);"*****     MENš - Auswahl wurde abgebrochen !     *****"
  ENDIF
  REPEAT
  UNTIL MOUSEK=0
  CLR obj%
RETURN
