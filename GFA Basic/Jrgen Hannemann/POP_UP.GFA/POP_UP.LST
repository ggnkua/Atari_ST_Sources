Setcolor 0,&H777
Menu Kill       !*                            löscht alte Pull_down Menüs
Az%=60          !*                            maximale Anzahl der Menüeinträge
H_az%=10        !*                            maximale Hauptmenüeinträge
'
'                                           ! Diese Arrays müssen in eigene
Dim M$(Az%),M_b%(Az%),M_h%(Az%),Hm$(H_az%)  ! Programme übernommen werden.
'                                           !
' ''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''
'
'  Hier, wie gewohnt der Aufbau eines PULL_DOWN Menüs. Die Routine 'EINLESEN'
'  übernimmt die Einträge genauso, somit können die POP_UP's auch in ältere
'  Programme ohne Änderung übernommen werden.
'  HINWEIS :  1. Bei normalen Menus wird durch das Minuszeichen (ASCII 45)
'                der Eintrag hell dagestellt, jedoch mit dem Minuszeichen
'                im Menü. Diesen Schönheitsfehler macht das POP_UP nicht.
'
'             2. Bei Unterteilung von Menüeinträgen genügt es zwei Minus-
'                zeichen zu setzen, die richtige Breite wird vom Programm
'                bestimmt, so da× immer eine gut Optik ohne viel probieren
'                erreicht wird.
'
'             3. Alle wie folgt gekennzeichneten Zeilen können entfernt werden,
'                da sie mit den POP_UP Routinen nichts zu tun haben.
'
'
'                KENNUNG  -->          !*
'
'
'             4. Der Bildschirmhintergrund wird im Programm mit  GET / PUT
'                erledigt, dies hat den Vorteil, da× es weniger Speicherplatz
'                kostet, braucht aber etwas länger !
'                Es kann natürlich auch durch  SGET / SPUT ersetzt
'                werden. Dies kostet allerdings 32000 kB, ist dafür aber
'                rasend schnell ! (relativ!)
'
'             5. Folgende Prozeduren müssen in eigene Programme mit über-
'                nommen werden :        PO_UP
'                                       MENU_XY
'                                       MENU_READ
'                                       MENU_DRAW
'                                       MENU(a%,b%)
'                                       POP_UP_MENU(nr%)
'                                       MENU_GET(br%,bx%)
'
'             6. Einiges hätte man in der GFA-Basic 3.0 Version wohl besser
'                schreiben können, doch sollten alle GFA-Besitzer, also
'                auch die  2.0 er in den Genu× dieser Routinen kommen.
'
'             7. Übrigens : Die reinen Prozeduren die als LST. File über-
'                nommen werden müssen, haben nur eine Länge von ca. 5200 Byte.
'
'
' ''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''
'
@Desk(4)                               !*  erstellt Desktopartigen Hintergrund
Get 0,0,639,20,M_zeile$                !*  rettet oberen Menüleistenbereich
@Menu_read                             !   einlesen der DATA Zeilen
Pop_up!=True                           !*  POPUP's einschalten
' ###################
' #  Hauptschleife  #
' ###################
' verzweigt zu POP_UP oder PULL_DOWN - MENÜ
Repeat                                 !*
  If Pop_up!=True                      !*
    @Pop_up_m.enu                      !*
  Else                                 !*
    @Pull_down_menu                    !*
  Endif                                !*
Until End!=True                        !*
'
Edit                                   !* wenn fertig hier QUIT oder SYTEM
Procedure Pop_up_m.enu
  Put 0,0,M_zeile$                     !* restoriert Menüzeilenbereich
  '
  Repeat
    If Mousek=2                        !  POP_UP wird aktiviert
      @Pop_up                          !  ersetzt die ON MENU
      @Auswahl                         !  Abfrage
    Endif
  Until Pop_up!=False Or End!=True     !  Abbruchkriterium ist nicht
  '                                    !  ma×gebend
  '
  Get 0,0,639,20,M_zeile$              !* rettet wieder die Menüleiste
Return
' #######################################
'
' ##########################################################################
' ##########################################################################
' ******           DIE FOLGENDEN PROZEDUREN WERDEN BENÖTIGT            *****
' ##########################################################################
' ##########################################################################
'
' Diese Procedure simuliert den Befehl MENU n,x
'
Procedure Menu(A%,B%)
  Local A$
  If Pop_up!=True                       !*  Kann, wenn nur POP_UP's
    If B%=0 Or B%=3
      A$=" "
    Endif
    If B%=1
      A$=Chr$(8)
    Endif
    If B%=2
      A$="-"
    Endif
    Mid$(M$(A%),1)=A$
  Else                                  !*  verwendet
    Menu A%,B%                          !*  werden,
    Menu M$()                           !*  gelöscht
  Endif                                 !*  werden.
Return
' #######################################
'
' Hier wird die MENÜLEISTE errechnet und dargestellt.
'
Procedure Pop_up
  Local Hm$
  Defmouse 3                            ! Mauszeiger wird zur zeigenden Hand
  Repeat
    Deftext 1,0
    Color 1
    Mbb%=(Hm_b%+4)*8
    Mx%=Mousex-Mbb%+16
    @Menu_xy
    My%=Mousey-8
    @Menu_xy
    Mb%=Mx%+Mbb%
    @Menu_xy
    Mhh%=M_max%*16
    Mh%=My%+Mhh%
    @Menu_xy
    Hx%=Mx%
    Hy%=My%
    Get Hx%,Hy%,Mb%+10,Mh%+5,Hm$        !  Bildhintergrund wird gerettet
    @Menu_draw                          !  errechnetes POP_UP zeichnen
    Clr I%,Z%,Zz%
    Graphmode 3
    Pbox Mx%,My%+Zz%*16,Mx%+(Hm_b%+4)*8,My%+Zz%*16+16
    Repeat
      M$=Hm$(I%)
      Text Mx%+16,My%+13+I%*16,M$       !  Menüeinträge schreiben
      Inc I%
    Until I%=M_h%(Nr%)
    @Wait(0)
    Repeat
      Head!=True
      Mouse X%,Y%,Mk%
      @Menu_get(Hm_b%,4)
      Mz%=Z%
      If M_enu!=True
        If Mk%=1
          Head!=False
          @Pop_up_menu(Mz%)
        Endif
      Else
        Clr Obj%
      Endif
    Until (Mk% And M_enu!=False) Or Obj%<>0
    '
    Put Hx%,Hy%,Hm$                             !  Hintergrund wird restauriert
    '
  Until (Mk% And M_enu!=False) Or Obj%<>0       !  wenn   mk%=2   gesetzt wird
  '                                             !  MENÜ gleich wieder zeichnen
Return                                          !
'
' #######################################
'
' Hier werden die X/Y Koordinaten gegebenenfalls angepasst, damit die
' POP_UP's immer voll auf dem Bildschirm erscheinen.
'
Procedure Menu_xy
  If Mb%>639-11
    Mx%=639-Mbb%-11
    Mb%=Mx%+Mbb%
  Endif
  If Mh%>399
    My%=400-Mhh%-7
    Mh%=My%+Mhh%
  Endif
  If Mx%<0
    Mx%=1
  Endif
  If My%-8<0
    My%=1
  Endif
Return
'
' #######################################
'
' Hier werden die einzelnen Menüpunkte invertiert und
' festgestellt welches Menü anwählbar ist.
'
Procedure Menu_get(Br%,Bx%)
  Mouse X%,Y%,Mk%
  If X%>Mx% And X%<Mb% And Y%>My% And Y%<Mh%
    Z%=(Y%-My%) Div 16
    M_enu!=True
    If Z%<>Zz%
      M1$=Left$(M$(M_add%+Z%+1),1)
      If (M$(M_add%+Z%+1)="--" Or M1$="-") And Head!=False
        Enable!=True
      Else
        Graphmode 3
        Pbox Mx%,My%+Z%*16,Mx%+(Br%+Bx%)*8,My%+Z%*16+16
        Pbox Mx%,My%+Zz%*16,Mx%+(Br%+Bx%)*8,My%+Zz%*16+16
        Graphmode 1
        Zz%=Z%
      Endif
    Endif
  Else
    M_enu!=False
  Endif
Return
'
' #######################################
'
' Hier werden die eigentlichen DROP_DOWN-MENÜS errechnet und ausgegeben.
'
Procedure Pop_up_menu(Nr%)
  Mbb%=(M_b%(Nr%)+2)*8
  Mx%=Mousex-8
  @Menu_xy
  My%=Mousey-8
  @Menu_xy
  Mb%=Mx%+Mbb%
  @Menu_xy
  If Nr%=0
    M_add%=0                            ! Es wird nur das erste MENü gezeichnet
    Mh%=My%+16                          ! also kein Zugriff auf ACC's
    Mhh%=16
  Else
    Clr I%
    For Il%=0 To Nr%-1
      Add I%,M_h%(Il%)+1
    Next Il%
    M_add%=I%
    Mhh%=M_h%(Nr%)*16-16
    Mh%=My%+Mhh%
  Endif
  @Menu_xy
  Clr I%
  Get Mx%,My%,Mb%+10,Mh%+5,Pm$         ! Bildhintergrund retten
  @Menu_draw                           ! errechnetes POP_UP zeichnen
  Repeat
    M$=M$(I%+M_add%+1)
    If M$="--" Or Left$(M$,1)="-" Or (Nr%=0 And I%>1)
      Deftext 1,2
    Else
      Deftext 1,0
    Endif
    If Left$(M$,2)="--" And Right$(M$,2)="--"
      If Mid$(M$,Len(M$)/2,1)="-"
        M$=String$(M_b%(Nr%)+2,"-")
        Xk%=0
      Else
      Endif
    Else
      If Left$(M$,2)="- "
        M$=" "+Mid$(M$,2)
      Endif
    Endif
    Text Mx%+Xk%,My%+13+I%*16,M$
    Inc I%
  Until I%=M_h%(Nr%) Or (Nr%=0 And I%=1)
  Clr I%,Z%,Zz%
  Graphmode 3
  Pbox Mx%,My%+Zz%*16,Mx%+Mbb%,My%+Zz%*16+16
  @Wait(0)
  Repeat
    Repeat
      Enable!=False
      @Menu_get(M_b%(Nr%),2)
      Obj%=M_add%+Z%+1
    Until ((Mk%=1 And M_enu!=True) Or (Mk% And M_enu!=False) And Enable!=False)
    '
    Put Mx%,My%,Pm$                    ! Bildhindergrund restaurieren
    '
  Until Enable!=False
  '
  If (Mk% And M_enu!=False)            ! wenn au×erhalb des POP_UP angeklickt
    Clr Obj%                           ! wurde auf null setzen
  Endif                                ! da ja keine Auswahl erfolgte.
Return
'
' #######################################
'
' Zeichenroutine für die POP_UP-MENÜS
'
Procedure Menu_draw
  Graphmode 1
  Deffill 1,2,8
  Pbox Mx%+4,My%+4,Mb%+4,Mh%+4
  Box Mx%+4,My%+4,Mb%+4,Mh%+4
  Graphmode 2
  Deffill 0
  Pbox Mx%,My%,Mb%,Mh%
  Box Mx%,My%,Mb%,Mh%
Return
' #######################################
'
' Hier werden die DATAS für das MENÜ eingelesen, der GFA-typisch Aufbau
' muss nicht verändert werden !
'
Procedure Menu_read
  Local Breit%,Q$,I%,Ii%
  Clr I%,Ii%,M_max%
  Restore Pop_up
  Do
    If I%=2                             !*  Diese Abfrage sollte bei übernahme
      Restore Normal                    !*  in ein eigenes Programm entfernt
    Endif                               !*  werden.
    Read Q$
    Exit If Q$="***"
    Breit%=Len(Q$)
    If Ii%=0
      Hm$(M_max%)=Q$
      If Hm_b%<Breit%
        Hm_b%=Breit%
      Endif
      Clr Breit%
    Endif
    Inc Ii%
    M$(I%)=Q$
    If Q$=""
      M_h%(M_max%)=Ii%-1
      Inc M_max%
      Clr Ii%
    Endif
    If M_b%(M_max%)<Breit%
      M_b%(M_max%)=Breit%
    Endif
    Inc I%
  Loop
  M$(I%)=""
  M$(I%+1)=""
Return
'
' ##########################################################################
' ##########################################################################
' ##########################################################################
'
'
' Alle folgenden Prozeduren werden für das POP_UP-Menu nicht benötigt, sie
' dienen lediglich zur besseren Programmveranschaulichung.
'
'
'
Procedure Pull_down_menu
  Restore Pull_down                    !  hier wird der erste Teil des Menüs
  For I%=0 To 2                        !  neu eingelesen, warum merkt Ihr
    Read M$(I%)                        !  während dem Prorammablauf.
  Next I%
  '
  Menu M$()
  On Menu  Gosub Auswahl
  Repeat
    On Menu
  Until Pop_up!=True Or End!=True
  Menu Kill                            !  WICHTIG  deaktiviert DROP_DOWN-MENÜ
  Restore Pop_up                       !  und am Ende nochmal das selbe wie
  For I%=0 To 2                        !  oben !
    Read M$(I%)                        !
  Next I%                              !
Return
'
Procedure Auswahl                        ! übernimmt Auswertung der angwählten
  Print At(1,3);Space$(80)
  If Pop_up!=False
    Obj%=Menu(0)
  Endif
  If Obj%<>0
    Print At(1,3);"     MENÜ -  [ Nr"'Obj%'"]   [";M$(Obj%)'" ]   wurde angewählt !"
    On Obj% Gosub Info
    On Obj%-9 Gosub Datei,Datei,Datei,L,Datei,Datei,Datei,L,L,L,Ende
    On Obj%-47 Gosub M_icheck,M_icheck,L,M_ienable,M_ienable
  Else
    Print At(13,3);"*****     MENÜ - Auswahl wurde abgebrochen !     *****"
  Endif
  @Wait(0)
  Menu Off
  Clr Obj%
Return
'
Procedure Info
  @Blatt(163,54,False,0,-58)
  Print At(26,6);" POP_UP - MENÜS in GFA-Basic"
  Print At(27,7);"geschrieben für alle ";Chr$(14)+Chr$(15)+" ST's"
  Print At(27,8);"04/89 von  Jürgen Hannemann"
  Print At(27,9);"Support : Reiner Bünte MA"
  Print At(27,10);"Ein Service von ST-Digital"
  @Wait(2)
  Alert 0,"",1,"POP_UP|PULLDOWN",Dummy%
  If Dummy%=1
    Pop_up!=True
  Else
    Pop_up!=False
  Endif
  @Desk(4)
Return
'
Procedure Ende
  Alert 0,"SOLL ICH WIRKLICH  |   AUFHÖREN ?",1,"  JA  | NEIN ",Dummy%
  If Dummy%=1
    End!=True
  Endif
Return
'
Procedure L
  '
Return
Procedure Wait(K%)
  Repeat
  Until Mousek=K%
Return
'
Procedure Datei
  @In_out(".*",Upper$(M$(Obj%)))
  If Obj%=10
    If Exist(File$) And File$<>""
      Bload File$,Xbios(2)
    Endif
  Endif
Return
'
Procedure M_icheck
  @Menu(20,Obj%-48)
  Out 2,7
Return
'
Procedure M_ienable
  @Menu(20,Obj%-49)
  Out 2,7
Return
'
Procedure Desk(Bc%)
  Graphmode 1
  Deffill 1,2,Bc%
  Pbox -1,-1,640,400
Return
'
Procedure In_out(Ke$,F_head$)
  @Wait(0)
  Ch%=Gemdos(25)+1
  Fl$=Chr$(Ch%+64)
  Pfad$=Fl$+":\*"+Ke$
  Get 157,19,482,53,Head$
  @Head_put(F_head$)
  Fileselect Pfad$,"",File$
  Put 157,19,Head$
Return
'
Procedure Head_put(F_head$)
  Local B%
  B%=Len(F_head$)
  Graphmode 1
  Deffill 0,2,8
  @Blatt(163,18,False,0,-143)
  Deftext 1,1,0,13
  Text 296-(B%*4),41,B%*8+B%*2,Mid$(F_head$,3)
  Deftext ,0
Return
'
Procedure Blatt(Bigb%,Bigh%,Shaddow!,Kor_x%,Kor_y%)
  Or%=325-Bigb%+Kor_x%
  Ur%=184-Bigh%+Kor_y%
  Ol%=314+Bigb%+Kor_x%
  Ul%=174+Bigh%+Kor_y%
  Graphmode 2
  Defline 1,1,0,0
  Deffill 1,2,8
  If Shaddow!=True Then
    Pbox Or%+9,Ur%+6,Ol%+17,Ul%+15
  Endif
  Deffill 0
  Pbox Or%-5,Ur%-4,Ol%+5,Ul%+4
  Color 1
  Graphmode 1
  Box Or%-1,Ur%,Ol%+1,Ul%
  Box Or%-2,Ur%-1,Ol%+2,Ul%+1
  Box Or%-5,Ur%-4,Ol%+5,Ul%+4
Return
' #######################################
Pop_up:
Data ACC's,PULL_DOWN  MENÜ,--
Pull_down:
Data ACC's,  POP_UP  MENÜ,-------------------
Normal:
Data 1,2,3,4,5,6,""
Data DATEI,  Bild laden,- Bild speichern,  Bild speichern als...,--- OBJEKTE ---
Data   Objekt laden,  Objekt speichern,  Objekt speichern als...
Data -----------,  Bytes frei,--,  »» ENDE ««,""
Data TEST 1,  10,  11,  12,  13,--,  15,  16,  17,""
Data TEST 2,  Test 19,  Test 20,  Test 21,--,  Test 23,  Test 24,""
Data TEST 3,  26,  27,  28,  29,  30,""
Data MENU_ICHECK,  Häckchen entfernen,  Häckchen setzen,--,  nicht wählbar
Data   wieder wählbar,""
Data ***
