' *************************************************************************
' *                                                                       *
' * Fenster = Procedur zur Darstellung eines Fenster in Gfa-Basic         *
' *           @Fenster(X-obenlinks,Y-obenlinks,Breite,H”he,Titelzeile)    *
' *                                                                       *
' * Cls     = Procedur zum L”schen der Fenster                            *
' *           @Cls(Fenster X-Obenlinks,Fenster Y-Obenlinks,Breite,H”he)   *
' *                                                                       *
' * von Karl Heinz Brinck                                                 *
' * Wer will kann die sache noch ausbauen (Clipping,Scrollboxen etc.)     *
' *                                                                       *
' *************************************************************************
'
@Fenster(0,0,639,399,"GFA-Basic Simulation eines Fensters")
@Cls(0,0,639,399)
Repeat
  Repeat
  Until Mousek Or Len(Inkey$)     ! Maustaste setze Fenster mit Neuer X,Y Coordinate
  ' Cls                           ! Tastatur  Breche ab
  If Mousek=1
    Mouse X%,Y%,K%
    @Fenster(X%,Y%,250,245," Test Fenster ")                    ! Linke Maustaste
    @Cls(X%,Y%,250,245)
  Else
    @Fenster(0,0,639,399,"GFA-Basic Simulation eines Fensters") ! Rechte Maustaste
    @Cls(0,0,639,399)
  Endif
Until Len(Inkey$)
Edit
Procedure Fenster(X%,Y%,Breit%,Hoch%,Ta$)
  Local Breit2%
  Breit2%=Breit%
  Breit%=Breit%+X%
  Hoch%=Hoch%+Y%
  Deffill ,0,0
  Pbox X%,Y%,Breit%-4,Hoch%
  Pbox X%,Y%,X%+18,Y%+18
  Deffill ,2,2
  Pbox X%+18,Y%,Breit%-17,Y%+18
  Deffill ,0,0
  Pbox Breit%-18,Y%,Breit%,Y%+18
  Pbox Breit%-18,Y%+18,Breit%,Y%+35
  Pbox Breit%-18,Y%+35,Breit%,Hoch%-16
  Pbox Breit%-18,Hoch%-16,Breit%,Hoch%+2
  Pbox Breit%-18,Hoch%+2,Breit%,Hoch%-19
  Pbox X%,Hoch%+2,X%+18,Hoch%-19
  Pbox X%+18,Hoch%+2,Breit%-36,Hoch%-19
  Pbox Breit%-36,Hoch%+2,Breit%-18,Hoch%-19
  Text X%+6,Y%+15,Chr$(5)
  Text Breit%-13,Y%+15,Chr$(7)
  Text Breit%-13,Hoch%-2,Chr$(6)
  Text Breit%-13,Y%+32,Chr$(1)
  Text Breit%-13,Hoch%-22,Chr$(2)
  Text X%+6,Hoch%-2,Chr$(4)
  Text Breit%-30,Hoch%-2,Chr$(3)
  If Breit2%-32>Len(Ta$)*8
    Text (X%+(Breit2%-(Len(Ta$)*8))/2),Y%+14,Ta$
  Endif
  Deffill 1,2
  Pbox Breit%-18,Hoch%-62,Breit%,Hoch%-35
  Pbox Breit%-63,Hoch%+2,Breit%-36,Hoch%-19
  Deffill 1,0,0
  Line X%,Hoch%-19,Breit%,Hoch%-19
Return
Procedure Cls(X%,Y%,Breit%,Hoch%)
  Breit%=Breit%+X%
  Hoch%=Hoch%+Y%
  Hidem
  Color 1
  Deffill 1,0,0
  Pbox X%,Y%+19,Breit%-19,Hoch%-20
  Deffill 1,0,0
  Showm
Return
