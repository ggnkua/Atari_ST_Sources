' ****************************************************
' *                                                  *
' * Error = Procedur zum Abfangen von Programmfehler *
' *         Aufruf      On Error Gosub Error         *
' *                                                  *
' *      von Karl Heinz Brinck                       *
' *                                                  *
' ****************************************************
'
'
Procedure Error
  Local A,A$
  Close
  Restore Alarm_datas
  Repeat
    Read A,A$
  Until A=Err Or A$="ENDE"
  If A$="ENDE"
    A$="Fehler Nummer "+Str$(Err)
  Endif
  If Err=-13
    Alert 1,"Bitte|Schreibschutz|entfernen !!!",1,"HINWEISS",Button%
  Endif
  If Err<>-13
    Alert 1,A$,1,"MAHNUNG",Button%
  Endif
  Alarm_datas:
  Data -1,ALLGEMEINER FEHLER
  Data -2,DRIVE NOT READY|ZEITÜBERSCHREITUNG
  Data -3,UNBEKANNTER BEFEHL
  Data -4,CRC FEHLER         |DISK-PRÜFSUMME FALSCH
  Data -5,BAD REQUEST        |UNGÜLTIGER BEFEHL
  Data -6,SEEK ERROR         |SPUR NICHT GEFUNDEN
  Data -7,UNKNOWN MEDIA      |FALSCHER BOOTSEKTOR
  Data -8,SEKTOR NICHT GEFUNDEN
  Data -9,KEIN PAPIER
  Data -10,SCHREIBFEHLER
  Data -11,LESEFEHLER
  Data -12,ALLGEMEINER FEHLER 12
  Data -14,DISKETTE WURDE GEWECHSELT
  Data -15,UNBEKANNTES GERÄT
  Data -16,BAD SEKTOR (VERIFY)
  Data -17,ANDERE DISKETTE EINLEGEN
  Data -32,UNGÜLTIGE FUNKTIONSNUMMER
  Data -33,DATEI NICHT GEFUNDEN
  Data -35,ZUVIELE DATEIEN OFFEN
  Data -36,ZUGRIFF NICHT MÖGLICH
  Data -37,UNGÜLTIGES HANDLE
  Data -39,SPEICHER VOLL
  Data -40,UNGÜLTIGE SPEICHERBLOCKADRESSE
  Data -46,UNGÜLTIGE LAUFWERKSBEZEICHNUNG
  Data -49,KEINE WEITEREN DATEN
  Data -64,GEMDOS BEREICHSFEHLER|SEEK FALSCH ?
  Data -65,INTERNER GEMDOS-FEHLER
  Data -66,KEIN BINÄRPROGRAMMFILE
  Data -67,SPEICHERBLOCKFEHLER
  Data 0,DIVISION DURCH NULL
  Data 1,ÜBERLAUF
  Data 7,UNBEKANNTER FEHLER
  Data 8,SPEICHER VOLL
  Data 10,STRING ZU LANG.|MAXIMAL 32767 ZEICHEN
  Data 22,FILE SCHON GEÖFFNET
  Data 23,FILE FALSCH
  Data 24,FILE NICHT GEÖFFNET
  Data 26,FILEENDE EREICHT EOF
  Data 37,DISKETTE VOLL
  Data 43,AUSDRUCK ZU KOMPLEX
  Data 100,C COPYRIGHT 1987|KARL HEINZ BRINCK
  Data 102,2 BOMBEN - BUS ERROR          |VILLEICHT PEEK ODER POKE FALSCH
  Data 103,3 BOMBEN - ADRESS ERROR       |UNGERADE WORTADRESSE!|BEI DPOKE- DPEEK-|LPOKE ODER LPEEK
  Data 104,4 BOMBEN - ILLEGAL INSTRUCTION|AUSFÜHRUNG EINES UNGÜLTIGEN|68000-MASCHINENBEFEHLS
  Data 105,5 BOMBEN - DIVIDE BY ZERO     |DIVISON DURCH NULL IN|68000-MASCHINENSPRACHE
  Data 106,6 BOMBEN - CHK-EXCEPTION      |68000-INTERRUPT DURCH|CHK-BEFEHL
  Data 107,7 BOMBEN - TRAPV-EXCEPTION    |68000-INTERRUPT DURCH|TRAPV-BEFEHL
  Data 108,8 BOMBEN - PRIVILEGE VIOLATION|68000-INTERRUPT DURCH|AUSFÜHRUNG EINES|PRIVILIGIERTEN BEFEHLS
  Data 109,9 BOMBEN - TRACE-EXCEPTION    |68000-TRACE-INTERRUPT
  Data 9999,ENDE
  Resume Anfang
Return
