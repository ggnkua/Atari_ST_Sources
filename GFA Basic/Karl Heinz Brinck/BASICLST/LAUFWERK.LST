' **************************************************************
' *                                                            *
' *  Procedure Zum Einstellen des Aktuellen Laufwerks          *
' *  Diskstation$ = Variable die den Laufwerksnamen enthÑlt    *
' *  Drive%       = Nummer des Aktuellen Laufwerks             *
' *                                                            *
' *       von Karl Heinz Brinck                                *
' **************************************************************
Procedure Laufkerk_einstellen
  Frage%=Gemdos(&H19)       ! Abfrage Welches Laufwerk das Aktuelle ist
  Inc Frage%                ! Da Laufwerk A den Wert 0 hat erhîhe um 1
  If Frage%>3               ! Alarmbox hat nur drei auswahlbuttons
    Frage%=0                ! deshalb wenn Laufwerk nicht in der Alarmbox vorhanden
  Endif                     ! kein Button fÅr Returntaste
  Alert 2,"Welches Laufwerk wird| bevorzugt ???",Frage%,"DISK A|DISK B|DISK C",Button%
  Diskstation$=Chr$(64+Button%)
  Chdrive Button%
  Drive%=Gemdos(&H19)
  If Button%<>Frage%
    Frage%=Button%
  Endif
Return
