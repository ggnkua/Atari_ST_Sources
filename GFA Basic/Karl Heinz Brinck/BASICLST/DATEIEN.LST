' **************************************************************
' *                                                            *
' *  Procedure fÅr vom Fileselect Befehl ausgesuchten Dateien  *
' *  Dn$ = Fileselect "","",Dn$                                *
' *                                                            *
' *  von Karl Heinz Brinck                                     *
' **************************************************************
Procedure Disk_speicher
  Local Dn2$
  If Dn$="" Or Dn$="\"
    Fehler%=1
    Goto Disk_speicher_ende         ! Wenn keine Datei gewÑhlt
  Endif
  Dn2$=""
  Fehler%=0                         ! Datei Speichern
  If Exist(Dn$) And Len(Dn$)>1      ! Sicherheitscopy wenn Datei bereits vorhanden
    Dn2$=Mid$(Dn$,1,Len(Dn$)-2)+"BAK"
    Alert 2,"Sicherheitscopie|< "+Dn2$+" >|der alten Datei",1," JA |NEIN",Button3%
    If Button3%=1
      If Exist(Dn2$)                ! Wenn BAK Datei bereits vorhanden lîschen
        Kill Dn2$
      Endif
      Name Dn$ As Dn2$              ! BAK Datei anlegen
    Endif
  Endif
  Frei=Fre(0)
  If Exist(Dn$)=0 And Disk!=True    ! Wenn beim Laden Datei nicht Vorhanden
    Alarm$="Datei|< "+Dn$+" >|ist nicht vorhanden !!!"
    Fehler%=1
  Endif
  If Dfree(0)<(Speicher-Fre(0)) And Disk!=False  ! Klar Diskette Voll
    Alarm$="Diskette Voll !!!"
    Fehler%=1
  Endif
  If Fehler%=1
    Alert 1,Alarm$,1,"MAHNUNG",Button%
  Endif
  Disk_speicher_ende:
Return
