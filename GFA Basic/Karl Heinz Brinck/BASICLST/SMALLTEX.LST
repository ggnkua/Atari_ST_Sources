' *************************************************************
' *                                                           *
' *  Procedure zum einstellen der Schrifth”he siehe GFA-Basic *
' *  Editor Text 16/Text 8                                    *
' *  Mit aufruf in der Procedure zur Abfrage der Menuzeile    *
' *  Menuarray$()  =  Variable zur erstellung der Menuzeile   *
' *  Menu(0)       =  Menuindex                               *
' *  Size%         =  Variable Welche Schriftgr”˛e            *
' *                                                           *
' *   von Karl Heinz Brinck                                   *
' *************************************************************
If Menuarray$(Menu(0))="Font 8*8  " Or Menuarray$(Menu(0))="Font 8*16 "
  If Size%=2
    Size%=1              ! Schriftgr”˛e 8*8
  Else
    Size%=2              ! Schriftgr”˛e 8*16
  Endif
  @Smalltext(Size%)
  Cls
Endif
Procedure Smalltext(Txtsize%)
  ' txtsize%=1 ==> 8*8 - Font  /  txtsize%=2 ==> 8*16 - Font
  If Txtsize%=1
    Fontadr%=16592128    ! Adresse des 8*8 Systemfonts  ( Farbe )
    M.enuarray$(Menu(0))="Font 8*16 "
  Endif
  If Txtsize%=2
    Fontadr%=16594780    ! Adresse des 8*16 Systemfonts ( Monochrom )
    M.enuarray$(Menu(0))="Font 8*8  "
  Endif
  Lpoke Intin,Fontadr%
  Dpoke Contrl+2,0
  Dpoke Contrl+6,2
  Dpoke Contrl+10,102
  Vdisys 5                ! Umschalten der Schriftart
Return
