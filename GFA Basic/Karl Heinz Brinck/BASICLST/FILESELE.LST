' **************************************************************
' *                                                            *
' *   Procedure zum Beseren ausnutzen des Fileselect Befehls   *
' *                                                            *
' *   von Karl Heinz Brinck                                    *
' **************************************************************
Procedure Disk_file(Disk_file%)
  Local Button%
  Help_dir$=""
  If Disk_file%=1
    Wahl$="\*.ADR"
    Help_dir$=Adr$
  Endif
  If Disk_file%=2
    Wahl$="\*.TXT"
    Help_dir$=Rud$
  Endif
  If Disk_file%=3
    Wahl$="\*.BLK"
    Help_dir$=Block$
  Endif
  If Disk_file%=5
    Wahl$="\*.*"
  Endif
  If Disk_file%<5 And Exist(Wahl$)<>-1
    Alert 1,"Datei mit der|Endung "+Right$(Wahl$,5)+" nicht|Vorhanden bitte Disk wechseln",1,"Hinweiss",Button%
  Endif
  If Left$(Help_dir$,1)="\"
    Help_dir$=Right$(Help_dir$,Len(Help_dir$)-1)
  Endif
  Repeat
    Fileselect Wahl$,Help_dir$,Dn$
  Until Len(Dn$)<>1
Return
