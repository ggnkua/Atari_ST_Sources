' Dieses Programm ist für Titelbilder eigener Programme gedacht.
' Eine wandernde Linie schreibt Titel etc. auf den Bildschirm.
@Anfang
Procedure Anfang
  Hidem                ! Maus abschalten.
  Deffill 1,2,23       ! Zeichnen einer Box
  Pbox 0,0,640,400
  Deffill 1,1,1
  Pbox 50,20,590,380
  Pbox 70,40,610,395
  Deffill 0,0,0
  Pbox 51,21,589,379
  Deftext 1,16,0,26
  For X%=215 To 440
    Color 1
    Line 320,370,X%,72
    If X%=215            ! Für TextgröŞe 26 sollte der Wert X% immer um
      Text X%,70,"G"     ! 30 erhöht werden.
    Endif
    If X%=245
      Text X%,70,"F"
    Endif
    If X%=275
      Text X%,70,"A"
    Endif
    If X%=305
      Text X%,70,"-"
    Endif
    If X%=335
      Text X%,70,"T"
    Endif
    If X%=365
      Text X%,70,"E"
    Endif
    If X%=395
      Text X%,70,"S"
    Endif
    If X%=425
      Text X%,70,"T"
    Endif
    Color 0
    Line 320,370,X%,72
  Next X%
  Co$=Chr$(189)         ! Copyright-Zeichen
  Deftext 1,0,0,13
  For X%=500 To 585
    Color 1
    Line 320,370,X%,46
    If X%=500
      Text X%,45,Co$
    Endif
    If X%=520
      Text X%,45,"1"
    Endif
    If X%=535
      Text X%,45,"9"
    Endif
    If X%=550
      Text X%,45,"8"
    Endif
    If X%=565
      Text X%,45,"8"
    Endif
    Color 0
    Line 320,370,X%,46
  Next X%
  Deftext 1,5,0,13
  For X%=200 To 455       ! Für TextgröŞe 13 sollte der Wert X% um
    Color 1               ! mindestens 9 erhöht werden.
    Line 320,370,X%,100
    If X%=200
      Text X%,99,"E"
    Endif
    If X%=209
      Text X%,99,"I"
    Endif
    If X%=218
      Text X%,99,"N"
    Endif
    If X%=235
      Text X%,99,"N"
    Endif
    If X%=242
      Text X%,99,"E"
    Endif
    If X%=251
      Text X%,99,"U"
    Endif
    If X%=260
      Text X%,99,"E"
    Endif
    If X%=269
      Text X%,99,"R"
    Endif
    If X%=287
      Text X%,99,"T"
    Endif
    If X%=296
      Text X%,99,"E"
    Endif
    If X%=305
      Text X%,99,"X"
    Endif
    If X%=314
      Text X%,99,"T"
    Endif
    If X%=323
      Text X%,99,"E"
    Endif
    If X%=332
      Text X%,99,"F"
    Endif
    If X%=341
      Text X%,99,"F"
    Endif
    If X%=350
      Text X%,99,"E"
    Endif
    If X%=359
      Text X%,99,"K"
    Endif
    If X%=368
      Text X%,99,"T"
    Endif
    If X%=386
      Text X%,99,"F"
    Endif
    If X%=395
      Text X%,99,"Ü"
    Endif
    If X%=404
      Text X%,99,"R"
    Endif
    If X%=422
      Text X%,99,"S"
    Endif
    If X%=431
      Text X%,99,"I"
    Endif
    If X%=440
      Text X%,99,"E"
    Endif
    If X%=449
      Text X%,99,"!"
    Endif
    Color 0
    Line 320,370,X%,100
  Next X%
  Void Inp(2)
Return
