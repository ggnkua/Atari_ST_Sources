DIM sp%(1280*25-1)
sp%=VARPTR(sp%(0))
ARRAYFILL sp%(),0
PRINT "  Bedienung des Zeichenprogramms"
PRINT "Unter 'Modi' Graphik- und Putmodus wählen."
PRINT "Der aktuelle Modus steht im Menüeintrag."
PRINT "Mausposition wird wahlweise angezeigt."
PRINT "Zeichnen mit gedrückter linker Maustaste."
PRINT "Beim Loslassen wird die Figur fixiert bzw."
PRINT "bei 'get' der Inhalt des Rechteckes "
PRINT "gespeichert.Dieses Rechteck "
PRINT "bitte nicht grö×er als 1/4 Bildschirm."
PRINT "'put'(ab Mausposition)durch Taste <p>."
PRINT "Die Funktionen unter 'ZEICHNEN' sowie"
PRINT "'OUTPUT-NEC P6'beenden durch Taste<Return>."
GET 0,0,335,200,info$
CLS
DIM menue$(36)
RESTORE mn
FOR i%=0 TO 36
  READ menue$(i%)
NEXT i%
mn:
DATA DESK,Super-Hardcopy,--------------,-1,-2,-3,-4,-5,-6,""
DATA OUTPUT,Diskette,NEC P6,--------,quit,""
DATA ZEICHNEN,info,------------,Punkt,Gerade,Kreis,Box,Get/put,Bild löschen,""
DATA DEMOS,Gerade,Kreise,Box,""
DATA MODI,Graphmode 1,Putmode   3, Anzeige,"",""
'
mco:
' Maschinencode output
DATA 8303,4,8815,8,12335,12,49660,3
DATA 53696,9288,8764,0,1279,28674,4824,20936
DATA 65532,54780,0,100,8266,28674,20937,65518
DATA 20085,-1
mcge:
' Maschinencode
DATA 17024,8303,4,12335,12,12847,14,36975
DATA 8,37487,10,13312,13825,3136,0,27650
DATA 17472,3137,0,27650,17473,45121,27650,12289
DATA 29184,14338,14851,51649,52161,35264,35776,55407
DATA 8,27446,3140,1279,28208,55919,10,27434
DATA 3141,799,28196,18629,35836,8,8776,53957
DATA 51708,100,54212,18501,31751,39941,3183,1
DATA 16,28164,3537,25602,3409,21057,45632,28594
DATA 20085,0,0,0,0
DATA -1
mcb:
' Maschinencode box
DATA 8303,4,8776,17024,12335,8,13359,12
DATA 46144,27650,49474,12800,50172,100,53697,15874
DATA 53244,100,54215,37952,17025,12847,10,13871
DATA 14,46657,27650,49987,18627,34812,8,11779
DATA 31751,28679,18503,40007,18625,33788,8,38465
DATA 21827,53441,9288,53953,18497,36929,14383,16
DATA 6716,255,57901,3140,1,28166,35600,35601
DATA 25604,47888,47889,3139,0,27936,21128,21129
DATA 3140,1,28170,4284,255,4796,255,25608
DATA 2576,255,2577,255,20939,65506,3139,65535
DATA 27908,21128,21129,6716,255,60709,3140,1
DATA 28166,35600,35601,25604,47888,47889,3138,2
DATA 27938,21826,53756,0,100,54780,0,100
DATA 3140,1,28166,3536,466,25604,3408,338
DATA 20938,65506,20085,-1
mcp:
' Maschinencode put
DATA 8303,4,8815,8,12335,12,49660,100
DATA 53696,12335,14,18624,33276,8,53440,18496
DATA 29703,37952,8194,9288,12817,53871,12,3137
DATA 1279,28426,12860,1279,37487,12,25602,12817
DATA 21641,13841,15363,18630,36348,8,21062,54895
DATA 14,3139,799,28426,13884,799,38511,14
DATA 25602,13841,21641,9801,14339,3183,0,16
DATA 28198,1424,3138,0,28164,29704,21128,21314
DATA 20939,65520,54780,0,100,8266,13828,13312
DATA 20937,65504,24576,138,31239,3183,3,16
DATA 28226,2833,26372,1488,25602,1424,3202,0
DATA 0,28164,29704,21128,21378,3205,0,0
DATA 28164,31240,21129,21381,20939,65496,54780,0
DATA 100,8266,13828,9216,31239,54982,8779,20937
DATA 65474,24636,2833,26370,1488,3202,0,0
DATA 28164,29704,21128,21314,3205,0,0,28164
DATA 31240,21129,21317,20939,65500,54780,0,100
DATA 8266,9216,13828,31239,54982,8779,20937,65478
DATA 20085,-1
mcg:
' Maschinencode get
DATA 8303,4,8815,8,17024,12335,12,49660
DATA 100,53696,12335,16,36975,12,12992,21056
DATA 12847,18,37487,14,12993,18625,33788,8
DATA 21057,15361,13359,14,18626,34300,8,53442
DATA 9288,18498,13884,8,38466,6168,58660,6672
DATA 58925,55301,4804,21313,28400,12806,54780,0
DATA 100,8266,21312,28386,20085,-1
'
mco$=""
RESTORE mco
DO
  READ m%
  EXIT IF m%<0
  mco$=mco$+MKI$(m%)
LOOP
mco%=VARPTR(mco$)
mcge$=""
RESTORE mcge
DO
  READ m%
  EXIT IF m%<0
  mcge$=mcge$+MKI$(m%)
LOOP
mcge%=VARPTR(mcge$)
mcp$=""
RESTORE mcp
DO
  READ m%
  EXIT IF m%<0
  mcp$=mcp$+MKI$(m%)
LOOP
mcp%=VARPTR(mcp$)
mcg$=""
RESTORE mcg
DO
  READ m%
  EXIT IF m%<0
  mcg$=mcg$+MKI$(m%)
LOOP
mcg%=VARPTR(mcg$)
mcb$=""
RESTORE mcb
DO
  READ m%
  EXIT IF m%<0
  mcb$=mcb$+MKI$(m%)
LOOP
mcb%=VARPTR(mcb$)
loesch$=MKI$(176)+MKI$(13)+MKI$(1)+STRING$(11*13,0)
'
MENU menue$()
anz!=-1
MENU 34,1
gm%=1
pm%=3
ON MENU  GOSUB abfrage
DO
  ON MENU
LOOP
'
PROCEDURE abfrage
  IF MENU(0)=1
    ALERT 1,"Graphik drucken in doppelter| Auflösung: 1280*800 Pixel|Kleines Demoprogramm von|Peter Matejcek ",0,"OK",d%
  ENDIF
  ON MENU(0)-10 GOSUB p1,p2,p0,p3,p0,p0,p4,p0,p5,p6,p7,p8,p9,p10,p0,p0,p11,p12,p13,p0,p0,p14,p15,p16
  MENU OFF
  PUT 456,2,loesch$,0          !Koordinatenanzeige weg
RETURN
PROCEDURE p0
RETURN
PROCEDURE p1
  ALERT 3,"Speichern noch nicht|     möglich.",0,"OK",d%
RETURN
PROCEDURE p2
  IF GEMDOS(17)
    ALERT 1,"   Ausdrucken  ",0,"Start|Abbruch",d%
    IF d%=1
      dr$=STRING$(640*6,0)
      LPRINT CHR$(27);"3";CHR$(24)
      l%=0
      dr%=VARPTR(dr$)
      REPEAT
        z$=INKEY$
        VOID C:mco%(L:sp%,L:dr%,l%)
        LPRINT CHR$(27);"*";CHR$(39);CHR$(0);CHR$(5);dr$
        INC l%
      UNTIL l%=33 OR ASC(z$)=13
    ENDIF
  ELSE
    ALERT 1,"Drucker nicht bereit!",1,"Ach so",d%
    IF GEMDOS(17)
      @p2
    ENDIF
  ENDIF
RETURN
PROCEDURE p3
  END
RETURN
PROCEDURE p4
  GET 140,30,500,240,org$
  PUT 140,30,org$,0
  BOX 140,31,499,239
  PUT 144,33,info$,7
  REPEAT
  UNTIL ASC(INKEY$)=13
  PUT 140,30,org$,3
RETURN
PROCEDURE p5
  IF anz!
    @text1
  ENDIF
  DO
    z$=INKEY$
    EXIT IF ASC(z$)=13
    MOUSE x%,y%,k%
    IF anz!
      @text2
    ENDIF
    WHILE k%=1 AND y%>18
      MOUSE x1%,y1%,k%
      VOID C:mcge%(L:sp%,2*x%,2*y%-38,2*x%,2*y1%-38,gm%)
      x%=x1%
      y%=y1%
      DRAW x%,y% TO x1%,y1%
    WEND
  LOOP
RETURN
PROCEDURE p6
  IF anz!
    @text1
  ENDIF
  DO
    z$=INKEY$
    EXIT IF ASC(z$)=13
    MOUSE x%,y%,k%
    IF y%>18
      IF anz!
        @text2
      ENDIF
      WHILE k%=1
        MOUSE x1%,y1%,k%
        IF anz!
          @text3
        ENDIF
        GRAPHMODE 3
        LINE x%,y%,x1%,y1%
        IF k%=0
          GRAPHMODE gm%
          LINE x%,y%,x1%,y1%
          VOID C:mcge%(L:sp%,2*x%,2*y%-38,2*x1%,2*y1%-38,gm%)
        ENDIF
        LINE x%,y%,x1%,y1%
        EXIT IF k%=0 OR y1%<19
      WEND
    ENDIF
  LOOP
RETURN
PROCEDURE p7
  IF anz!
    @text1
  ENDIF
  DO
    z$=INKEY$
    EXIT IF ASC(z$)=13
    MOUSE x%,y%,k%
    IF y%>18
      IF anz!
        @text2
      ENDIF
      WHILE k%=1
        MOUSE x1%,y1%,k%
        IF anz!
          @text3
        ENDIF
        GRAPHMODE 3
        cx%=(x%+x1%)/2
        cy%=(y%+y1%)/2
        ra%=INT(SQR((x1%-x%)^2+(y1%-y%)^2)/2)
        CIRCLE cx%,cy%,ra%
        IF k%=0
          GRAPHMODE gm%
          CIRCLE cx%,cy%,ra%
          @cir(2*cx%,2*cy%-38,2*ra%)
        ENDIF
        CIRCLE cx%,cy%,ra%
        EXIT IF k%=0 OR y1%<19
      WEND
    ENDIF
  LOOP
RETURN
PROCEDURE p8
  IF anz!
    @text1
  ENDIF
  DO
    z$=INKEY$
    EXIT IF ASC(z$)=13
    MOUSE x%,y%,k%
    IF y%>18
      IF anz!
        @text2
      ENDIF
      WHILE k%=1
        MOUSE x1%,y1%,k%
        IF anz!
          @text3
        ENDIF
        GRAPHMODE 3
        BOX x%,y%,x1%,y1%
        IF k%=0
          GRAPHMODE gm%
          BOX x%,y%,x1%,y1%
          VOID C:mcb%(L:sp%,2*x%,2*y%-38,2*x1%,2*y1%-38,gm%)
        ENDIF
        BOX x%,y%,x1%,y1%
        EXIT IF k%=0 OR y1%<19
      WEND
    ENDIF
  LOOP
RETURN
PROCEDURE p9
  IF anz!
    @text1
  ENDIF
  DO
    MOUSE x%,y%,k%
    z$=INKEY$
    EXIT IF ASC(z$)=13
    IF y%>18
      IF anz!
        @text2
      ENDIF
      WHILE k%=1
        MOUSE x1%,y1%,k%
        GRAPHMODE 3
        IF x1%<x%
          x1%=x%
        ENDIF
        IF y1%<y%
          y1%=y%
        ENDIF
        pr%=(x1%-x%)*(y1%-y%)
        WHILE pr%>64000
          DEC x1%
          pr%=(x1%-x%)*(y1%-y%)
        WEND
        IF anz!
          @text3
        ENDIF
        DEFLINE 2,1,0,0
        BOX x%,y%,x1%,y1%
        BOX x%,y%,x1%,y1%
        IF k%=0
          @gt(x%,y%,x1%,y1%)
        ENDIF
        EXIT IF k%=0 OR y1%<19
      WEND
      IF z$="p" AND gt%<>0
        VOID C:mcp%(L:sp%,L:gt%,2*x%,2*y%-38,pm%)
        IF x%+DPEEK(VARPTR(g$))<640 AND y%+DPEEK(VARPTR(g$)+2)<400
          PUT x%,y%,g$,pm%
        ENDIF
      ENDIF
    ENDIF
  LOOP
  DEFLINE 1,1,0,0
  GRAPHMODE gm%
RETURN
PROCEDURE p10
  ARRAYFILL sp%(),0
  CLS
  MENU menue$()
  IF anz!
    MENU 34,1
  ENDIF
RETURN
PROCEDURE p11
  GRAPHMODE gm%
  FOR x%=50 TO 550 STEP 5
    VOID C:mcge%(L:sp%,300,317,2*x%,22,gm%)
    LINE 150,177,x%,30
  NEXT x%
  FOR y%=52 TO 338 STEP 4
    y1%=390-y%
    x%=50
    x1%=590
    VOID C:mcge%(L:sp%,2*x%,2*y%-38,2*x1%,2*y1%-38,gm%)
    LINE x%,y%,x1%,y1%
  NEXT y%
  FOR x%=500 TO 590 STEP 3
    LINE x%,375,590,30
    VOID C:mcge%(L:sp%,2*x%,712,1180,22,gm%)
  NEXT x%
  FOR j%=1 TO 20
    x%=510+4*j%
    x1%=334
    y1%=267
    LINE x%,30,x1%,y1%
    VOID C:mcge%(L:sp%,2*x%,22,2*x1%,2*y1%-38,gm%)
  NEXT j%
RETURN
PROCEDURE p12
  GRAPHMODE gm%
  FOR j%=1 TO 10
    cx%=280+j%*4
    r%=180-j%*6
    CIRCLE cx%,195,r%
    @cir(2*cx%,352,2*r%)
  NEXT j%
  FOR j%=1 TO 20
    cx%=320-j%*4
    cy%=195-j%*2
    r%=120-j%*6
    CIRCLE cx%,cy%,r%
    @cir(2*cx%,2*cy%-38,2*r%)
    cx%=320+j%*4
    cy%=195-j%*2
    r%=120-j%*6
    CIRCLE cx%,cy%,r%
    @cir(2*cx%,2*cy%-38,2*r%)
  NEXT j%
  FOR j%=0 TO 20
    cx%=164+80*SIN(j%*PI/40)
    cy%=155-80*COS(j%*PI/40)
    CIRCLE cx%,cy%,6
    @cir(2*cx%,2*cy%-38,12)
    cx%=476-80*SIN(j%*PI/40)
    cy%=155-80*COS(j%*PI/40)
    CIRCLE cx%,cy%,6
    @cir(2*cx%,2*cy%-38,12)
  NEXT j%
RETURN
PROCEDURE p13
  FOR i%=1 TO 50
    ax%=150-2*i%
    ay%=180-3*i%
    ex%=150+8*i%
    ey%=175+4*i%
    BOX ax%,ay%,ex%,ey%
    VOID C:mcb%(L:sp%,2*ax%,2*ay%-38,2*ex%,2*ey%-38,gm%)
  NEXT i%
RETURN
PROCEDURE p14
  ALERT 0,"Graphikmodus wählen:",0,"1|3",d%
  IF d%=1
    gm%=1
  ELSE
    gm%=3
  ENDIF
  POKE VARPTR(menue$(32))+10,48+gm%
  MENU menue$()
RETURN
PROCEDURE p15
  ALERT 0,"Putmodus wählen:",0,"0|3|7",d%
  IF d%=1
    pm%=0
  ENDIF
  IF d%=2
    pm%=3
  ENDIF
  IF d%=3
    pm%=7
  ENDIF
  POKE VARPTR(menue$(33))+10,48+pm%
  MENU menue$()
RETURN
PROCEDURE p16
  IF anz!
    anz!=0
    MENU 34,0
  ELSE
    anz!=-1
    MENU 34,1
  ENDIF
RETURN
PROCEDURE cir(cex%,cey%,r%)
  i%=0
  gra=2*PI/60
  REPEAT
    g1=gra*i%
    g2=gra*(i%+1)
    ax%=INT(r%*SIN(g1))
    ex%=INT(r%*SIN(g2))
    ay%=INT(r%*COS(g1))
    ey%=INT(r%*COS(g2))
    VOID C:mcge%(L:sp%,cex%+ax%,cey%+ay%,cex%+ex%,cey%+ey%,gm%)
    VOID C:mcge%(L:sp%,cex%-ax%,cey%+ay%,cex%-ex%,cey%+ey%,gm%)
    VOID C:mcge%(L:sp%,cex%+ax%,cey%-ay%,cex%+ex%,cey%-ey%,gm%)
    VOID C:mcge%(L:sp%,cex%-ax%,cey%-ay%,cex%-ex%,cey%-ey%,gm%)
    INC i%
  UNTIL i%>14
RETURN
PROCEDURE gt(ax%,ay%,ex%,ey%)
  gt$=STRING$(4+((2*(ex%-ax%)+1)*(2*(ey%-ay%) DIV 8)+1),0)
  gt%=VARPTR(gt$)
  VOID C:mcg%(L:sp%,L:gt%,2*ax%,2*ay%-38,2*ex%,2*ey%-38)
  GET ax%,ay%,ex%,ey%,g$
RETURN
PROCEDURE text1
  TEXT 457,13,"x:   b:    y:   h:   "
RETURN
PROCEDURE text2
  PRINT AT(60,1);USING "###",x%
  PRINT AT(71,1);USING "###",y%-19
RETURN
PROCEDURE text3
  PRINT AT(65,1);USING "+###",x1%-x%
  PRINT AT(76,1);USING "+###",y1%-y%
RETURN
