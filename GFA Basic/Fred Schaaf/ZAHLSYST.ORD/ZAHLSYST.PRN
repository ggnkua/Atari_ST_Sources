
 Nummeriertes Listing von \ZAHLSYST.LST
================================================================================

  1: '  ________________________________________________________________________
  2: '  |                  UMWANDLUNG VON ZAHLEN-SYSTEMEN.                     |
  3: '  |                  ===============================                     |
  4: '  |  Dieses GfA-BASIC 3.0 Prg. wandelt Dez.-Hex.-Okt.-u.Bin.-Zahlen um.  |
  5: '  |             Dieses Demo-Programm zeigt unter anderen :               |
  6: '  |       Pulldownmenü- und Fensterprogrammierung,Programmsteuerung,     |
  7: '  |          Variablen- Zeichenketten- und Speicherverwaltung .          |
  8: '  |                                                                      |
  9: '  |   Au×erdem eine formatierte Eingaberoutine die nur die benötigten    |
 10: '  |            Zeichen für die jeweilige Systemzahl zulä×t.              |
 11: '  ------------------------------------------------------------------------
 12: '
 13: ' *** Alertbox: SORRY ***
 14: IF XBIOS(4)<>2      !* wenn aktuelle Bildschirm-Auflösung nicht 640x400:
 15:   ALERT 3,"|SORRY !|Das Programm läuft nur korrekt|mit einem Monochrom-Monitor !",1,"SCHADE !",a|
 16: ENDIF               !* weiter:
 17: CLS                 !* Bildschirm löschen
 18: CLEAR               !* alle Variablen & Felder löschen
 19: '
 20: ' *** Grafik: Titelbild ***
 21: DEFFILL 1,2,3       !* Füllmuster 2,3
 22: PBOX 10,10,630,390  !* äu×ere Boxkontur u. Füllmuster zeichnen
 23: DEFFILL 1,2,2       !* Füllmuster 2,2
 24: PBOX 15,15,625,385  !* innere Boxkontur u. Füllmuster zeichnen
 25: DEFTEXT ,0,900,4    !* Minitext 90 Grad gedreht
 26: TEXT 6,397," 1989, Fred Schaaf, Lindenstr.23, 2900 OLDENBURG, Tel.0441-87770 "
 27: GRAPHMODE 2  !* folgende Grafikausgaben transparent verknüpft
 28: DEFTEXT ,16,0,32    !* Gro×text umrandet
 29: TEXT 40,100,"UMWANDLUNG VON ZAHLEN-SYSTEMEN:"
 30: DEFTEXT ,17,,16     !* Schrifthöhe 16 umrandet
 31: TEXT 50,130,"DEZIMAL-,HEXADEZIMAL-,BINÄR- UND OKTAL-ZAHLEN"
 32: DEFTEXT ,2,,13      !* Normale Schrifthöhe hell
 33: TEXT 175,180,"Ein Demo-Programm in GFA-Basic 3.0"
 34: TEXT 160,200,"mit vielen Kommentaren im Prg.-Listing."
 35: TEXT 115,230,"Menü-und Fensterprogrammierung, Programmsteuerung,"
 36: TEXT 105,250,"Variablen- Zeichenketten- u. Speicherverwaltung u.a."
 37: TEXT 160,280,"Au×erdem eine eigene Eingaberoutine :"
 38: TEXT 80,300,"Nur die benötigten Zeichen für die jeweiligen Systemzahlen"
 39: TEXT 240,320,"werden zugelassen."
 40: DEFTEXT ,8,,6       !* normale Kleischrift
 41: TEXT 225,370,"( Monochrom-Version )"
 42: DEFTEXT ,0,,4       !* Minitext
 43: TEXT 240,6,"Public Domain-Programm."
 44: GRAPHMODE 0  !* Grafmodus zurücksetzen(sonst Fehler bei Esc- & Backspaceeingabe)
 45: '
 46: REPEAT              !* Schleife:
 47: UNTIL MOUSEK OR INP?(2) !* Weiter mit Taste oder Maus
 48: CLS                 !* Titelbild löschen
 49: DIM men$(23)        !* Feld für Menüeinträge
 50: '
 51: ' *** DATA-Werte einlesen ***
 52: i&=-1               !* damit Schleife mit i&=0 anfängt
 53: REPEAT              !* Schleife bis DATA > (23 Durchläufe)
 54:   INC i&            !* i&+1
 55:   READ men$(i&)     !* Menüeinträge einlesen
 56: UNTIL men$(i&)=">"  !* bei DATA > raus
 57: '
 58: men$(i&)=""         !* damit das Data-Ende ( men$(22)= '>' ) nicht sichtbar wird
 59: '
 60: ' *** Datenspeicher ***
 61: DATA DESK        ,  ZAHLEN-SYSTEME
 62: DATA -------------------
 63: DATA 1,2,3,4,5,6,""
 64: DATA MENÜ ---> ,""
 65: DATA OPTIONS,  RUN   ,  EDIT  , SYSTEM  ,""
 66: DATA UMWANDELN, DEZIMAL , HEXADEZ. , BINÄR , OKTAL
 67: DATA >
 68: '
 69: ' *** Ereignisverwaltung ***
 70: MENU men$()        !* stellt das Pull-Down-Menü auf Bildschirm dar
 71: ON MENU GOSUB men  !* Verzweigung nach Anwahl eines Menüeintrags
 72: OPENW 0            !* Pull-Down-Menüleiste vor überschreiben schützen
 73: DO                 !* Schleife:
 74:   ON MENU          !* warten auf Ereignis
 75: LOOP
 76: '
 77: ' **** Die Prozeduren werden mit <Help> geöffnet oder geschlossen! ****
 78: '      ===========================================================
 79: '
 80: ' *** Menü-Leiste ***
 81: > PROCEDURE men
 82:   SELECT MENU(0) !* Verzweigung in Abhängigkeit vom gewählten Menüeintrag:
 83:   CASE 1         !* MENU(1) = ZAHLEN-SYSTEME
 84:     @info_box
 85:   CASE 13        !* MENU(13)= RUN
 86:     RUN
 87:   CASE 14        !* MENU(14)= EDIT
 88:     @edit
 89:   CASE 15        !* MENU(15)= SYSTEM
 90:     @system
 91:   CASE 18        !* MENU(18)= DEZIMAL
 92:     @fenster_1
 93:   CASE 19        !* MENU(18)= HEXADEZ.
 94:     @fenster_2
 95:   CASE 20        !* MENU(19)= BINÄR
 96:     @fenster_3
 97:   CASE 21        !* MENU(20)= OKTAL
 98:     @fenster_4
 99:   ENDSELECT      !* Verzweigung beendet
100:   d|=0  !* Flag für fenster_1-Anwahl zurücksetzen
101:   h|=0  !* dto. für fenster_2
102:   b|=0  !* dto.            _3
103:   o|=0  !* dto.            _4
104: RETURN
105: '
106: ' *** Informations-Box ***
107: > PROCEDURE info_box
108:   text$="[1][GFA-3.0-Programmier-Beispiel:|ZAHLEN-SYSTEME (Jan. 1989)|( Public Domain-Programm )|Fred Schaaf,2900 Oldenburg|Tel.: 0441-87770][ RETURN ]"
109:   ~FORM_ALERT(1,text$) ! lä×t 5 anstatt 4 Textzeilen zu. Siehe ALERT nächste Zeile!
110:   '  ALERT 0,"GFA-3.0-Programmier-Beispiel:|ZAHLEN-SYSTEME (Jan. 1989)|( Public Domain-Programm )|Fred Schaaf,2900 Oldenburg|Tel.: 0441-87770",1,"RETURN",x
111: RETURN
112: '
113: ' *** Alertbox: Zum Editor ? ***
114: > PROCEDURE edit
115:   ALERT 1,"Wirklich zum Editor ?",1," ja | nein ",al|
116:   IF al|=1
117:     EDIT
118:   ENDIF
119: RETURN
120: '
121: ' *** Alertbox: Zum System ? ***
122: > PROCEDURE system
123:   ALERT 3,"Wirklich zum System ?",2,"ja|nein",al|
124:   IF al|=1 !* wenn ja
125:     QUIT  !* zum System zurück
126:   ENDIF
127: RETURN
