'  ________________________________________________________________________
'  |                  UMWANDLUNG VON ZAHLEN-SYSTEMEN.                     |
'  |                  ===============================                     |
'  |  Dieses GfA-BASIC 3.0 Prg. wandelt Dez.-Hex.-Okt.-u.Bin.-Zahlen um.  |
'  |             Dieses Demo-Programm zeigt unter anderen :               |
'  |       Pulldownmenü- und Fensterprogrammierung,Programmsteuerung,     |
'  |          Variablen- Zeichenketten- und Speicherverwaltung .          |
'  |                                                                      |
'  |   Au×erdem eine formatierte Eingaberoutine die nur die benötigten    |
'  |            Zeichen für die jeweilige Systemzahl zulä×t.              |
'  ------------------------------------------------------------------------
'
' *** Alertbox: SORRY ***
IF XBIOS(4)<>2      !* wenn aktuelle Bildschirm-Auflösung nicht 640x400:
  ALERT 3,"|SORRY !|Das Programm läuft nur korrekt|mit einem Monochrom-Monitor !",1,"SCHADE !",a|
ENDIF               !* weiter:
CLS                 !* Bildschirm löschen
CLEAR               !* alle Variablen & Felder löschen
'
' *** Grafik: Titelbild ***
DEFFILL 1,2,3       !* Füllmuster 2,3
PBOX 10,10,630,390  !* äu×ere Boxkontur u. Füllmuster zeichnen
DEFFILL 1,2,2       !* Füllmuster 2,2
PBOX 15,15,625,385  !* innere Boxkontur u. Füllmuster zeichnen
DEFTEXT ,0,900,4    !* Minitext 90 Grad gedreht
TEXT 6,397," 1989, Fred Schaaf, Lindenstr.23, 2900 OLDENBURG, Tel.0441-87770 "
GRAPHMODE 2  !* folgende Grafikausgaben transparent verknüpft
DEFTEXT ,16,0,32    !* Gro×text umrandet
TEXT 40,100,"UMWANDLUNG VON ZAHLEN-SYSTEMEN:"
DEFTEXT ,17,,16     !* Schrifthöhe 16 umrandet
TEXT 50,130,"DEZIMAL-,HEXADEZIMAL-,BINÄR- UND OKTAL-ZAHLEN"
DEFTEXT ,2,,13      !* Normale Schrifthöhe hell
TEXT 175,180,"Ein Demo-Programm in GFA-Basic 3.0"
TEXT 160,200,"mit vielen Kommentaren im Prg.-Listing."
TEXT 115,230,"Menü-und Fensterprogrammierung, Programmsteuerung,"
TEXT 105,250,"Variablen- Zeichenketten- u. Speicherverwaltung u.a."
TEXT 160,280,"Au×erdem eine eigene Eingaberoutine :"
TEXT 80,300,"Nur die benötigten Zeichen für die jeweiligen Systemzahlen"
TEXT 240,320,"werden zugelassen."
DEFTEXT ,8,,6       !* normale Kleischrift
TEXT 225,370,"( Monochrom-Version )"
DEFTEXT ,0,,4       !* Minitext
TEXT 240,6,"Public Domain-Programm."
GRAPHMODE 0  !* Grafmodus zurücksetzen(sonst Fehler bei Esc- & Backspaceeingabe)
'
REPEAT              !* Schleife:
UNTIL MOUSEK OR INP?(2) !* Weiter mit Taste oder Maus
CLS                 !* Titelbild löschen
DIM men$(23)        !* Feld für Menüeinträge
'
' *** DATA-Werte einlesen ***
i&=-1               !* damit Schleife mit i&=0 anfängt
REPEAT              !* Schleife bis DATA > (23 Durchläufe)
  INC i&            !* i&+1
  READ men$(i&)     !* Menüeinträge einlesen
UNTIL men$(i&)=">"  !* bei DATA > raus
'
men$(i&)=""         !* damit das Data-Ende ( men$(22)= '>' ) nicht sichtbar wird
'
' *** Datenspeicher ***
DATA DESK        ,  ZAHLEN-SYSTEME
DATA -------------------
DATA 1,2,3,4,5,6,""
DATA MENÜ ---> ,""
DATA OPTIONS,  RUN   ,  EDIT  , SYSTEM  ,""
DATA UMWANDELN, DEZIMAL , HEXADEZ. , BINÄR , OKTAL
DATA >
'
' *** Ereignisverwaltung ***
MENU men$()        !* stellt das Pull-Down-Menü auf Bildschirm dar
ON MENU GOSUB men  !* Verzweigung nach Anwahl eines Menüeintrags
OPENW 0            !* Pull-Down-Menüleiste vor überschreiben schützen
DO                 !* Schleife:
  ON MENU          !* warten auf Ereignis
LOOP
'
' **** Die Prozeduren werden mit <Help> geöffnet oder geschlossen! ****
'      ===========================================================
'
' *** Menü-Leiste ***
> PROCEDURE men
  SELECT MENU(0) !* Verzweigung in Abhängigkeit vom gewählten Menüeintrag:
  CASE 1         !* MENU(1) = ZAHLEN-SYSTEME
    @info_box
  CASE 13        !* MENU(13)= RUN
    RUN
  CASE 14        !* MENU(14)= EDIT
    @edit
  CASE 15        !* MENU(15)= SYSTEM
    @system
  CASE 18        !* MENU(18)= DEZIMAL
    @fenster_1
  CASE 19        !* MENU(18)= HEXADEZ.
    @fenster_2
  CASE 20        !* MENU(19)= BINÄR
    @fenster_3
  CASE 21        !* MENU(20)= OKTAL
    @fenster_4
  ENDSELECT      !* Verzweigung beendet
  d|=0  !* Flag für fenster_1-Anwahl zurücksetzen
  h|=0  !* dto. für fenster_2
  b|=0  !* dto.            _3
  o|=0  !* dto.            _4
RETURN
'
' *** Informations-Box ***
> PROCEDURE info_box
  text$="[1][GFA-3.0-Programmier-Beispiel:|ZAHLEN-SYSTEME (Jan. 1989)|( Public Domain-Programm )|Fred Schaaf,2900 Oldenburg|Tel.: 0441-87770][ RETURN ]"
  ~FORM_ALERT(1,text$) ! lä×t 5 anstatt 4 Textzeilen zu. Siehe ALERT nächste Zeile!
  '  ALERT 0,"GFA-3.0-Programmier-Beispiel:|ZAHLEN-SYSTEME (Jan. 1989)|( Public Domain-Programm )|Fred Schaaf,2900 Oldenburg|Tel.: 0441-87770",1,"RETURN",x
RETURN
'
' *** Alertbox: Zum Editor ? ***
> PROCEDURE edit
  ALERT 1,"Wirklich zum Editor ?",1," ja | nein ",al|
  IF al|=1
    EDIT
  ENDIF
RETURN
'
' *** Alertbox: Zum System ? ***
> PROCEDURE system
  ALERT 3,"Wirklich zum System ?",2,"ja|nein",al|
  IF al|=1 !* wenn ja
    QUIT  !* zum System zurück
  ENDIF
RETURN
'
' *** DEZIMAL >>> HEX.-BIN.-OKT.-UMWANDLUNG ***
> PROCEDURE fenster_1
  LOCAL f|,dez !* diese Variablen nur in dieser Procedur gültig
  f|=0         !* Flag für Fehlerroutine
  d|=1         !* siehe Zeile 99
  TITLEW #1,"DEZ. >>> HEX.-BIN.-OKT.-UMWANDLUNG :"   !* oberste Zeile
  INFOW #1," Bereich: -2147483648 bis +2147483647 !" !* darunter Info.-Zeile
  OPENW 1      !* Fenster_1 oben links öffnen
  CLEARW 1     !*    "       "     "   löschen
  '                      !* Variablen für Eingaberoutine:
  l&=11                  !* maximale Stringlänge
  u$="DEZ. "             !* String für Eingaberoutine
  erlaubt$="-+0123456789"!* nur diese Zeichen sind erlaubt
  punkte$=STRING$(l&,".")!* Anzahl Punkte bis max. Länge
  leer$=""+STRING$(l&," ")  !* Punkte Löschen
  rueckgabe%=*e$         !* Rückgabeadresse beinhaltet eingabe$
  DEFTEXT ,0,,6  !* Kleinschrift
  TEXT 5,42,"( Mit Vorzeichen -/+ )"
  PRINT
  DEFTEXT ,0,,13 !* Normalschrift
  PRINT " DEZIMAL-ZAHL EINGEBEN :";
  '
  '        !*** GOSUB Form_eingabe(Zeile, Spalte, Max. Eingabelänge, u$,
  '             erlaubte Zeichen, ...-String, Rueckgabe-adresse für e$
  '             =======================================================
  '
  @form_eingabe(7,4,l&,u$,erlaubt$,punkte$,leer$,rueckgabe&)
  dez=VAL(e$)
  '
  IF LEFT$(e$,1)<>"+" AND LEFT$(e$,1)<>"-" !* Vorzeichen ?
    PRINT " Vorzeichen vergessen !"
    GOTO marke             !* wegen Doppel-Anzeige Sprung zur Zeile 170
  ENDIF
  IF dez>+2147483647 OR dez<-2147483648 !* Fehlerroutine
    f|=1                   !* Bereich überschritten
    ~FORM_ALERT(1,ERR$(2)) !* Info-Box (Fehlermeldung 2)
    @fenster_1             !* ohne Abbruch
  ELSE                     !* wenn kein Fehler Ergebniss anzeigen:
    PRINT '"HEX. ";HEX$(dez)
    PRINT '"OKT. ";OCT$(dez)
    PRINT '"BIN. ";BIN$(dez)
  ENDIF
  marke:     !* siehe Zeile 157
  IF f|=0    !* Bereich nicht überschritten
    @nochmal
  ENDIF
RETURN
'
' *** HEXADEZIMAL >>> DEZ.-BIN.-OKT.-UMWANDLUNG ***
' ( fehlende Kommentare siehe auch PROC. fenster_1 )
> PROCEDURE fenster_2
  LOCAL hex
  h|=1
  TITLEW #2,"HEX. >>> DEZ.-BIN.-OKT.-UMWANDLUNG :"
  INFOW #2," Bereich : 1 bis FFFFFFFF !"
  OPENW 2
  CLEARW 2
  l&=8
  u$="HEX. "
  erlaubt$="1234567890abcdefABCDEF"
  punkte$=STRING$(l&,".")
  leer$=STRING$(l&," ")
  rueckgabe%=*e$
  PRINT
  DEFTEXT ,0,,13
  PRINT " HEXADEZIMAL-ZAHL EINGEBEN :  ";
  @form_eingabe(7,4,l&,u$,erlaubt$,punkte$,leer$,rueckgabe&)
  e$="&H"+e$
  hex=VAL(e$)
  PRINT '"DEZ. ";hex
  PRINT '"OCT. ";OCT$(hex)
  PRINT '"BIN. ";BIN$(hex)
  @nochmal
RETURN
'
' *** BINÄR >>> DEZ.-HEX.-OKT.-UMWANDLUNG ***
' ( fehlende Kommentare siehe auch PROC. fenster_1 )
> PROCEDURE fenster_3
  LOCAL bin,bin$
  b|=1
  TITLEW #3,"BIN. >>> DEZ.-HEX.-OKT.-UMWANDLUNG :"
  INFOW #3," Bereich : Bis 32 Stellen (32 bit) !"
  OPENW 3
  CLEARW 3
  l&=32
  u$="BIN. "
  erlaubt$="10"
  punkte$=STRING$(l&,".")
  leer$=STRING$(l&," ")
  rueckgabe%=*e$
  PRINT
  DEFTEXT ,0,,13
  PRINT " BINÄR-ZAHL EINGEBEN :"
  @form_eingabe(7,4,l&,u$,erlaubt$,punkte$,leer$,rueckgabe&)
  bin$="&X"+e$
  bin=VAL(bin$)
  PRINT '"DEZ. ";VAL(bin$)
  PRINT '"HEX. ";HEX$(bin)
  PRINT '"OCT. ";OCT$(bin)
  @nochmal
RETURN
'
' *** OKTAL >>> DEZ.-HEX.-BIN.-UMWANDLUNG ***
' ( fehlende Kommentare siehe auch PROC. fenster_1 )
> PROCEDURE fenster_4
  LOCAL f|,okt,okt$
  f|=0
  o|=1
  TITLEW #4,"OKT. >>> DEZ.-HEX.-BIN.-UMWANDLUNG :"
  INFOW #4," Bereich : 1 bis 37777777777 !"
  OPENW 4
  CLEARW 4
  l&=11
  u$="OKT. "
  erlaubt$="01234567"
  punkte$=STRING$(l&,".")
  leer$=STRING$(l&," ")
  rueckgabe%=*e$
  PRINT
  DEFTEXT ,0,,13
  PRINT "  OKTAL-ZAHL EINGEBEN :    ";
  @form_eingabe(7,4,l&,u$,erlaubt$,punkte$,leer$,rueckgabe&)
  okt$="&O"+e$
  okt=VAL(okt$)
  eingabe=VAL(e$)
  '
  IF eingabe>37777777777    !* wenn Bereich überschritten:
    f|=1                    !* Fehler!
    ~FORM_ALERT(1,ERR$(71)) !* Info-Box (Fehlermeldung 71)
    @fenster_4              !* ohne Abbruch
    '
  ELSE                      !* wenn kein Fehler:
    PRINT                   !* Ergebnis anzeigen
    PRINT '"DEZ. ";VAL(okt$)
    PRINT '"HEX. ";HEX$(okt)
    PRINT '"BIN. ";BIN$(okt)
  ENDIF
  IF f|=0                   !* kein Fehler
    @nochmal
  ENDIF
RETURN
'
' *** Alert-Box ( und nochmal) ***
> PROCEDURE nochmal
  ALERT 0,"und nochmal? ",1," JA |MENÜ",a|
  IF a|=1 AND d|=1  !* wenn ja und d|=1
    @fenster_1      !* zurück zur Proc. fenster_1
  ELSE IF a|=1 AND h|=1  !* siehe oben (ELSE IF: Vermeiden vieler ENDIF !)
    @fenster_2
  ELSE IF a|=1 AND b|=1  !*   "    "
    @fenster_3
  ELSE IF a|=1 AND o|=1  !*   "    "
    @fenster_4
  ENDIF
  DO
    EXIT IF a|=2    !* raus wenn MENÜ angeklickt
  LOOP
RETURN
'
' ***  Eigene Formatierte Eingabe-Routine ***
> PROCEDURE form_eingabe(x&,y&,l&,u$,erlaubt$,punkte$,leer$,VAR rueckgabe&)
  LOCAL asc|,asc$,eigabe$,p&,zurueck!
  eingabe$=punkte$
  p&=0               !* Position im eingabe$
  zurueck!=FALSE     !* Flag auf 0 gesetzt (logisch falsch)
  '
  REPEAT
    PRINT AT(x&,y&);eingabe$;  !* punkte$ an x(Spalte)-y(Zeile)-Pos. schreiben
    asc|=INP(2)      !* ASCII-Code von Tastatur einlesen
    asc$=CHR$(asc|)  !* ASCII-Zeichen der gedrückten Taste
    IF INSTR(erlaubt$,asc$)<>0 AND p&<l&  !* auf erlaubte Zeichen prüfen
      eingabe$=LEFT$(eingabe$,p&)+LEFT$(asc$,p&+1)
      INC p&        !* Position +1 (nächstes Zeichen)
    ELSE
      PRINT CHR$(7) !* Ton ( wenn asc$ nicht erlaubt )
    ENDIF
    '
    SELECT asc|     !* Verzweigungsbedingung je nach ASCII-Code:
    CASE 13         !* <Return> gedrückt
      zurueck!=TRUE !* auf -1 (logisch wahr) gesetzt
      PRINT AT(x&-5,y&);u$+eingabe$+" ="+leer$;CHR$(27)+"p" !* String schreiben
      '                                     !*    "      " = Text unterstrichen
      *rueckgabe%=eingabe$
    CASE 8          !* <Backspace> gedrückt
      ON ERROR GOSUB fehler_abfang          !* wenn n u r <Backspace> gedrückt
      eingabe$=LEFT$(eingabe$,p&-1)+MID$(punte$,p&+1)+"."
      '             !* oben: Letztes Zeichen löschen und Punkt setzen
      DEC p&        !* Position -1 (letztes Zeichen löschen)
      weiter:       !* Ansprung-Marke aus Fehlerabfang-Routine (siehe Zeile 327)
    CASE 27         !* <Esc> gedrückt
      p&=0          !* String löschen, Punkte schreiben:
      eingabe$=STRING$(l&,".")
    ENDSELECT       !* Verzweigungsbedingungen abgearbeitet
  UNTIL zurueck!    !* raus wenn zurueck! =-1 (logisch wahr)
RETURN
'
' *** Fehlerabfang-Routine ***
> PROCEDURE fehler_abfang
  IF ERR=10         !* wenn Fehlermeldung 10
    RESUME weiter   !* bei Marke ( weiter: )ohne Fehlerbox im Pgr. fortfahren
  ENDIF
RETURN
'
' ======= Progr.- Ende =======
