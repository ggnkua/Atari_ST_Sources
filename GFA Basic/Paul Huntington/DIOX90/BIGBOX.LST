Procedure Radio3_Bigbox (Rbutton$,Old_stat$,New_stat)
  If Old_stat$="Radioc1"
    @Radioc1(0)
  Endif
  If Old_stat$="Radioc2"
    @Radioc2(0)
  Endif
  If Old_stat$="Radioc3"
    @Radioc3(0)
