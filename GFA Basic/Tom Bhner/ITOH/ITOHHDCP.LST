'
PROCEDURE hardcopy_c.itoh_8510(dump_screen_address%)
  '
  ' Distributed by GFA Systemtechnik, DÅsseldorf, West Germany.
  '
  ' After Frank Ostrowski "GFA Basic", p.73 f. (first German edition).
  ' Adapted for printer C. Itoh 8510 (Binder 8510) and for good
  ' Basic style by Tom BÅhner.
  '
  ' Address any questions concerning this procedure to:
  ' Tom BÅhner, LÅneburger Str. 6, D-1000 Berlin 21
  ' or call me at: 030 / 393 22 73.
  ' If I have moved meanwhile, GFA will give you my new address or forward
  ' any written comments to me (I am club member no. 00824).
  '
  ' This procedure dumps a hardcopy of the screen on a C.Itoh 8510 (Binder 8510)
  ' printer. The hardcopy is centered on the (12" long) page on both axes.
  ' It has got nearly the same size as the b/w monitor's (SM 124) screen, but
  ' is turned by 90 degrees clockwise.
  '
  ' Call as:
  ' @Hardcopy_C.itoh_8510(Dump_screen_address%)
  ' The advantage of passing the screen address as parameter, instead of
  ' doing an XBIOS(3) call in the routine, is: You dump a screen, while
  ' the user looks at another one! (E.g. a message: "Please wait")
  '
  ' Caution!
  ' This procedure forces a garbage collect, so VARPTR values of string
  ' variables may have changed after this procedure is run.
  '
  ' When this procedure returns, the following printer features are set:
  ' Linefeed 1/6 inch
  ' Pica characters
  ' Bidirectional printing
  '
  ' Force garbage collect, as GFA Basic hangs if a garbage collect is made
  ' when a local string variable has got the same name as a global one
  ' and a new array has been dimensioned (that's what happens now):
  VOID FRE(0)
  '
  LOCAL pica$,linefeed_14_144_inch$,linefeed_1_6_inch$,graphmode_400_columns$
  LOCAL push_right$,next_line$,hardcopy_buffer$,column_byte%,line_byte%
  LOCAL buffer%,i%,unidirectional$,bidirectional$,orig_byte%,swapped_byte%
  LOCAL linefeed_9_144_inch$,linefeed_25_144_inch$
  '
  hardcopy:
  DATA 1,2,4,8,16,32,64,128
  '
  ' Local constants and local array:
  DIM bit.itoh%(7)
  RESTORE hardcopy
  FOR i%=0 TO 7
    READ bit.itoh%(i%)
  NEXT i%
  pica$=CHR$(27)+"N"
  unidirectional$=CHR$(27)+">"
  bidirectional$=CHR$(27)+"<"
  linefeed_14_144_inch$=CHR$(27)+"T14"
  linefeed_1_6_inch$=CHR$(27)+"A"
  linefeed_9_144_inch$=CHR$(27)+"T09"
  linefeed_25_144_inch$=CHR$(27)+"T25"
  graphmode_400_columns$=CHR$(27)+"S0400"
  push_right$=SPACE$(15)
  next_line$=CHR$(13)+CHR$(10)
  hardcopy_buffer$=SPACE$(400)
  '
  ' Prevent graphics characters from being disturbed by printer drivers,
  ' so use OPEN "LST:" instead of LPRINT or OPEN "PRT:":
  OPEN "",#99,"LST:"
  '
  ' Center hardcopy vertically (found out by trial-and-error):
  PRINT #99,linefeed_9_144_inch$;
  FOR i%=1 TO 21
    PRINT #99,next_line$;
  NEXT i%
  '
  ' Print hardcopy:
  PRINT #99,pica$;linefeed_14_144_inch$;unidirectional$;
  FOR column_byte%=dump_screen_address% TO dump_screen_address%+79
    buffer%=VARPTR(hardcopy_buffer$)
    FOR line_byte%=column_byte%+399*80 TO column_byte% STEP -80
      orig_byte%=PEEK(line_byte%)
      ' Here the bits' positions are changed: bit0 gets bit7, bit1 gets bit6...
      ' This is necessary because of the unusual Itoh graphics byte structure:
      swapped_byte%=0
      IF orig_byte%<>0    ! Don't swap bits if byte is $00 (--> faster)
        FOR i%=0 TO 7
          IF (orig_byte% AND bit.itoh%(i%))
            swapped_byte%=swapped_byte%+bit.itoh%(7-i%)
          ENDIF
        NEXT i%
      ENDIF
      POKE buffer%,swapped_byte%
      INC buffer%
    NEXT line_byte%
    PRINT #99,push_right$;graphmode_400_columns$;hardcopy_buffer$;next_line$;
  NEXT column_byte%
  '
  ' Skip rest of page and take same position relative to TOF as before hardcopy:
  ' (72 lines per page assumed!)
  PRINT #99,linefeed_9_144_inch$;
  FOR i%=1 TO 41
    PRINT #99,next_line$;
  NEXT i%
  PRINT #99,linefeed_25_144_inch$;
  PRINT #99,next_line$;next_line$;
  '
  ' Switch back to standard values:
  PRINT #99,linefeed_1_6_inch$;bidirectional$;
  '
  CLOSE #99
  '
  ' Forget the local array:
  ERASE bit.itoh%()
RETURN
