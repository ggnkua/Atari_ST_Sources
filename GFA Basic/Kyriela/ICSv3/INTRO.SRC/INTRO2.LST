Mono=1
Mfx=0
If Xbios(4)=2
  Mono=2
  Mfx=1
Endif
On Break Gosub Break
Dim Blit_s%(5),Blit_d%(5),Blit_p%(8)
'
' voreinstellungen
'
Out 4,18
Out 4,22
For I=0 To 15
  Setcolor I,0,0,0
Next I
Dim Fx$(320)
Reserve 200000
Sample%=Himem+2
Dim Samroutine%(1000)
Gosub Parameter_laden
If Digi=1
  Gosub Sample_laden
Endif
Virtuell%=Sample%+Samlen%+36
If Bpic=1
  Gosub Bildload
Endif
If Apic=1
  Gosub Degas_laden
Endif
If X32=1
  Gosub Xbiosload
Endif
Sget Pic1$
'
' intro beginn
'
Do
  If Apic=1
    Sput Pic1$
  Endif
  If Digi=1
    Gosub Play
  Endif
  If X32=1 And Digi=0
    Gosub Xplay
  Endif
  Pause Lang
  If Inkey$<>""
    Out 4,128
    Out 4,1
    If X32=1
      Gosub Xplay
    Endif
    Quit
  Endif
  If Bpic=1
    Sput Pic2$
    If Digi=1
      Gosub Play
    Endif
    If X32=1 And Digi=0
      Gosub Xplay
    Endif
    Pause Lang
  Endif
  If Inkey$<>""
    Out 4,128
    Out 4,1
    If X32=1
      Gosub Xplay
    Endif
    Quit
  Endif
  If Exitf$="A"
    Out 4,128
    Out 4,1
    If X32=1
      Gosub Xplay
    Endif
    Quit
  Endif
Loop
'
' proceduren
'
Procedure Parameter_laden
  Open "I",#1,"A:\Auto\introprg.LST"
  Input #1,Sample$
  Input #1,Bild$
  Input #1,Bild2$
  Input #1,Lang
  Input #1,Speed%
  Input #1,Xbios$
  Input #1,Exitf$
  Input #1,Fx$
  If Xbios(4)=2
    Input #1,Bild$
    Input #1,Bild2$
  Endif
  Close #1
  If Bild$<>""
    Apic=1
  Endif
  If Sample$<>""
    Digi=1
  Endif
  If Xbios$<>""
    X32=1
  Endif
  If Bild2$<>""
    Bpic=1
  Endif
  If Xbios$<>""
    X32=1
  Endif
Return
'
'
'
Procedure Degas_laden
  Sadr%=Xbios(2)
  Bload Bild$,Virtuell%-34
  Gosub Blit_parameter_setzen(Virtuell%,Sadr%)
  Cls
  If Fx$="N"
    For I=0 To 15
      Void Xbios(7,I,Dpeek(Virtuell%-32+I*2))
    Next I
    For A%=0 To 158*Mono Step 2
      X1%=160*Mono+A%
      X2%=159*Mono-A%
      Y0%=A%*(99*Mono)/(159*Mono)
      Y1%=100*Mono+Y0%
      Y2%=100*Mono-Y0%
      Gosub Blit(X2%,Y1%,X1%,Y1%,X2%,Y1%,3)
      Gosub Blit(X2%,Y2%,X1%,Y2%,X2%,Y2%,3)
      Gosub Blit(X2%,Y2%,X2%,Y1%,X2%,Y2%,3)
      Gosub Blit(X1%,Y2%,X1%,Y1%,X1%,Y2%,3)
    Next A%
    For A%=159*Mono To 1 Step -2
      X1%=160*Mono+A%+Mfx
      X2%=159*Mono-A%+Mfx
      Y0%=(A%+Mfx)*(99*Mono)/(159*Mono)
      Y1%=100*Mono+Y0%
      Y2%=100*Mono-Y0%
      Gosub Blit(X2%,Y1%,X1%,Y1%,X2%,Y1%,3)
      Gosub Blit(X2%,Y2%,X1%,Y2%,X2%,Y2%,3)
      Gosub Blit(X2%,Y2%,X2%,Y1%,X2%,Y2%,3)
      Gosub Blit(X1%,Y2%,X1%,Y1%,X1%,Y2%,3)
    Next A%
  Endif
  If Fx$="V"
    For I=0 To 15
      Void Xbios(7,I,Dpeek(Virtuell%-32+I*2))
    Next I
    For A%=0 To 318*Mono Step 2
      Gosub Blit(A%,0,A%,199*Mono,A%,0,3)
    Next A%
    For A%=319*Mono To 1 Step -2
      Gosub Blit(A%+Mfx,0,A%+Mfx,319*Mono,A%+Mfx,0,3)
    Next A%
  Endif
  If Fx$="H"
    For I=0 To 15
      Void Xbios(7,I,Dpeek(Virtuell%-32+I*2))
    Next I
    For A%=0 To 198*Mono Step 2
      Gosub Blit(0,A%,319*Mono,A%,0,A%,3)
    Next A%
    For A%=199*Mono To 1 Step -2
      Gosub Blit(0,A%+Mfx,319*Mono,A%+Mfx,0,A%+Mfx,3)
    Next A%
  Endif
  If Fx$="Z"
    For I=0 To 15
      Void Xbios(7,I,Dpeek(Virtuell%-32+I*2))
    Next I
    For A%=0 To 318*Mono Step 2
      Gosub Blit(A%,0,A%,199*Mono,A%,0,3)
    Next A%
    For A%=0 To 198*Mono Step 2
      Gosub Blit(0,A%,319*Mono,A%,0,A%,3)
    Next A%
    For A%=319*Mono To 1 Step -1
      Gosub Blit(A%,0,A%,199*Mono,A%,0,3)
    Next A%
  Endif
  If Mfx=1
    For I=0 To 2
      Box I,I,640-I,400-I
    Next I
  Endif
Return
'
'
'
Procedure Sample_laden
  Restore Maschinensprache_daten
  Zeiger%=Varptr(Samroutine%(0))
  Read Zahl%
  Repeat
    Poke Zeiger%,Zahl%
    Inc Zeiger%
    Read Zahl%
  Until Zahl%=-1
  Open "I",#1,Sample$
  Samlen%=Lof(#1)
  Close #1
  Bload Sample$,Sample%
  Rsamstart=Varptr(Samroutine%(0))+28 ! REM Address of sample
  Rsamend=Varptr(Samroutine%(0))+32   ! REM End address
  Rsamspeed=Varptr(Samroutine%(0))+36 ! REM Speed in KHz
  Lpoke Rsamstart,Sample%             ! REM Set up routine
  Lpoke Rsamend,Sample%+Samlen%
  Lpoke Rsamspeed,Speed%
  Routine=Varptr(Samroutine%(0))+40
  For I=0 To 3
    Sound 0,1,1,15,15
  Next I
Return
'
'
'
Procedure Play
  Call Routine !  REM Play the sample
Return
Procedure Bildload
  Sadr=Virtuell%
  Orig=Xbios(2)
  Src=Virtuell%
  Bload Bild2$,Sadr-34
  Void Xbios(5,L:Src,L:-1,-1)
  Sget Pic2$
  Void Xbios(5,L:Orig,L:-1,-1)
Return
Procedure Xbiosload
  Open "I",#1,Xbios$
  Music$=Input$(Lof(#1),#1)
  Close #1
Return
Procedure Xplay
  Void Xbios(32,L:Varptr(Music$))
Return
'
'
' Diese beiden Prozeduren unterstÅtzen den Bitblt-Befehl. Die Prozedur
' BLIT_PARAMETER_SETZEN setzt wie der Name schon sagt, die Bildschirm-
' spezifischen Daten fÅr den Bitblt_Befehl. öbergeben wird als Parameter die
' Adresse des Quell- und Zielrasters.
' Die Prozedur Blit fÅhrt dann den BITBLT-Befehl aus. öbergeben werden die
' Eckpunkte des Quellrechtecks und der linke obere Eckpunkt des Zielrechtecks,
' sowie der Schreibmodus (wie bei PUT).
'
'
'
Procedure Blit(Sax%,Say%,Sex%,Sey%,Dax%,Day%,Modus%)
  Blit_p%(0)=Sax%
  Blit_p%(1)=Say%
  Blit_p%(2)=Sex%
  Blit_p%(3)=Sey%
  Blit_p%(4)=Dax%
  Blit_p%(5)=Day%
  Blit_p%(6)=(Sex%-Sax%)+Dax%
  Blit_p%(7)=(Sey%-Say%)+Day%
  Blit_p%(8)=Modus%
  Bitblt Blit_s%(),Blit_d%(),Blit_p%()
Return
Procedure Blit_parameter_setzen(Von_bild%,Nach_bild%)
  Local Aufloesung%,A%
  Aufloesung%=Xbios(4)
  Blit_s%(0)=Von_bild%
  Blit_s%(1)=320
  If Aufloesung%>0
    Add Blit_s%(1),320
  Endif
  Blit_s%(2)=200
  If Aufloesung%>1
    Add Blit_s%(2),200
  Endif
  Blit_s%(3)=Blit_s%(1)/16
  Blit_s%(4)=0
  Blit_s%(5)=4
  If Aufloesung%=1
    Blit_s%(5)=2
  Endif
  If Aufloesung%=2
    Blit_s%(5)=1
  Endif
  For A%=1 To 5
    Blit_d%(A%)=Blit_s%(A%)
  Next A%
  Blit_d%(0)=Nach_bild%
Return
Procedure Break
  Setcolor 0,7,7,7
  Out 4,128
  Out 4,1
Return
