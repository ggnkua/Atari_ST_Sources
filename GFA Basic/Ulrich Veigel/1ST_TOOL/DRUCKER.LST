  Dpoke Gintin+2,Fo_dilittlx%
  Dpoke Gintin+4,Fo_dilittly%
  Dpoke Gintin+6,Fo_dilittlw%
  Dpoke Gintin+8,Fo_dilittlh%
  Dpoke Gintin+10,Fo_dibigx%
  Dpoke Gintin+12,Fo_dibigy%
  Dpoke Gintin+14,Fo_dibigw%
  Dpoke Gintin+16,Fo_dibigh%
  Gemsys 51
  Fo_direturn%=Dpeek(Gintout)
Return
Procedure Form_center(Fo_ctree%,P_fo_cx%,P_fo_cy%,P_fo_cw%,P_fo_ch%)
  Lpoke Addrin,Fo_ctree%
  Gemsys 54
  *P_fo_cx%=Dpeek(Gintout+2)
  *P_fo_cy%=Dpeek(Gintout+4)
  *P_fo_cw%=Dpeek(Gintout+6)
  *P_fo_ch%=Dpeek(Gintout+8)
Return
Procedure Graf_rubberbox(Gr_rx%,Gr_ry%,Gr_rminwidth%,Gr_rminheight%,P_gr_rlastwidth%,P_gr_rlastheight%)
