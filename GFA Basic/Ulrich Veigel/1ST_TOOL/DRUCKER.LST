'     Druckeranpassung
'
' Routinen zur Anpassung von GFA-BASIC-Programmen an den jeweiligen
' Drucker.
'
' Į 1987 by UVS, Mönchseestr. 83-85 7100 Heilbronn
'
' Autor: Ulrich Veigel
'
' Diese Routine ist Bestandteil des 1st BASIC Tool, einer Sammlung
' wichtiger Hilfsprogramme für's GFA-BASIC.
'
' Die Routine kann ohne Lizenzzahlungen in eigenen Programmen verwendet
' werden, allerdings mu× im Programm (oder der Dokumentation) gut sichtbar
' ein Hinweis auf unsere Routine angebracht werden.
' Dieser kann z.B. so lauten:
'
' "Programm XY verwendet die Druckeranpassung aus dem 1st BASIC Tool von UVS"
'
' Erforderliche Festlegungen zu Programmbeginn:
Procedure Start_druck !Mu× zu Beginn aufgerufen werden
  '                    oder die Deklarationen müssen im Hauptprogramm erfolgen
  Druck_ok=63 !OK-Button
  L1=2   !Diese drei Variablen sind zur Verarbeitung (Beschreiben
  L7=8   ! und Lesen der Dialogbox notwendig und sollten nicht verändert
  L34=61 ! werden.
  Object_druck=0 !Baum-Nummer innerhalb des RSC-Files (kann selbstverst. geändert werden !)
  Dim Zeichen$(40),Zeichen(40) !Arrays, die die Zeichen (Zeichen$()) und ihre neuen Codes (Zeichen()) enthalten
Return
'
' Die einzelnen Proceduren der Druckeranpassung:
'
' Druck_vor: Voreinstellung der Druckeranpassung (ATARI-Codes)
' Druckeranpassung: Dialogbox zur Druckeranpassung
' Save_printer: Abspeichern des Druckertreibers
' Load_printer: Einladen eines Druckertreibers
' Wandeln: Wandelt Strings entsprechend der Druckeranpassung
'
' Die beiden Proceduren "Save_printer" und "Load_printer" benötigen
' in der vorliegenden Fassung die Fileselect-Box aus dem 1st BASIC Tool.
' Eine Anpassung an die "Standard"-Fileselect-Box stellt allerdings kein
' Problem dar (Siehe Demo-Programm DEMO.BAS !).
'
'
' Folgende GEM-Routinen können Sie selbstverständlich auch aus
' anderer Quelle verwenden:
'
Procedure Rsrc_free
  Gemsys 111
  Re_freturn%=Dpeek(Gintout)
Return
Procedure Rsrc_gaddr(Re_gtype%,Re_gindex%,P_re_gaddr%)
  Dpoke Gintin,Re_gtype%
  Dpoke Gintin+2,Re_gindex%
  Gemsys 112
  Re_greturn%=Dpeek(Gintout)
  *P_re_gaddr%=Lpeek(Addrout)
Return
Procedure Put_string(Form_index%,Objc_index%,P_string$)
  @Rsrc_gaddr(0,Form_index%,*Form_adr%) !Formularadresse->form_adr%
  Objc_adr%=Form_adr%+Objc_index%*24 !Objektadresse  ->objc_adr%
  Tedinfo_adr%=Lpeek(Objc_adr%+12)   !TEDINFO-Adresse->tedinfo_adr%
  String_adr%=Lpeek(Tedinfo_adr%)    !String-Adresse ->string_adr%
  I%=0
  For I%=0 To Len(P_string$)-1
    Poke String_adr%+I%,Asc(Mid$(P_string$,I%+1,1))        !Zeichen holen
  Next I%
  Poke String_adr%+I%,0
Return
Procedure Get_string(Form_index%,Objc_index%,P_string%)
  @Rsrc_gaddr(0,Form_index%,*Form_adr%) !Formularadresse->form_adr%
  Objc_adr%=Form_adr%+Objc_index%*24 !Objektadresse  ->objc_adr%
  Tedinfo_adr%=Lpeek(Objc_adr%+12)   !TEDINFO-Adresse->tedinfo_adr%
  String_adr%=Lpeek(Tedinfo_adr%)    !String-Adresse ->string_adr%
  I%=-1
  Repeat
    I%=I%+1
    Zstr$=Chr$(Peek(String_adr%+I%))!Zeichen holen
  Until Zstr$<>" "
  Zstr$=""
  Repeat
    Ii%=Peek(String_adr%+I%)        !Zeichen holen
    If Ii%<>0
      Zstr$=Zstr$+Chr$(Ii%)         !an String anheften
    Endif
    I%=I%+1
  Until Ii%=0
  *P_string%=Zstr$
Return
Procedure Formular(Index%,End_status%)
  @Wind_update(1)                   !Benutzer sperren
  @Rsrc_gaddr(0,Index%,*Ind_adr%)   !Formularadresse holen
  @Form_center(Ind_adr%,*For_x%,*For_y%,*For_w%,*For_h%)
  Get For_x%,For_y%,For_w%+For_x%+1,For_h%+For_y%+1,Rette$
  @Form_dial(0,0,0,0,0,For_x%,For_y%,For_w%,For_h%)
  @Form_dial(1,0,0,0,0,For_x%,For_y%,For_w%,For_h%)
  @Objc_draw(Ind_adr%,Index%,8,For_x%,For_y%,For_w%,For_h%)
  @Wind_update(0)                   !Benutzer zulassen
  @Form_do(Ind_adr%,0)              !Formular editieren lassen
  Rueck%=Fo_doreturn%               !Rückgabeknopf
  @Form_dial(2,0,0,0,0,For_x%,For_y%,For_w%,For_h%)
  @Form_dial(3,0,0,0,0,For_x%,For_y%,For_w%,For_h%)
  @Objc_change(Ind_adr%,Rueck%,0,0,0,0,0,End_status%,0)
  Put For_x%,For_y%,Rette$
Return
Procedure Objc_draw(Ob_drtree%,Ob_drstartob%,Ob_drdepth%,Ob_drxclip%,Ob_dryclip%,Ob_drwclip%,Ob_drhclip%)
  Dpoke Gintin,Ob_drstart_ob%
  Dpoke Gintin+2,Ob_drdepth%
  Dpoke Gintin+4,Ob_drxclip%
  Dpoke Gintin+6,Ob_dryclip%
  Dpoke Gintin+8,Ob_drwclip%
  Dpoke Gintin+10,Ob_drhclip%
  Lpoke Addrin,Ob_drtree%
  Gemsys 42
  Ob_drreturn%=Dpeek(Gintout)
Return
Procedure Objc_change(Ob_ctree%,Ob_cobject%,Ob_cresvd%,Ob_cxclip%,Ob_cyclip%,Ob_cwclip%,Ob_chlip%,Ob_cnewstate%,Ob_credraw%)
  Dpoke Gintin,Ob_cobject%
  Dpoke Gintin+2,Ob_cresvd%
  Dpoke Gintin+4,Ob_cxclip%
  Dpoke Gintin+6,Ob_cyclip%
  Dpoke Gintin+8,Ob_cwclip%
  Dpoke Gintin+10,Ob_chclip%
  Dpoke Gintin+12,Ob_cnewstate%
  Dpoke Gintin+14,Ob_credraw%
  Lpoke Addrin,Ob_ctree%
  Gemsys 47
  Ob_creturn%=Dpeek(Gintout)
Return
Procedure Form_do(Fo_dotree%,Fo_dostart_ob%)
  Dpoke Gintin,Fo_dostart_ob%
  Lpoke Addrin,Fo_dotree%
  Gemsys 50
  Fo_doreturn%=Dpeek(Gintout)
Return
Procedure Form_dial(Fo_diflag%,Fo_dilittlx%,Fo_dilittly%,Fo_dilittlw%,Fo_dilittlh%,Fo_dibigx%,Fo_dibigy%,Fo_dibigw%,Fo_dibigh%)
