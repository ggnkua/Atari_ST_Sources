Procedure Rsrc_load(Re_lpfname$)
  Re_lpfname$=Upper$(Re_lpfname$+Chr$(0))
  Lpoke Addrin,Varptr(Re_lpfname$)
  Gemsys 110
  Re_lreturn%=Dpeek(Gintout)
Return
Procedure Wind_update(Wi_ubegend%)
  Dpoke Gintin,Wi_ubegend%
  Gemsys 107
  Wi_ureturn%=Dpeek(Gintout)
Return
'
' Voreinstellung (zu Beginn des Programms):
'
Procedure Druck_vor
  Local X,A$,B$,Ind
  Restore Druck_zeichen
  Ind=1
  For X=L1 To L7
    Read A$
    Zeichen$(Ind)=A$
    Zeichen(Ind)=Asc(A$)
    Inc Ind
    B$=Space$(3-Len(Str$(Asc(A$))))+Str$(Asc(A$))
    @Put_string(Object_druck,X,B$)
  Next X
  For X=L7+1 To L34+4 Step 2
    Read A$
    Zeichen$(Ind)=A$
    Zeichen(Ind)=Asc(A$)
    Inc Ind
    B$=Space$(3-Len(Str$(Asc(A$))))+Str$(Asc(A$))
    @Put_string(Object_druck,X+1,A$)
    @Put_string(Object_druck,X,B$)
  Next X
  Druck_zeichen:
  Data ü,ö,ä,Ü,Ö,Ä,×
  Data é,ā,ģ,ł,Ŗ,ī,Ź,É,ō,Ģ,¢,Ś,Ā,Ī,ó,Ż,ż,ź,”,¦,©,Ł,░,▒,Č,Ę,Ė,Ć,ć
Return
'
' Aufruf und Lesen der Druckeranpassungs-Dialogbox:
'
Procedure Druckeranpassung
  Local X%,A$,B$,Ind,Y
  Ind=1
  For X%=L1 To L7
    B$=Space$(3-Len(Str$(Zeichen(Ind))))+Str$(Zeichen(Ind))
    @Put_string(Object_druck,X%,B$)
    Inc Ind
  Next X%
  For X%=L7+1 To L34+4 Step 2
    B$=Space$(3-Len(Str$(Zeichen(Ind))))+Str$(Zeichen(Ind))
    @Put_string(Object_druck,X%,B$)
    Inc Ind
  Next X%
  @Formular(Druck,32)
  Ind=1
  Y=0
  For X%=L1 To L7
    @Get_string(Object_druck,X%,*B$)
    Zeichen(Ind)=Val(B$)
    If Val(B$)>255
      Y=Y+1
      Zeichen(Ind)=Asc(Zeichen$(Ind))
    Endif
    Inc Ind
  Next X%
  For X%=L7+1 To L34+4 Step 2
    @Get_string(Object_druck,X%,*B$)
    Zeichen(Ind)=Val(B$)
    If Val(B$)>255
      Y=Y+1
      Zeichen(Ind)=Asc(Zeichen$(Ind))
    Endif
    Inc Ind
  Next X%
  If Y>0
    Alert 1,Str$(Y)+" Eingabe(n) war(en) zu|gro× !",1,"Na !",Wahl
  Endif
Return
'
' Abspeichern einer Druckeranpassung:
'
Procedure Save_printer
  @Fileselect(3,Da$,Da$,*Da$,*Db$,"Druckeranpassung speichern:",True)
  If Exobj%=28
    Open "O",#1,Da$
    Print #1,"1"
    Print #1,"Druckeranpassung aus dem 1st BASIC Tool"
    Print #1,"(C) 1987 by Ulrich Veigel"
    For X%=1 To 36
      Print #1,Zeichen$(X%);Chr$(Zeichen(X%));
    Next X%
    Close #1
  Endif
Return
'
' Einladen einer Druckeranpassung
'
Procedure Load_printer
  @Fileselect(3,Da$,"",*Da$,*Db$,"Druckeranpassung einladen:",True)
  If Exobj%=28 And Exist(Da$)
    Open "i",#1,Da$
    Line Input #1,V$
    Line Input #1,Cop$
    Line Input #1,Cop2$
    If V$<>"1" Or Cop$<>"Druckeranpassung aus dem 1st BASIC Tool" Or Cop2$<>"(C) 1987 by Ulrich Veigel"
      Alert 3,"Keine Druckeranpassung|Version 1.0 !!!",1,"Abbruch",Wahl
    Else
      For X%=1 To 36
        Zeichen$(X%)=Input$(1,#1)
        Zeichen(X%)=Asc(Input$(1,#1))
      Next X%
    Endif
    Close #1
  Endif
Return
'
' Umwandeln eines "normalen" Strings in einen String, den man z.B.
' mittels Lprint zum Drucker schicken kann.
'
Procedure Wandeln(A1$,A%)
  ' A1$: String, der umgewandelt werden soll
  ' A%: Pointer auf die globale Variable, die den umgewandelten String
  '     enthalten soll.
  Local X%,Init!
  Zeichen1$=""
  Zeichen2$=""
  For X%=1 To 36
    Zeichen1$=Zeichen1$+Zeichen$(X%)
    Zeichen2$=Zeichen2$+Chr$(Zeichen(X%))
  Next X%
  For X%=1 To Len(A1$)
    Altinstr=0
    While Instr(Zeichen1$,Mid$(A1$,X%,1))>Altinstr
      Altinstr=Instr(Zeichen1$,Mid$(A1$,X%,1))
      A1$=Mid$(A1$,1,X%-1)+Mid$(Zeichen2$,Instr(Zeichen1$,Mid$(A1$,X%,1)),1)+Mid$(A1$,X%+1)
    Wend
  Next X%
  *A%=A1$
Return
