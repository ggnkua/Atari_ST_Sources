' Diese Routinen sind Bestandteil des 1st BASIC Tool, einer Sammlung
' wichtiger Hilfsprogramme für's GFA-BASIC.
'
' Die Routinen können ohne Lizenzzahlungen in eigenen Programmen verwendet
' werden, allerdings mu× im Programm (oder der Dokumentation) gut sichtbar
' ein Hinweis auf unsere Routinen angebracht werden.
' Dieser kann z.B. so lauten:
'
' "Programm XY verwendet Routinen aus dem 1st BASIC Tool von UVS"
'
Procedure Center(A$,Arueck,Breite)
  If Len(A$)<Breite
    A$=Space$((Breite-Len(A$))/2)+A$
  Endif
  *Arueck=A$
Return
Procedure Right(A$,Arueck,Breite)
  If Len(A$)<Breite
    A$=Space$(Breite-Len(A$))+A$
  Endif
  *Arueck=A$
Return
Procedure Space_weg(A$,Arueck) !Alle Spaces beseitigen
  Do
    Exit If Instr(A$," ")=0
    A$=Mid$(A$,1,Instr(A$," ")-1)+Mid$(A$,Instr(A$," ")+1)
  Loop
  *Arueck=A$
Return
Procedure Space_weg_start(A$,Arueck) !Spaces am Anfang beseitigen
  Do
    Exit If Mid$(A$,1,1)<>" " Or A$=""
    A$=Mid$(A$,2)
  Loop
  *Arueck=A$
Return
Procedure Space_weg_ende(A$,Arueck) !Spaces am Ende beseitigen
  Do
    Exit If Mid$(A$,Len(A$))<>" " Or A$=""
    A$=Mid$(A$,1,Len(A$)-1)
  Loop
  *Arueck=A$
Return
Procedure Put_in_spaces(A$,Arueck) !Zwischen jeden Buchstaben ein Space einfügen
  Local X%
  If Len(A$)<>0
    For X%=1 To Len(A$)
      A$=Mid$(A$,1,X%*2-1)+" "+Mid$(A$,X%*2)
    Next X%
  Endif
  *Arueck=A$
Return
Procedure Aufloesung
  Aufl=Xbios(4)
  If Aufl=0
    Alert 1,"XYZ arbeitet|nicht in der|niedrigsten Auf-|lösung !",1,"Abbruch",Wahl
    End !Für XYZ setzen Sie bitte den Namen Ihres Programms ein
  Endif
  If Aufl=2
    Aufl=1 !Die "normale" Y-Koordinate mu× durch Aufl dividiert werden
    Sh=13  !Schrifthöhe
  Else
    Aufl=2
    Sh=6
  Endif
Return
