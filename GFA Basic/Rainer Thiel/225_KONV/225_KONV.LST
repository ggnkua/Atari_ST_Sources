' 225_KONV.PRG: Verwandelt in einer Datei den ASVCII-Code 225 in 158, was
' besonders zur öbernahme auf IBM-Kompatiblen erstellter Textdateien in
' einige ATARI-Textsysteme nÅtzlich ist (SIGNUM! ignoriert ASCII 225)
' Das Programm erzeugt eine Datei, die um ein Zeichen kÅrzer ist als die
' Originaldatei; diese wird nicht verÑndert.
'
' (c) 7/1988 by Rainer Thiel, Kînigsteiner Str. 3, 6200 Wiesbaden
'     This program is Public Domain. VerÑnderung und kommerzielle
'     Nutzung des Programms ist untersagt. Geschrieben in GFA-BAsic
'
Alert 0,"225_KONV.PRG - "+Chr$(189)+" 7/88 by|Rainer Thiel, Kînigsteiner|Str. 3, D-6200 Wiesbaden|GFA-Basic - Public Domain",1," START | ABORT ",C%
Do
  Exit If C%=2
  Fileselect Chr$(65+Gemdos(25))+Dir$(Gemdos(25)+1)+"\*.*","",Name$
  Exit If Name$=""
  If Exist(Name$)
    Open "I",#1,Name$
    Open "O",#2,Left$(Name$,Len(Name$)-1)
    Length%=Lof(#1)
    While Length%>0
      Z$=Input$(Min(Length%,32000),#1)
      Sub Length%,Min(Length%,32000)
      Do
        X%=Instr(Z$,Chr$(225))
        Exit If X%=0
        Mid$(Z$,X%,1)=Chr$(158)
      Loop
      Print #2,Z$;
    Wend
    Close
  Else
    Alert 1,"Datei existiert nicht!",1,"   OK   ",C%
  Endif
Loop
Edit
