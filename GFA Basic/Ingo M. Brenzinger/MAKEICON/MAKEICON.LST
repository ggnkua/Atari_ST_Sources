Cls
Print
Print " Dieses Programm lÑdt ein Bild in SCREEN-Format und aus diesem Bild lassen sich"
Print " fÅr das Resource-Construction-Set Bildausschnitt im ICON-Format ausschneiden !"
Print
Print " Ingo M. Brenzinger"
Print " Lindemannstr. 81"
Print " 4000 DÅsseldorf Zoo"
Print
Print
Print
Print At(1,24);" DrÅcke eine Taste !";
Repeat
Until Inkey$<>"" Or Mousek<>0
Fileselect "*.PIC","",File$
If File$<>"" And Right$(File$)<>"\"
  Bload File$,Xbios(3)
  Sget Bildschirm$
  Repeat
    Sput Bildschirm$
    Repeat
    Until Mousek=1
    Mx%=Mousex
    My%=Mousey
    @Graf_rubbox(Mx%,My%,5,5)
    B%=Mousex-Mx%
    H%=Mousey-My%
    Get Mx%,My%,Mx%+B%,My%+H%,A$
    Cls
    Put 0,0,A$
    Fileselect "\*.ICN","",File$
    If File$<>"" And Right$(File$)<>"\"
      Bsave File$,Varptr(A$),Len(A$)    ! Auf Diskette
      '
      Open "I",#1,File$
      A$=Input$(Lof(#1),#1)
      Close #1
      @W_icon(A$)
    Endif
    Alert 1,"Nochein Icon auswÑhlen !",1,"Nocheins|Ende",X%
  Until X%=2
Endif
Edit
Procedure W_icon(A$)
  B%=Cvi(A$)+16 And &HFFF0
  H%=Cvi(Mid$(A$,3))+1
  R%=Cvi(Mid$(A$,5))*2    !Doppelte Anzahl Bitplanes
  Cls
  Put 0,0,A$
  Get 0,0,B%-1,H%-1,A$
  '
  Open "O",#1,File$
  Print #1,"/* GFA SHAPE */"
  Print #1,"#define SHAP_W ";@H$(B%)
  Print #1,"#define SHAP_H ";@H$(H%)
  Print #1,"#define DATASIZE ";@H$(B%*H%/16)
  Print #1,"int image[DATASIZE] = int mas"
  Print #1,"{ ";
  For I%=1 To B%*H%/16-1
    Print #1,@H$(Cvi(Mid$(A$,I%*2+5)));", ";
    If I% Mod 4=0
      Print #1
      Print #1,"  ";
    Endif
  Next I%
  Print #1,@H$(Cvi(Mid$(A$,I%*2+5)))
  Print #1,"};"
  Close #1
Return
'
Deffn H$(X%)="0x"+Right$("000"+Hex$(X%),4)
'
Procedure Graf_rubbox(X%,Y%,B%,H%)
  Dpoke Gintin,X%
  Dpoke Gintin+2,Y%
  Dpoke Gintin+4,B%
  Dpoke Gintin+6,H%
  Gemsys 70
Return
