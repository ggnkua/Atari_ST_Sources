Gosub Thermometer
Print At(1,10);"Innentemp.  = ";Ti
Print At(1,12);"Aussentemp. = ";Ta
End
Procedure Thermometer !   THERMOMETER
  Cls
  Deffill 1,2,2
  Box 310,100,330,340 ! max=100 min=340
  Box 309,99,331,341
  Box 230,70,410,370
  Box 229,69,411,371
  Box 225,65,415,375
  Print At(37,6);"°CELSIUS"
  Txt$="+24"
  Text 245,105,Txt$
  Txt$="-24"
  Text 245,345,Txt$
  Txt$="+-0"
  Text 245,225,Txt$
  Line 280,100,280,340
  For Y=100 To 340 Step 10
    Line 275,Y,285,Y
  Next Y
  Line 270,220,290,220
  Line 270,100,290,100
  Line 270,340,290,340
  Print At(29,3);"INNENTEMPERATUR WÄHLEN !"
  Gosub Cwahl
  Ti=C
  Print At(29,3);"AUSSENTEMPERATUR WÄHLEN!"
  Gosub Cwahl
  Ta=C
Return
Procedure Cwahl
  C=-50
  Repeat
    Mouse X,Y,Button%
    Y%=Int(Y-220)
    If Y<>Y1
      If Y>100 And Y<340
        Y1=Y
        Pbox 311,101,329,339
        Line 310,Y,330,Y
        Line 310,Y+1,330,Y+1
        C=Int(-Y%/5+0.5)
        If C<24.1 And C>-24.1
          Print At(38,23);"     "
          Print At(40,23);C
          Print At(44,23);"°C"
        Endif
      Endif
    Endif
  Until Button%=1 And Not C=-50
Return
