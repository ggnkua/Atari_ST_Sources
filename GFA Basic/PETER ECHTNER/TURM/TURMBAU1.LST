' TURMBAU.LST
'
DIM kloetze$(19),feld%(10,20),wkoor%(20,4,4),binp%(19),hinp%(19)
DIM des%(5),koor%(8),high$(10),high%(10),adr%(2),stat%(7)
joy_adr%=XBIOS(34)+61
FOR i%=1 TO 19
  READ byte%
  hinp%(i%)=byte% !HOEHE IN PIXEL
NEXT i%
DATA 48,32,48,32,48,32,48,32,32,48,32,48,32,48,32,48,16,64,32
'
' EXPANDIEREN VON WKOOR%()
'
FOR m%=1 TO 19
  FOR i%=1 TO 4
    READ byte%
    FOR n%=0 TO 3
      b$="0000"+BIN$(byte%)
      IF MID$(b$,LEN(b$)-n%,1)="1" THEN
        wkoor%(m%,n%+1,i%)=1
      ENDIF
    NEXT n%
  NEXT i%
NEXT m%
' WUERFELKOORDINATEN
DATA 3,1,1,0,1,7,0,0,2,2,3,0,7,4,0,0
DATA 3,2,2,0,7,1,0,0,1,1,3,0,4,7,0,0
DATA 2,7,0,0,2,3,2,0,7,2,0,0,1,3,1,0
DATA 6,3,0,0,1,3,2,0
DATA 3,6,0,0,2,3,1,0
DATA 1,5,0,0,0,1,1,1,1
DATA 3,3,0,0,
'
ALERT 0,"   TURMBAU| |@ BY ECHTNER PETER| ",1,"GENIAL !",ant
PRINT AT(30,12);"NICHT EINSCHLAFEN!"
'
' INIT LOG <> PHYS SCREEN
adr%(1)=XBIOS(2)
platz$=STRING$(32256,CHR$(0))
adr%(2)=(VARPTR(platz$) DIV 256+1)*256
screen%=0
VOID XBIOS(5,L:adr%(2),L:adr%(1),-1)
BMOVE XBIOS(2),XBIOS(3),32000
'
'
FOR m%=1 TO 19 ! seiten festlegen und kloetze zeichnen
  FOR n%=1 TO 4
    FOR i%=1 TO 4
      IF wkoor%(m%,i%,n%)=1 THEN
        IF i%=1 THEN
          LINE (i%-1)*16,hinp%(m%)-(n%-1)*16-1,(i%-1)*16,hinp%(m%)-n%*16
        ENDIF
        IF i%=4 THEN
          LINE i%*16-1,hinp%(m%)-(n%-1)*16-1,i%*16-1,hinp%(m%)-n%*16
        ENDIF
        IF n%=1 THEN
          LINE (i%-1)*16,hinp%(m%)-(n%-1)*16-1,i%*16-1,hinp%(m%)-(n%-1)*16-1
        ENDIF
        IF n%=4 THEN
          LINE (i%-1)*16,hinp%(m%)-n%*16,i%*16-1,hinp%(m%)-n%*16
          ADD binp%(m%),16
        ENDIF
        IF i%<>1 THEN
          IF wkoor%(m%,i%-1,n%)=0 THEN
            LINE (i%-1)*16,hinp%(m%)-(n%-1)*16-1,(i%-1)*16,hinp%(m%)-n%*16
          ENDIF
        ENDIF
        IF i%<>4 THEN
          IF wkoor%(m%,i%+1,n%)=0 THEN
            LINE i%*16-1,hinp%(m%)-(n%-1)*16-1,i%*16-1,hinp%(m%)-n%*16
          ENDIF
        ENDIF
        IF n%<>1 THEN
          IF wkoor%(m%,i%,n%-1)=0 THEN
            LINE (i%-1)*16,hinp%(m%)-(n%-1)*16-1,i%*16-1,hinp%(m%)-(n%-1)*16-1
          ENDIF
        ENDIF
        IF n%<>4 THEN
          IF wkoor%(m%,i%,n%+1)=0 THEN
            LINE (i%-1)*16,hinp%(m%)-n%*16,i%*16-1,hinp%(m%)-n%*16
            ADD binp%(m%),16
          ENDIF
        ENDIF
      ENDIF
    NEXT i%
  NEXT n%
  READ byte%
  DEFFILL 1,2,byte%
  IF POINT(0,0)=1 THEN
    FILL 1,1
  ELSE
    IF POINT(16,0)=1 THEN
      FILL 17,1
    ELSE
      IF POINT(32,0)=1 THEN
        FILL 33,1
      ENDIF
    ENDIF
  ENDIF
  GET 0,0,binp%(m%),hinp%(m%),kloetze$(m%)
  CLS
NEXT m%
' fuellmuster
DATA 1,1,1,1,4,4,4,4,13,13,13,13,2,2,3,3,22,22,9
'
IF EXIST("/turmsco.dat") THEN
  OPEN "i",#1,"/turmsco.dat"
  FOR i%=1 TO 10
    INPUT #1,high$(i%),high%(i%)
  NEXT i%
  CLOSE #1
ENDIF
'
REPEAT !schleife fuer naechstes spiel
  CLS
  reiheweg%=0
  ges%=0
  des%(0)=XBIOS(2)
  des%(1)=640
  des%(2)=400
  des%(3)=40
  des%(4)=0
  des%(5)=1
  koor%(0)=88
  koor%(1)=50
  koor%(8)=6
  '
  DEFFILL 1,2,2
  PBOX 0,0,231,339
  PBOX 409,0,639,399
  DEFFILL 0
  PBOX 84,13,153,33
  PBOX 82,45,157,117
  DEFLINE 1,2
  BOXĽ85,47,154,115
  BOX 85,14,152,32
  PBOX 415,144,631,335
  BOX 417,146,629,333
  RESTORE kk
  FOR m%=1 TO 7!kleine kloetze zeichnen
    READ byte1%,byte2%
    FOR i%=3 DOWNTO 0
      FOR n%=0 TO 3
        IF wkoor%(byte1%,n%+1,i%+1)=1 THEN
          DEFFILL 1,2,8
          PBOX byte2%+n%*4,390-i%*4,byte2%+n%*4+3,387-i%*4
        ENDIF
      NEXT n%
    NEXT i%
  NEXT m%
  kk:
  DATA 1,65,13,80,19,99,17,112,9,131,15,148,5,167
  '
  GRAPHMODE 2
  GOSUB score
  DEFTEXT 1,0,0,6
  TEXT 5,193,"100%"
  TEXT 5,283,"50%"
  TEXT 5,373,"0%"
  DEFTEXT 1,1,0,18
  TEXT 61,176,128,"statistik"
  GET 61,177,180,370,stathinter$
  TEXT 245,25,155,"turmbau"
  TEXT 430,50,120,"reihen:"
  GET 600,32,630,50,reihehinter$
  TEXT 600,50,reiheweg%
  DEFLINE 1,4,2,1
  LINE 235,400,235,128
  LINE 405,400,405,128
  DEFLINE 1,1,2,2
  '
  DO!schleife fuer naechsten klotz
    GRAPHMODE 1
    INC ges%
    zufall=RANDOM(100)
    IF zufall<10 THEN
      akt%=17! aktuelle klotznummer
      INC stat%(4)
    ENDIF
    IF zufall>=10 AND zufall<22 THEN
      akt%=9
      INC stat%(5)
    ENDIF
    IF zufall>22 AND zufall<34 THEN
      akt%=19
      INC stat%(3)
    ENDIF
    IF zufall>=34 AND zufall<49 THEN
      akt%=13
      INC stat%(2)
    ENDIF
    IF zufall>=49 AND zufall<64 THEN
      akt%=15
      INC stat%(6)
    ENDIF
    IF zufall>=64 AND zufall<82 THEN
      akt%=1
      INC stat%(1)
    ENDIF
    IF zufall>=82 AND zufall<100 THEN
      akt%=5
      INC stat%(7)
    ENDIF
    GOSUB statistik
    x%=240+RANDOM(10-binp%(akt%)/16)*16
    y%=127
    turbo%=0
    DEFFILL 0
    PBOX 88,50,152,114
    PUT 88,50,kloetze$(akt%)
    GRAPHMODE 2
    PRINT AT(12,2);USING "nr.###",ges%
    GOSUB switch
    '
    sum%=0
    FOR i%=1 TO 10
      sum%=sum%+feld%(i%,17)
    NEXT i%
    EXIT IF sum%<>0
    OUT 4,18!maus aus
    koor%(2)=88+binp%(akt%)
    koor%(3)=50+hinp%(akt%)
    koor%(4)=x%
    koor%(5)=y%-hinp%(akt%)
    koor%(6)=x%+binp%(akt%)
    koor%(7)=y%
    abbruch!=FALSE
    DO !schleife: 1 klotz faellt
      koor%(8)=7
      BITBLT des%(),des%(),koor%()
      GOSUB switch
      IF turbo%=0 THEN
        OUT 4,22
        joy%=PEEK(joy_adr%)
      ENDIF
      IF joy%>=128 AND (399-y%) MOD 8=0 THEN !drehen
        alt%=akt%
        IF akt%<=12 THEN
          IF akt% MOD 4=0 THEN
            SUB akt%,3
          ELSE
            INC akt%
          ENDIF
        ENDIF
        IF akt%>12 AND akt%<>19 THEN
          IF EVEN(akt%)=TRUE THEN
            DEC akt%
          ELSE
            INC akt%
          ENDIF
        ENDIF
        IF x%+binp%(akt%)>400 THEN
          flag_d!=TRUE
        ELSE
          richt%=0
          GOSUB pruef
        ENDIF
        IF flag_d!=FALSE
          koor%(8)=6!klotz loeschen
          BITBLT des%(),des%(),koor%()
          GRAPHMODE 1
          DEFFILL 0!referenz klotz loeschen
          PBOX 86,48,152,114
          PUT 88,50,kloetze$(akt%)
          GRAPHMODE 2
          koor%(2)=88+binp%(akt%)
          koor%(3)=50+hinp%(akt%)
          koor%(5)=y%-hinp%(akt%)
          koor%(6)=x%+binp%(akt%)
          koor%(8)=7
          BITBLT des%(),des%(),koor%()
          GOSUB switch
        ELSE
          akt%=alt%
        ENDIF
      ENDIF
      IF (399-y%) MOD 16=0 THEN
        IF joy%=8 AND x%<400-binp%(akt%) THEN !rechts
          richt%=1
          GOSUB scroll_hor
        ENDIF
        IF joy%=4 AND x%>=256 THEN !links
          richt%=1
          GOSUB scroll_hor
        ENDIF
        IF joy%=2 THEN!unten
          turbo%=14
        ENDIF
        '                                       Oberste Schicht erreicht
        IF y&=399 THEN
          GOSUB stein_ab
        ELSE
          INC y%
          richt%=0
          GOSUB pruef
          DEC y%
          IF flag_d! THEN
            GOSUB stein_ab
          ENDIF
        ENDIF
      ENDIF
      EXIT IF abbruch!
      koor%(8)=6
      BITBLT des%(),des%(),koor%()
      ADD y%,2+turbo%
      koor%(5)=y%-hinp%(akt%)
      koor%(7)=y%
    LOOP
    OUT 4,8!maus an
    '
    '
    FOR n%=1 TO 17!reihe wegnehmen
      REPEAT
        frisch!=FALSE
        sum%=0
        FOR j%=1 TO 10
          ADD sum%,feld%(j%,n%)
        NEXT j%
        IF sum%=10 THEN!reihe voll
          FOR m%=n% TO 19
            FOR i%=1 TO 10
              feld%(i%,m%)=feld%(i%,m%+1)
            NEXT i%
          NEXT m%
          GET 240,32,400,(25-n%)*16-2,runter$
          PUT 240,48,runter$
          PUT 600,32,reihehinter$
          INC reiheweg%
          TEXT 600,50,reiheweg%
          GOSUB switch
          frisch!=TRUE
        ENDIF
      UNTIL NOT frisch!
    NEXT n%
  LOOP
  GOSUB reset
  '
  ' neuer high score?
  '
  zaehler%=10
  WHILE reiheweg%>high%(zaehler%) AND zaehler%>0
    DEC zaehler%
  WEND
  INC zaehler%
  IF zaehler%<>11 THEN
    FOR i%=9 DOWNTO zaehler%
      high$(i%+1)=high$(i%)
      high%(i%+1)=high%(i%)
    NEXT i%
    PRINT AT(53,24);"ihr name?";
    FORM INPUT 12,high$(zaehler%)
    high%(zaehler%)=reiheweg%
  ENDIF
  ALERT 2,"nochmal spielen?",1,"ja|nein",ant
  '
  ARRAYFILL feld%(),0
  ARRAYFILL stat%(),0
  screen%=0
  VOID XBIOS(5,L:adr%(2),L:adr%(1),-1)! log=phy screen
  CLS
  BMOVE XBIOS(2),XBIOS(3),32000
UNTIL ant=2
GOSUB reset
OPEN "o",#1,"/turmsco.dat"
FOR i%=1 TO 10
  WRITE #1,high$(i%),high%(i%)
NEXT i%
CLOSE #1
END
' ---------------------------------------------------------
'
' proceduren
'
PROCEDURE stein_ab
  FOR i%=1 TO 4
    FOR n%=1 TO 4
      IF wkoor%(akt%,n%,i%)=1 THEN
        feld%((x%-240) DIV 16+n%,24-y% DIV 16+i%)=1
      ENDIF
    NEXT n%
  NEXT i%
  abbruch!=TRUE
  SOUND 1,10,#3500,1
  WAVE 0,0
RETURN
'
PROCEDURE pruef
  flag_d!=FALSE!true,wenn ein feld doppelt besetzt ist
  FOR hoehe%=1 TO hinp%(akt%) DIV 16
    FOR breite%=1 TO binp%(akt%) DIV 16
      kx%=(x%-240) DIV 16+breite%+richt%!kaestchenx
      ky%=24-y% DIV 16+hoehe%
      IF feld%(kx%,ky%)=1 AND wkoor%(akt%,breite%,hoehe%)>0 THEN
        flag_d!=TRUE
      ENDIF
      EXIT IF flag_d!
    NEXT breite%
    EXIT IF flag_d!
  NEXT hoehe%
RETURN
'
PROCEDURE scroll_hor
  GOSUB pruef
  IF flag_d!=FALSE
    koor%(8)=6
    BITBLT des%(),des%(),koor%()
    IF richt%=1 THEN
      ADD x%,16
    ELSE
      SUB x%,16
    ENDIF
    koor%(4)=x%
    koor%(6)=x%+binp%(akt%)
    koor%(8)=7
    BITBLT des%(),des%(),koor%()
    GOSUB switch
  ENDIF
RETURN
'
PROCEDURE statistik
  PUT 61,177,stathinter$
  GRAPHMODE 1
  DEFFILL 1,2,22
  PBOX 112,370,128,370-stat%(4)/ges%*180
  DEFFILL ,,13
  PBOX 129,370,145,370-stat%(5)/ges%*180
  DEFFILL ,,9
  PBOX 95,370,111,370-stat%(3)/ges%*180
  DEFFILL ,,2
  PBOX 78,370,94,370-stat%(2)/ges%*180
  DEFFILL ,,3
  PBOX 146,370,162,370-stat%(6)/ges%*180
  DEFFILL ,,1
  PBOX 61,370,77,370-stat%(1)/ges%*180
  DEFFILL ,,4
  PBOX 163,370,179,370-stat%(7)/ges%*180
RETURN
'
PROCEDURE switch !vertausche log und phy screen
  screen%=1-screen%
  VOID XBIOS(5,L:adr%(2-screen%),L:adr%(screen%+1),-1)
  BMOVE XBIOS(2),XBIOS(3),32000
  des%(0)=adr%(2-screen%)
RETURN
'
PROCEDURE reset !log=phy
  VOID XBIOS(5,L:adr%(1),L:adr%(1),-1)
RETURN
'
PROCEDURE score
  DEFTEXT 1,13,0,26
  TEXT 415,130,228,"high-score"
  FOR i%=1 TO 10
    PRINT AT(54,10+i%);high$(i%)
    PRINT AT(67,10+i%);USING "reihen:###",high%(i%)
  NEXT i%
RETURN
