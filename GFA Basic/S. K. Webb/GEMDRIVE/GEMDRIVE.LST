' ********** UNIVERSAL GFA BASIC GEM-LIKE DRIVE SELECTOR DIALOG **********
'
' the following routines can be placed in any GFA Basic (3.0+) program to
' produce a centered SET DRIVE DIALOG, which functions in all the three
' resolutions (dimension an array VALID_DRIVE%(16) for it and call the
' PRO_RESOLVER first...) Of course, if you have TOS 1.4 or a replacement
' item selector installed, YOU don't need it; but it remains a programming 
' necessity, just as a courtesy to all the users who don't have those helps.
'         ˝ 1990 SKWare One and S. K. Webb, but free for your use...
'
'
'                       ****************************
'                       *  START OF DRIVE PACKAGE  *
'                       ****************************
'
'
Procedure Resolver
  ' resolution-dependent variables
  Rez%=Xbios(4)
  Xf%=Add(Div(Add(Rez%,1),2),1)
  Yf%=Add(Div(Rez%,2),1)
  Max_x%=Add(319,Mul(Sub(Xf%,1),320))
  Max_y%=Add(199,Mul(Sub(Yf%,1),200))
  Ty%=Add(Mul(Sub(Yf%,1),7),6)
Return
Procedure Drive
  ' centering coordinates
  Dox%=Div(Sub(Max_x%,175),2)
  Doy%=Div(Sub(Max_y%,Mul(114,Yf%)),2)
  ' save the screen_patch
  Get Add(Dox%,3),Add(Doy%,Mul(4,Yf%)),Add(Dox%,178),Add(Doy%,Mul(114,Yf%)),Drive_keeper$
  ' do the GEM thang!
  @Grow_box(Add(Dox%,88),Add(Doy%,Mul(58,Yf%)),2,2,Add(Dox%,3),Add(Doy%,Mul(4,Yf%)),178,Mul(114,Yf%))
  ' gotta have the rodent
  Showm
  ' drawing color
  Color 1
  @Standard_text
  ' blank_out the screen_patch
  Deffill 0,2,8
  Pbox Add(Dox%,4),Add(Doy%,Mul(4,Yf%)),Add(Dox%,178),Add(Doy%,Mul(114,Yf%))
  ' draw the upper box
  Graphmode 1
  Box Add(Dox%,4),Add(Doy%,Mul(4,Yf%)),Add(Dox%,178),Add(Doy%,Mul(14,Yf%))
  '  Box Add(Dox%,4),Add(Doy%,Mul(14,Yf%)),Add(Dox%,178),Add(Doy%,Mul(114,Yf%))
  ' center the title in the upper box
  @Center(Add(Dox%,4),Add(Dox%,178),Add(Doy%,Mul(12,Yf%)),"SET DRIVE")
  ' nice dots for a background
  Deffill 3,2,1
  Pbox Add(Dox%,4),Add(Doy%,Mul(14,Yf%)),Add(Dox%,178),Add(Doy%,Mul(114,Yf%))
  ' draw the lower box border
  Box Add(Dox%,4),Add(Doy%,Mul(14,Yf%)),Add(Dox%,178),Add(Doy%,Mul(114,Yf%))
  ' go check out the connected drives
  @Drive_map
  ' in a pair of FOR...NEXT loops (across and down) draw each radio_button
  Dsr%=0
  For I%=Add(Dox%,29) To Add(Dox%,164) Step 35
    Dsw%=0
    For J%=Add(Doy%,Mul(21,Yf%)) To Add(Doy%,Mul(78,Yf%)) Step Mul(19,Yf%)
      ' select the appropriate type_style for connected vs. non-connected
      If Mid$(Drive_map$,Sub(16,Add(Mul(Dsw%,4),Dsr%)),1)="0"
        @Lightened_text
      Else
        @Standard_text
      Endif
      @Radio_button(I%,J%,Chr$(Add(65,Add(Mul(Dsw%,4),Dsr%))))
      Add Dsw%,1
    Next J%
    Add Dsr%,1
  Next I%
  ' next, draw the OK and CANCEL buttons
  @Standard_text
  @Radio_button(Add(Dox%,37),Add(Doy%,Mul(97,Yf%)),"OK")
  @Radio_button(Add(Dox%,86),Add(Doy%,Mul(97,Yf%)),"CANCEL")
  ' the currently selected drive
  Drive_code%=Gemdos(25)
  ' save it
  Original_drive%=Drive_code%
  ' light the button for current drive
  @Drive_button(Drive_code%)
  Drive_ok%=1
  Drive_x%=0
  ' here's the MAIN input loop:
  ' you can mouseclick on the buttons or enter a key_press for the drive;
  ' you can mouseclick on "OK" or press <Return>; bad choices are voided.
  ' ("CANCEL" you hafta click yerself...)
  Repeat
    Repeat
      ' check for key_press "a-p" or "A-P"
      Dr$=Inkey$
      If Len(Dr$)>0
        Dr$=Upper$(Dr$)
        Dr%=Asc(Dr$)
      Endif
      ' in a another pair of FOR...NEXT loops,
      ' check whether a button has been pushed
      For I%=Add(Dox%,29) To Add(Dox%,164) Step 35
        For J%=Add(Doy%,Mul(21,Yf%)) To Add(Doy%,Mul(78,Yf%)) Step Mul(19,Yf%)
          ' check the key_press value, if any
          If Dr%>64 And Dr%<81
            Drive_ok%=0
            ' de-select the highlite button
            @Drive_button(Drive_code%)
            ' take the new value
            Drive_code%=Dr%-65
            ' highlite the new button
            @Drive_button(Drive_code%)
            Clr Dr%
          Endif
          ' check the buttons for mice
          @Inbox(I%,J%,Add(I%,24),Add(J%,Mul(19,Yf%)),Inbox!)
          If Inbox!=True
            Drive_ok%=0
            ' de-select the highlite button
            @Drive_button(Drive_code%)
            ' calculate which button has been pushed from the loop indices
            ' (Boy, do I love linear equations!)
            Drive_code%=Add(Mul(Div(Sub(Sub(J%,Doy%),Mul(21,Yf%)),Mul(19,Yf%)),4),Div(Sub(Sub(I%,29),Dox%),35))
            ' highlite the new button
            @Drive_button(Drive_code%)
          Endif
        Next J%
      Next I%
      ' check the OK button for mice
      @Inbox(Add(Dox%,37),Add(Doy%,Mul(97,Yf%)),Add(Add(Dox%,69),Mul(Sub(Xf%,1),14)),Add(Doy%,Mul(107,Yf%)),Inbox!)
      If Inbox!=True Or Dr$=Chr$(13)
        @Push_this_button(Add(Dox%,37),Add(Doy%,Mul(97,Yf%)),"OK")
        If Valid_drive%(Drive_code%)=1
          ' if the drive selection is valid, accept it...
          Chdrive Drive_code%+1
          Drive_x%=1
        Else
          ' ...if not, reset the button but don't exit
          @Drive_button(Original_drive%)
          @Drive_button(Drive_code%)
          Drive_code%=Original_drive%
        Endif
        Drive_ok%=1
        ' hold it!
        Pause 20
        ' turn off the button
        @Push_this_button(Dox%+37,Doy%+97*Yf%,"OK")
      Endif
      ' check the CANCEL button for mice
      @Inbox(Add(Dox%,86),Add(Doy%,Mul(97,Yf%)),Add(Add(Dox%,134),Mul(Sub(Xf%,1),14)),Add(Doy%,Mul(107,Yf%)),Inbox!)
      If Inbox!=True
        ' turn it on...
        @Push_this_button(Add(Dox%,86),Add(Doy%,Mul(97,Yf%)),"CANCEL")
        @Drive_button(Drive_code%)
        @Drive_button(Original_drive%)
        Pause 20
        ' turn it off...
        @Push_this_button(Add(Dox%,86),Add(Doy%,Mul(97,Yf%)),"CANCEL")
        Chdrive Gemdos(25)+1
        Drive_code%=Gemdos(25)
        Drive_ok%=1
        Drive_x%=1
      Endif
    Until Drive_ok%=1
  Until Drive_x%=1
  ' replace the screen_patch
  Put Add(Dox%,3),Add(Doy%,Mul(4,Yf%)),Drive_keeper$
  ' trash that memory-wasting string
  Dkeep$=""
  ' dump the rodent (if you need to, otherwise don't)
  Hidem
  ' I'm outta here...
  @Shrink_box(Add(Dox%,88),Add(Doy%,Mul(58,Yf%)),2,2,Add(Dox%,3),Add(Doy%,Mul(4,Yf%)),178,Mul(114,Yf%))
Return
Procedure Drive_map
  ' make a string out of a bitwise value
  Drive_map$=Bin$(Bios(10),16)
  ' label the drives
  For I%=15 To 0 Step -1
    Valid_drive%(I%)=Val(Mid$(Drive_map$,Sub(16,I%),1))
  Next I%
Return
Procedure Drive_button(Z%)
  ' translates a drive_number into coordinates
  Jj%=Div(Z%,4) ! row down
  Ii%=Sub(Z%,Mul(Jj%,4)) ! column across
  ' pretty fond of Reverse_Polish_Notation, too!
  @Button(Add(Add(Dox%,Mul(Ii%,35)),28),Add(Add(Doy%,Mul(Mul(Jj%,19),Yf%)),Sub(Mul(21,Yf%),1)),Add(Add(Add(Dox%,Mul(Ii%,35)),28),Mul(13,Xf%)),Add(Add(Doy%,Mul(Mul(Jj%,19),Yf%)),Add(Mul(31,Yf%),1)))
Return
Procedure Button(Cb1%,Cb2%,Cb3%,Cb4%)
  ' highlite or un-highlite a plain rectangular button
  Get Cb1%,Cb2%,Cb3%,Cb4%,But$
  Put Cb1%,Cb2%,But$,12
  But$=""
Return
Procedure Radio_button(Cb1%,Cb2%,C$)
  ' calculate the dimensions of a radio_button to hold this text C$
  Cb3%=Add(Add(Add(Cb1%,Mul(Len(C$),8)),2),Mul(Sub(Xf%,1),14))
  Cb4%=Add(Cb2%,Mul(10,Yf%))
  ' punch out a little hole for it
  Deffill 0,2,8
  Pbox Sub(Cb1%,2),Sub(Cb2%,2),Add(Cb3%,3),Add(Cb4%,3)
  ' draw the button
  Box Cb1%,Cb2%,Cb3%,Cb4%
  Box Sub(Cb1%,2),Sub(Cb2%,2),Add(Cb3%,2),Add(Cb4%,2)
  Box Sub(Cb1%,2),Sub(Cb2%,2),Add(Cb3%,3),Add(Cb4%,3)
  ' fit the text inside
  Text Add(Add(Cb1%,1),Mul(Sub(Xf%,1),7)),Add(Cb2%,Mul(8,Yf%)),C$
Return
Procedure Push_this_button(Cb1%,Cb2%,C$)
  ' highlite or un-highlite a radio_button
  Cb3%=Add(Add(Add(Cb1%,Mul(Len(C$),8)),2),Mul(Sub(Xf%,1),14))
  Cb4%=Add(Cb2%,Mul(10,Yf%))
  Get Cb1%,Cb2%,Cb3%,Cb4%,Rev$
  Put Cb1%,Cb2%,Rev$,12
Return
Procedure Grow_box(Mx%,My%,Sw%,Sh%,Gex%,Gey%,Ew%,Eh%)
  ' the usual GEM stuff
  Dpoke Gintin,Mx%
  Dpoke Gintin+2,My%
  Dpoke Gintin+4,Sw%
  Dpoke Gintin+6,Sh%
  Dpoke Gintin+8,Gex%
  Dpoke Gintin+10,Gey%
  Dpoke Gintin+12,Ew%
  Dpoke Gintin+14,Eh%
  Gemsys (73)
Return
Procedure Shrink_box(Mx%,My%,Sw%,Sh%,Gex%,Gey%,Ew%,Eh%)
  ' the usual GEM stuff
  Dpoke Gintin,Mx%
  Dpoke Gintin+2,My%
  Dpoke Gintin+4,Sw%
  Dpoke Gintin+6,Sh%
  Dpoke Gintin+8,Gex%
  Dpoke Gintin+10,Gey%
  Dpoke Gintin+12,Ew%
  Dpoke Gintin+14,Eh%
  Gemsys (74)
Return
Procedure Center(Sx%,Fx%,Tl%,T$)
  ' centers a text T$ between Sx% and Fx% on screen scanline Tl% as baseline
  ' works for any size text as long as the DEFTEXT statement is used elsewhere
  Dpoke Contrl,117
  Dpoke Intin,Asc("L")
  Vdisys
  Cw%=Dpeek(Ptsout)
  Ld%=Dpeek(Ptsout+4)
  Rd%=Dpeek(Ptsout+8)
  Tcw%=Cw%+Ld%+Rd%
  Pos%=Add(Sx%,Int(Sub(Div(Sub(Fx%,Sx%),2),Mul(Div(Len(T$),2),Tcw%))))
  Text Pos%,Tl%,T$
Return
Procedure Standard_text
  ' normal type_style
  Deftext 1,0,0,Ty%
Return
Procedure Lightened_text
  ' lightened type_style
  Deftext 1,2,0,Ty%
Return
Procedure Inbox(Cb1%,Cb2%,Cb3%,Cb4%,Var Inbox!)
  ' asks (and answers) the two age-old questions:
  ' is the mousie in the boxie?
  ' and... is the mousie squeaking?
  Inbox!=False
  If Mousex>Cb1% And Mousey>Cb2% And Mousex<Cb3% And Mousey<Cb4% And Mousek=1
    Inbox!=True
  Endif
  ' this is a lot faster than having Old Man GEM plod thru the EVENT_MULTI!
Return
