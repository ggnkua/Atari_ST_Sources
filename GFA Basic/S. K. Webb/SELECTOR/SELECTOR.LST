'
'          This SBR changes the title used in the GEM fileselect
'
'
' first, 
' gather the fileselect title that GEM is (presumably)
' using (hope so...) and save it for restoration at exit.
'
' Stitle$="FILE SELECTOR"
' Boot_stitle$=Stitle$
'
'
' then,
' immediately BEFORE calling the fileselect,
' call the routine to replace title like this:
'
' @Selector_title("LOAD TEXT",Stitle$)
'
'
'
'
' here's the SBR
Procedure Selector_title(Dt$,Var Stitle$)
  ' create buffer to mirror lower memory
  St_buffer$=String$(32000,0)
  ' convert new title to upper case, if not already
  Dt$=Upper$(Dt$)
  ' GEM really gets fussy about this...
  Dt$=Dt$+Chr$(0)
  ' start searching for current title just above
  ' the supervisor area in low memory and search upwards...
  Start%=2048
  ' zero the pointer to location in the buffer
  Clr Bloc%
  ' set the search flag
  Sgottit!=False
  Do
    ' put 32000 bytes of low memory in the buffer
    Bmove Start%,V:St_buffer$,32000
    ' search the buffer for the old title from pointer location
    Sgottit%=Instr(St_buffer$,Stitle$,Bloc%)
    While Sgottit%>0
      ' when you find old title, set the flag
      Sgottit!=True
      ' mark the location in the buffer, but
      ' note that flag pointer starts counting from 1, 
      ' while pointer counts from 0, hence the offset...
      Bloc%=Sgottit%-1
      ' determine the corresponding location in low memory
      From%=Bloc%+Start%
      ' ...replace the old title in low memory with the new title
      Bmove Varptr(Dt$),From%,Len(Dt$)
      ' bump the buffer pointer, adding 1 for position, 1 to correct offset
      Add Bloc%,2
      ' keep up the good work, seeking and replacing...
      Sgottit%=Instr(St_buffer$,Stitle$,Bloc%)
      ' ...until you reach the basepage
      Exit if From%=>Basepage
    Wend
    ' after you're searched the buffer to its end,
    ' get ready to move the next 32000 bytes to the buffer
    Add Start%,32000
    ' reset to zero the pointer to buffer location
    Clr Bloc%
    Exit if Start%=>Basepage
    ' continue until all memory locations below the basepage are changed...
  Loop
  ' then store the new title for the next replacement operation
  If Sgottit!=True
    Stitle$=Dt$
  Endif
  ' no point in wasting 32,000 bytes of useful memory, is there?
  St_buffer$=""
Return
'
'
'
'
' replace the GEM title in your exit routine, like this:
'
' @Selector_title("FILE SELECT",Stitle$)
'
' or like this:
'
' @Selector_title(Boot_stitle$,Stitle$)
'
'
'
