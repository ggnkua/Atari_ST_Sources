'
' Bitte die Maus bewegen !
'
' Animationsdemo von Karl-Heinz Wallon
'
IF XBIOS(4)=0
  aufx%=320
  aufy%=200
ENDIF
IF XBIOS(4)=1
  aufx%=640
  aufy%=200
ENDIF
IF XBIOS(4)=2
  aufx%=640
  aufy%=400
ENDIF
DIM bild%(32255/4),x$(20)
r!=TRUE
FOR i%=1 TO 20
  PRBOX i%,i%,40-i%,40-i%
  GET 0,0,40,40,x$(i%)
  CLS
NEXT i%
FOR l%=1 TO aufx% STEP 10
  LINE l%,0,l%,aufy%
NEXT l%
i%=1
a%=XBIOS(3)
b%=(VARPTR(bild%(0))+255) AND &HFFFF00
SGET h$
REPEAT
  SWAP a%,b%
  VOID XBIOS(5,L:a%,L:b%,-1)
  SPUT h$
  MOUSE mx%,my%,mk%
  IF r!=TRUE
    IF i%=20
      r!=FALSE !i%=1
    ELSE
      INC i%
    ENDIF
  ELSE
    IF i%=1
      r!=TRUE
    ELSE
      DEC i%
    ENDIF
  ENDIF
  PUT mx%,my%,x$(i%),7
  ax%=mx%
  ay%=my%
UNTIL mk%=2
a%=MAX(a%,b%)
VOID XBIOS(5,L:a%,L:a%,-1)
SPUT h$
END
