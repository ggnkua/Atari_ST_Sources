' ------------------------------------------------------------------------------
' Name          : MINPUT
' Sprache       : GFA-Basic V3.03
' Autor         : Karl-Heinz Wallon
' Level         : 1
' Aufgabe       : Unterprogramm stellt einen neuen INPUT-Befehl zur
'               : Verfügung!
' -----------------------------------------------------------------------------
DEFBYT "a-z"
DEFBIT "f"
' -----------------------------------------------------------------------------
' Variabeln vorbereiten, MINPUT aufrufen
' -----------------------------------------------------------------------------
x=2            ! Xpos des cursors
y=8            ! Ypos
einglaenge=50  ! Eingabelänge maximal 80-x-länge des Ausgabestrings
format$=CHR$(7)
ausgabe$="Bitte Text eingeben :"
rueckgabestr$=""
@minput(x,y,einglaenge,format$,ausgabe$,rueckgabestr$)
' -----------------------------------------------------------------------------
' Ergebniss ausgeben
' -----------------------------------------------------------------------------
CLS
PRINT rueckgabestr$,VAL(rueckgabestr$),HEX$(VAL(rueckgabestr$))
'
' Unterprogramm MINPUT
'
> PROCEDURE minput(xp,yp,laenge,f$,a$,VAR r$)
  LOCAL lp,rp,f1,f2,f3,f4,f5,f6,falsch
  falsch=FALSE                          ! Wenn Parameter Falsch dann TRUE
  IF xp<1 OR xp>80 OR yp<1 OR yp>25
    ALERT 3,"Fehler     :|Die XPOS oder YPOS für die|Textausgabe sind falsch!!",1,"RETURN",a
    falsch=TRUE
  ENDIF
  '
  ' Formatstring aufschlü×eln . In 'zu$' stehen die Zeichen die zugelassen sind
  '
  IF xp+LEN(a$)+laenge>80
    ALERT 3,"FEHLER: Stringlänge|Die maximal Zeilenlänge be-|trägt 80 Zei minus X-Pos und|und ausgabestring",1,"Return",a
    falsch=TRUE
  ENDIF
  FOR i=1 TO LEN(f$)                    ! Alle Zeichen des Formatstrings prüfen
    SELECT MID$(f$,i,1)
    CASE 0                              ! CHR$(0) danach zusatzzeichen
      lp=i                              ! das erste CHR$(0)
      rp=RINSTR(f$,CHR$(0))             ! das lestzte CHR$(0)
      IF lp=rp                          ! gleich -> FEHLER, es fehlen die Zusatzzeichen
        ALERT 3,"FEHLER : im Formatstring|Nach CHR$(0) mu× mindestens|1 Zeichen kommen, dann nochmal|CHR$(0)!!",1,"Return",a
        falsch=TRUE
      ELSE
        zu$=zu$+MID$(f$,lp,rp-lp)       ! zusatzzeichen in ZU$ übernehmen
      ENDIF
      i=rp+1                            ! Schleifenzähler HINTER die zusatzzeichen setzten
      '                                 ! falls noch weiter Codes folgen
    CASE 1                              ! CHR$(1) - Alle Zeichen
      IF NOT (f1)                       ! Flag schon gesetzt
        CLR zu$
        FOR l=1 TO 255
          zu$=zu$+CHR$(l)               ! Alle Zeichen zulassen
        NEXT l
        f1=TRUE
      ENDIF
    CASE 2
      IF NOT (f2) AND NOT (f1)          ! Wenn F1 gesetzt ist CHR$(2) blödsinn
        FOR l=65 TO 90
          zu$=zu$+CHR$(l)               ! Alle GRO×BUCHSTABEN übernehmen
        NEXT l
        zu$=zu$+" "                     ! Leerzeichen zulassen
        f2=TRUE
      ENDIF
    CASE 3
      IF NOT (f3) AND NOT (f1)
        FOR l=97 TO 122
          zu$=zu$+CHR$(l)               ! Alle kleinbuchstaben übernehmen
        NEXT l
        zu$=zu$+" "                     ! und noch das Leerzeichen
        f3=TRUE
      ENDIF
    CASE 5
      IF NOT (f5) AND NOT (f1)
        FOR l=48 TO 57
          zu$=zu$+CHR$(l)               ! Zahlen zulassen 0-9
        NEXT l
        f5=TRUE
      ENDIF
    CASE 6
      IF NOT (f6) AND NOT (f1)
        FOR l=32 TO 47
          zu$=zu$+CHR$(l)               ! Sonderzeichen zulassen
        NEXT l
        zu$=zu$+" :;<=>?@[\]^_`{|}~"   ! weitere Sonderzeichen
        f6=TRUE
      ENDIF
    CASE 7
      fscan=TRUE                        ! Flag für Scancodeauswertung
    DEFAULT
      '                                 ! Alle anderen Codes erzeugen FEHLER
      ALERT 3,"FEHLER: Formatstring|Falscher CHR$-Code übergeben",1,"Return",a
      falsch=TRUE
    ENDSELECT
  NEXT i
  IF NOT falsch                         ! Alle Parameter OKAY
    VDISYS 38                           ! Grö×e des Zeichensatzes bestimmen
    cb%=DPEEK(PTSOUT+4)                 ! Zeichenbreite
    ch%=DPEEK(PTSOUT+6)                 ! Zeichenhöhe
    @sprite                             ! Spritecode einlesen
    IF NOT fscan                        ! ASC-II bearbeiten wenn FSCAN=FALSE
      PRINT AT(xp,yp);a$;               ! Ausgabestring ausgeben
      zp&=yp*ch%                        ! Zeilenkoordinate des Spritecursors
      sp&=xp*cb%+LEN(a$)*cb%            ! Spaltenkoordinate des Spritecursors
      SPRITE cursor$,sp&,zp&            ! Sprite setzten
      REPEAT
        REPEAT
          t$=INKEY$                     ! Tastatur abfragen, wenn Taste gedrückt
        UNTIL t$<>""                    ! dann weiter im Programm
        IF LEN(t$)=1                    ! Normale Taste
          @normal(ASC(t$))
        ELSE
          @scancode(ASC(RIGHT$(t$)))    ! Scancode bearbeiten (HELP,UNDO)
        ENDIF
      UNTIL t$=CHR$(13)                 ! RETURN -> Eingabe beenden und rückkehr zum Hauptprg
    ELSE
      fscan=FALSE                       ! SCAN-Code auswerten
      IF LEN(a$)>0                      ! Ausgabetext ausgeben wenn vorhanden !
        PRINT AT(xp,yp);a$;
      ENDIF
      t%=GEMDOS(8)                      ! Auf Tastendruck warten
      e$=STR$(t%/&HFFFF AND 255)        ! Scancode der Taste auslesen
      '                                 ! Scancode mit VAL auslesen
    ENDIF
    r$=e$                               ! String in Rückgabevariable übergeben
  ENDIF
RETURN
> PROCEDURE normal(code)
  LOCAL cpos,tpos
  SELECT code
  CASE 8                                ! Backspace-Taste
    IF e$<>""                           ! Nur wenn was zum löschen da ist
      SPRITE cursor$                    ! Cursor abschalten
      alt$=e$                           ! Für UNDO megern
      cpos=xp+LEN(a$)+LEN(e$)           ! Zeichenposition des zu löschenden Zeichens
      PRINT AT(cpos,yp);" ";            ! Zeichen löschen
      e$=LEFT$(e$,LEN(e$)-1)            ! String um ein Zeichen kürzen
      PRINT AT(xp+1+LEN(a$),yp);e$;     ! String ausgeben
      SUB sp&,cb%                       ! Neue Cursorposition
      SPRITE cursor$,sp&,zp&            ! Cursor setzten
    ENDIF
  CASE 27                               ! ESC-Taste
    alt$=e$                             ! Für UNDO mergen
    e$=""                               ! alles weg
    SPRITE cursor$                      ! Cursor aus
    PRINT AT(xp+1+LEN(a$),yp);SPACE$(laenge)    ! Text auf Bildschirm löschen
    PRINT AT(xp+1+LEN(a$),yp);"";       ! Ausgabepos wieder an des Anfang setzen
    sp&=xp*cb%+LEN(a$)*cb%              ! Startpos des Spritescursors berechnen
    SPRITE cursor$,sp&,zp&              ! Sprite setzen
  DEFAULT                               ! Alle anderen Tasten
    IF LEN(e$)<laenge                   ! Eingabelänge erreicht -> Ja dann weiter im Unterprogramm
      CLR p
      p=INSTR(zu$,CHR$(code))           ! gedrückte Taste zugelassen, dann p>0
      IF p>0
        SPRITE cursor$
        alt$=e$
        e$=e$+t$                        ! gedrückte Taste übernehmen
        PRINT AT(xp+LEN(a$)+1,yp);e$;   ! ausgeben
        ADD sp&,cb%                     ! neue Spriteposition
        SPRITE cursor$,sp&,zp&
      ENDIF
    ENDIF
  ENDSELECT
RETURN
> PROCEDURE scancode(code)
  SELECT code
  CASE &H62                             ! HELP-TASTE
    SGET bild$
    CLS
    PRINT CHR$(27)+"E"
    PRINT AT(2,1);" Eine kleine Hilfe zum MINPUT-Unterprgramm"
    PRINT AT(2,2);STRING$(78,"-")
    PRINT AT(2,3);"Der FORMATSTRING:                          "
    PRINT AT(10,5);"= chr$(1) - Alle Zeichen von code 0-255"
    PRINT AT(10,6);"= chr$(2) - Gro×buchstaben  A-Z,Ä,Ö,Ü,×,' '"
    PRINT AT(10,7);"= chr$(3) - kleinbuchstaben a-z,ä,ö,ü,×,' '"
    PRINT AT(10,8);"= chr$(4) - FREI"
    PRINT AT(10,9);"= chr$(5) - Nur Zahlen 0-9"
    PRINT AT(10,10);"= chr$(6) - Nur Sonderzeichen,SHIFT 1-# usw."
    PRINT AT(10,11);"= chr$(7) - Scan-Codes auswerten, alle Tasten sind"
    PRINT AT(10,12);"            erlaubt. Der Scancode wird dem Rückgabestring"
    PRINT AT(10,13);"            übergeben, mit VAL auslesen"
    PRINT AT(10,14);"="+CHR$(34)+"2dasCA"+CHR$(34)+" - Nur in Anführungszeichen stehende Zeichen sind"
    PRINT AT(10,15);"            erlaubt müssen aber mit chr$(0) beginnen und enden"
    PRINT AT(2,16);STRING$(78,"-")
    PRINT AT(2,17);"Die Help-Taste zeigt diese Seite!"
    PRINT AT(2,18);"Die UNDO-Taste hebt die letzte Änderung auf!"
    PRINT AT(2,20);"Bitte ein Taste drücken :";
    ~INP(2)
    SPUT bild$
  CASE &H61        !Die UNDO-Taste
    SWAP e$,alt$
    SPRITE cursor$
    PRINT AT(xp+LEN(a$)+1,yp);SPACE$(laenge);
    PRINT AT(xp+LEN(a$)+1,yp);e$;
    sp&=xp*cb%+LEN(a$)*cb%+LEN(e$)*cb%
    SPRITE cursor$,sp&,zp&
  ENDSELECT
RETURN
> PROCEDURE sprite
  cursor$=MKI$(1)+MKI$(15)+MKI$(-1)+MKI$(0)+MKI$(1)
  FOR i=0 TO 15
    cursor$=cursor$+MKL$(&HFF00)
  NEXT i
RETURN
