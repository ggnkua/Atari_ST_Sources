'
' Ein DEMO-Programm zu dem GEMDOS-Kurs in den Clubnachrichten
' Bitte die Komentarzeichen vor den Unterprogrammaufrufen einzeln Löschen!
'
' @daten     ! für Datenverwaltungdemo in GEMDOS
' END
'
' @speicher  ! für Freien Speicherplatz auf der Diskette
' END
'
' @uhrzeit   ! Für Uhrzeit/Datum änderen einer Datei
' END
' ---------------------------------------------------------------------------
' Datenverwaltung mit GEMDOS
' ---------------------------------------------------------------------------
> PROCEDURE daten
  '
  ' Daten zum Speichern vorbereiten
  '
  DIM t$(3),zahlen&(1000)
  t$(0)="Dies ist ein Beispieltext um einmal zu Demonstrieren "
  t$(1)="wie man mit GEMDOS Daten auf Diskette speichern und  "
  t$(2)="und wieder lesen kann. Dabei wird auch der Zugriff   "
  t$(3)="über FSEEK gezeigt, deshalb gleiche länger!          "
  FOR i&=1 TO 1000
    zahlen&(i&)=i&+i&/2
  NEXT i&
  '
  ' Name der NEUEN Datei hohlen
  '
  FILESELECT "\*.*",datname$,datname$
  IF LEN(datname$)<4  ! kein Name dann DEMO.GEM nehmen
    datname$="A:\DEMO.GEM"+CHR$(0) ! mit CHR$(0) beenden für GEMDOS
  ELSE
    datname$=datname$+CHR$(0)
  ENDIF
  '
  ' adresse des Dateinames in ADR% legen
  adr%=V:datname$
  '
  ' Datei verstecken - Ja dann nachher mal ins Desktop springen
  '
  ALERT 2,"Soll die Datei|versteckt werden?",1," Ja | Nein ",weg
  IF weg=1
    attr%=2
  ENDIF
  PRINT "Die Datei :"+datname$+" wird mit dem Attribute :";STR$(attr%,2)+" angelegt."
  '
  ' Datei neu anlegen
  '
  nummer%=GEMDOS(60,L:adr%,attr%)
  PRINT "Die Datei :"+datname$+" bekam das Handle :";nummer%
  '
  ' Einschreiben der Strings in die Datei
  '
  PRINT "Strings in die Datei schreiben."
  FOR i|=0 TO 3
    adr%=V:t$(i|)
    PRINT t$(i|)
    fehler%=GEMDOS(64,nummer%,L:53,L:adr%)
    @fehler
  NEXT i|
  '
  ' Einschreiben des Zahlenfeldes
  '
  adr%=V:zahlen&(0)          ! ADR% jetz adresse des Zahlenfeldes
  anz%=DIM?(zahlen&())*2     ! gesamte länge des Feldes ermitteln
  PRINT "Zahlen in die Datei schreiben."
  fehler%=GEMDOS(64,nummer%,L:anz%,L:adr%)
  @fehler
  '
  ' Datei Schlie×en
  '
  PRINT "Datei wieder geschlo×en!"
  fehler%=GEMDOS(62,nummer%)
  @fehler
  '
  ' Felder zum neuladen löschen
  '
  ERASE t$(),zahlen&()
  DIM t$(3),zahlen&(1000)
  FOR i|=0 TO 3
    t$(i|)=SPACE$(53)
  NEXT i|
  '
  ' Arbeiten mit den Daten!
  '
  nummer%=GEMDOS(61,L:V:datname$,0) ! datei öffnen auch so kann man die Adresse des Namens übergeben!
  PRINT "Die Datei hat jetzt das Handel :nummer%"
  '
  ' Abfragen welcher String gelesen werden soll
  '
  REPEAT
    PRINT "welcher String soll gelesen werden (1-4) ?";
    INPUT "",nr%
  UNTIL nr%>=1 OR nr%<=4
  DEC nr%             ! da t$ von 0-3 dimensioniert war NR% um 1 verringern
  satzzeiger%=nr%*53  ! zeiger auf String berechnen
  PRINT "setze Zeiger auf String nummer ";nr%;" postion :";satzzeiger%
  fehler%=GEMDOS(66,L:satzzeiger%,nummer%,0)
  @fehler
  fehler%=GEMDOS(63,nummer%,L:53,L:V:t$(nr%))
  @fehler
  PRINT "Dieser Text wurde gelesen : "
  PRINT t$(nr%)
  PRINT
  PRINT "Nach einem Tastendruck werden die Zahlenwerte gelesen!"
  ~INP(2)
  satzzeiger%=(4-nr%)*53 ! relativ zum lezten gelesenen Satz die Position der Zahlen bestimmen
  '
  ' Schreib/Lesekopf positionieren
  '
  fehler%=GEMDOS(66,L:satzzeiger%,nummer%,1)
  @fehler
  '
  ' Zahlen einlesen
  '
  fehler%=GEMDOS(63,nummer%,L:anz%,L:V:zahlen&(0))
  @fehler
  '
  ' Ausgabe auf dem Bildschirm
  '
  FOR i&=1 TO 1000
    PRINT STR$(i&,5);" -> ";STR$(zahlen&(i&),5)
  NEXT i&
  fehler%=GEMDOS(62,nummer%)
  PRINT "Das war die Datenverwaltung in GEMDOS - einfachstes Demo"
RETURN
'
' ---------------------------------------------------------------------------
' Freier Speicherplatz in GEMDOS mit DFREE ermitteln
' ---------------------------------------------------------------------------
> PROCEDURE speicher
  DIM i%(3)
  adr%=V:i%(0)
  fehler%=GEMDOS(54,L:adr%,1)
  @fehler
  PRINT i%(0);" -> anzahl der freien Cluster  (anz%)"
  PRINT i%(1);" -> gesamtzahl der Cluster     (ganz%)"
  PRINT i%(2);" -> Bytes pro sector           (bsec%)"
  PRINT i%(3);" -> Sektoren pro Cluster       (cseg%)"
  PRINT "Daraus ergibt sich folgende Berechnung:"
  PRINT "Freier Speicher = (bsec% * cseg%) * anz%"
  PRINT "Gesamt Speicher = (bsec% * cseg%) * ganz%"
  PRINT
  PRINT "Freier Speicher auf Disk mit GEMDOS : ";STR$((i%(2)*i%(3))*i%(0),7)
  PRINT "Freier Speicher mit Basic - DFREE   : ";STR$(DFREE(1),7)
  PRINT
  PRINT "Gesamter Speicherplatz laut GEMDOS  : ";STR$((i%(2)*i%(3))*i%(1),7)
  PRINT "Davon gehen 2 Cluster für die FAT ab: ";STR$((i%(2)*i%(3))*i%(1)-2048,7)
  PRINT
  PRINT "Bitte eine Taste drücken"
  ~INP(2)
RETURN
'
' ---------------------------------------------------------------------------
' Uhrzeit mit GEMDOS lesen und dann neue mit TOUCH schreiben
' ---------------------------------------------------------------------------
> PROCEDURE uhrzeit
  CLS
  PRINT "Bitte einen Dateinamen wählen !"
  REPEAT
    FILESELECT "\*.*",dn$,dn$
  UNTIL LEN(dn$)>4
  dh%=GEMDOS(61,L:V:dn$,2)        ! FOPEN - Datei öffnen
  IF dh%=-33 OR dh%=-35 OR dh%=-36
    ALERT 3,"Fehler beim Uhrzeitprog!|Welcher kommt gleich!",1,"Aha",a
    ~FORM_ALERT(1,ERR$(ERR))
    EDIT
  ELSE
    dat%=0                                ! Hilfsvariable
    ~GEMDOS(87,L:V:dat%,dh%,0)            ! Datum/Uhrzeit lesen
    u16&=WORD(dat%)                       ! enthält das Datum
    o16&=WORD(SHR(dat%,16))               ! enthält die Zeit
    tag=u16& AND 2^5-1                    ! Werte herausfiltern
    mon=SHR(u16&,5) AND 15
    jahr&=SHR(u16&,9)
    PRINT tag,mon,1980+jahr&
    sek=o16& AND 2^5-1
    min=SHR(o16&,5) AND 2^6-1
    std=SHR(o16&,11) AND 2^5-1
    PRINT std,min,sek*2
    dat$=STR$(tag,2)+"."+STR$(mon,2)+"."+STR$(1980+jahr&,4)
    uhr$=STR$(std,2)+":"+STR$(min,2)+":"+STR$(sek*2,2)
  ENDIF
  PRINT "Datum der Datei  "+dn$+" :";dat$
  PRINT "Uhrzeit der Datei"+dn$+" :";uhr$
  PRINT
  PRINT "Bitte eine Taste drücken"
  ~INP(2)
  REPEAT
    CLS
    PRINT "Neu Eingabe der Daten :"
    PRINT "Neue Uhrzeit eingeben HH:MM:SS Format beachten! ";
    INPUT uhr$
    PRINT "Neues Datum eingeben TT.MM.JJJJ Format beachten! ";
    INPUT dat$
    SETTIME uhr$,dat$                      ! Zeit/Datum intern setzen
  UNTIL LEFT$(TIME$,5)=LEFT$(uhr$,5) AND dat$=DATE$
  '
  ' Die UNTIL-Abfrage bewirkt das erst dann die Schleife verlassen wird wenn das
  ' Datum und die Uhrzeit richtig eingegeben wurden.
  '
  OPEN "U",#1,dn$    ! Datei mit für TOUCH mit OPEN öffnen.
  TOUCH #1           ! Systemdatum als neues Datum für die Datei
  CLOSE #1
  fehler%=GEMDOS(62,dh%) ! Datei von GEMDOS aus schlie×en
RETURN
> PROCEDURE fehler
  IF fehler%<0
    ERROR fehler%
    STOP
  ENDIF
RETURN
