If Xbios(4)=0 Then
  R=320
  B=200
  Gr=2
  Ln=14
  Bg=4
Endif
If Xbios(4)=1 Then
  R=640
  B=200
  Gr=1
  Ln=2
  Bg=3
Endif
If Xbios(4)=2 Then
  R=640
  B=400
  Gr=1
  Ln=1
  Bg=0
Endif
T=0
L=0
Lng=R/4
Inp=Pi/Lng
Off=B/4
Zvalue=-2*Pi
Dim A$(24)
A$(0)=" Desk "
A$(1)=" About Trig Graphs "
A$(2)="-------------------"
A$(3)="1"
A$(4)="2"
A$(5)="3"
A$(6)="4"
A$(7)="5"
A$(8)="6"
A$(9)=""
A$(10)=" Angles 1 "
A$(11)="  Sine    "
A$(12)="  Cosine  "
A$(13)="  Tangent "
A$(14)="----------"
A$(15)="  Quit  "
A$(16)=""
A$(17)="  Angles 2  "
A$(18)="  Cosecant  "
A$(19)="  Secant    "
A$(20)="  Cotangent "
A$(21)=""
A$(22)=""
B$="Trigonmetric Graphs|Converted By|Charles Harris|& Braun Tacon"
C$="Ho-Hum|Great!|More!"
Menu A$()
Menu Off
On Menu  Gosub Info
Do
  On Menu
Loop
Procedure Info
  Menu Off
  Cls
  Value=Menu(0)
  If Value=1
    Gosub Get_rez
  Endif
  If Value=11
    Gosub Sine
  Endif
  If Value=12
    Gosub Cosine
  Endif
  If Value=13
    Gosub Tangent
  Endif
  If Value=15
    Alert 1,B$,2,C$,B
    If B=2
      Gosub Thanks
    Endif
    If B=3
      Gosub Byebye
    Endif
    End
  Endif
  If Value=18
    Gosub Cosecant
  Endif
  If Value=19
    Gosub Secant
  Endif
  If Value=20
    Gosub Cotangent
  Endif
  Menu A$()
Return
Procedure Fini
  Pause 150
  Cls
  Showm
Return
Procedure Grid
  Line L,B/2,R,B/2
  Line R/2,T,R/2,B
  Zvalue=-2*Pi
  X=L
  X1=L
  Y1=B/2
Return
Procedure Plot
  Y=Off*Y
  Y=B/2-Y
  If Y<T Or Y>B
    Goto Skip
  Endif
  If X<L Or X>R
    Goto Skip
  Endif
  Plot X,Y
  Draw X1,Y1
  Skip:
  X1=X
  Y1=Y
  X=X+1
  Zvalue=Zvalue+Inp
  If Zvalue>2*Pi Then
    Gosub Fini
  Else
  Endif
Return
Procedure Sine
  Hidem
  Gosub Grid
  Repeat
    Y=Sin(Zvalue)
    Gosub Plot
  Until Zvalue>2*Pi
Return
Procedure Cosine
  Hidem
  Gosub Grid
  Repeat
    Y=Cos(Zvalue)
    Gosub Plot
  Until Zvalue>2*Pi
Return
Procedure Tangent
  Hidem
  Gosub Grid
  Repeat
    Y=Tan(Zvalue)
    Gosub Plot
  Until Zvalue>2*Pi
Return
Procedure Cosecant
  Hidem
  Gosub Grid
  Repeat
    Hold=Sin(Zvalue)
    If Hold=0 Then
      Gosub Plot
    Else
      Y=1/Hold
      Gosub Plot
    Endif
  Until Zvalue>2*Pi
Return
Procedure Secant
  Hidem
  Gosub Grid
  Repeat
    Hold=Cos(Zvalue)
    If Hold=0 Then
      Gosub Plot
    Else
      Y=1/Hold
      Gosub Plot
    Endif
  Until Zvalue>2*Pi
Return
Procedure Cotangent
  Hidem
  Gosub Grid
  Repeat
    Hold=Tan(Zvalue)
    If Hold=0 Then
      Gosub Plot
    Else
      Y=1/Hold
      Gosub Plot
    Endif
  Until Zvalue>2*Pi
Return
Procedure Byebye
  Alert 2,"Would You Like To|Know More About|GFA Basic",1,"Yes|No",B
  If B=1
    Alert 2,"$79.95 From|Michtron|Still Want It",1,"You Bet!",B
  Endif
  If B=2
    Alert 1,"You'll|Be|Sorry",1,"Too Bad",B
    Quit
  Endif
Return
Procedure Thanks
  Alert 0,"Written And Compiled|In GFA Basic|Look For More Soon",1,"See Ya!",B
Return
Procedure Low
  Cls
  Defline ,2
  Box 75,40,245,160
  Graphmode 2
  Color 1
  Deftext 1,1,0,13
  Text 80,65,"T R I G  G R A P H S"
  Text 80,90,"   By Rob Collier"
  Deftext 1,1,0,6
  Text 80,120,"    Programed in"
  Deftext 1,8,0,13
  Text 95,145,"G F A  B A S I C"
  Gosub Fini
Return
Procedure Medium
  Cls
  Get 150,50,445,160,A$
  Deffill 0,2,8
  Defline ,2
  Pbox 150,50,445,160
  Box 150,50,445,160
  Box 152,52,443,158
  Graphmode 2
  Color 1
  Deftext 1,1,0,13
  Text 155,75,"        T R I G  G R A P H S"
  Text 158,100,"           By Rob Collier"
  Deftext 1,1,0,6
  Text 155,120,"            Programed in"
  Deftext 1,8,0,13
  Text 236,145,"G F A  B A S I C"
  Gosub Fini
Return
Procedure High
  Cls
  Defline ,2
  Box 220,120,420,280
  Graphmode 2
  Color 1
  Deftext 1,1,0,13
  Text 240,145,"T R I G  G R A P H S"
  Text 242,185,"   By Rob Collier"
  Deftext 1,1,0,6
  Text 240,230,"    Programed in"
  Deftext 1,8,0,13
  Text 255,265,"G F A  B A S I C"
  Gosub Fini
Return
Procedure Get_rez
  If Xbios(4)=0
    Gosub Low
  Endif
  If Xbios(4)=1
    Gosub Medium
  Endif
  If Xbios(4)=2
    Gosub High
  Endif
Return
