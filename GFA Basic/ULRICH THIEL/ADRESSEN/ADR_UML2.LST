' ----------------
Procedure Umlaut
  Do
    Exit If Right$(Daten$(I%,1),1)<>" "
    Daten$(I%,1)=Left$(Daten$(I%,1),Len(Daten$(I%,1))-1)
  Loop
  For Fel%=1 To 7
    Datuml$(Fel%)=Daten$(I%,Fel%)
    If Len(Datuml$(Fel%))>0
      For Uml=1 To 7
        Repeat
          Umlflag=0
          Ins=Instr(Datuml$(Fel%),Uml$(Uml))
          If Ins<>0
            Umlflag=1
            Mid$(Datuml$(Fel%),Ins,1)=Um$(Uml)
          Endif
        Until Umlflag=0
      Next Uml
    Endif
  Next Fel%
Return
