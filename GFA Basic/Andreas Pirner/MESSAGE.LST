' -------------------------------- GFA Tips und Tricks # 3 --------------------
'
' filename.ext
' MESSAGE .LST
'
' I    02.1988
' U 18.08.1988
'
' -------------------------------- Demo ---------------------------------------
'
' Openw 0                        ! *
' Openw 1                        ! **
' Fullw 1                        ! **
'
Deffill 1,2,4                    ! "Profigrauer"
Pbox 0,0,639,399                 !  Hintergrund
@Me("MOMENT:|MACH MAL|PAUSE...") ! Aufruf der Message
Defmouse 2                       ! Fleissiges-Bienchen-Mauszeiger
'
Pause 200                        ! Hier findet die Aktion statt, die etwas Zeit
'                                  kostet und auf die hingewiesen wird.
'
Put 242,137,Backgr$              ! Alte Rahmenfläche (Hintergrund) restaurieren
' Put 242,155,Backgr$            !   dito , wenn oben *      gilt
' Put 242,173,Backgr$            !   dito , wenn oben * + ** gilt
'                                ... denn GET zählt ab linker Ecke des geöffne-
'                                  ten Fensters, PUT ab linker Ecke Bildschirm
'
Defmouse 0                       ! Normal-Pfeil-Mauszeiger
Pause 100                        ! So ist es danach ...
'
' Closew 1                       ! **
' Closew 0                       ! *
'
Edit                             ! Das war's !
'
' -------------------------------- Message ------------------------------------
'
Procedure Me(T$)
  Local I%,J%                           ! Nur lokal nötige Variablen
  @Rahmen(242,137,388,223)              ! Rahmen zeichnen (s.u.)
  Deftext 1,17,0,13                     ! Textformat auf 'Fett + Outlined'.
  I%=Instr(T$,"|")                      ! Trennstrich 1 suchen.
  J%=Instr(I%+1,T$,"|")                 ! Trennstrich 2 suchen.
  Text 270,164,90,Left$(T$,I%-1)        ! Message in
  Text 270,184,90,Mid$(T$,I%+1,J%-I%-1) ! drei Teilen
  Text 270,204,90,Mid$(T$,J%+1,50)      ! ausgeben.
  Deftext 1,0,0,13                      ! Textformat auf normal zurücksetzen.
Return
'
' --------------------------------- Rahmen im ATARI-Look ----------------------
'
Procedure Rahmen(X1%,Y1%,X2%,Y2%)
  Get X1%-1,Y1%-1,X2%+1,Y2%+1,Backgr$   ! Rahmenfläche mit Rand retten
  Deffill 1,0                           ! Mit Hintergrundfarbe
  Pbox X1%+0,Y1%+0,X2%-0,Y2%-0          ! (=wei×) gefüllte Box
  Box X1%+3,Y1%+3,X2%-3,Y2%-3           ! und zwei weitere
  Box X1%+4,Y1%+4,X2%-4,Y2%-4           ! 'Normal'boxen zeichnen.
Return
'
' --------------------------------- Ende --------------------------------------
