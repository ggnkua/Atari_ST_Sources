' ----------------------------------------------------------------------------
'
' filename.ext
' SLCTFILE.LST
'
' I       1987
' U 10.05.1988
'
' ----------------------------------------------------------------------------
'
' ----- Initialisierung
'
Max_path%=2
Dim Pathname$(Max_path%),Filename$(Max_path%),F_name$(Max_path%),Extension$(Max_path%)
'
' ----- Test der Routine
Repeat
  Repeat
    @Select_a_file(1)
  Until Exist(Pathname$(1)+Filename$(1)) Or Abbruch!
  Print Pathname$(1)+Filename$(1)
Until Abbruch!
Edit
'
' ----- Programmende
'
' -------------------------------------- Select_a_file Unterprogramm ---------
'
Procedure Select_a_file(No%)
  Local Choice$,Extension$,Index%
  If Pathname$(No%)="" Then
    Pathname$(No%)=Chr$(65+Gemdos(&H19))+":"+Dir$(0)+"\"
  Endif
  If Extension$(No%)="" Then
    Extension$="*"
  Else
    Extension$=Extension$(No%)
  Endif
  Fileselect Pathname$(No%)+"*."+Extension$,Filename$(No%),Choice$
  If Choice$>"" Then
    Abbruch!=False
    Index%=Len(Choice$)
    While Mid$(Choice$,Index%,1)<>"\" And Index%>0
      Dec Index%
    Wend
    Pathname$(No%)=Left$(Choice$,Index%)
    Filename$(No%)=Right$(Choice$,Len(Choice$)-Index%)
    If Filename$(No%)>""
      Length%=Len(Filename$(No%))
      Index%=Instr(Filename$(No%),".")
      If Index%>0
        Extension$(No%)=Right$(Filename$(No%),Length%-Index%)
        F_name$(No%)=Left$(Filename$(No%),Index%-1)
      Else
        F_name$(No%)=Filename$(No%)
        If Extension$(No%)<>"" Then
          Filename$(No%)=Filename$(No%)+"."+Extension$(No%)
        Endif
      Endif
    Endif
  Else
    Abbruch!=True
  Endif
Return
'
' --------------------------------------- Programm Ende ----------------------
