@node "gemagnetic_start" "GEMagnetic: guide"

 A respawn GEM port for Magnetic 2.3, 
                        interpretor for Magnetic Scrolls games.

@image gemagnet.img 2






  
  
 @{"Generalities" LINK "gemagnetic_general"} - @{"Legal" LINK "gemagnetic_legal"}
 
 @{"Installation" LINK "gemagnetic_install"} - @{"Basic use" LINK "gemagnetic_use"} - @{"Scripts" LINK "gemagnetic_scripts"} - @{"Preferences" LINK "gemagnetic_prefs"} 
 
