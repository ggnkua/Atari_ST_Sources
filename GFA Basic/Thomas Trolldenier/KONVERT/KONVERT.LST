' *****************************************
' Formatwandler PC/ASCII Texte in 1ST_WORD
' Thomas Trolldenier August 1988
' ******************************************
FILESELECT "\*.*","",selected$  !Datei auswÑhlen
OPEN "U",#1,selected$           !und îffnen
REPEAT
  a$=INPUT$(1,#1)               !Ein Zeichen lesen
  PRINT a$;
  a=ASC(a$)                     !in ASCII verwandeln
  IF a=32                       !SPACE ? Dann fÅr 1ST_WORD fixed-Space
    SEEK #1,zaehler             !nach lesen wieder positionieren
    OUT #1,30                   !30 dezimal, 'normales' Space bei 1ST_WORD
  ENDIF
  INC zaehler                   !Filepointer erhîhen
  SEEK #1,zaehler               !und auf nÑchstes Byte in Datei
UNTIL EOF(#1)                   !bis Ende
