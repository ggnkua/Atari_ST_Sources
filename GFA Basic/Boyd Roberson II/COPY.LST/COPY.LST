Procedure Copy(Source$,Dest$)
  'By Boyd Roberson II
  Local Lf%,File$
  Open "I",#1,Source$
  Open "O",#2,Dest$
  Lf%=Lof(#1)
  If Lf%>32000 Then
    ?"File to Large"
    Goto Copy_exit
  Endif
  File$=String$(Lof(#1)," ")
  Bget #1,Varptr(File$),Lf%
  Bput #2,Varptr(File$),Lf%
  Close #1
  Close #2
  Copy_exit:
Return
