Dim Leiste$(50)
For I%=0 To 50
  Read Leiste$(I%)
  Exit If Leiste$(I%)="***"
Next I%
Leiste$(I%)=""
Leiste$(I%+1)=""
Data Desk,Info
Data --------------------
Data 1,2,3,4,5,6,""
Data Berechnen, Frequenzgang,  ...nochmal,  Tabelle,  Gehäuse,  Grafik,geschlossenes G.,""
Data Vorschlag,Reflexgehäuse,geschlossen,""
Data Crossover, Hochpass , Tiefpass , Schaltbild ,-----------,  Entzerrung,Induktivität,""
Data Hörner ,Grenzfrequenz, Länge , Liste ,""
Data Programm,  Quit ,""
Data ***
Menu Leiste$()
Openw 0
'
Menu 12,2
Menu 13,2
Menu 14,2
Menu 15,2
Menu 27,0
'
On Menu  Gosub Menue1
Do
  On Menu
Loop
'
'
Procedure Menue1
  Deftext 1,0,0,13
  If Leiste$(Menu(0))="Induktivität"
    @Indi
    Menu Off
  Endif
  If Leiste$(Menu(0))="Grenzfrequenz"
    @Grenzfq
    Menu Off
  Endif
  If Leiste$(Menu(0))=" Länge "
    @Laenge
    Menu Off
  Endif
  If Leiste$(Menu(0))=" Liste "
    @Horn
    Menu Off
  Endif
  If Menu(0)=27    !  If Leiste$(Menu(0))="  Entzerrung"
    Inc Zaehler%
    If Even(Zaehler%)
      Menu 27,0
      Equ!=False
    Else
      Menu 27,1
      Equ!=True
    Endif
    Menu Off
  Endif
  If Leiste$(Menu(0))=" Schaltbild "
    If Lopass!
      @Scheme_lo
    Endif
    If Hipass!
      @Scheme_hi
    Endif
    Menu Off
  Endif
  If Leiste$(Menu(0))=" Hochpass "
    @Hochpass
    Menu Off
  Endif
  If Leiste$(Menu(0))=" Tiefpass "
    @Tiefpass
    Menu Off
  Endif
  If Leiste$(Menu(0))=" Frequenzgang"
    @Frequenzgang
    Menu Off
  Endif
  If Leiste$(Menu(0))="  ...nochmal"
    Nochmal!=True
    @Frequenzgang
    Menu Off
  Endif
  If Leiste$(Menu(0))="  Gehäuse"
    @Box
    Menu Off
  Endif
  If Leiste$(Menu(0))="  Grafik"
    @Grafik
    Menu Off
  Endif
  If Leiste$(Menu(0))="  Tabelle"
    @Tabelle
    Menu Off
  Endif
  If Leiste$(Menu(0))="Reflexgehäuse"
    Opt_refl!=True
    @Frequenzgang
    Menu Off
  Endif
  If Leiste$(Menu(0))="geschlossenes G."
    @Kiste1
    For I=12 To 15
      Menu I,2
    Next I
    Menu Off
  Endif
  If Leiste$(Menu(0))="geschlossen"
    @Kiste2
    Menu Off
  Endif
  If Leiste$(Menu(0))="  Quit "
    End
  Endif
  If Leiste$(Menu(0))="Info"
    @Info
    Menu Off
  Endif
Return
Procedure Frequenzgang
  Cls
  Erase P()
  Dim P(10)
  If Nochmal!=False And Opt_refl!=False
    Print "Frequenzgang"
    Input "Resonanzfrequenz des Lautsprechers ( Fs ): ";Fs
    Input "Vas-Volumen des Lautsprechers (Liter): ";Va
    Input "Qt-Faktor: ";Q
    Input "Resonanzfrequenz der Box ( Fb ): ";Fb
    Input "Anfangsvolumen der Box in Litern";Vb
    Input "Schrittweite in Litern";W
  Endif
  If Opt_refl!
    Print
    Print "Vorschlag für ein Reflexgehäuse mit optimalem Frequenzgang"
    Print
    Input "Resonanzfrequenz des Lautsprechers ( Fs ): ";Fs
    Input "Vas-Volumen des Lautsprechers (Liter): ";Va
    Input "Qt-Faktor: ";Q
    Print
    Vb=Va*15*Q^2.87
    Fb=Int(0.5+0.42*Fs*Q^-0.9)
    Print
    Print "> Nettovolumen der Box : ";Int(Vb*10+0.5)/10;" Liter"
    Print "> Resonanzfrequenz des Gehäuses : ";Fb;" Hz"
    Print
    Print "Weiter mit einer Maustaste..."
    Repeat
    Until Mousek>0
  Endif
  If Nochmal!
    Print
    Print "Neuer Versuch mit dem gleichen Lautsprecher:"
    Print
    Input "Resonanzfrequenz der Box ( Fb ): ";Fb
    Input "Anfangsvolumen der Box in Litern";Vb
    Input "Schrittweite in Litern";W
  Endif
  V1=Vb
  @Tabelle
  '  Freq!=True
  Nochmal!=False
  Opt_refl!=False
  Menu 12,3
  Menu 13,3
  Menu 14,3
  Menu 15,3
Return
'
Procedure Box
  Cls
  Print
  Input "Länge des Tunnels in cm: ";L
  Input "Volumen der Box in Litern: ";Vb
  L=L/100
  Vb=Vb/1000
  D=0.1
  Pi=2*Atn(10^12)
  While Int(F)>Fb
    B=((Pi/2)*(D/2)+L)*Vb
    A=(D/2)^2*Pi
    F=Int(54*Sqr(A/B)*10+0.5)/10
    Let D=D-D/100
  Wend
  While Int(F)<Fb
    B=((Pi/2)*(D/2)+L)*Vb
    A=(D/2)^2*Pi
    F=Int(54*Sqr(A/B)*10+0.5)/10
    Let D=D+D/100
  Wend
  If Int(F)=Fb Then
    Print
    Print "*   Resonanzfrequenz = ";F;"  Hz"
  Endif
  Print
  Print "*   Der Durchmesser mu× ";Int(D*1000+0.5)/10;" Zentimeter betragen"
  A=(D/2)^2*Pi
  Print
  Print "*   Das entspricht einer Fläche von ";Int(A*10^5+0.5)/10;
  Print " Quadratzentimetern"
  Print
  Print
  Input "Soll die Öffnung rechteckig sein?     J/N";X$
  If Not (X$="J" Or X$="j")
    End
  Endif
  Print
  Input "Gib eine Seitenlänge in cm an: ";S
  Print
  Print "*   Die andere Seite mu× ";Int(A*10^5/S+0.5)/10;" Zentimeter lang sein"
Return
'
Procedure Grafik
  Cls
  Print
  Print
  Input "   Gewähltes Volumen (Liter): ";Vb
  '
  Cls
  Nullinie=350/5*2
  Line 35,0,35,399
  Line 0,350,639,350
  Defline 3
  Line 34,140,639,140
  Defline 1
  '  Line Fb+35,355,Fb+35,335             ! Fb-Markierung auf X-Achse
  Deftext 1,0,0,6
  '  Text Fb+27,345,"Fb"                  !und der Text dazu
  I%=40
  Repeat
    Line I%+35,348,I%+35,355
    I$=Str$(I%)
    Text I%+25,365,I$
    Add I%,40
  Until I%>520
  Text I%+55,365,"Hz"
  '
  Text 2,20," dB"
  Text 1,Nullinie-30,"+ 3"
  Text 1,Nullinie-60,"+ 6"
  Text 1,Nullinie-90,"+ 9"
  Text 19,Nullinie,"0"
  Text 1,Nullinie+30,"- 3"
  Text 1,Nullinie+60,"- 6"
  Text 1,Nullinie+90,"- 9"
  Text 1,Nullinie+120,"- 12"
  Text 1,Nullinie+150,"- 15"
  Text 1,Nullinie+180,"- 18"
  '
  A=Fb^2/Fs^2
  B=A/Q+Fb/(7*Fs)
  C=1+A+Fb/(7*Fs*Q)+Va/Vb
  D=1/Q+Fb/(7*Fs)
  Max=-10000
  Max!=False
  For F=20 To 600
    E=F/Fs
    M=(E^4-C*E^2+A)^2
    N=(B*E-D*E^3)^2
    O=E^4/Sqr(M+N)
    Z=10*Int(20*Log(O)/Log(10)*10+0.5)/10
    Draw 35+F,Nullinie-Z
    If Max<Z
      Max=Z
    Endif
    If F=Fb     ! Hier ist die Fb-Markierung in der Frequenzkurve
      Line F+35,Nullinie-Z-10,F+35,Nullinie-Z+20
      Text F+37,Nullinie-Z+20,"Fb"
    Endif                                                ! Fertig
    If Max>Z And Max!=False
      Max!=True
      If Z<0
        F$=Str$(F)+" Hz"
        Text F+8,Nullinie-Max-12,F$
        Z$=Str$(Z/10)+" dB"
        Text F,Nullinie-Max-4,Z$
      Else
        Z$="+"+Str$(Z/10)+" dB"
        Text F+35,Nullinie-Max-4,Z$
        F$=Str$(F)+" Hz"
        Text F+43,Nullinie-Max-12,F$
      Endif
    Endif
  Next F
  Deftext 1,0,0,13
  Print At(50,15);"Fs=";Fs;" Hz"
  Print At(50,16);"Qt=";Q
  Print At(50,17);"Fb=";Fb;" Hz"
  Print At(50,18);"Vb=";Vb;" Liter"
  '
Return
'
Procedure Tabelle
  Cls
  Print "Frequenz";"    Relative Lautstärke für Volumen"
  Print "           ";
  If Opt_refl!
    Print Using "    ####",V1;
    Print "  Liter"
  Else
    For I=1 To 6
      Print Using "    ####",V1+(I-1)*W;
      If I=6
        Print "     Liter"
      Endif
    Next I
  Endif
  Print
  For F=200 To 40 Step -10
    Vb=V1
    For I=1 To 6
      A=Fb^2/Fs^2
      B=A/Q+Fb/(7*Fs)
      C=1+A+Fb/(7*Fs*Q)+Va/Vb
      D=1/Q+Fb/(7*Fs)
      E=F/Fs
      M=(E^4-C*E^2+A)^2
      N=(B*E-D*E^3)^2
      O=E^4/Sqr(M+N)
      P(I)=Int(20*Log(O)/Log(10)*10+0.5)/10
      Vb=Vb+W
    Next I
    Print Using "###  Hz:   ",F;
    If Opt_refl!
      Print Using "   ###.#",P(1)
    Else
      For I=1 To 6
        Print Using "   ###.#",P(I);
      Next I
    Endif
    If Not Opt_refl!
      Print
    Endif
  Next F
Return
'
Procedure Info
  Cls
  Print At(5,4);" Programm zur Vorausberechnung von Lautsprecher-Frequenzgängen"
  Print At(5,5);" in Bassreflexgehäusen"
  Print At(5,9);" Version 2.0         vom     29.5.1989"
  Print At(5,11);" Programmiert in GFA-Basic V 2.02"
  Print At(5,13);"Das Programm ist Public-Domain und steht hiermit der Allgemeinheit"
  Print At(5,14);"zur beliebigen Weitergabe und Verbesserung zu Verfügung."
  Print At(5,15);"Wer es aber einfach in kommerzielle Programme einbaut, dem möge"
  Print At(5,16);"manch schlaflose Nacht gegönnt sein. Wenigstens Bescheid sagen"
  Print At(5,17);"kann man ja vorher, oder?"
  Print At(10,20);"Christian Hu×"
  Print At(10,21);"Skarbinastra×e 74"
  Print At(10,22);"1000 Berlin 49"
  Print At(55,22);"KLICK . . ."
  Box 400,335,550,355
  Repeat
  Until Mousek=1 Or Mousek=2
  Cls
  Print
  Print "   Ein Hinweis:"
  Print
  Print " Ich habe einige Zeit davon gelebt, Lautsprecher zu konstruieren und zu"
  Print " bauen. Dabei habe ich über ein Jahr lang Informationen aus allen möglichen"
  Print " Quellen zusammengetragen und so meine Erfahrungen gemacht."
  Print
  Print " Zur Zeit bin ich dabei, das so  gewonnene Wissen aufzuschreiben."
  Print " Es wird zwar kein Buch werden, aber einiges wird schon drin stehen,"
  Print " was man nicht im 'Klinger' und ähnlichen Bastelbüchern findet."
  Print " Au×erdem werden noch Erläuterungen zum Programm mit hineinkommen. Könnte ja"
  Print " sein, da× nicht alle schon ein bis sechs Lautsprecherbaubücher gelesen haben."
  Print " Ich denke, im Juni/Juli 1989 wird die kleine Trickkiste fertig."
  Print
  Print " Wer sich dafür interessiert, kann das Heft für DM 12,- (incl. Porto usw.)"
  Print " bestellen. Bitte Betrag auf untenstehendes Konto überweisen und Deinen"
  Print " NAMEN und ANSCHRIFT deutlich schreiben!"
  Print " Wer das Geld im Brief schickt (Risiko!), tut das auf eigene Gefahr!"
  Print
  Print " Postgirokonto Christian Hu×, Kto.-Nr. 29 60 87 - 106, BLZ 10010010"
  Print " Postgiroamt Berlin (BlnW)"
  Print
  Print " Danke."
  Print At(55,22);"KLICK . . ."
  Box 400,335,550,355
  Repeat
  Until Mousek=1 Or Mousek=2
  Cls
  Print At(5,10);"Noch eine BITTE:"
  Print At(5,12);"Ich würde mich freuen, wenn Leute, die dieses Programm womöglich"
  Print At(5,13);"professionell verwenden oder wesentlich weiterentwickeln (wer wei×,"
  Print At(5,14);"vielleicht macht's ja einer...), mir das mitteilt und gegebenenfalls"
  Print At(5,15);"eine Kopie seiner Weiterentwicklung schickt. Einfach nur so,"
  Print At(5,16);"ich bin halt entsetzlich neugierig."
  Print At(5,17);"Aber nicht, da× irgend jemand ein 'Update' meines Programmes in"
  Print At(5,18);"in den Public-Domain-Pool gibt, das fände ich unfair."
  Print At(5,20);"Christian Hu×"
  Print At(55,22);"ENDE . . ."
  Box 400,335,550,355
  Repeat
  Until Mousek=1 Or Mousek=2
  Cls
Return
'
Procedure Kiste1
  Cls
  Print
  Input "Resonanzfrequenz des Lautsprechers ( Fs ): ";Fs
  Input "Vas-Volumen des Lautsprechers (Liter): ";Va
  Input "Qt-Faktor: ";Q
  Input "Anfangsvolumen der Box in Litern";Vb
  Input "Schrittweite in Litern";W
  Print
  Print
  Print
  Print " Im eingebauten Zustand ergeben sich folgende neue Werte:"
  Print
  Print " Volumen des geschlossenen Gehäuses:"
  Print "           ";
  V1=Vb
  For I=1 To 6
    Print Using "    ####",V1+(I-1)*W;
    If I=6
      Print "     Liter"
    Endif
  Next I
  Print
  Print " Neue Resonanzfrequenz im eingebauten Zustand:"
  Print "           ";
  For I=1 To 6
    Print Using "    ####",Fs*Sqr(1+Va/(V1+(I-1)*W));
    If I=6
      Print "     Hz"
    Endif
  Next I
  Print
  Print " Neues Qt im eingebauten Zustand:"
  Print "              ";
  For I=1 To 6
    Print Using "    #.##",Q*Sqr(1+Va/(V1+(I-1)*W));
  Next I
Return
'
Procedure Kiste2
  Cls
  Print
  Input "Resonanzfrequenz des Lautsprechers ( Fs ): ";Fs
  Input "Vas-Volumen des Lautsprechers (Liter): ";Va
  Input "Qt-Faktor: ";Q
  Print
  Print
  Print
  Print "Das Gehäusevolumen sollte zwischen folgenden Grenzwerten liegen :"
  Print
  V1=Va/((1/Q)^2-1)
  V2=Va/((0.7/Q)^2-1)
  Print "                  ",Int(V1+0.5);" Liter",Int(V2+0.5);" Liter"
  Print
  Print "    Qt,eingebaut:",1,0.7
  Print "Resonanzfrequenz,"
  Print "            eingebaut: ",Int(Fs*Sqr(1+Va/V1));"  Hz",Int(Fs*Sqr(1+Va/V2));"  Hz"
  Print
  Print
  Print " Achtung! Das ist natürlich nur eine ganz allgemeine Empfehlung!"
  Print " Manchmal liefert diese Rechnung absurde Ergebnisse. Dann ist"
  Print " möglicherweise der Lautsprecher für eine geschlossene Box ungeeignet."
Return
'
Procedure Hochpass
  Cls
  Print
  Print " Zur Berechnung werden der Gleichstromwiderstand (Re) und"
  Print " die Induktivität (L) der Schwingspule benötigt !"
  Alert 1,"    Na, und ?        ",1,"Hab ich!| Mist ! ",Var
  If Var=1
    Alert 2," Flankensteilheit wählen: ",0,"6 dB/Okt|12db/Okt|18dB/Okt",Var
    Print
    Print
    Input "  Gleichstromwiderstand in Ohm ";Re
    Input "  Induktivität in mH ";Ind
    Input "  Grenzfrequenz in Hz ";Fg
    Xl=2*Pi*Fg*Ind/1000
    Impedanz=Sqr(Re^2+Xl^2)
    If Var=1
      Kond=Int(1/(2*Pi*Impedanz*Fg)*10^8+0.5)/100
      Print
      Print " HOCHPASSFILTER mit 6 dB/Oktave:"
      Print
      Print " Der Kondensator sollte eine Kapazität von        ";Kond;" ";Chr$(230);"F    haben."
      Db6!=True
      Db12!=False
      Db18!=False
    Endif
    If Var=2
      @X_12_db
      Db6!=False
      Db12!=True
      Db18!=False
    Endif
    If Var=3
      Kond=Int(1/(3*Pi*Fg*Impedanz)*10^8+0.5)/100
      Kond2=Int(1/(Pi*Fg*Impedanz)*10^8+0.5)/100
      Spule=Int(3*Impedanz/(8*Pi*Fg)*10^5+0.5)/100
      Print
      Print " HOCHPASSFILTER mit 18 dB/Oktave:"
      Print
      Print " Der erste Kondensator sollte eine Kapazität von  ";Kond;" ";Chr$(230);"F"
      Print " die Drosselspule sollte eine Induktivität von    ";Spule;" mH"
      Print " der zweite Kondensator sollte eine Kapazität von  ";Kond2;" ";Chr$(230);"F       haben."
      Print
      Print " Den nächsten käuflichen Wert nehmen; im Zweifelsfalle den grö×eren."
      Db6!=False
      Db12!=False
      Db18!=True
    Endif
    Hipass!=True
    Lopass!=False
  Else
    Cls
  Endif
Return
'
Procedure Tiefpass
  Cls
  Print
  Print " Zur Berechnung werden der Gleichstromwiderstand (Re) und"
  Print " die Induktivität (L) der Schwingspule benötigt !"
  If Equ!
    Print " Für die Berechnung der Impedanzentzerrung au×erdem die Leistung des"
    Print " zu beschaltenden Einzellautsprechers (z.B. Tieftöner)."
  Endif
  Alert 1,"    Na, und ?        ",1,"Hab ich!| Mist ! ",Var
  Cls
  If Var=1
    Alert 2," Flankensteilheit wählen: ",0,"6 dB/Okt|12db/Okt|18dB/Okt",Var
    Cls
    Print
    Input "  Gleichstromwiderstand in Ohm ";Re
    Input "  Induktivität in mH ";Ind
    Input "  Grenzfrequenz in Hz ";Fg
    If Equ!
      Input "  Lautsprecherleistung in Watt ";Power
    Endif
    Xl=2*Pi*Fg*Ind/1000
    Impedanz=Sqr(Re^2+Xl^2)
    C_entzerr=Int(Ind/Re^2*10^5+0.5)/100
    If Var=1
      If Equ!
        Spule=Int(Re/(2*Pi*Fg)*10^5+0.5)/100
      Else
        Spule=Int(Impedanz/(2*Pi*Fg)*10^5+0.5)/100
      Endif
      Print
      Print " TIEFPASSFILTER mit 6 dB/Oktave:"
      Print
      Print " Die Drosselspule sollte eine Induktivität von    ";Spule;" mH    haben."
      Print " Den nächsten käuflichen Wert nehmen; im Zweifelsfalle den grö×eren."
      Print
      If Equ!
        Print " Impedanzentzerrung mit R=";Re;" Ohm   und C=";C_entzerr;" ";Chr$(230);"F"
      Else
        Print " Impedanzentzerrung ist hier besonders empfehlenswert!"
      Endif
      Db6!=True
      Db12!=False
      Db18!=False
    Endif
    If Var=2
      @X_12_db
      If Equ!
        Print
        Print " Impedanzentzerrung mit R=";Re;" Ohm   und C=";Int(Ind/Re^2*10^5+0.5)/100;" ";Chr$(230);"F"
      Endif
      Db6!=False
      Db12!=True
      Db18!=False
    Endif
    If Var=3
      If Equ!
        Spule=Int(3*Re/(4*Pi*Fg)*10^5+0.5)/100
        Spule2=Int(Re/(4*Pi*Fg)*10^5+0.5)/100
        Kond=Int(2/(3*Pi*Fg*Re)*10^8+0.5)/100
      Else
        Spule=Int(3*Impedanz/(4*Pi*Fg)*10^5+0.5)/100
        Spule2=Int(Impedanz/(4*Pi*Fg)*10^5+0.5)/100
        Kond=Int(2/(3*Pi*Fg*Impedanz)*10^8+0.5)/100
      Endif
      Print
      Print " TIEFPASSFILTER mit 18 dB/Oktave:"
      Print
      Print " Die erste Drosselspule sollte eine Induktivität von    ";Spule;" mH"
      Print " der Kondensator sollte eine Kapazität von              ";Kond;" ";Chr$(230);"F"
      Print " die zweite Drosselspule sollte eine Induktivität von   ";Spule2;" mH       haben."
      Print
      Print " Den nächsten käuflichen Wert nehmen; im Zweifelsfalle den grö×eren."
      If Equ!
        Print
        Print " Impedanzentzerrung mit R=";Re;" Ohm   und C=";Int(Ind/Re^2*10^5+0.5)/100;" ";Chr$(230);"F"
      Endif
      Db6!=False
      Db12!=False
      Db18!=True
    Endif
    If Equ!
      '
      If Fg<2000
        P_r=-10*Log10(Fg/100)
        P_r=Int(10^(P_r/10)*Power+0.5)
        P_r=P_r*(Re/(Re+1/(2*Pi*Fg*(Ind/(Re^2*10^3)))))
      Endif
      If Fg>2000
        P_r=-30*Log10(Fg/2000)-13
        P_r=Int(10^(P_r/10)*Power+0.5)
        P_r=P_r*(Re/(Re+1/(2*Pi*Fg*(Ind/(Re^2*10^3)))))
      Endif
      Print " Widerstand 'R' sollte mindestens mit ";Int(P_r+0.5);" Watt belastbar sein."
    Endif
    Lopass!=True
    Hipass!=False
  Else
    Cls
  Endif
Return
'
Procedure X_12_db
  If Equ!
    Spule=Int(Sqr(2)*Re/(2*Pi*Fg)*10^5+0.5)/100
    Kond=Int(Sqr(2)/(4*Pi*Fg*Re)*10^8)/100
  Else
    Spule=Int(Sqr(2)*Impedanz/(2*Pi*Fg)*10^5+0.5)/100
    Kond=Int(Sqr(2)/(4*Pi*Fg*Impedanz)*10^8)/100
  Endif
  Print
  Print " Hoch- oder Tiefpass mit 12 dB/Oktave:"
  Print
  Print " Die Drosselspule sollte eine Induktivität von    ";Spule;" mH    haben."
  Print " Der Kondensator sollte eine Kapazität von        ";Kond;" ";Chr$(230);"F    haben."
  Print
  Print " Den nächsten käuflichen Wert nehmen; im Zweifelsfalle den grö×eren."
Return
'
Procedure Scheme_hi
  Cls
  Deffill 1,1
  Draw 600,150 To 600,250 To 540,220 To 540,180 To 600,150
  Box 540,220,500,180
  Line 0,30,150,30
  Box 150,15,152,45
  Box 158,15,160,45
  C1$=Str$(Kond)+" "+Chr$(230)+"F"
  Text 110,70,C1$
  If Db18!
    Line 160,30,320,30
    Draw 330,30 To 520,30 To 520,180
    Box 320,15,322,45
    Box 328,15,330,45
    C2$=Str$(Kond2)+" "+Chr$(230)+"F"
    Text 300,70,C2$
  Else
    Draw 160,30 To 520,30 To 520,180
  Endif
  Draw 520,220 To 520,340 To 0,340
  If Db12! Or Db18!
    Line 240,30,240,100
    Line 240,200,240,340
    Pbox 235,100,245,200
    L1$=Str$(Spule)+" mH"
    Text 260,230,L1$
  Endif
  '  Repeat
  '  If Mousek=1
  '  Print At(2,2);"X :";Mousex;"   "
  '  Print At(2,3);"Y :";Mousey;"   "
  ' Endif
  ' Until Mousek=2
Return
'
Procedure Scheme_lo
  Cls
  Deffill 1,1
  Draw 600,150 To 600,250 To 540,220 To 540,180 To 600,150
  Box 540,220,500,180
  Text 532,264,"Lautsprecher-"
  Text 532,280,"impedanz:"
  Text 532,296,Str$(Int(Impedanz*10+0.5)/10)+" "+Chr$(234)
  Text 532,312,"bei "+Str$(Fg)+" Hz"
  Line 0,30,90,30
  Pbox 90,15,170,45
  L1$=Str$(Spule)
  Text 110,70,L1$+" mH"
  If Db18!
    Line 170,30,280,30
    Draw 360,30 To 520,30 To 520,180
    Pbox 280,15,360,45
    L2$=Str$(Spule2)+" mH"
    Text 300,70,L2$
  Else
    Draw 170,30 To 520,30 To 520,180
  Endif
  Draw 520,220 To 520,340 To 0,340
  If Db12! Or Db18!
    Line 240,30,240,195
    Line 240,205,240,340
    Box 225,195,255,197
    Box 225,203,255,205
    C1$=Str$(Kond)
    Text 260,230,C1$+" "+Chr$(230)+"F"
  Endif
  If Equ!
    Line 430,30,430,90
    Box 425,90,435,180
    R$=Str$(Re)
    Text 450,130,R$+" "+Chr$(234)
    P_r$="min. "+Str$(Int(P_r+0.5))+" Watt"
    Text 450,146,P_r$
    Line 430,180,430,260
    Line 430,270,430,340
    Box 415,260,445,262
    Box 415,268,445,270
    C2$=Str$(Int(Ind/Re^2*10^5+0.5)/100)
    Text 455,290,C2$+" "+Chr$(230)+"F"
  Endif
  '  Repeat
  '  If Mousek=1
  '  Print At(2,2);"X :";Mousex;"   "
  '  Print At(2,3);"Y :";Mousey;"   "
  ' Endif
  ' Until Mousek=2
Return
'
Procedure Grenzfq
  Local Laenge,Fa,Fm,Konstante,Fg
  Cls
  Print
  Print "  Aus Vorgaben für Länge, Anfangs- und Endöffnungsfläche"
  Print "  die theoretische Grenzfrequenz ermiteln"
  Print "  ( 10 000 cm";Chr$(253);" = 1 m";Chr$(253);" )"
  Print
  Input "  Trichterlänge in Zentimetern ";Laenge
  Div Laenge,100
  Input "  Anfangsfläche in Quadratzentimetern ";Fa
  Div Fa,10^4
  Input "  Mündungsfläche in Quadratzentimetern ";Fm
  Div Fm,10^4
  Print
  Print
  Konst=Log(Fm/Fa)/Laenge
  Fg=Int(Konst*340/(4*Pi)+0.5)
  Print "  Theoretische Grenzfrequenz für Exponentialtrichter: ";Fg;" Hz"
Return
Procedure Laenge
  Local Laenge,Fa,Fm,Fg
  Cls
  Print
  Print "  Aus Vorgaben für Grenzfrequenz, Anfangs- und Endöffnungsfläche"
  Print "  die notwendige Trichterlänge ermitteln"
  Print "  ( 10 000 cm";Chr$(253);" = 1 m";Chr$(253);" )"
  Print
  Input "  Grenzfrequenz ";Fg
  Input "  Anfangsfläche in Quadratzentimetern ";Fa
  Div Fa,10000
  Input "  Mündungsfläche in Quadratzentimetern";Fm
  Div Fm,10000
  Print
  Print
  Laenge=Int(Log(Fm/Fa)*340/(4*Pi*Fg)*100+0.5)/100
  Print " Mindestlänge des Exponentialtrichters: ";Laenge*100;" Zentimeter"
Return
'
Procedure Horn
  Local Fa,Fg,Laenge,Hier,W,Konst
  Cls
  Print
  Print " Tabelle der Querschnitts(flächen!)erweiterungen im Verlauf des "
  Print " Exponentialtrichters, ausgehend von der Anfangsöffnung (Lautsprecher)."
  Print
  Input " Anfangsfläche des Trichters in Quadratzentimetern ";Fa
  Div Fa,10000
  Input " Grenzfrequenz des Trichters ";Fg
  Input " Länge des Trichters in Zentimetern ";Laenge
  Div Laenge,100
  Cls
  Print " Grenzfrequenz: ";Fg;" Hz"
  Print " Anfangsfläche des Trichters in Quadratzentimetern: ";Fa*10^4
  Print
  If Laenge<=2
    W=0.1
  Endif
  If Laenge<=1
    W=0.05
  Endif
  If Laenge<0.2
    W=0.01
  Endif
  If Laenge>2
    W=Int(Laenge/20)
  Endif
  Konst=4*Pi*Fg/340
  Hier=0
  For I=W To (Laenge-W) Step W
    Hier=Hier+W
    Print Using "   #####  ",Hier*100;
    Print " cm : ";
    Print Using "      ##### ",Fa*Exp(Konst*Hier)*10^4;
    Print " cm";Chr$(253)
  Next I
  Print Using "   #####  ",Laenge*100+0.5;
  Print " cm : ";
  Print Using "      ##### ",Fa*Exp(Konst*Laenge)*10^4;
  Print " cm";Chr$(253)
Return
'
Procedure Indi
  Local Nennimp,Re,Ind
  Cls
  Print
  Print " Induktivität der Schwingspule abschätzen, falls der Hersteller nur"
  Print " Nennimpedanz und Gleichstromwiderstand angibt. ( Schämen soll er sich!)"
  Print
  Print
  Input " Nennimpedanz ( Ohm ) ";Nennimp
  Input " Gleichstromwiderstand ( Ohm ) ";Re
  Ind=Int(Sqr(Nennimp^2-Re^2)/(2*Pi*400)*10^5+0.5)/100
  Print
  Print
  Print " Induktivität der Schwingspule mü×te ungefähr bei ";Ind;" mH liegen"
  Print
  Print " Wert merken !"
Return
