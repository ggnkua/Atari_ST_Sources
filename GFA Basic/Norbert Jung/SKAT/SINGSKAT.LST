PROCEDURE b06
  IF vh=1
    IF f1%=5
      ON ze GOSUB b11,b20,b21,b22,cb1,c4
    ELSE
      IF w1%>w2%
        ON ze GOSUB b20,b21,b11,b22,b022,c4
      ELSE
        ON ze GOSUB b26,b28,b31,b_7,cb1,c4
      ENDIF
    ENDIF
  ELSE IF vh=2
    IF f2%=5
      ON ze GOSUB b14,b13,cb1,c4
    ELSE
      ON ze GOSUB b.7,b.8,b30,a17,cb1,c4
    ENDIF
