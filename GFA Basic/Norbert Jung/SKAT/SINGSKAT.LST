    ENDIF
  ELSE IF vh=2
    IF f2%=5
      ON ze GOSUB b13,cb1,c4
    ELSE
      ON ze GOSUB b29,cb3,c4
    ENDIF
  ENDIF
RETURN
PROCEDURE b08
  IF farb=6
    ON ze GOSUB br4,ar5,c4
  ELSE
    ON ze GOSUB br4,ar5,c4
  ENDIF
RETURN
PROCEDURE sp_2
  FOR n2%=0 TO 9
    s=2
    EXIT IF card2!
    no%=k2%(n2%)
    IF a%(no%)>0
      b2%=b%(no%)
      w2%=w%(no%)
      f2%=a%(no%)
      maks%=wma%(f2%)
      ON f2% GOSUB ana1,ana2,ana3,ana4,ana5
      IF farb>5
        IF farb=6
          ON ze GOSUB anr0a,anr1a,anr2,ca6,c4
        ELSE
          ON ze GOSUB anr0a,anr1a,anr3,ca6,c4
        ENDIF
      ELSE
        IF spieler=1
          ON ze GOSUB fehl10_1,angr1,an7,an6,tru2.1,ca2,ca3,ca1,c4
        ELSE IF spieler=2
          ON ze GOSUB an1a,an1gr,an1,an03,an02,an4a,an4,an2,an2a,an2b,an55,an56,ca2,ca3,c7,ca1,c4
        ELSE IF spieler=3
          ON ze GOSUB fehl10_3,angr3,tru2.3,an55,an8,ca2,ca3,ca1,c4
        ENDIF
      ENDIF
    ENDIF
  NEXT n2%
  IF NOT card2!
    INC ze
    @sp_2
  ENDIF
RETURN
PROCEDURE sp_3
  FOR n3%=0 TO 9
    EXIT IF card3!
    s=3
    no%=k3%(n3%)
    IF a%(no%)>0
      b3%=b%(no%)
      w3%=w%(no%)
      f3%=a%(no%)
      maks%=wma%(f3%)
      ON f3% GOSUB ana1,ana2,ana3,ana4,ana5
      IF farb>5
        IF farb=6
          ON ze GOSUB anr0b,anr1b,anr2,cb1,c4
        ELSE
          ON ze GOSUB anr0b,anr1b,anr.3,cb1,c4
        ENDIF
      ELSE
        IF spieler=1
          ON ze GOSUB fehl.10.1,an.gr1,tru3.1,an.55,an.8,an.9,b_7,cb2,cb3,cb1,c4
        ELSE IF spieler=2
          ON ze GOSUB fehl.10.2,an.gr2,tru3.2,an.56,an.7,b_7,cb2,cb3,cb1,c4
        ELSE IF spieler=3
          ON ze GOSUB an.1a,an.1gr,an.1,an.03,an.02,an.3a,an.3,an.2,an.2a,an.2b,an.55,an.56,cb2,cb3,c7,cb1,c4
        ENDIF
      ENDIF
    ENDIF
  NEXT n3%
  IF NOT card3!
    INC ze
    @sp_3
  ENDIF
RETURN
PROCEDURE blzehn(s,fb%)
  IF fb%<5
    IF col%(s,fb%)=2
      IF zehn%(fb%)<>s
        @karte(s)
      ELSE
        @as1(fb%)
      ENDIF
    ELSE
      @karte(s)
    ENDIF
  ENDIF
RETURN
PROCEDURE as1(fb%)
  LOCAL i%
  i%=7*(fb%-1)+5
  IF a%(i%)=0 OR as%(fb%)<>spieler
    @karte(s)
  ENDIF
RETURN
PROCEDURE fehl(s,fb%)
  flg%(s,fb%)=0
RETURN
PROCEDURE kenn(s,fb%)
  flg%(s,fb%)=2
RETURN
PROCEDURE anu1
  IF w1%>wmi%(f1%)
    IF w2%<w1%
      @karte(2)
    ENDIF
  ELSE
    @anua
  ENDIF
RETURN
