ON BREAK GOSUB ende
IF XBIOS(4)<2
  ALERT 1,"SINGLE-SkaT|lÑuft nur in|hoher Auflîsung!",1,"SORRY!",dum#
  END
ENDIF
HIDEM
DEFBYT "a-z"
ACLIP 1,0,0,639,399
mus3%=&X1010101010101010101010101010101
mus4%=0
ad4%=V:mus4%
ad3%=V:mus3%
muster%=-1
ad%=V:muster%
ARECT 0,0,639,399,1,0,ad%,1
DIM c$(28),t$(95)
GRAPHMODE 2
COLOR 0
DEFTEXT 0,8,0,26
TEXT 235,30,"SINGLE-SkaT"
DEFTEXT 0,0,0,6
TEXT 260,42,"September 1988"
DEFTEXT 0,1,0,13
TEXT 300,57,"von"
TEXT 30,75,"        Norbert Jung         Bergerstr.125       6000 Frankfurt 60"
RBOX 10,83,630,398
RBOX 10,0,630,81
COLOR 1
OPEN "i",#1,"Skat.Dat"
FOR i=1 TO 28
  c$(i)=INPUT$(CVI(INPUT$(2,#1)),#1)
NEXT i
CLOSE #1
OPEN "i",#1,"Info.txt"
RECALL #1,t$(),-1,dum%
CLOSE #1
FOR i=1 TO 16
  @kt(i,(32*i)-12,90,12)
  @kt(i+16,(32*i)-12,200,12)
NEXT i
@felder
DIM a%(32),wkl1%(5),wkl2%(5),wkl3%(5),wmi%(5),wgr1%(5),wgr2%(5),wgr3%(5),wma%(5)
DIM k1%(11),k2%(11),k3%(11),k4%(2),b%(32),w%(32),aw%(32)
ARRAYFILL flg%(),1
flg%(3,5)=1
ARRAYFILL a%(),1
a%(32)=1
anf!=TRUE
voha=1
@zufall
ALERT 0,"INFORMATIONEN|  öBER DAS|  PROGRAMM?",2,"JA|NEIN",al
IF al=1
  CLIP 15,85,612,306
  FOR i=0 TO 30
    RC_COPY XBIOS(2),15,87,611,306 TO XBIOS(2),15,85
  NEXT i
  i=65
  DO
    INC j
    RC_COPY XBIOS(2),15,87,611,306 TO XBIOS(2),15,85
    TEXT 25,405-j*2,t$(i)
    IF j=15
      INC i
      CLR j
    ENDIF
  LOOP UNTIL i=96
  CLR i,j
  CLIP 0,0,640,399
  PAUSE 10
ENDIF
GRAPHMODE 1
DIM pic%(32255/4)
@wechs1
DIM px#(3),py#(3),rcl2%(36,1),rcl%(36,38),nam%(36,41),far$(36),spil%(36)
@schirm
FOR i%=1 TO 199 STEP 3
  RC_COPY tl%,0,0,639,199 TO tn%,0,i%-199
  RC_COPY tl%,0,199,639,199 TO tn%,0,399-i%
NEXT i%
tl%=MAX(tl%,tn%)
~XBIOS(5,L:tl%,L:tl%,-1)
BOUNDARY 0
FOR i=0 TO 190 STEP 5
  @wechs1
  PUT 125,8,tex$
  PBOX 125,8,315-i,197
  PBOX 325+i,8,515,197
  @wechs2
NEXT i
PUT 125,8,tex$
CLR tl%,tn%,h$,tex$
ERASE pic%()
@init1
HIDEM
@t0
tim#=TIMER
DO
  @menue
LOOP
PROCEDURE namspeich
  FOR i=0 TO 39
    nam%(fang,i)=st%(i+1)
  NEXT i
  rcl2%(fang,0)=k4%(0)
  rcl2%(fang,1)=k4%(1)
  far$(fang)=farb$
  spil%(fang)=spieler
RETURN
PROCEDURE namrcl
  FOR i=0 TO 39
    st%(i+1)=nam%(op,i)
  NEXT i
  k4%(0)=rcl2%(op,0)
  k4%(1)=rcl2%(op,1)
  spieler=spil%(op)
  farb$=far$(op)
RETURN
PROCEDURE speicher
  FOR i=0 TO 9
    rcl%(fang,i)=k1%(i)
    rcl%(fang,i+10)=k2%(i)
    rcl%(fang,i+20)=k3%(i)
    IF i<2
      rcl%(fang,i+30)=k4%(i)
    ENDIF
  NEXT i
RETURN
PROCEDURE opspeich
  FOR i=0 TO 9
    k1%(i)=rcl%(op,i)
    k2%(i)=rcl%(op,i+10)
    k3%(i)=rcl%(op,i+20)
    IF i<2
      k4%(i)=rcl%(op,i+30)
    ENDIF
  NEXT i
RETURN
PROCEDURE optionen
  PUT 125,8,li$
  DEFTEXT 1,0,0,32
  TEXT 180,35,"Bitte wÑhlen Sie!"
  DEFTEXT 1,0,0,13
  TEXT 200,53,"(mit Cursortasten + <INSERT>)"
  rp!=FALSE
  op=nr-1
  @opcu0
  @opcur
  IF rep=1
    @bcl
    CLR stich,farb$
    @namrcl
    @namlis
    @anz0
    @bcl
    @t0
  ELSE IF rep=2
    anf!=FALSE
    re!=TRUE
    @neugeben
    @opspeich
    @init1
    PUT 13,19,i1$,10
    @beginn
  ENDIF
RETURN
PROCEDURE opcur
  REPEAT
    z=ASC(RIGHT$(INKEY$))
    SELECT z
    CASE 72
      @opcu1
      @t0
    CASE 80
      @opcu2
      @t0
    ENDSELECT
  UNTIL z=82 OR z=71 OR z=98
RETURN
PROCEDURE opcu0
  IF op<12
    @opcu3(0,op*10)
  ELSE IF op<24
    @opcu3(129,(op-12)*10)
  ELSE IF op<36
    @opcu3(258,(op-24)*10)
  ENDIF
RETURN
PROCEDURE opcu01
  IF op<12
    PUT 129,73+(op*10),rep$
  ELSE IF op<24
    PUT 258,73+((op-12)*10),rep$
  ELSE IF op<36
    PUT 387,73+((op-24)*10),rep$
  ENDIF
  CLR rep$
RETURN
PROCEDURE opcu1
  IF op>0
    @opcu01
    DEC op
    @opcu0
  ENDIF
RETURN
PROCEDURE opcu2
  IF op<fang
    @opcu01
    INC op
    @opcu0
  ENDIF
RETURN
PROCEDURE opcu3(li1%,li2%)
  GET 129+li1%,73+li2%,251+li1%,81+li2%,rep$
  PUT 129+li1%,73+li2%,rep$,12
RETURN
PROCEDURE wechs1
  tl%=XBIOS(3)
  tn%=(VARPTR(pic%(0))+255) AND &HFFFF00
  SWAP tl%,tn%
  ~XBIOS(5,L:tl%,L:tn%,-1)
RETURN
PROCEDURE wechs2
  SGET h$
  tl%=MAX(tl%,tn%)
  ~XBIOS(5,L:tl%,L:tl%,-1)
  SPUT h$
RETURN
PROCEDURE schirm
  HIDEM
  BOUNDARY 0
  ARECT 0,0,639,216,1,0,ad3%,1
  DEFFILL 1,3,9
  PBOX 0,217,639,399
  @lin
  ARECT 122,5,518,200,1,0,ad%,1
  ARECT 6,5,116,196,1,0,ad%,1
  ARECT 524,5,634,196,1,0,ad%,1
  ARECT 125,8,515,197,1,0,ad4%,1
  DEFFILL 1,2,5
  BOUNDARY 1
  PBOX 7,6,115,172
  PBOX 525,6,633,172
  DEFFILL 1,2,6
  PBOX 11,10,111,168
  PBOX 529,10,629,168
  ARECT 12,18,110,50,1,0,ad%,1
  DEFFILL 1,2,2
  PBOX 13,19,109,49
  GET 12,18,110,50,i0$
  GET 13,19,109,49,i1$
  @bcl
  DEFFILL 1,2,18
  PBOX 125,8,515,197
  FOR i=0 TO 60 STEP 5
    ux1%=320+INT(COSQ(i*6)*73)
    uy1%=102+INT(SINQ(i*6)*73)
    CIRCLE ux1%,uy1%,2
  NEXT i
  FOR i=0 TO 2
    PUT 12,18+50*i,i0$
    PUT 530,18+50*i,i0$
  NEXT i
  GRAPHMODE 2
  DEFTEXT 0,5,0,8
  FOR i=0 TO 2
    TEXT 50,63+50*i,"F"+STR$(i+1)
    TEXT 565,63+50*i,"F"+STR$(i+4)
  NEXT i
  DEFTEXT 1,1,0,13
  TEXT 40,32,"Karten"
  TEXT 44,45,"geben"
  TEXT 34,82,"Letzter"
  TEXT 40,96,"Stich"
  TEXT 26,139,"Uhr/Druck"
  TEXT 535,40,"Wiederholen"
  TEXT 542,139,"Statistik"
  DEFTEXT 1,2,0,13
  TEXT 535,89,"Bock/Ramsch"
  GET 13,119,109,150,i3$
  GRAPHMODE 1
  GET 125,8,515,197,uhr$
  @bcl
  PRINT AT(2,12);CHR$(27)+"p"
  PRINT AT(3,12);"Vorhand:"
  PRINT AT(68,12);"Gereizt: "
  DEFTEXT 1,0,0,26
  TEXT 180,55,"WÑhlen Sie mit den"
  TEXT 210,100,"Funktionstasten"
  TEXT 260,145,"F1 - F6"
  DEFTEXT 1,0,0,13
  TEXT 200,170,"FÅr weitere Hinweise bitte die"
  TEXT 230,190,"<HELP> - Taste drÅcken!"
  GET 125,8,515,197,tex$
  DEFFILL 1,2,16
  PBOX 125,8,515,197
RETURN
PROCEDURE fil(s,p%)
  IF p%>1100
    p%=1100
  ELSE IF p%<-640
    p%=-640
  ENDIF
  BOUNDARY 0
  DEFFILL 1,2,5
  IF p%<=0
    PBOX 132+(32*s),186,156+(32*s),122-(p%*0.1)
  ELSE
    PBOX 132+(32*s),186,156+(32*s),122
    DEFFILL 1,2,3
    PBOX 132+(32*s),122,156+(32*s),122-(p%*0.1)
  ENDIF
  BOUNDARY 1
  BOX 132+(32*s),186,156+(32*s),122-(p%*0.1)
  CLR s,p%
RETURN
PROCEDURE zeit
  GRAPHMODE 1
  PUT 125,8,uhr$
  ux%=320
  uy%=102
  ur2%=84*0.8
  ur3%=84*0.571
  ti$=LEFT$(TIME$,2)
  ti$=ti$+MID$(TIME$,4,2)
  ti$=ti$+RIGHT$(TIME$,2)
  us%=VAL(MID$(ti$,5,2))
  uw1%=us%-15
  um%=VAL(MID$(ti$,3,2))
  uw2%=um%-15
  ust%=VAL(MID$(ti$,1,2))
  IF ust%>12
    ust%=ust%-12
  ENDIF
  ust%=ust%*5+INT(um%/12)
  uw3%=ust%-15
  @fil(0,punkt11%)
  @fil(1,punkt22%)
  @fil(2,punkt33%)
  GET 420,140,510,180,mau$
  GRAPHMODE 2
  DEFTEXT 1,0,0,6
  FOR i=0 TO 2
    TEXT 132+i*32,194,"SP"+STR$(i+1)
  NEXT i
  DEFTEXT 1,0,0,32
  TEXT 415,50,"SPIEL:"
  TEXT 420,138,"ZEIT:"
  TEXT 440,90,anfang%
  mau#=INT((TIMER-tim#)/12000)
  TEXT 435,178,STR$(mau#)+"'"
  GRAPHMODE 1
  GET 230,12,410,192,uhr2$
  @uhrzeichnen
  uti%=TIMER
  BOUNDARY 0
  @vorsek
  DO
    IF TIMER>uti%+199
      uti%=TIMER
      GRAPHMODE 1
      @sekunde
    ENDIF
    EXIT IF INKEY$>""
    mau2#=INT((TIMER-tim#)/12000)
    GRAPHMODE 2
    IF mau2#>mau#
      PUT 420,140,mau$
      mau#=INT((TIMER-tim#)/12000)
      TEXT 435,178,STR$(mau#)+"'"
    ENDIF
  LOOP
  GRAPHMODE 1
  CLR uhr2$,mau$,um%,uw2%,ust%,ur2%,uti%,p%,ux%,uy%,u1%,mau#,mau2#,us%,uw1%,uw3%
  DEFLINE 1,1
RETURN
PROCEDURE vorsek
  u1%=-15
  BOUNDARY 1
  WHILE u1%<uw1%
    win1%=u1%*6
    win2%=(u1%+1)*6
    px#(0)=ux%+INT(COSQ(win1%)*80)
    py#(0)=uy%+INT(SINQ(win1%)*80)
    px#(1)=ux%+INT(COSQ(win1%)*85)
    py#(1)=uy%+INT(SINQ(win1%)*85)
    px#(2)=ux%+INT(COSQ(win2%)*85)
    py#(2)=uy%+INT(SINQ(win2%)*85)
    px#(3)=ux%+INT(COSQ(win2%)*80)
    py#(3)=uy%+INT(SINQ(win2%)*80)
    DEFFILL 1,2,16
    POLYFILL 4,px#(),py#()
    INC u1%
  WEND
RETURN
PROCEDURE sekunde
  INC us%
  win1%=uw1%*6
  px#(0)=ux%+INT(COSQ(win1%)*80)
  py#(0)=uy%+INT(SINQ(win1%)*80)
  px#(1)=ux%+INT(COSQ(win1%)*85)
  py#(1)=uy%+INT(SINQ(win1%)*85)
  INC uw1%
  win1%=uw1%*6
  px#(2)=ux%+INT(COSQ(win1%)*85)
  py#(2)=uy%+INT(SINQ(win1%)*85)
  px#(3)=ux%+INT(COSQ(win1%)*80)
  py#(3)=uy%+INT(SINQ(win1%)*80)
  DEFFILL 1,2,16
  POLYFILL 4,px#(),py#()
  IF us%=60
    CLR us%
    PUT 230,12,uhr2$
    @minute
  ENDIF
RETURN
PROCEDURE minute
  INC um%
  DEFLINE 1,3,2,2
  INC uw2%
  ux2%=ux%+INT(COSQ(uw2%*6)*ur2%)
  uy2%=uy%+INT(SINQ(uw2%*6)*ur2%)
  LINE ux%,uy%,ux2%,uy2%
  IF um%/12=INT(um%/12)
    @stunde
  ELSE
    DEFLINE 1,5,2,2
    ux3%=ux%+INT(COSQ(uw3%*6)*ur3%)
    uy3%=uy%+INT(SINQ(uw3%*6)*ur3%)
    LINE ux%,uy%,ux3%,uy3%
  ENDIF
RETURN
PROCEDURE stunde
  INC ust%
  DEFLINE 1,5,2,2
  INC uw3%
  ux3%=ux%+INT(COSQ(uw3%*6)*ur3%)
  uy3%=uy%+INT(SINQ(uw3%*6)*ur3%)
  LINE ux%,uy%,ux3%,uy3%
  IF ust%=60
    CLR ust%
  ENDIF
RETURN
PROCEDURE uhrzeichnen
  DEFLINE 1,3,2,2
  ux2%=ux%+INT(COSQ(uw2%*6)*ur2%)
  uy2%=uy%+INT(SINQ(uw2%*6)*ur2%)
  LINE ux%,uy%,ux2%,uy2%
  DEFLINE 1,5,2,2
  ux3%=ux%+INT(COSQ(uw3%*6)*ur3%)
  uy3%=uy%+INT(SINQ(uw3%*6)*ur3%)
  LINE ux%,uy%,ux3%,uy3%
RETURN
PROCEDURE t0
  LPOKE XBIOS(14,1)+6,0
RETURN
PROCEDURE tast
  ALERT 1,"Taste|zur Zeit|nicht|wÑhlbar",1,"Schade",dum
RETURN
PROCEDURE bcl
  ARECT 125,8,515,197,1,0,ad4%,1
RETURN
PROCEDURE menue
  DO
    HIDEM
    key$=INKEY$
    IF LEN(key$)=2
      key%=ASC(RIGHT$(key$))
      SELECT key%
      CASE 59
        IF rei!
          farb=1
          PUT 13,19,i1$,10
          @abfrag
        ELSE
          IF anf!
            PUT 13,19,i1$,10
            IF anfang%>0
              rp!=TRUE
              INC anfang%
              INC voha
              IF anfang% MOD 36=1
                CLR fang
              ELSE
                INC fang
              ENDIF
              anf!=FALSE
              re!=TRUE
              @neugeben
              @zufall
              @init1
              @t0
              @beginn
            ELSE
              rp!=TRUE
              anf!=FALSE
              INC anfang%
              re!=TRUE
              @t0
              @beginn
            ENDIF
          ELSE
            @tast
          ENDIF
        ENDIF
      CASE 60,71
        IF rei!
          farb=2
          PUT 13,69,i1$,10
          @abfrag
        ELSE
          IF stich>1
            @liste
          ELSE
            @tast
          ENDIF
        ENDIF
      CASE 98
        @hilfe
      CASE 61
        IF rei!
          farb=3
          PUT 13,119,i1$,10
          @abfrag
        ELSE
          PUT 13,119,i1$,10
          ALERT 2,"  AUSWAHL:    ",3,"UHR|DRUCK|NIX",dum
          IF dum=1
            ALERT 2,"Eingabe der|Uhrzeit|FORMAT: HHMMSS",2,"JA|NEIN",al
            IF al=1
              PUT 13,119,i1$,0
              PRINT AT(5,9);
              FORM INPUT 6 AS ti2$
              SETTIME ti2$,DATE$
              @t0
            ENDIF
          ELSE IF dum=2
            IF GEMDOS(17)
              ALERT 1,"DRUCKER ONLINE!|Alles paletti fÅr|Protokollausdruck!",1,"GUT",dum
            ELSE
              ALERT 1,"FÅr Protokollausdruck|Drucker ONLINE|schalten!",1,"OKAY",dum
            ENDIF
          ENDIF
          PUT 13,119,i3$
        ENDIF
      CASE 62
        IF rei!
          farb=4
          PUT 531,19,i1$,10
          @abfrag
        ELSE
          IF (stich=0 OR stich>10) AND sto=2
            PUT 531,19,i1$,10
            @init1
            ALERT 2,"Anzeige des Protokolls|oder|Spielwiederholung?",3,"PROTO|SPIEL|ZURöCK",rep
            IF rep<3
              @optionen
            ENDIF
            PUT 531,19,i1$,10
          ELSE
            @tast
          ENDIF
        ENDIF
      CASE 63
        IF rei!
          farb=5
          PUT 531,69,i1$,10
          @abfrag
        ELSE
          IF bock=0
            @bora
          ELSE
            @tast
          ENDIF
        ENDIF
      CASE 64
        PUT 531,119,i1$,10
        IF rei!
          farb=6
          @abfrag
        ELSE
          SGET h$
          @zeit
          SPUT h$
          CLR h$
          PUT 531,119,i1$,10
          @t0
        ENDIF
      ENDSELECT
    ENDIF
    IF LEN(key$)=1
      IF ASC(key$)=27
        ALERT 2,"Wirklich|beenden?",0,"Bitte|NEIN!",al
        IF al=1
          END
        ENDIF
      ELSE
        GOTO marke
      ENDIF
    ENDIF
  LOOP
  marke:
RETURN
PROCEDURE bora
  PUT 531,69,i1$
  GRAPHMODE 2
  IF bora!
    bora!=FALSE
    DEFTEXT 1,2,0,13
  ELSE
    DEFTEXT 1,1,0,13
    bora!=TRUE
  ENDIF
  TEXT 535,89,"Bock/Ramsch"
  GRAPHMODE 1
RETURN
PROCEDURE bock0
  PUT 531,69,i1$,0
  DEFFILL 1,2,2
  BOUNDARY 1
  @bock1
  @bock2
  @bock3
  @bock4
  @bock5
  @bock6
RETURN
PROCEDURE bock1
  PBOX 536,74,541,94
RETURN
PROCEDURE bock2
  PBOX 546,74,551,94
RETURN
PROCEDURE bock3
  PBOX 556,74,561,94
RETURN
PROCEDURE bock4
  PCIRCLE 580,84,7
RETURN
PROCEDURE bock5
  PCIRCLE 597,84,7
RETURN
PROCEDURE bock6
  PCIRCLE 614,84,7
RETURN
PROCEDURE zoom
  FOR i=0 TO 94 STEP 2
    ARECT 313-i*2,102-i,327+i*2,103+i,1,0,ad4%,1
  NEXT i
RETURN
PROCEDURE hilfe
  LOCAL j,i%
  SGET h$
  @fu
  @zoom
  DEFTEXT 1,9,0,14
  TEXT 250,150,t$(32)
  DEFTEXT 1,0,0,13
  i%=33
  CLIP 140,9,375,188
  DO
    INC j
    RC_COPY XBIOS(2),140,9,375,189 TO XBIOS(2),140,8
    TEXT 140,211-j,t$(i%)
    IF j=20
      INC i%
      CLR j
    ENDIF
  LOOP UNTIL i%=63 AND j=16
  CLIP 0,1,640,399
  DEFTEXT 1,0,0,10
  TEXT 220,212,"TASTE DRöCKEN!"
  ~INP(2)
  @zoom
  DEFTEXT 1,0,0,32
  FOR i%=0 TO 2
    @umri(130+130*i%,10,3)
    TEXT 135+(130*i%),80,"SPIELER"
    TEXT 180+(130*i%),120,i%+1
  NEXT i%
  DEFTEXT 1,0,0,13
  TEXT 135,160,"Das sind immer"
  TEXT 170,180,"SIE!"
  ~INP(2)
  SPUT h$
  CLR h$,j,i%
RETURN
PROCEDURE zufall
  FOR n=1 TO 4
    z=RANDOM(32)+1
    IF a%(z)>0
      ON n GOSUB kk1,kk2,kk3,kk4
    ENDIF
    c5=c1+c2+c3+c4
  NEXT n
  IF c5<32
    @zufall
  ENDIF
  CLR z,c1,c2,c3,c4,c5
RETURN
PROCEDURE kk1
  IF c1<10
    k1%(c1)=z
    a%(z)=0
    INC c1
  ENDIF
RETURN
PROCEDURE kk2
  IF c2<10
    k2%(c2)=z
    a%(z)=0
    INC c2
  ENDIF
RETURN
PROCEDURE kk3
  IF c3<10
    k3%(c3)=z
    a%(z)=0
    INC c3
  ENDIF
RETURN
PROCEDURE kk4
  IF c4<2
    k4%(c4)=z
    a%(z)=0
    INC c4
  ENDIF
RETURN
PROCEDURE ende
  END
RETURN
PROCEDURE vorh
  PRINT CHR$(27)+"p"
  PRINT AT(11,12);"Sp."+STR$(voha)
RETURN
PROCEDURE loesch
  ARECT 80,172,110,192,1,0,ad%,1
  ARECT 600,172,630,192,1,0,ad%,1
RETURN
PROCEDURE rz
  PRINT CHR$(27)+"p"
  PRINT AT(76,12);STR$(rz%)
RETURN
PROCEDURE felder
  DIM bg%(3),wa%(3),flg%(3,5),st%(40)
  DIM zehn%(4),bu%(3),as%(4),punkt%(3),mal%(3),col%(3,5),ass%(3)
RETURN
PROCEDURE neugeben
  ERASE as%(),mal%(),st%()
  ERASE zehn%(),col%(),punkt%(),bu%(),bg%(),ass%(),wa%(),flg%()
  @felder
  CLR farb,farb2,farb3
  CLR z,stich,sto,spieler,gef,s
  CLR ha$,h$,n1%,n2%,n3%,n4%,ram,m%,ska,kabu,hebu,pbu,krbu
  CLR rz%,vorg,reizda%,farb$,ra1,ra2,ra3
  CLR karo,herz,pek,kreuz,trumpf
  graha!=FALSE
  ARRAYFILL flg%(),1
  flg%(3,5)=1
  ARRAYFILL a%(),1
  a%(32)=1
  ~FRE(0)
  HIDEM
RETURN
PROCEDURE init1
  HIDEM
  RESTORE bilddat
  FOR i=1 TO 32
    READ b%(i)
  NEXT i
  RESTORE fawertdat
  FOR i=1 TO 32
    @initfaw(i)
  NEXT i
  RESTORE awdat
  FOR i=1 TO 32
    READ aw%(i)
  NEXT i
RETURN
PROCEDURE initfaw(i)
  READ a%(i),w%(i)
RETURN
awdat:
DATA 40,35,30,25,20,10,5,3,0,0,0,20,10,5,3,0,0,0,20,10,5,3,0,0,0,20,10,5,3,0,0,0
bilddat:
DATA 2,2,2,2,11,10,4,3,0,0,0,11,10,4,3,0,0,0,11,10,4,3,0,0,0,11,10,4,3,0,0,0
fawertdat:
DATA 5,90,5,85,5,80,5,75,1,7,1,6,1,5,1,4,1,3,1,2,1,1,2,7,2,6,2,5,2,4,2,3,2,2,2,1
DATA 3,7,3,6,3,5,3,4,3,3,3,2,3,1,4,7,4,6,4,5,4,4,4,3,4,2,4,1
nulldat:
DATA 4,5,3,5,2,5,1,5,1,8,1,4,1,7,1,6,1,3,1,2,1,1,2,8,2,4,2,7,2,6,2,3,2,2,2,1
DATA 3,8,3,4,3,7,3,6,3,3,3,2,3,1,4,8,4,4,4,7,4,6,4,3,4,2,4,1
PROCEDURE initial(farb)
  IF farb<>6
    RESTORE fawertdat
    FOR i=1 TO 32
      @initfaw(i)
      IF farb=a%(i)
        a%(i)=5
        MUL w%(i),10
      ENDIF
    NEXT i
  ELSE
    RESTORE nulldat
    FOR i=1 TO 32
      @initfaw(i)
    NEXT i
  ENDIF
RETURN
PROCEDURE trumpf
  FOR n=0 TO 9
    IF a%(k1%(n))=5
      INC col%(1,5)
    ENDIF
    IF a%(k2%(n))=5
      INC col%(2,5)
    ENDIF
    IF a%(k3%(n))=5
      INC col%(3,5)
    ENDIF
  NEXT n
  IF farb<5
    FOR i=1 TO 3
      col%(i,farb)=0
    NEXT i
  ENDIF
  CLR n
RETURN
PROCEDURE beginn
  HIDEM
  stich=1
  IF voha=4
    voha=1
  ENDIF
  IF bock>0 AND bora!
    DEFFILL 1,1
    ON bock GOSUB bock6,bock5,bock4,bock3,bock2,bock1
  ENDIF
  k2%(10)=k4%(0)
  k2%(11)=k4%(1)
  FOR n=0 TO 11
    @awert(k2%(n),2)
  NEXT n
  @r1(2)
  @aus(2)
  @reiz2
  SWAP farb2,farb
  punkt%(2)=mal%(2)*m%
  CLR m%
  k3%(10)=k4%(0)
  k3%(11)=k4%(1)
  FOR n=0 TO 11
    @awert(k3%(n),3)
  NEXT n
  @r1(3)
  @aus(3)
  @reiz2
  SWAP farb3,farb
  punkt%(3)=mal%(3)*m%
  CLR m%
  SSORT k1%(),10
  @an
  @bcl
  @vorh
  PUT 13,19,i1$,10
  IF rp!
    @speicher
    IF bora! AND (bock>0 AND bock<4)
      @bockramsch
    ENDIF
  ENDIF
  FOR i=0 TO 11
    ADD wa%(2),aw%(k2%(i))
    ADD wa%(3),aw%(k3%(i))
  NEXT i
  @blattwert(2)
  @blattwert(3)
  IF wa%(2)=wa%(3)
    IF ODD(anfang%)
      INC wa%(2)
    ELSE
      INC wa%(3)
    ENDIF
  ENDIF
  @t0
  DEFTEXT 1,0,0,13
  IF punkt%(2)=0 AND punkt%(3)=0
    ALERT 2,"RAMSCHEN?",0,"Okay|NENENE!",ram
    IF ram=1
      @ramsch
    ELSE
      rz%=18
      @t0
      @spiel1
    ENDIF
  ELSE
    DEFTEXT 1,0,0,10
    TEXT 65,212,"REIZEN = <Return>"
    TEXT 310,212,"PASSEN = <Leertaste>"
    DEFTEXT 1,0,0,26
    RESTORE reizdat
    IF wa%(2)>wa%(3)
      s=2
    ELSE IF wa%(3)>wa%(2)
      s=3
    ENDIF
    rei$="Spieler "+STR$(s)
    IF voha=1
      @reit(punkt%(s))
    ELSE
      @reit.2(punkt%(s))
    ENDIF
    IF punkt%(s)>=reizda%
      spieler=s
      CLR s
      @bcl
      @spiel2
    ELSE
      CLR s
      @reit2
    ENDIF
  ENDIF
RETURN
PROCEDURE bockramsch
  IF voha=1
    ALERT 2,"GRAND-HAND|spielen?",2,"YES|NIXDA",dum
    IF dum=2
      IF farb2<>5 AND farb3<>5
        @ramsch
      ENDIF
    ELSE
      INC bock
      graha!=TRUE
      @grandhand
    ENDIF
  ENDIF
  IF farb2=5
    spieler=2
    @grh
  ELSE IF farb3=5
    spieler=3
    @grh
  ENDIF
  IF voha>1
    ALERT 2,"GRAND-HAND|spielen?",2,"YES|NIXDA",dum
    IF dum=2
      @ramsch
    ELSE
      INC bock
      graha!=TRUE
      @grandhand
    ENDIF
  ENDIF
RETURN
PROCEDURE spielwahl
  DEFTEXT 1,0,0,13
  FOR i=0 TO 2
    PUT 13,19+i*50,i1$,0
    PUT 531,19+i*50,i1$,0
  NEXT i
  TEXT 559,89,"Grand"
  TEXT 564,139,"Null"
  PUT 46,22,c$(13)
  PUT 46,72,c$(10)
  PUT 46,122,c$(11)
  PUT 564,22,c$(12)
  @menue
RETURN
PROCEDURE abfrag
  DEFTEXT 1,8,0,26
  @farst(farb)
  TEXT 290,50,farb$
  ALERT 1,"Bitte|bestÑtigen",1,"O.K.|ZurÅck",abf
  IF abf=2
    @t0
    DEFTEXT 0,8,0,26
    TEXT 290,50,farb$
    CLR farb,farb$
    @spielwahl
  ELSE
    sp!=TRUE
    rei!=FALSE
    SPUT h$
    CLR h$
    DEFTEXT 1,0,0,13
    @t0
    @anfang
  ENDIF
RETURN
PROCEDURE blattwert(s)
  IF MAX(col%(s,1),col%(s,2),col%(s,3),col%(s,4))>4
    ADD wa%(s),10
  ENDIF
  IF bu%(s)>2
    ADD wa%(s),10
  ENDIF
  IF ass%(s)=3
    ADD wa%(s),10
  ENDIF
  IF wa%(s)<100
    punkt%(s)=0
  ENDIF
RETURN
PROCEDURE grh
  ha$="Hand"
  INC bock
  graha!=TRUE
  INC mal%(spieler)
  @fu
  @no2(2,k2%())
  @no2(3,k3%())
  IF spieler=2
    FOR n=0 TO 11
      @werte2(k2%(n),2)
    NEXT n
    farb=farb2
  ELSE
    FOR n=0 TO 11
      @werte2(k3%(n),3)
    NEXT n
    farb=farb3
  ENDIF
  @initial(farb)
  sto=2
  sp!=TRUE
  @eins
  @anfang
RETURN
PROCEDURE grandhand
  sp!=TRUE
  farb=5
  ha$="Hand"
  @bcl
  sto=2
  @no2(2,k2%())
  @no2(3,k3%())
  @eins
  @r1(1)
  INC mal%(1)
  rei!=FALSE
  spieler=1
  @anfang
RETURN
PROCEDURE ramsch
  sp!=TRUE
  CLR spieler
  farb=7
  @bcl
  @no2(2,k2%())
  @no2(3,k3%())
  @eins
  sto=2
  @anfang
RETURN
PROCEDURE reit2
  TEXT 285,90,"PASSE!"
  PAUSE 20
  spieler=1
  @t0
  @spiel1
RETURN
PROCEDURE reit(pu%)
  DO
    READ reizda%
    EXIT IF pu%<reizda%
    TEXT 250,50,rei$
    TEXT 300,90,reizda%
    rz%=reizda%
    DEFTEXT 1,3,0,26
    TEXT 250,135,"Spieler 1"
    mark:
    @t0
    x=INP(2)
    IF x=13
      TEXT 295,175,"JA"
    ELSE IF x=32
      TEXT 280,175,"PASSE"
    ELSE
      GOTO mark
    ENDIF
    PAUSE 20
    EXIT IF x=32
    DEFTEXT 0,0,0,26
    TEXT 295,175,"JA"
    DEFTEXT 1,0,0,26
  LOOP
RETURN
PROCEDURE reit.2(pu%)
  DO
    DEFTEXT 1,0,0,26
    TEXT 250,50,rei$
    DEFTEXT 1,3,0,26
    TEXT 250,135,"Spieler 1"
    mark2:
    @t0
    x=INP(2)
    IF x=32
      TEXT 280,175,"PASSE"
      IF reizda%=0
        rz%=18
      ENDIF
    ELSE IF x=13
      DEFTEXT 0,0,0,26
      TEXT 295,90,"JA"
      READ reizda%
      rz%=reizda%
      DEFTEXT 1,3,0,26
      TEXT 295,175,reizda%
    ELSE
      GOTO mark2
    ENDIF
    PAUSE 20
    DEFTEXT 1,0,0,26
    EXIT IF x=32
    EXIT IF pu%<reizda%
    IF pu%>=reizda%
      TEXT 295,90,"JA"
    ENDIF
  LOOP
RETURN
reizdat:
DATA 18,20,22,23,24,27,30,33,35,36,40,44,45,48,50,54,55,60,66,72,96,120,144,999
PROCEDURE r1(s)
  IF bu%(s)=4 OR bu%(s)=0
    mal%(s)=5
  ELSE IF (krbu=s AND pbu=s AND hebu=s AND kabu<>s) OR (krbu<>s AND pbu<>s AND hebu<>s AND kabu=s)
    mal%(s)=4
  ELSE IF (krbu=s AND pbu=s AND hebu<>s) OR (krbu<>s AND pbu<>s AND hebu=s)
    mal%(s)=3
  ELSE IF (krbu=s AND pbu<>s) OR (krbu<>s AND pbu=s)
    mal%(s)=2
  ENDIF
RETURN
PROCEDURE werte2(i%,s)
  SELECT i%
  CASE 1
    krbu=s
  CASE 5,12,19,26
    as%(INT(i%+2)/7)=s
  CASE 6,13,20,27
    zehn%(INT(i%+1)/7)=s
  ENDSELECT
RETURN
PROCEDURE awert(i%,s)
  SELECT i%
  CASE 1
    krbu=s
    INC bu%(s)
  CASE 2
    pbu=s
    INC bu%(s)
  CASE 3
    hebu=s
    INC bu%(s)
  CASE 4
    kabu=s
    INC bu%(s)
  CASE 5 TO 11
    INC col%(s,1)
  CASE 12 TO 18
    INC col%(s,2)
  CASE 19 TO 25
    INC col%(s,3)
  CASE 26 TO
    INC col%(s,4)
  ENDSELECT
  IF i%=5 OR i%=12 OR i%=19 OR i%=26
    INC ass%(s)
  ENDIF
RETURN
PROCEDURE aus(s)
  aus!=FALSE
  CLR farb
  @aw0
  REPEAT
    INC zf
    FOR f%=4 DOWNTO 1
      EXIT IF aus!
      ON zf GOSUB aw1,aw2,aw3,aw4
    NEXT f%
    CLR f%
  UNTIL aus!
  CLR f%,zf
RETURN
PROCEDURE aw4
  IF NOT aus!
    aus!=TRUE
  ENDIF
RETURN
PROCEDURE aw0
  IF (bu%(s)>2 AND ass%(s)>2) OR (bu%(s)>2 AND ass%(s)>1 AND MAX(col%(s,1),col%(s,2),col%(s,3),col%(s,4))>5) OR (ass%(s)=4 AND bu%(s)>0) OR (bu%(s)=4 AND ass%(s)>1)
    farb=5
    aus!=TRUE
  ENDIF
RETURN
PROCEDURE aw1
  IF (bu%(s)+col%(s,f%))>4 AND bu%(s)>0 AND ass%(s)>0 AND col%(s,f%)=MAX(col%(s,1),col%(s,2),col%(s,3),col%(s,4))
    farb=f%
    aus!=TRUE
  ENDIF
RETURN
PROCEDURE aw2
  IF (col%(s,f%)>=5 AND ass%(s)>1) OR (ass%(s)=4 AND col%(s,f%)>3)
    farb=f%
    aus!=TRUE
  ENDIF
RETURN
PROCEDURE aw3
  IF (col%(s,f%)>2 AND bu%(s)>=3) OR col%(s,f%)>6 OR col%(s,f%)+bu%(s)>=6
    farb=f%
    aus!=TRUE
  ENDIF
RETURN
PROCEDURE no2(s,VAR k%())
  FOR n=10 TO 11
    ON a%(k%(n)) GOSUB abw21,abw22,abw23,abw24,l1
    k%(n)=0
  NEXT n
RETURN
PROCEDURE l1
  DEC bu%(s)
RETURN
PROCEDURE eins
  FOR n1%=0 TO 9
    @awert(k1%(n1%),1)
    @werte2(k1%(n1%),1)
  NEXT n1%
RETURN
PROCEDURE spiel1
  @fu
  @no2(2,k2%())
  @no2(3,k3%())
  CLR spieler
  @rz
  IF vorg=0
    @bcl
    @skat
    @t0
    @bcl
  ENDIF
  DEFTEXT 1,0,0,13
  IF ha$<>"Hand"
    @anf3
  ENDIF
  @r1(1)
  IF ha$="Hand"
    INC mal%(1)
  ENDIF
  CLR m%
  spieler=1
  sp!=FALSE
  rei!=TRUE
  HIDEM
  SGET h$
  @spielwahl
RETURN
PROCEDURE spiel2
  @fu
  IF spieler=2
    @no2(3,k3%())
    FOR n%=0 TO 11
      @werte2(k2%(n%),2)
    NEXT n%
    farb=farb2
  ELSE
    @no2(2,k2%())
    FOR n%=0 TO 11
      @werte2(k3%(n%),3)
    NEXT n%
    farb=farb3
  ENDIF
  @initial(farb)
  ska=0
  ab%=1
  @ab0(spieler)
  CLR m%
  IF spieler=2
    @box02(k2%())
  ELSE IF spieler=3
    @box02(k3%())
  ENDIF
  sto=2
  sp!=TRUE
  @eins
  @anfang
RETURN
PROCEDURE box02(VAR k%())
  LOCAL z
  FOR i=0 TO 11
    IF k%(i)>0
      k%(z)=k%(i)
      INC z
    ENDIF
  NEXT i
RETURN
PROCEDURE an
  FOR n1%=0 TO 9
    @kt(k1%(n1%),64*n1%,216,3)
    @lin
  NEXT n1%
RETURN
PROCEDURE lin
  HLINE 0,216,639,1,0,ad%,1
  HLINE 0,217,639,1,0,ad%,1
RETURN
PROCEDURE anf3
  LOCAL z
  FOR n%=0 TO 11
    IF k1%(n%)>0
      @kt(k1%(n%),64*z,216,3)
      @lin
      k1%(z)=k1%(n%)
      INC z
    ENDIF
  NEXT n%
  CLR z
RETURN
PROCEDURE farst(farb)
  SELECT farb
  CASE 1
    farb$="KARO"
  CASE 2
    farb$="HERZ"
  CASE 3
    farb$="PIK"
  CASE 4
    farb$="KREUZ"
  CASE 5
    farb$="GRAND"
  CASE 6
    farb$="NULL"
  CASE 7
    farb$="RAMSCH"
  ENDSELECT
RETURN
PROCEDURE anfang
  IF sp!
    IF bock=0 OR bock>3
      @rz
    ENDIF
    CLR gesb%
    @farst(farb)
    IF spieler=1
      @initial(farb)
    ENDIF
    DEFTEXT 1,0,0,10
    IF farb<6
      @trumpf
      TEXT 170,212,"Spieler "+STR$(spieler)+" spielt "+farb$+ha$
    ELSE
      spieler=4
      IF farb=6
        IF ha$="Hand"
          punkt%(1)=35
        ELSE
          punkt%(1)=23
        ENDIF
      ENDIF
      IF farb=7
        @trumpf
      ENDIF
      TEXT 220,212,farb$+ha$
    ENDIF
    vh=voha
    HIDEM
    ON a%(k4%(0)) GOSUB bw21,bw22,bw23,bw24,bw25
    ON a%(k4%(1)) GOSUB bw21,bw22,bw23,bw24,bw25
    SSORT k2%(),10
    SSORT k3%(),10
    SELECT farb
    CASE 2 TO 4
      @box01(k1%())
      @box01(k2%())
      @box01(k3%())
    CASE 6
      @nullwert(1,k1%())
      @nullwert(2,k2%())
      @nullwert(3,k3%())
      @boxnull(k1%())
      @boxnull(k2%())
      @boxnull(k3%())
    ENDSELECT
    @an
    @lin
    CLR n1%,s
    PUT 13,119,i1$
    @klwert
    ON voha GOSUB vorhand1,vorhand2,vorhand3
  ENDIF
RETURN
PROCEDURE nullwert(s,VAR k%())
  FOR i%=0 TO 9
    SELECT k%(i%)
    CASE 1
      INC col%(s,4)
    CASE 2
      INC col%(s,3)
    CASE 3
      INC col%(s,2)
    CASE 4
      INC col%(s,1)
    ENDSELECT
  NEXT i%
RETURN
PROCEDURE boxnull(VAR k%())
  DIM k0%(9)
  CLR z%
  FOR fa%=1 TO 4
    h%=8
    REPEAT
      @boxn(fa%)
      DEC h%
    UNTIL h%=0
  NEXT fa%
  BMOVE VARPTR(k0%(0)),VARPTR(k%(0)),40
  ERASE k0%()
RETURN
PROCEDURE boxn(fa%)
  FOR i%=0 TO 9
    IF a%(k%(i%))=fa% AND w%(k%(i%))=h%
      k0%(z%)=k%(i%)
      k%(i%)=0
      INC z%
    ENDIF
  NEXT i%
RETURN
PROCEDURE box01(VAR k%())
  DIM k0%(9)
  CLR z%
  @box.0
  @box.01
  BMOVE VARPTR(k0%(0)),VARPTR(k%(0)),40
  ERASE k0%()
RETURN
PROCEDURE box.0
  FOR i%=0 TO 9
    IF a%(k%(i%))=5
      k0%(z%)=k%(i%)
      k%(i%)=0
      INC z%
    ENDIF
  NEXT i%
RETURN
PROCEDURE box.01
  FOR i%=0 TO 9
    IF k%(i%)>0
      k0%(z%)=k%(i%)
      INC z%
    ENDIF
  NEXT i%
RETURN
PROCEDURE reiz2
  SELECT farb
  CASE 1
    m%=9
  CASE 2
    m%=10
  CASE 3
    m%=11
  CASE 4
    m%=12
  CASE 5
    m%=24
  DEFAULT
    m%=0
  ENDSELECT
RETURN
PROCEDURE ab0(s)
  CLR i%
  REPEAT
    EXIT IF ska>1
    IF s=2
      no%=k2%(i%)
    ELSE
      no%=k3%(i%)
    ENDIF
    IF a%(no%)<5
      fa%=a%(no%)
      ba%=b%(no%)
      IF col%(s,fa%)=1 AND ba%<11
        @ab01
      ELSE
        ON ab% GOSUB ab1,ab1,ab1,ab2,ab2,ab3,ab3,ab3,ab4,ab4,ab4,abi2
      ENDIF
    ENDIF
    INC i%
  UNTIL i%>11
  IF ska<2
    INC ab%
    @ab0(s)
  ENDIF
RETURN
PROCEDURE ab1
  IF col%(s,fa%)=2 AND as%(fa%)<>s
    ON ab% GOSUB abi3,abi1,abi2
  ENDIF
RETURN
PROCEDURE abi1
  IF ba%>0 AND ba%<11
    @ab01
  ENDIF
RETURN
PROCEDURE abi2
  IF ba%<11
    @ab01
  ENDIF
RETURN
PROCEDURE abi3
  IF ba%=10
    @ab01
  ENDIF
RETURN
PROCEDURE ab2
  IF col%(s,fa%)=2
    ON ab%-3 GOSUB abi1,abi2
  ENDIF
RETURN
PROCEDURE ab3
  IF col%(s,fa%)=3
    ON ab%-5 GOSUB abi3,abi1,abi2
  ENDIF
RETURN
PROCEDURE ab4
  IF col%(s,fa%)=4
    ON ab%-8 GOSUB abi3,abi1,abi2
  ENDIF
RETURN
PROCEDURE ab01
  s=spieler
  IF no%>0
    ON fa% GOSUB abw21,abw22,abw23,abw24,abw25
    k4%(ska)=no%
    IF spieler=2
      k2%(i%)=0
    ELSE
      k3%(i%)=0
    ENDIF
    INC ska
  ENDIF
RETURN
PROCEDURE liste
  PUT 13,69,i1$,10
  IF stich>1
    SGET h$
    n4%=st%(stich-1)
    n2%=st%(stich+9)
    n3%=st%(stich+19)
    @kt(n4%,130,10,3)
    @kt(n2%,260,10,3)
    @kt(n3%,390,10,3)
    ~INP(2)
    SPUT h$
    @t0
  ENDIF
  CLR h$
  PUT 13,69,i1$,10
RETURN
PROCEDURE maus1
  HIDEM
  SGET cu2$
  REPEAT
    SPUT cu2$
    @zei
    @cur
    SELECT z
    CASE 82
      @weg1
    CASE 71
      @liste
    CASE 98
      @hilfe
    ENDSELECT
  UNTIL card1!
RETURN
PROCEDURE weg1
  IF a%(k1%(n1%))=0
    @maus1
  ELSE
    @kart
  ENDIF
RETURN
PROCEDURE zei
  WHILE n1%<10
    EXIT IF a%(k1%(n1%))>0
    INC n1%
  WEND
  REPEAT
    IF n1%>9
      DEC n1%
    ENDIF
    EXIT IF a%(k1%(n1%))>0
    DEC n1%
  UNTIL n1%=0
RETURN
PROCEDURE cur
  SGET cu$
  @cu2
  REPEAT
    cufl!=FALSE
    @t0
    REPEAT
      z$=INKEY$
    UNTIL z$<>""
    z=ASC(RIGHT$(z$))
    SELECT z
    CASE 75
      @cu3
    CASE 77
      @cu4
    ENDSELECT
  UNTIL z=82 OR z=71 OR z=98
RETURN
PROCEDURE cu3
  IF n1%>0
    FOR i%=1 TO n1%
      n2%=n1%-i%
      IF a%(k1%(n2%))>0
        cufl!=TRUE
      ENDIF
      EXIT IF cufl!
    NEXT i%
    IF cufl!
      n1%=n2%
      @cu2
    ENDIF
  ENDIF
RETURN
PROCEDURE cu4
  IF n1%<cu%
    FOR i%=1 TO cu%
      n2%=n1%+i%
      EXIT IF n2%>cu%
      IF a%(k1%(n2%))>0
        cufl!=TRUE
      ENDIF
      EXIT IF cufl!
    NEXT i%
    IF cufl!
      n1%=n2%
      @cu2
    ENDIF
  ENDIF
RETURN
PROCEDURE cu2
  SPUT cu$
  DEFLINE 1,3
  CLIP 0,1,640,399
  IF sto=2
    RBOX n1%*64,216,(n1%*64)+120,399
    cu%=9
    DEFTEXT 1,0,0,13
    GRAPHMODE 2
    TEXT 51-3*(LEN(t$(k1%(n1%)-1))),139,t$(k1%(n1%)-1)
    GRAPHMODE 1
  ELSE
    RBOX n1%*53,216,(n1%*53)+120,399
    cu%=11
  ENDIF
  DEFLINE 1,1
RETURN
PROCEDURE m2(fb%)
  HIDEM
  SGET cu2$
  REPEAT
    SPUT cu2$
    @zei
    @cur
    SELECT z
    CASE 82
      @k2(fb%)
    CASE 71
      @liste
    CASE 98
      @hilfe
    ENDSELECT
  UNTIL card1!
RETURN
PROCEDURE k2(fb%)
  bek!=TRUE
  IF a%(k1%(n1%))>0
    IF a%(k1%(n1%))<>fb%
      @k2.1(fb%)
      IF bek!=TRUE
        @fehl(1,fb%)
        IF a%(k1%(n1%))=5
          @kart
        ELSE
          w%(k1%(n1%))=0
          @kart
        ENDIF
      ENDIF
    ELSE
      @kart
    ENDIF
  ENDIF
RETURN
PROCEDURE k2.1(fb%)
  FOR i%=0 TO 9
    EXIT IF bek!=FALSE
    IF a%(k1%(i%))>0
      IF a%(k1%(i%))=fb%
        ALERT 3,"BITTE|BEKENNEN!",1,"Sorry",dum
        bek!=FALSE
      ENDIF
    ENDIF
  NEXT i%
RETURN
PROCEDURE anf2
  FOR n%=0 TO 11
    IF k1%(n%)=k4%(0) OR k1%(n%)=k4%(1)
      @kt(k1%(n%),53*n%,216,12)
    ELSE
      @kt(k1%(n%),53*n%,216,3)
    ENDIF
    @lin
  NEXT n%
RETURN
PROCEDURE kart
  HIDEM
  SPUT cu$
  CLR cu2$,cu$
  no%=k1%(n1%)
  w1%=w%(no%)
  f1%=a%(no%)
  b1%=b%(no%)
  BOUNDARY 0
  DEFFILL 1,3,9
  IF a%(k1%(n1%+1))=0
    PBOX 64*n1%,217,127+(64*n1%),399
  ELSE
    PBOX 64*n1%,217,63+(64*n1%),399
  ENDIF
  IF n1%>0
    IF a%(k1%(n1%-1))>0
      @kt(k1%(n1%-1),64*(n1%-1),216,3)
    ENDIF
  ENDIF
  card1!=TRUE
  @lin
  ~GRAF_MOVEBOX(64,120,64*n1%,216,130,10)
  @kt(no%,130,10,3)
  IF no%<5
    DEC bu%(1)
  ENDIF
  s=1
  ON f1% GOSUB abw21,abw22,abw23,abw24,abw25
  ON f1% GOSUB bw21,bw22,bw23,bw24,bw25
  st%(stich)=no%
  @kenn(1,f1%)
  CLR s,no%,gef
  PUT 13,119,i1$
RETURN
PROCEDURE skat
  sto=0
  @t0
  ALERT 2,"Skat aufnehmen?",1,"Ja|Nein",ant4
  IF ant4=1
    k1%(10)=k4%(0)
    k1%(11)=k4%(1)
    FOR i%=0 TO 11
      @awert(k1%(i%),1)
      @werte2(k1%(i%),1)
    NEXT i%
    SSORT k1%(),12
    @anf2
    @maus2
    @fu
  ELSE
    @eins
    sto=2
    ha$="Hand"
  ENDIF
RETURN
PROCEDURE maus2
  REPEAT
    EXIT IF sto=2
    HIDEM
    @cur
    IF z=82
      IF k1%(n1%)>0
        no%=k1%(n1%)
        @kt(no%,200+(140*sto),10,3)
        @t0
        ALERT 2,"Richtig ?",1,"JA|NEIN",ant2
        IF ant2=2
          @kt(no%,200+(120*sto),10,0)
          SPUT cu$
          @maus2
        ELSE
          @kt(no%,53*n1%,216,0)
          @fu
          k4%(sto)=no%
          k1%(n1%)=0
          IF sto=0
            @box001
          ELSE
            DEFFILL 1,3,9
            PBOX 53*n1%,217,110+(53*n1%),399
          ENDIF
          IF sto<2
            INC sto
            @maus2
          ENDIF
        ENDIF
      ELSE
        SPUT cu$
        @fu
      ENDIF
    ENDIF
  UNTIL sto=2
RETURN
PROCEDURE box001
  DEFFILL 1,3,9
  PBOX 53*n1%,217,110+(53*n1%),399
  FOR n%=0 TO 11
    no%=k1%(n%)
    IF a%(no%)>0
      @kt(no%,53*n%,216,3)
      @lin
    ENDIF
  NEXT n%
RETURN
PROCEDURE wertung
  HIDEM
  gesb%=b1%+b2%+b3%
  IF stich<12 AND stich>0
    IF w1%=MAX(w1%,w2%,w3%)
      st%(stich+30)=st%(stich)
      IF farb=6
        stich=10
        bg%(1)=1
      ENDIF
      INC ra1
      ADD bg%(1),gesb%
      vh=1
    ELSE IF w2%=MAX(w1%,w2%,w3%)
      st%(stich+30)=st%(stich+10)
      ADD bg%(2),gesb%
      INC ra2
      vh=2
    ELSE IF w3%=MAX(w1%,w2%,w3%)
      st%(stich+30)=st%(stich+20)
      ADD bg%(3),gesb%
      INC ra3
      vh=3
    ENDIF
    @bcl
    FOR i=0 TO 2
      a%(st%(stich+10*i))=0
    NEXT i
    CLR w1%,w2%,w3%,f1%,f2%,f3%,b1%,b2%,b3%,gesb%
    @t0
    INC stich
    IF stich<11
      @klwert
      ON vh GOSUB vorhand1,vorhand2,vorhand3
    ENDIF
  ENDIF
  IF stich=11
    PUT 13,119,i3$
    IF rp!
      @namspeich
    ENDIF
    @ergebnis
  ENDIF
RETURN
PROCEDURE zu
  @fu
  DEFTEXT 1,16,0,10
  TEXT 180,150,zu$
  DEFTEXT 1,2,0,26
  TEXT 270,50,mit$
  DEFTEXT 1,0,0,26
  TEXT 250,100,zu2$
  TEXT 180,190,zu3$
  DEFTEXT 1,0,0,10
  @stex(spieler)
RETURN
PROCEDURE sperg(s)
  CLR mit$
  ADD bg%(s),bg%(0)
  @reiz2
  punkt12%=mal%(s)*m%
  IF ha$="Hand"
    DEC mal%(s)
  ENDIF
  IF krbu=s
    mit$="MIT "+STR$(mal%(s)-1)
  ELSE
    mit$="OHNE "+STR$(mal%(s)-1)
  ENDIF
  IF bg%(s)<30
    ADD punkt12%,m%
    zu$="    BôS VERLOREN!"
  ENDIF
  IF bg%(s)>90
    ADD punkt12%,m%
    zu$="SCHNEIDER gespielt!"
  ENDIF
  IF bg%(s)=120
    ADD punkt12%,m%
    zu$="SCHWARZ gespielt!"
  ENDIF
  punkt13%=punkt12%
  IF bg%(s)>60
    IF punkt12%<rz%
      MUL punkt12%,-2
      zu2$="öBERREIZT!"
    ELSE
      zu2$="GEWONNEN!"
    ENDIF
  ELSE
    MUL punkt12%,-2
    IF bg%(s)=60 AND bora!
      zu2$="GESPALTEN!"
      zu3$="3 Bock / 3 Ramsch!"
      @spalt
    ELSE
      zu2$="VERLOREN!"
    ENDIF
  ENDIF
  IF bora!
    IF bock>2 AND bock<6 AND NOT graha!
      MUL punkt12%,2
    ENDIF
    @bock
  ENDIF
  punkt%(s)=punkt12%
RETURN
PROCEDURE spalt
  IF bock=0
    bock=6
    INC bock2
  ELSE
    INC bock2
  ENDIF
RETURN
PROCEDURE bock
  IF punkt13%>100
    zu3$="3 Bock / 3 Ramsch!"
    @spalt
  ENDIF
RETURN
PROCEDURE duma(s)
  TEXT 150,212,"Spieler "+STR$(s)+" hat Durchmarsch geschafft"
  punkt%(s)=120
RETURN
PROCEDURE jufra(s)
  TEXT 170,190,"Eine Jungfrau"
  MUL bg%(s),2
RETURN
PROCEDURE stex(sp)
  TEXT 170,212,"Spieler "+STR$(sp)+" hat "+STR$(bg%(sp))+" Augen!"
RETURN
PROCEDURE ergebnis
  IF bock>0 AND bora!
    bock!=TRUE
    IF bock=1
      DEC bock2
      IF bock2=0
        bora!=FALSE
        @bora
      ELSE
        ADD bock,6
      ENDIF
    ENDIF
    DEC bock
  ELSE
    bock!=FALSE
  ENDIF
  FOR n%=0 TO 1
    ADD bg%(0),b%(k4%(n%))
  NEXT n%
  DEFTEXT 1,0,0,10
  IF rp!
    IF farb=7
      IF bg%(1)=MAX(bg%(1),bg%(2),bg%(3))
        spieler=1
        IF ra2+ra3=0
          @duma(1)
        ELSE
          @stex(spieler)
          IF ra2=0 OR ra3=0
            @jufra(1)
          ENDIF
          ADD bg%(spieler),bg%(0)
          SUB punkt11%,bg%(1)
          punkt%(1)=bg%(1)*-1
        ENDIF
        punkt%(2)=0
        punkt%(3)=0
      ELSE IF bg%(2)=MAX(bg%(1),bg%(2),bg%(3))
        spieler=2
        IF ra1+ra3=0
          @duma(2)
        ELSE
          @stex(spieler)
          IF ra1=0 OR ra3=0
            @jufra(2)
          ENDIF
          ADD bg%(spieler),bg%(0)
          SUB punkt22%,bg%(2)
          punkt%(2)=bg%(2)*-1
        ENDIF
        punkt%(1)=0
        punkt%(3)=0
      ELSE IF bg%(3)=MAX(bg%(1),bg%(2),bg%(3))
        spieler=3
        IF ra1+ra2=0
          @duma(3)
        ELSE
          @stex(spieler)
          IF ra1=0 OR ra2=0
            @jufra(3)
          ENDIF
          ADD bg%(spieler),bg%(0)
          SUB punkt33%,bg%(3)
          punkt%(3)=bg%(3)*-1
        ENDIF
        punkt%(2)=0
        punkt%(1)=0
      ENDIF
    ELSE
      IF spieler=1
        IF farb<>6
          IF ha$="Hand"
            FOR i%=0 TO 9
              @awert(k1%(i%),1)
            NEXT i%
            @awert(k4%(0),1)
            @awert(k4%(1),1)
            @r1(1)
            INC mal%(1)
          ENDIF
          s=1
          @sperg(1)
          ADD punkt11%,punkt%(1)
          punkt%(2)=0
          punkt%(3)=0
          @zu
        ENDIF
      ELSE IF spieler=2
        s=2
        @sperg(2)
        ADD punkt22%,punkt%(2)
        punkt%(1)=0
        punkt%(3)=0
        @zu
      ELSE IF spieler=3
        s=3
        @sperg(3)
        ADD punkt33%,punkt%(3)
        punkt%(2)=0
        punkt%(1)=0
        @zu
      ELSE IF spieler=4 AND farb=6
        punkt12%=punkt%(1)
        IF bock>0
          MUL punkt%(1),2
        ENDIF
        IF bg%(1)=0
          IF punkt12%<rz%
            MUL punkt%(1),-2
            TEXT 300,212,"öBERREIZT!"
          ELSE
            TEXT 220,212,farb$+ha$+" gewonnen!"
          ENDIF
        ELSE
          MUL punkt%(1),-2
          TEXT 220,212,farb$+ha$+" verloren!"
          DEFFILL 1,3,9
          PBOX 0,217,640,399
          @lin
        ENDIF
        ADD punkt11%,punkt%(1)
        punkt%(2)=0
        punkt%(3)=0
        spieler=1
      ENDIF
    ENDIF
  ELSE
    ADD bg%(spieler),bg%(0)
    @stex(spieler)
    PUT 531,19,i1$,10
  ENDIF
  ~INP(2)
  @fu
  DEFTEXT 1,0,0,13
  @bcl
  IF rp!
    IF nr=36
      CLR nr
    ENDIF
    IF nr>0 AND nr<36
      PUT 125,8,li$
      CLR li$
    ENDIF
    @plist(nr)
    GET 125,8,515,196,li$
    DEFTEXT 1,0,0,18
    TEXT 135,30,"Spieler 1"
    TEXT 265,30,"Spieler 2"
    TEXT 395,30,"Spieler 3"
    IF anfang%=1
      GET 135,12,235,33,sp1$
      GET 265,12,365,33,sp2$
      GET 395,12,495,33,sp3$
    ENDIF
    TEXT 190-10*LEN(STR$(punkt11%)),50,punkt11%
    TEXT 320-10*LEN(STR$(punkt22%)),50,punkt22%
    TEXT 450-10*LEN(STR$(punkt33%)),50,punkt33%
    INC nr
    DEFTEXT 1,0,0,10
    TEXT 220,212,"TASTE DRöCKEN!"
    @anz0
    ARECT 126,34,514,196,0,0,ad%,1
    @namlis
    @anz0
    @fu
    @bcl
  ENDIF
  IF bora!
    IF bock=6
      @bock0
    ENDIF
  ENDIF
  @loesch
  CLR zu2$,zu3$,mit%
  CLR tr%,stich,dum
  anf!=TRUE
  HIDEM
  CLR zu$,mit$
  DEFTEXT 1,0,0,13
  DO
    @menue
  LOOP
RETURN
PROCEDURE fu
  BOUNDARY 0
  ARECT 0,201,639,215,1,0,ad3%,1
RETURN
PROCEDURE anz0
  DO
    EXIT IF INKEY$<>""
    ON spieler GOSUB anz1,anz2,anz3
    IF bora!
      IF bock=6
        PUT 531,69,i1$,6
      ENDIF
    ENDIF
    PAUSE 15
  LOOP
RETURN
PROCEDURE anz1
  PUT 135,12,sp1$,6
RETURN
PROCEDURE anz2
  PUT 265,12,sp2$,6
RETURN
PROCEDURE anz3
  PUT 395,12,sp3$,6
RETURN
PROCEDURE namlis
  DEFTEXT 1,4,0,6
  TEXT 200,55,"Skat:"
  TEXT 250,50,t$(k4%(0)-1)
  TEXT 250,60,t$(k4%(1)-1)
  TEXT 380,55,"Spiel: "+farb$
  LINE 150,68,150,190
  LINE 485,68,485,190
  FOR i%=1 TO 10
    no1%=st%(i%)
    no2%=st%(i%+10)
    no3%=st%(i%+20)
    DEFTEXT 1,1,0,6
    TEXT 130,68+(i%*12),i%
    DEFTEXT 1,16,0,6
    TEXT 490,68+(i%*12),(b%(no1%)+b%(no2%)+b%(no3%))
    IF no1%>0
      @sond(i%,no1%)
      TEXT 155,68+(i%*12),t$(no1%-1)
      @sond(i%,no2%)
      TEXT 270,68+(i%*12),t$(no2%-1)
      @sond(i%,no3%)
      TEXT 385,68+(i%*12),t$(no3%-1)
    ENDIF
    HLINE 130,70+(i%*12),510,1,0,ad%,1
  NEXT i%
  CLR i%
  IF GEMDOS(17)
    ALERT 2,"AUSDRUCKEN?",2,"JA|NEIN",dum
    IF dum=1
      @namprint
    ENDIF
  ENDIF
  DEFTEXT 1,0,0,13
RETURN
PROCEDURE namprint
  DIM pr$(32)
  ps$=CHR$(27)+"F"
  LPRINT SPACE$(20)+"SPIELER "+STR$(spieler)
  LPRINT
  LPRINT "Skat:"+SPACE$(3)+t$(k4%(0)-1)+SPACE$(3)+t$(k4%(1)-1)+SPACE$(5)+"Spiel: "+farb$
  LPRINT
  FOR i%=1 TO 10
    no1%=st%(i%)
    no2%=st%(i%+10)
    no3%=st%(i%+20)
    bh%=b%(no1%)+b%(no2%)+b%(no3%)
    @psond(i%,no1%)
    @psond(i%,no2%)
    @psond(i%,no3%)
    IF i%<10
      pr=3
    ELSE
      pr=2
    ENDIF
    IF no1%>0
      LPRINT STR$(i%)+SPACE$(pr)+pr$(no1%)+t$(no1%-1)+SPACE$(15-LEN(t$(no1%-1)))+pr$(no2%)+t$(no2%-1)+SPACE$(15-LEN(t$(no2%-1)))+pr$(no3%)+t$(no3%-1)+SPACE$(15-LEN(t$(no3%-1)))+ps$+STR$(bh%)
    ENDIF
  NEXT i%
  ERASE pr$()
RETURN
PROCEDURE psond(stich,no0%)
  IF st%(stich+30)=no0%
    pr$(no0%)=CHR$(27)+"E"
  ELSE
    pr$(no0%)=CHR$(27)+"F"
  ENDIF
RETURN
PROCEDURE sond(stich,no0%)
  IF st%(stich+30)=no0%
    DEFTEXT 1,1,0,6
  ELSE
    DEFTEXT 1,0,0,6
  ENDIF
RETURN
PROCEDURE lize
  BOX 127,70,254,194
  DEFTEXT 1,0,0,6
  FOR i=0 TO 2
    TEXT 131+i*35,67,"Sp."+STR$(i+1)
    LINE 163+i*36,60,163+i*36,194
  NEXT i
  TEXT 237,67,"SP"
  LINE 255,60,255,194
  GET 127,60,255,194,lz$
  PUT 256,60,lz$
  PUT 385,60,lz$
  CLR lz$
RETURN
PROCEDURE plist(lis)
  IF nr=0
    @lize
  ENDIF
  IF bock! AND bora!
    DEFTEXT 1,1,0,6
  ELSE
    DEFTEXT 1,0,0,6
  ENDIF
  IF lis<12
    @ausg(0,lis*10)
  ELSE IF lis<24
    @ausg(129,(lis-12)*10)
  ELSE IF lis<36
    @ausg(258,(lis-24)*10)
  ENDIF
RETURN
PROCEDURE ausg(li1%,li2%)
  FOR i=0 TO 2
    TEXT 161+i*36-8*LEN(STR$(punkt%(i+1)))+li1%,80+li2%,punkt%(i+1)
  NEXT i
  TEXT 237+li1%,80+li2%,MID$(farb$,1,2)
RETURN
PROCEDURE karte(s)
  DEFTEXT 1,0,0,13
  IF a%(no%)>0
    IF s=2
      @kt(no%,260,10,3)
      ON f2% GOSUB abw21,abw22,abw23,abw24,abw25
      ON f2% GOSUB bw21,bw22,bw23,bw24,bw25
      card2!=TRUE
      st%(stich+10)=no%
      @kenn(2,f2%)
    ELSE IF s=3
      @kt(no%,390,10,3)
      ON f3% GOSUB abw21,abw22,abw23,abw24,abw25
      ON f3% GOSUB bw21,bw22,bw23,bw24,bw25
      card3!=TRUE
      st%(stich+20)=no%
      @kenn(3,f3%)
    ENDIF
    IF no%<5
      DEC bu%(s)
    ENDIF
    CLR fa1%,fa2%,gef,ze,no%,s
  ENDIF
RETURN
PROCEDURE abw21
  DEC col%(s,1)
RETURN
PROCEDURE abw22
  DEC col%(s,2)
RETURN
PROCEDURE abw23
  DEC col%(s,3)
RETURN
PROCEDURE abw24
  DEC col%(s,4)
RETURN
PROCEDURE abw25
  DEC col%(s,5)
RETURN
PROCEDURE bw21
  INC karo
RETURN
PROCEDURE bw22
  INC herz
RETURN
PROCEDURE bw23
  INC pek
RETURN
PROCEDURE bw24
  INC kreuz
RETURN
PROCEDURE bw25
  INC trumpf
RETURN
PROCEDURE vorhand1
  card1!=FALSE
  @maus1
  ze=1
  card2!=FALSE
  @sp2(f1%)
  ze=1
  card3!=FALSE
  @sp3(f1%)
  @menue
  @wertung
RETURN
PROCEDURE vorhand2
  card2!=FALSE
  ze=1
  @sp_2
  card3!=FALSE
  ze=1
  @sp3(f2%)
  card1!=FALSE
  @m2(f2%)
  @menue
  @wertung
RETURN
PROCEDURE vorhand3
  card3!=FALSE
  ze=1
  @sp_3
  card1!=FALSE
  @m2(f3%)
  card2!=FALSE
  ze=1
  @sp2(f3%)
  @menue
  @wertung
RETURN
PROCEDURE klwert
  FOR i%=1 TO 5
    @mini(i%,k1%(),wkl1%())
    @mini(i%,k2%(),wkl2%())
    @mini(i%,k3%(),wkl3%())
    wmi%(i%)=MIN(wkl1%(i%),wkl2%(i%),wkl3%(i%))
    @maxi(i%,k1%(),wgr1%())
    @maxi(i%,k2%(),wgr2%())
    @maxi(i%,k3%(),wgr3%())
    wma%(i%)=MAX(wgr1%(i%),wgr2%(i%),wgr3%(i%))
  NEXT i%
  kl2%=MIN(wkl2%(1),wkl2%(2),wkl2%(3),wkl2%(4))
  kl3%=MIN(wkl3%(1),wkl3%(2),wkl3%(3),wkl3%(4))
RETURN
PROCEDURE mini(i%,VAR k%(),wkl%())
  CLR ei%
  n%=9
  REPEAT
    ei%=k%(n%)
    EXIT IF a%(ei%)=i%
    DEC n%
  UNTIL n%=-1
  IF n%>=0
    wkl%(i%)=w%(ei%)
  ELSE
    wkl%(i%)=100
  ENDIF
RETURN
PROCEDURE maxi(i%,VAR k%(),wgr%())
  CLR n%,ei%
  REPEAT
    ei%=k%(n%)
    EXIT IF a%(ei%)=i%
    INC n%
  UNTIL n%=10
  IF n%=10
    wgr%(i%)=0
  ELSE
    wgr%(i%)=w%(ei%)
  ENDIF
RETURN
PROCEDURE ana1
  gef=karo+col%(s,1)
RETURN
PROCEDURE ana2
  gef=herz+col%(s,2)
RETURN
PROCEDURE ana3
  gef=pek+col%(s,3)
RETURN
PROCEDURE ana4
  gef=kreuz+col%(s,4)
RETURN
PROCEDURE ana5
  gef=trumpf+col%(s,5)
RETURN
PROCEDURE sp2(fa2%)
  s=2
  IF ze=1
    ON fa2% GOSUB ana1,ana2,ana3,ana4,ana5
  ENDIF
  FOR n2%=0 TO 9
    s=2
    EXIT IF card2!
    no%=k2%(n2%)
    IF a%(no%)>0
      b2%=b%(no%)
      w2%=w%(no%)
      f2%=a%(no%)
      IF col%(2,fa2%)>0
        maks%=wma%(f2%)
        IF f2%=fa2%
          IF col%(2,fa2%)=1
            @karte(2)
          ELSE
            ON spieler GOSUB a01,a02,a03,a04
          ENDIF
        ENDIF
      ELSE
        @fehl(2,fa2%)
        IF f2%<5
          w2%=0
        ENDIF
        ON spieler GOSUB a05,a06,a07,a08
      ENDIF
    ENDIF
  NEXT n2%
  IF NOT card2!
    INC ze
    @sp2(fa2%)
  ENDIF
RETURN
PROCEDURE a01
  IF vh=1
    IF f1%=5
      ON ze GOSUB ag1,a6,a4,a5,a3,a2,a11,ca2,ca10,ca3,a015,ca0,c4
    ELSE
      ON ze GOSUB a6,a11,a2,ca2,ca10,ca3,ca0,c4
    ENDIF
  ELSE IF vh=3
    IF w1%>w3%
      ON ze GOSUB a.2,b1,ca2,ca10,ca3,ca0,c4
    ELSE
      ON ze GOSUB a18,a.6,ca2,ca10,ca3,c4
    ENDIF
  ENDIF
RETURN
PROCEDURE a02
  IF vh=1
    ON ze GOSUB a7,a1,ca2,ca10,ca3,ca0,c4
  ELSE IF vh=3
    ON ze GOSUB a.2,b1,ca2,ca10,ca3,ca0,c4
  ENDIF
RETURN
PROCEDURE a03
  IF vh=1
    ON ze GOSUB a8,a9,ca2,ca10,ca3,ca0,c4
  ELSE IF vh=3
    IF w1%>w3%
      ON ze GOSUB a18,a.6,ca2,ca10,ca3,c4
    ELSE
      ON ze GOSUB a.2,a.3,a.4,b1,ca2,ca10,ca3,ca0,c4
    ENDIF
  ENDIF
RETURN
PROCEDURE a04
  IF vh=1
    IF farb=6
      ON ze GOSUB anu1,c4
    ELSE
      ON ze GOSUB ar1,ar1,ar1,ar2,ar3,ar3,ar3,c4
    ENDIF
  ELSE IF vh=3
    IF farb=6
      ON ze GOSUB anu.1,anua,c4
    ELSE
      ON ze GOSUB ar.1,ar.1b,ar.2,ar.3,c4
    ENDIF
  ENDIF
RETURN
PROCEDURE a05
  IF vh=1
    IF f1%=5
      ON ze GOSUB a11,a12,a10,ca1,c4
    ELSE
      ON ze GOSUB a13,a19,a19,a19,a10,a2,ca1,c4
    ENDIF
  ELSE IF vh=3
    IF w1%>w3%
      ON ze GOSUB a.15,a.15,a.15,ca1,c4
    ELSE
      ON ze GOSUB a.10,a.11,a.9,a.12,a.13,ca1,c4
    ENDIF
  ENDIF
RETURN
PROCEDURE a06
  IF vh=1
    ON ze GOSUB a20,a21g,a21,a17,a10,ca1,c4
  ELSE IF vh=3
    IF f3%=5
      ON ze GOSUB a12,a10,ca1,c4
    ELSE
      ON ze GOSUB a.16,a.17,b26,a.19,a.21,a10,ca1,c4
    ENDIF
  ENDIF
RETURN
PROCEDURE a07
  IF vh=1
    ON ze GOSUB a15,a14,a16,a10,ca1,c4
  ELSE IF vh=3
    IF w1%>w3%
      ON ze GOSUB a.7,a.8,a.9,a.22,c4
    ELSE
      ON ze GOSUB b26,a.20,a.21,a10,ca1,c4
    ENDIF
  ENDIF
RETURN
PROCEDURE a08
  IF vh=1
    IF farb=6
      ON ze GOSUB ar4,ar5,c4
    ELSE
      ON ze GOSUB ar4,ar5,c4
    ENDIF
  ELSE IF vh=3
    IF farb=6
      ON ze GOSUB ar.4,arab,ar5,c4
    ELSE
      ON ze GOSUB ar.4,arab,ar5,c4
    ENDIF
  ENDIF
RETURN
PROCEDURE sp3(fa3%)
  s=3
  IF ze=1
    ON fa3% GOSUB ana1,ana2,ana3,ana4,ana5
  ENDIF
  FOR n3%=0 TO 9
    s=3
    EXIT IF card3!
    no%=k3%(n3%)
    IF a%(no%)>0
      b3%=b%(no%)
      w3%=w%(no%)
      f3%=a%(no%)
      IF col%(3,fa3%)>0
        maks%=wma%(f3%)
        IF f3%=fa3%
          IF col%(3,fa3%)=1
            @karte(3)
          ELSE
            ON spieler GOSUB b01,b02,b03,b04
          ENDIF
        ENDIF
      ELSE
        @fehl(3,fa3%)
        IF f3%<5
          w3%=0
        ENDIF
        ON spieler GOSUB b05,b06,b07,b08
      ENDIF
    ENDIF
  NEXT n3%
  IF NOT card3!
    INC ze
    @sp3(fa3%)
  ENDIF
RETURN
PROCEDURE b01
  IF vh=1
    IF f1%=5
      ON ze GOSUB b5,b9,b27,b3,ag1,b2,b1,cb2,cb10,cb3,cb0,c4
    ELSE
      ON ze GOSUB b5,b9,b1,cb2,cb10,cb3,cb0,c4
    ENDIF
  ELSE IF vh=2
    IF f2%=5
      ON ze GOSUB b6,cb2,cb10,cb3,cb0,c4
    ELSE
      ON ze GOSUB b.1,b.2,cb2,cb10,cb3,cb0,c4
    ENDIF
  ENDIF
RETURN
PROCEDURE b02
  IF vh=1
    ON ze GOSUB b10,b7,b1,cb2,cb10,cb3,cb0,c4
  ELSE IF vh=2
    ON ze GOSUB b.6,cb2,cb10,cb3,cb0,c4
  ENDIF
RETURN
PROCEDURE b03
  IF vh=1
    ON ze GOSUB b8,b27,b1,cb2,cb10,cb3,cb0,c4
  ELSE IF vh=2
    ON ze GOSUB b.2,b.3,b.5,cb2,cb10,cb3,cb0,c4
  ENDIF
RETURN
PROCEDURE b04
  IF vh=1
    IF farb=6
      ON ze GOSUB bnu1,c4
    ELSE
      ON ze GOSUB br1,br2,ar.3,c4
    ENDIF
  ELSE IF vh=2
    IF farb=6
      ON ze GOSUB br.0,br.0,br.0,bnu.1,bnu.1,bnu.1,c4
    ELSE
      ON ze GOSUB br.0,br.0,br.0,br.1,br.2,br.2,br.2,c4
    ENDIF
  ENDIF
