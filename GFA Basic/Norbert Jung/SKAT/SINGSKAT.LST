    @abwurf(3,f3%)
  ENDIF
RETURN
PROCEDURE br.1
  IF w2%>w3%
    @karte(3)
  ENDIF
RETURN
PROCEDURE abwurf(s,f%)
  IF col%(s,f%)=1 AND f%<5
    @karte(s)
  ENDIF
RETURN
PROCEDURE a1
