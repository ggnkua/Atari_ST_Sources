PROCEDURE kt(i%,x%,y%,mod)
  SELECT i%
  CASE 1
    @bube(x%,y%,8,19,12,16,mod)
  CASE 2
    @bube(x%,y%,7,18,11,15,mod)
  CASE 3
    @bube(x%,y%,6,17,10,14,mod)
  CASE 4
    @bube(x%,y%,9,9,13,13,mod)
  CASE 5
    @as(x%,y%,9,9,13,mod)
  CASE 6
    @zehn(x%,y%,9,9,13,13,mod)
  CASE 7
    @koenig(x%,y%,9,9,13,13,mod)
  CASE 8
    @dame(x%,y%,9,9,13,13,mod)
  CASE 9
    @neun(x%,y%,9,9,13,13,mod)
  CASE 10
    @acht(x%,y%,9,9,13,13,mod)
  CASE 11
    @sieben(x%,y%,9,9,13,13,mod)
  CASE 12
    @as(x%,y%,6,17,10,mod)
  CASE 13
    @zehn(x%,y%,6,17,10,14,mod)
  CASE 14
    @koenig(x%,y%,6,17,10,14,mod)
  CASE 15
    @dame(x%,y%,6,17,10,14,mod)
  CASE 16
    @neun(x%,y%,6,17,10,14,mod)
  CASE 17
    @acht(x%,y%,6,17,10,14,mod)
  CASE 18
    @sieben(x%,y%,6,17,10,14,mod)
  CASE 19
    @as(x%,y%,7,18,11,mod)
  CASE 20
    @zehn(x%,y%,7,18,11,15,mod)
  CASE 21
    @koenig(x%,y%,7,18,11,15,mod)
  CASE 22
    @dame(x%,y%,7,18,11,15,mod)
  CASE 23
    @neun(x%,y%,7,18,11,15,mod)
  CASE 24
    @acht(x%,y%,7,18,11,15,mod)
  CASE 25
    @sieben(x%,y%,7,18,11,15,mod)
  CASE 26
    @as(x%,y%,8,19,12,mod)
  CASE 27
    @zehn(x%,y%,8,19,12,16,mod)
  CASE 28
    @koenig(x%,y%,8,19,12,16,mod)
  CASE 29
    @dame(x%,y%,8,19,12,16,mod)
  CASE 30
    @neun(x%,y%,8,19,12,16,mod)
  CASE 31
    @acht(x%,y%,8,19,12,16,mod)
  CASE 32
    @sieben(x%,y%,8,19,12,16,mod)
  ENDSELECT
RETURN
PROCEDURE koenig(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  @umri(x%,y%,mod)
  PUT x%+9,y%+3,c$(27),mod
  @grob(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
RETURN
PROCEDURE dame(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  @umri(x%,y%,mod)
  PUT x%+8,y%+3,c$(26),mod
  @grob(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
RETURN
PROCEDURE bube(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  @umri(x%,y%,mod)
  PUT x%+9,y%+3,c$(25),mod
  @grob(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
RETURN
PROCEDURE grob(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  @grob2(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  PUT x%+23,y%+15,c$(bi3%),mod
  PUT x%+68,y%+145,c$(bi4%),mod
RETURN
PROCEDURE grob2(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  PUT x%+7,y%+21,c$(bi1%),mod
  PUT x%+99,y%+21,c$(bi1%),mod
  PUT x%+7,y%+151,c$(bi2%),mod
  PUT x%+99,y%+151,c$(bi2%),mod
RETURN
PROCEDURE umri(x%,y%,mod)
  PUT x%,y%,c$(28),mod
RETURN
PROCEDURE as(x%,y%,bi1%,bi2%,bi3%,mod)
  @umri(x%,y%,mod)
  PUT x%+10,y%+8,c$(5),mod
  PUT x%+102,y%+8,c$(5),mod
  PUT x%+8,y%+165,c$(20),mod
  PUT x%+100,y%+165,c$(20),mod
  @grob2(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  PUT x%+45,y%+78,c$(bi3%),mod
RETURN
PROCEDURE zehn(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  @umri(x%,y%,mod)
  PUT x%+7,y%+8,c$(4),mod
  PUT x%+99,y%+8,c$(4),mod
  @grob2(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  PUT x%+24,y%+13,c$(bi3%),mod
  PUT x%+66,y%+13,c$(bi3%),mod
  PUT x%+45,y%+35,c$(bi3%),mod
  PUT x%+24,y%+57,c$(bi3%),mod
  PUT x%+66,y%+57,c$(bi3%),mod
  PUT x%+7,y%+165,c$(21),mod
  PUT x%+99,y%+165,c$(21),mod
  PUT x%+23,y%+97,c$(bi4%),mod
  PUT x%+65,y%+97,c$(bi4%),mod
  PUT x%+23,y%+146,c$(bi4%),mod
  PUT x%+65,y%+146,c$(bi4%),mod
  PUT x%+44,y%+123,c$(bi4%),mod
RETURN
PROCEDURE neun(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  @umri(x%,y%,mod)
  PUT x%+10,y%+8,c$(3),mod
  PUT x%+102,y%+8,c$(3),mod
  @grob2(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  PUT x%+10,y%+165,c$(22),mod
  PUT x%+102,y%+165,c$(22),mod
  PUT x%+24,y%+15,c$(bi3%),mod
  PUT x%+68,y%+15,c$(bi3%),mod
  PUT x%+47,y%+82,c$(bi3%),mod
  PUT x%+24,y%+55,c$(bi3%),mod
  PUT x%+68,y%+55,c$(bi3%),mod
  PUT x%+24,y%+105,c$(bi4%),mod
  PUT x%+68,y%+105,c$(bi4%),mod
  PUT x%+24,y%+145,c$(bi4%),mod
  PUT x%+68,y%+145,c$(bi4%),mod
RETURN
PROCEDURE acht(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  @umri(x%,y%,mod)
  PUT x%+10,y%+8,c$(2),mod
  PUT x%+102,y%+8,c$(2),mod
  @grob2(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  PUT x%+22,y%+15,c$(bi3%),mod
  PUT x%+68,y%+15,c$(bi3%),mod
  PUT x%+45,y%+45,c$(bi3%),mod
  PUT x%+22,y%+75,c$(bi3%),mod
  PUT x%+68,y%+75,c$(bi3%),mod
  PUT x%+10,y%+165,c$(23),mod
  PUT x%+102,y%+165,c$(23),mod
  PUT x%+45,y%+110,c$(bi4%),mod
  PUT x%+22,y%+145,c$(bi4%),mod
  PUT x%+68,y%+145,c$(bi4%),mod
RETURN
PROCEDURE sieben(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  @umri(x%,y%,mod)
  PUT x%+10,y%+8,c$(1),mod
  PUT x%+102,y%+8,c$(1),mod
  @grob2(x%,y%,bi1%,bi2%,bi3%,bi4%,mod)
  PUT x%+22,y%+15,c$(bi3%),mod
  PUT x%+68,y%+15,c$(bi3%),mod
  PUT x%+45,y%+45,c$(bi3%),mod
  PUT x%+22,y%+75,c$(bi3%),mod
  PUT x%+68,y%+75,c$(bi3%),mod
  PUT x%+10,y%+165,c$(24),mod
  PUT x%+102,y%+165,c$(24),mod
  PUT x%+22,y%+145,c$(bi4%),mod
  PUT x%+68,y%+145,c$(bi4%),mod
RETURN
