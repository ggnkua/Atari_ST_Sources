PROCEDURE b05
  IF vh=1
    IF f1%=5
      ON ze GOSUB b15,b17,b18,b12,b19,cb1,c4
    ELSE
      IF w2%>w1%
        ON ze GOSUB b15,b12,b19,b18,c4
      ELSE
        ON ze GOSUB b26,b24,b24,b24,cb3,cb1,c4
      ENDIF
    ENDIF
  ELSE IF vh=2
    IF f2%=5
      ON ze GOSUB b13,cb1,c4
    ELSE
      ON ze GOSUB b.9,b.10,b.8,b_7,cb3,c4
    ENDIF
  ENDIF
