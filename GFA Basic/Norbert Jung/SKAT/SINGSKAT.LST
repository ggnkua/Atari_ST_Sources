    @karte(s)
  ENDIF
RETURN
PROCEDURE br1
  IF b3%>3
    @br2
  ENDIF
RETURN
PROCEDURE br2
  IF w3%<w2% OR w3%<w1%
    @karte(3)
  ENDIF
RETURN
