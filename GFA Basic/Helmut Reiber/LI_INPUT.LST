'     **************************************************
'     *                 LI_INPUT.GFA                   *  Helmut Reiber
'     *      Prozedur für besondere Eingabetechnik     *  StädelstraŞe 25
'     *                                                *  6000 Frankfurt 70
'     *      erstellt von H. Reiber im August 1989     *
'     **************************************************
'
> PROCEDURE line_input(l,VAR y$)
  ' *** Labels: li1
  LOCAL y,y1$,y2$,i&,j&,l,l&,m1&,m2&,n&,a&,b&,c&,d&,delta_c&,delta_d&
  '
  PRINT CHR$(27)+"e";                       ! Cursor an
  '
  a&=CRSCOL                                 ! Cursorposition am Beginn der
  b&=CRSLIN                                 ! Eingabe speichern
  '
  IF l=0
    l&=20                                   ! vorgewählte Länge der Eingabe
  ELSE
    l&=l                                    ! Eingabe der Stringlänge
  ENDIF
  n&=((l&+a&-1) DIV 80)+1                   ! wieviele Zeilen werden benötigt?
  '
  IF n&>18
    n&=18                                   ! n& auf maximal 18 begrenzen
  ENDIF
  ' ------------------- Platz schaffen für Eingabestring --------------
  j&=b&+n&-26                               ! Anzahl der fehlenden Zeilen
  IF j&>0                                   ! nur wenn Zeilen fehlen
    FOR i&=2 TO n&                          ! Schleife schafft Platz für n&
      PRINT                                 ! Zeilen, womit Scrollen bei der
    NEXT i&                                 ! Eingabe vermieden wird
    b&=b&-j&                                ! Korrekturwert für Cursor
    LOCATE a&,b&                            ! Cursor an neue Position setzen
  ENDIF
  ' ========================== Eingabeschleife =========================
  DO
    li1:
    ' ---------------------------- Eingabe -----------------------------
    y=INP(2)
    ' ------------------------ Eingabe beenden -------------------------
    EXIT IF y=13                            ! Beenden mit RETURN
    ' --------------------------- Backspace ----------------------------
    IF y=8
      IF LEN(y1$)=0                         ! verhindert Absturz
        GOTO li1
      ENDIF
      c&=CRSCOL                             ! Cursorposition
      d&=CRSLIN                             ! merken
      y1$=LEFT$(y1$,LEN(y1$)-1)
      IF d&>b& AND c&=1
        d&=d&-1
        LOCATE 80,d&                        ! Cursor eine Zeile höher
      ELSE
        LOCATE c&-1,d&                      ! Cursor eine Spalte nach links
      ENDIF
      PRINT CHR$(27)+"J";                   ! Bildschirm ab Cursor löschen
      PRINT y2$;                            ! Reststring ausgeben
      LOCATE c&-1,d&                        ! Cursor an alte Position
    ENDIF
    ' ---------------------------- Delete ------------------------------
    IF y=127
      IF LEN(y2$)=0                         ! verhindert Absturz
        GOTO li1
      ENDIF
      c&=CRSCOL                             ! Cursorposition
      d&=CRSLIN                             ! merken
      y2$=RIGHT$(y2$,LEN(y2$)-1)
      PRINT CHR$(27)+"J";                   ! Bildschirm ab Cursor löschen
      PRINT y2$;                            ! Reststring ausgeben
      LOCATE c&,d&                          ! Cursor an alte Position
    ENDIF
    ' ------------------------- alles löschen --------------------------
    IF y=27                                 ! Eingabe mit ESC löschen
      y1$=""
      y2$=""
      LOCATE a&,b&                          ! Cursor an Anfang
      PRINT CHR$(27)+"J";                   ! Bildschirm ab Cursor löschen
    ENDIF
    ' ----------------------- Cursor nach links ------------------------
    IF y=203
      IF LEN(y1$)=0                         ! verhindert Absturz
        GOTO li1
      ENDIF
      c&=CRSCOL                             ! Cursorposition
      d&=CRSLIN                             ! merken
      y2$=RIGHT$(y1$)+y2$
      y1$=LEFT$(y1$,LEN(y1$)-1)
      IF d&>b& AND c&=1
        d&=d&-1
        LOCATE 80,d&                        ! Cursor eine Zeile höher
      ELSE
        LOCATE c&-1,d&                      ! Cursor eine Spalte nach links
      ENDIF
      LOCATE c&-1,d&                        ! Cursor an alte Position
    ENDIF
    ' ----------------------- Cursor nach rechts -----------------------
    IF y=205
      IF LEN(y2$)=0                         ! verhindert Absturz
        GOTO li1
      ENDIF
      c&=CRSCOL                             ! Cursorposition
      d&=CRSLIN                             ! merken
      y1$=y1$+LEFT$(y2$)                    ! Die Reihenfolge dieser und der
      y2$=RIGHT$(y2$,LEN(y2$)-1)            ! folgenden Zeile ist wichtig!
      IF c&=80
        d&=d&+1
        LOCATE 1,d&                         ! Cursor eine Zeile tiefer
      ELSE
        LOCATE c&+1,d&                      ! Cursor eine Spalte nach rechts
      ENDIF
    ENDIF
    ' -------------------- Cursor an Stringanfang ----------------------
    IF y=200
      y2$=y1$+y2$
      y1$=""
      LOCATE a&,b&
    ENDIF
    ' --------------------- Cursor an Stringende -----------------------
    IF y=208
      c&=CRSCOL                             ! Cursor-Position
      d&=CRSLIN                             ! merken
      delta_d&=(c&+LEN(y2$)-1) DIV 80       ! Position des Stringendes
      delta_c&=(c&+LEN(y2$)) MOD 80         ! errechnen
      c&=delta_c&
      d&=d&+delta_d&
      y1$=y1$+y2$
      y2$=""
      LOCATE c&,d&                          ! Cursor ans Stringende
    ENDIF
    ' ------------------------ Abbruch mit F10 -------------------------
    IF y=196
      PRINT CHR$(27)+"f";                   ! Cursor aus
      ende                                  ! Prozedur "ende" aufrufen
    ENDIF
    ' -------------------------- Eingabesieb ---------------------------
    IF y<43 OR y=44 OR y=47 OR y>57         ! Definition des Eingabefilters
      GOTO li1                              ! Die definierten Bereiche werden
    ENDIF                                   ! ausgeblendet
    ' ---------------------------- Eingabe -----------------------------
    IF LEN(y2$)=0 AND LEN(y1$)<l&           ! Wenn Cursor am Ende des Strings
      y1$=y1$+CHR$(y)
      PRINT CHR$(y);
    ELSE IF LEN(y2$)=0 AND LEN(y1$)=l&      ! Eingabe wird ignoriert
    ELSE IF LEN(y1$+y2$)>=l&                ! Eingabe wird ignoriert
    ELSE
      y1$=y1$+CHR$(y)
      PRINT CHR$(y);
      PRINT CHR$(27)+"J";                   ! Bildschirm ab Cursor löschen
      PRINT CHR$(27)+"j";                   ! Cursor-Position merken
      PRINT y2$;                            ! Reststring ausgeben
      PRINT CHR$(27)+"k";                   ! Cursor an alte Position
    ENDIF
  LOOP
  ' ===================== Ende der Eingabeschleife ====================
  PRINT CHR$(27)+"f";                       ! Cursor aus
  c&=CRSCOL                                 ! Cursor-Position
  d&=CRSLIN                                 ! merken
  delta_d&=(c&+LEN(y2$)-1) DIV 80           ! Position des Stringendes
  delta_c&=(c&+LEN(y2$)) MOD 80             ! errechnen
  c&=delta_c&
  d&=d&+delta_d&
  y1$=y1$+y2$
  y2$=""
  LOCATE c&,d&                              ! Cursor ans Stringende
  '                                         ! sonst nur Teilausdruck
  y$=y1$                                    ! Rückgabevariable initialisieren
RETURN
'
> PROCEDURE info
  ' Kernpunkt  des  Programms ist die Prozedur "line_input".  Sie  arbeitet
  ' ähnlich dem GFA-BASIC-Befehl LINE INPUT. Der Cursor kann mit den Tasten
  ' des Cursorblocks bewegt werden. AuŞerdem reagiert er mit der Backspace-
  ' und  der  Delete-Taste, die in bekannter Weise funktionieren.  Mit  der
  ' F10-Taste  gelingt  über  die  Prozedur "ende" der  Ausstieg. Nach  dem
  ' Verlassen  der "line_input"-Prozedur fehlt ein Zeilenvorschub,  so  daŞ
  ' eine  mehrmalige Eingabe mittels "line_input" in der selben Zeile  mög-
  ' lich ist. Die maximale Länge des Eingabestrings ist auf 20 Spalten vor-
  ' eingestellt, eine Änderung läŞt sich durch die Angabe des Übergabepara-
  ' meters  (1. Parameter) bei Aufruf der Prozedur  "line_input"  bewirken.
  ' Die  zulässigen  ASCII-Zeichen lassen sich durch  geeignete  Gestaltung
  ' des Eingabefilters  im Eingabesieb festlegen. Zur Zeit ist die  Eingabe
  ' von Zahlen eingestellt.
RETURN
' ------------------------------  E n d e  -------------------------------
