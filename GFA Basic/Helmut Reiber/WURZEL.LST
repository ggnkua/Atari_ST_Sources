'     *          Beispielprogramm n-te Wurzel          *  StĄdelstraěe 25
'     *             Anwendung von PROCEDURE            *  6000 Frankfurt 70
'     *     nach Handbuch GFA-BASIC 3.0 Seite 7-25     *
'     *   mit spezieller Eingabe-Prozedur line_input   *
'     *      erstellt von H. Reiber im August 1989     *
'     **************************************************
'
main
'
> PROCEDURE main
  ' *** Labels: m1
  CLS
  PRINT
  PRINT '"Bestimmung der n-ten Wurzel";SPACE$(20);"Ausstieg mit F10"
  s2$="Bestimmung der n-ten Wurzel"
  PRINT ';STRING$(LEN(s2$),"=");SPACE$(20);"Bei Irrtum : BACKSPACE bzw. DEL"
  PRINT ';STRING$(LEN(s2$)," ");SPACE$(20);"Gesamte Eingabe lĒschen ..: ESC"
  PRINT SPACE$(9);"Gleichzeitig vorhandene komplexe Wurzeln werden nicht erfaět."
  PRINT ';STRING$(78,"_")
  m1:
  PRINT
  PRINT " Wurzelgrad: ";
  line_input(5,n$)                           ! StringlĄnge auf 5 beschrĄnkt
  n=VAL(n$)
  IF n>32767
    PRINT " => Die Eingabe darf 32767 nicht Ābersteigen!";
    GOTO m1
  ENDIF
  IF n=0
    PRINT " => Die nullte Wurzel ist nicht definiert!";
    GOTO m1
  ENDIF
  IF n<0
    PRINT " => Das Programm berechnet keine Wurzeln negativen Grades!";
    GOTO m1
  ENDIF
  IF FRAC(n)<>0
    PRINT " => Warnung! Der Nachkommateil wird unterdrĀckt.";
  ENDIF
  PRINT ,"Wurzel aus: ";
  line_input(0,x$)                          ! 0: Standard Einstellung
  n&=n
  a=VAL(x$)
  wurzel(n&,a)
  GOTO m1
RETURN
> PROCEDURE line_input(l,VAR y$)
  ' *** Labels: li1
  LOCAL y,y1$,y2$,i&,j&,l,l&,m1&,m2&,n&,a&,b&,c&,d&,delta_c&,delta_d&
  '
  PRINT CHR$(27)+"e";                       ! Cursor an
  '
  a&=CRSCOL                                 ! Cursorposition am Beginn der
  b&=CRSLIN                                 ! Eingabe speichern
  '
  IF l=0
    l&=20                                   ! vorgewĄhlte LĄnge der Eingabe
  ELSE
    l&=l                                    ! Eingabe der StringlĄnge
  ENDIF
  n&=((l&+a&-1) DIV 80)+1                   ! wieviele Zeilen werden benĒtigt?
  '
  IF n&>18
    n&=18                                   ! n& auf maximal 18 begrenzen
  ENDIF
  ' ------------------- Platz schaffen fĀr Eingabestring --------------
  j&=b&+n&-26                               ! Anzahl der fehlenden Zeilen
  IF j&>0                                   ! nur wenn Zeilen fehlen
    FOR i&=2 TO n&                          ! Schleife schafft Platz fĀr n&
      PRINT                                 ! Zeilen, womit Scrollen bei der
    NEXT i&                                 ! Eingabe vermieden wird
    b&=b&-j&                                ! Korrekturwert fĀr Cursor
    LOCATE a&,b&                            ! Cursor an neue Position setzen
  ENDIF
  ' ========================== Eingabeschleife =========================
  DO
    li1:
    ' ---------------------------- Eingabe -----------------------------
    y=INP(2)
    ' ------------------------ Eingabe beenden -------------------------
    EXIT IF y=13                            ! Beenden mit RETURN
    ' --------------------------- Backspace ----------------------------
    IF y=8
      IF LEN(y1$)=0                         ! verhindert Absturz
        GOTO li1
      ENDIF
      c&=CRSCOL                             ! Cursorposition
      d&=CRSLIN                             ! merken
      y1$=LEFT$(y1$,LEN(y1$)-1)
      IF d&>b& AND c&=1
        d&=d&-1
        LOCATE 80,d&                        ! Cursor eine Zeile hĒher
      ELSE
        LOCATE c&-1,d&                      ! Cursor eine Spalte nach links
      ENDIF
      PRINT CHR$(27)+"J";                   ! Bildschirm ab Cursor lĒschen
      PRINT y2$;                            ! Reststring ausgeben
      LOCATE c&-1,d&                        ! Cursor an alte Position
    ENDIF
    ' ---------------------------- Delete ------------------------------
    IF y=127
      IF LEN(y2$)=0                         ! verhindert Absturz
        GOTO li1
      ENDIF
      c&=CRSCOL                             ! Cursorposition
      d&=CRSLIN                             ! merken
      y2$=RIGHT$(y2$,LEN(y2$)-1)
      PRINT CHR$(27)+"J";                   ! Bildschirm ab Cursor lĒschen
      PRINT y2$;                            ! Reststring ausgeben
      LOCATE c&,d&                          ! Cursor an alte Position
    ENDIF
    ' ------------------------- alles lĒschen --------------------------
    IF y=27                                 ! Eingabe mit ESC lĒschen
      y1$=""
      y2$=""
      LOCATE a&,b&                          ! Cursor an Anfang
      PRINT CHR$(27)+"J";                   ! Bildschirm ab Cursor lĒschen
    ENDIF
    ' ----------------------- Cursor nach links ------------------------
    IF y=203
      IF LEN(y1$)=0                         ! verhindert Absturz
        GOTO li1
      ENDIF
      c&=CRSCOL                             ! Cursorposition
      d&=CRSLIN                             ! merken
      y2$=RIGHT$(y1$)+y2$
      y1$=LEFT$(y1$,LEN(y1$)-1)
      IF d&>b& AND c&=1
        d&=d&-1
        LOCATE 80,d&                        ! Cursor eine Zeile hĒher
      ELSE
        LOCATE c&-1,d&                      ! Cursor eine Spalte nach links
      ENDIF
      LOCATE c&-1,d&                        ! Cursor an alte Position
    ENDIF
    ' ----------------------- Cursor nach rechts -----------------------
    IF y=205
      IF LEN(y2$)=0                         ! verhindert Absturz
        GOTO li1
      ENDIF
      c&=CRSCOL                             ! Cursorposition
      d&=CRSLIN                             ! merken
      y1$=y1$+LEFT$(y2$)                    ! Die Reihenfolge dieser und der
      y2$=RIGHT$(y2$,LEN(y2$)-1)            ! folgenden Zeile ist wichtig!
      IF c&=80
        d&=d&+1
        LOCATE 1,d&                         ! Cursor eine Zeile tiefer
      ELSE
        LOCATE c&+1,d&                      ! Cursor eine Spalte nach rechts
      ENDIF
    ENDIF
    ' -------------------- Cursor an Stringanfang ----------------------
    IF y=200
      y2$=y1$+y2$
      y1$=""
      LOCATE a&,b&
    ENDIF
    ' --------------------- Cursor an Stringende -----------------------
    IF y=208
      c&=CRSCOL                             ! Cursor-Position
      d&=CRSLIN                             ! merken
      delta_d&=(c&+LEN(y2$)-1) DIV 80       ! Position des Stringendes
      delta_c&=(c&+LEN(y2$)) MOD 80         ! errechnen
      c&=delta_c&
      d&=d&+delta_d&
      y1$=y1$+y2$
      y2$=""
      LOCATE c&,d&                          ! Cursor ans Stringende
    ENDIF
    ' ------------------------ Abbruch mit F10 -------------------------
    IF y=196
      PRINT CHR$(27)+"f";                   ! Cursor aus
      ende                                  ! Prozedur "ende" aufrufen
    ENDIF
    ' -------------------------- Eingabesieb ---------------------------
    IF y<43 OR y=44 OR y=47 OR y>57         ! Definition des Eingabefilters
      GOTO li1                              ! Die definierten Bereiche werden
    ENDIF                                   ! ausgeblendet
    ' ---------------------------- Eingabe -----------------------------
    IF LEN(y2$)=0 AND LEN(y1$)<l&           ! Wenn Cursor am Ende des Strings
      y1$=y1$+CHR$(y)
      PRINT CHR$(y);
    ELSE IF LEN(y2$)=0 AND LEN(y1$)=l&      ! Eingabe wird ignoriert
    ELSE IF LEN(y1$+y2$)>=l&                ! Eingabe wird ignoriert
    ELSE
      y1$=y1$+CHR$(y)
      PRINT CHR$(y);
      PRINT CHR$(27)+"J";                   ! Bildschirm ab Cursor lĒschen
      PRINT CHR$(27)+"j";                   ! Cursor-Position merken
      PRINT y2$;                            ! Reststring ausgeben
      PRINT CHR$(27)+"k";                   ! Cursor an alte Position
    ENDIF
  LOOP
  ' ===================== Ende der Eingabeschleife ====================
  PRINT CHR$(27)+"f";                       ! Cursor aus
  c&=CRSCOL                                 ! Cursor-Position
  d&=CRSLIN                                 ! merken
  delta_d&=(c&+LEN(y2$)-1) DIV 80           ! Position des Stringendes
  delta_c&=(c&+LEN(y2$)) MOD 80             ! errechnen
  c&=delta_c&
  d&=d&+delta_d&
  y1$=y1$+y2$
  y2$=""
  LOCATE c&,d&                              ! Cursor ans Stringende
  '                                         ! sonst nur Teilausdruck
  y$=y1$                                    ! RĀckgabevariable initialisieren
RETURN
> PROCEDURE wurzel(n&,VAR x)
  LOCAL flag&,s1$,s2$,s3$
  ' *** Labels: w1
  s1$=" Gerade Wurzeln aus negativen Zahlen sind komplex!"
  s2$=" Diese werden vom Programm nicht erfaět."
  s3$=SPACE$(5)+"Die "+STR$(n&)+"-te Wurzel aus "+STR$(x)+" ist "
  IF n&=0
    GOTO w1
  ENDIF
  IF n& MOD 2=0 AND x<0
    PRINT                                   ! Korrektur, verhindert Fehl-
    PRINT                                   ! funktion beim Scrollen des
    PRINT CHR$(27)+"A"+CHR$(27)+"A";        ! Bildschirms
    PRINT
    PRINT CHR$(27)+"j";                     ! Cursor-Position merken
    PRINT s1$
    PRINT s2$;
    PAUSE 100
    PRINT CHR$(27)+"k";                     ! Cursor an alte Position
    PRINT CHR$(27)+"J";                     ! ab Cursor alles LĒschen
    PRINT s3$+"komplex."
    GOTO w1
  ENDIF
  PRINT
  PRINT s3$;
  IF x<0 AND ODD(n&)
    x=-x
    flag&=1
  ENDIF
  x=x^(1/n&)                                ! Wurzelberechnung
  IF flag&=1
    x=-x
  ENDIF
  IF EVEN(n&)
    PRINT CHR$(241);
  ENDIF
  PRINT STR$(x)+" ."
  w1:
RETURN
> PROCEDURE ende
  LOCAL i&
  PRINT
  PRINT                                     ! Korrektur, verhindert Fehl-
  PRINT                                     ! funktion beim Scrollen des
  PRINT CHR$(27)+"A"+CHR$(27)+"A";          ! Bildschirms
  FOR i&=1 TO 4
    PRINT CHR$(27)+"j";                     ! Cursor-Position merken
    PRINT SPACE$(50);" Programmende "
    PAUSE 15
    PRINT CHR$(27)+"k";                     ! Cursor an alte Position
    PRINT CHR$(27)+"J";                     ! ab Cursor alles LĒschen
    '                                       ! im Wechsel mit ...
    PRINT CHR$(27)+"j";                     ! Cursor-Position merken
    PRINT SPACE$(50);
    PRINT CHR$(27)+"p";                     ! invers ein
    PRINT " Programmende "
    PRINT CHR$(27)+"q";                     ! invers aus
    PAUSE 15
    PRINT CHR$(27)+"k";                     ! Cursor an alte Position
    PRINT CHR$(27)+"J";                     ! ab Cursor alles LĒschen
  NEXT i&
  EDIT
RETURN
'
> PROCEDURE info
  ' Kernpunkt  des  Programms ist die Prozedur "line_input".  Sie  arbeitet
  ' Ąhnlich dem GFA-BASIC-Befehl LINE INPUT. Der Cursor kann mit den Tasten
  ' des Cursorblocks bewegt werden. Auěerdem reagiert er mit der Backspace-
  ' und  der  Delete-Taste, die in bekannter Weise funktionieren.  Mit  der
  ' F10-Taste  gelingt  Āber  die  Prozedur "ende" der  Ausstieg. Nach  dem
  ' Verlassen  der "line_input"-Prozedur fehlt ein Zeilenvorschub,  so  daě
  ' eine  mehrmalige Eingabe mittels "line_input" in der selben Zeile  mĒg-
  ' lich ist. Die maximale LĄnge des Eingabestrings ist auf 20 Spalten vor-
  ' eingestellt, eine énderung lĄět sich durch die Angabe des öbergabepara-
  ' meters  (1. Parameter) bei Aufruf der Prozedur  "line_input"  bewirken.
  ' Die  zulĄssigen  ASCII-Zeichen lassen sich durch  geeignete  Gestaltung
  ' des Eingabefilters  im Eingabesieb festlegen. Zur Zeit ist die  Eingabe
  ' von Zahlen eingestellt.
RETURN
