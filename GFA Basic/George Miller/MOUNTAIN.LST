Dim Lv(64,64),Palette(15),Pal2(15),Sx(8),Sy(9)
Cls
'
Rez=Xbios(4)
If Rez<>0
  Alrt$="Need Lo Rez"
  Alert 3,Alrt$,1,"OK",B
  End
Endif
'
Alrt$="  Fractual Mountains| |   By George Miller|Written with GFA BASIC     "
Alert 0,Alrt$,1,"OK",B
'
@Save_palette
@Set_colour
'
Maxvar:
Print "Enter maximum variation (0-5)"
Input Max
Maxlv=0
If Max>5
  Goto Maxvar
Endif
'
Cls
Print At(7,15);"Wait!   Calculating landscape"
Makemount:
For Iter=6 To 1 Step -1
  Sk=2^Iter
  H1=Sk/2
  Tops:
  For Y=0 To 64 Step Sk
    For X=H1 To 64 Step Sk
      Ran=(Rnd-0.35)*Max*Sk
      Old=(Lv(X-Hl,Y)+Lv(X+Hl,Y))/2
      Lv(X,Y)=Old+Ran
    Next X
  Next Y
  '
  Bottoms:
  '
  For X=0 To 64 Step Sk
    For Y=H1 To 64 Step Sk
      Ran=(Rnd-0.18)*Max*Sk
      Old=(Lv(X,Y-H1)+Lv(X,Y+H1))/2
      Lv(X,Y)=Old+Ran
    Next Y
  Next X
  '
  Centres:
  For X=H1 To 64 Step Sk
    For Y=H1 To 64 Step Sk
      Ran=(Rnd-0.4)*Max*Sk
      Old1=(Lv(X+H1,Y-H1)+Lv(X-H1,Y+H1))/2
      Old2=(Lv(X-H1,Y-H1)+Lv(X+H1,Y+H1))/2
      Old=(Old1+Old2)/2
      If Lv(X,Y)>Maxlv Then
        Maxlv=Lv(X,Y)
      Endif
    Next Y
  Next X
Next Iter
'
Snowline=Maxlv-Maxlv/8
'
'
Mount:
'
Cls
Xm=4
Ym=1
Xshift=0.35
Yp=70
For X=0 To 64
  If Lv(X,0)<0 Then
    Lv(X,0)=0
  Endif
Next X
For Y=0 To 63
  If Lv(0,Y)<0 Then
    Lv(0,Y)=0
  Endif
  For X=0 To 63
    If Lv(X+1,Y+1)<0 Then
      Lv(X+1,Y+1)=0
    Endif
    Lv=Lv(X,Y)+Lv(X+1,Y)+Lv(X,Y+1)
    Lv=(Lv+Lv(X+1,Y+1))/4
    A=X
    B=Y
    Rx1=Xm*A+Xshift*B
    Ry1=Ym*B+Yp-Lv(A,B)
    Gosub Getshade
    Shade1=Shade
    A=X+1
    Rx2=Xm*A+Xshift*B
    Ry2=Ym*B+Yp-Lv(A,B)
    Gosub Getshade
    Shade2=Shade
    A=X
    B=Y+1
    Rx3=Xm*A+Xshift*B
    Ry3=Ym*B+Yp-Lv(A,B)
    Gosub Getshade
    Shade3=Shade
    A=X+1
    Rx4=Xm*A+Xshift*B
    Ry4=Ym*B+Yp-Lv(A,B)
    Gosub Getshade
    Shade4=Shade
    A=X+0.5
    B=Y+0.5
    Rx=Xm*A+Xshift*B
    Ry=Ym*B+Yp
    A=X
    B=Y
    Ry=Ry-Lv
    '
    Sx(0)=Rx
    Sy(0)=Ry
    Sx(1)=Rx1
    Sy(1)=Ry1
    Sx(2)=Rx2
    Sy(2)=Ry2
    Deffill Shade1,2,8
    Polyfill 3,Sx(),Sy()
    '
    Sx(1)=Rx2
    Sy(1)=Ry2
    Sx(2)=Rx4
    Sy(2)=Ry4
    Deffill Shade2,2,8
    Polyfill 3,Sx(),Sy()
    '
    Sx(1)=Rx1
    Sy(1)=Ry1
    Sx(2)=Rx3
    Sy(2)=Ry3
    Deffill Shade3,2,8
    Polyfill 3,Sx(),Sy()
    '
    Sx(1)=Rx3
    Sy(1)=Ry3
    Sx(2)=Rx4
    Sy(2)=Ry4
    Deffill Shade4,2,8
    Polyfill 3,Sx(),Sy()
    '
  Next X
Next Y
'
B=0
Alrtbox:
Alrt$="Save Picture?"
Alert 2,Alrt$,1,"Yes|No",B
If B=1
  Gosub Sav_scrn
Endif
If B=2
  B=0
  Alrt$="View Picture"
  Alert 2,Alrt$,1,"Yes|No",B
Endif
'
If B=1
  Pause 3000
  Goto Alrtbox
Endif
'
Alrt$="New picture or End?"
Alert 2,Alrt$,1,"New|End",B
'
If B=1
  Cls
  Goto Maxvar
Endif
'
@Restore_palette
End
'
Procedure Getshade
  '
  C=X+1-(B-Y)
  D=Y+(A-X)
  Xc=X+0.5
  Yc=Y+0.5
  Xrun1=Xc-A
  Xrun2=Xc-C
  Yrun1=Yc-B
  Yrun2=Yc-D
  Rise1=Lv-Lv(A,B)
  Rise2=Lv-Lv(C,D)
  Yrise=Abs(Rise1*Xrun2-Rise2*Xrun1)
  Yrun=Abs(Yrun1*Xrun2-Xrun1*Yrun2)
  If Yrun=Yrise
    Yrun=1
    Yrise=1
  Endif
  Xrise=Abs(Xrun1*Yrun2-Rise2*Yrun1)
  Xrun=Abs(Xrun*Yrun2-Yrun1*Xrun2)
  If Xrun=Xrise
    Xrun=1
    Xrise=1
  Endif
  Xrise=Xrise/2
  Yrise=Yrise/2
  Xshade=1-Abs(Xrise/(Xrun+Xrise))
  Yshade=1-Abs(Yrise/(Yrun+Yrise))
  Shade=14*Xshade*Yshade-9
  If Lv>Snowline
    Shade=Shade+16
  Endif
  If Lv<=0
    Shade=16
  Endif
Return
'
'
'
'
Procedure Set_rez
  '
  Rez=Xbios(4)
  '
  ' Switch to low resolution
  '
  If Rez=1
    Rez=0
  Else
    If Rez=0
      Rez=1
    Endif
    If Rez=2
      Alrt$="Sorry!|This program requires| a color monitor."
      Alert 3,Alrt$,1,"Okay",B
      End
    Endif
  Endif
  Dummy=Xbios(5,L:-1,L:-1,W:Rez)
Return
'
Procedure Set_colour
  ' Set correct colors
  '
  ' Set up color table
  '
  Data 4,6,7
  Data 2,7,6
  Data 7,7,5
  Data 7,7,0
  Data 3,3,3
  Data 7,7,7
  Data 2,3,3
  Data 4,5,3
  Data 3,7,5
  Data 4,3,3
  Data 4,5,4
  Data 7,5,4
  Data 3,7,4
  Data 0,5,2
  Data 0,3,2
  Data 0,0,7
  '
  '
  For I=0 To 15
    Read R,G,B
    Setcolor I,R,G,B
  Next I
  '
Return
'
' Save Original Color Palette
'
Procedure Save_palette
  Local I
  '
  ' must be located at start of program:  Dim Palette(15)
  '
  '
  For I=0 To 15
    Palette(I)=Xbios(7,W:I,W:-1)
  Next I
Return
'
'
'
' Restore Original Color Palette
'
Procedure Restore_palette
  Local I
  '
  For I=0 To 15
    Setcolor I,Palette(I)
  Next I
Return
'
Procedure Sav_scrn
  '
  Default$="C:\*.NEO"
  Fileselect Default$,"",Infile$
  Cls
  If Infile$=""                     !equals "" if CANCEL selected
    Goto Not_neo
  Endif
  Gosub Set_new_colors
  Sput Screen1$
  Open "o",#1,Infile$
  '
  ' First two bytes to zero
  '
  For I=0 To 2
    Out #1,0
    Out #1,0
  Next I
  '
  ' Save color palette
  '
  For I=0 To 15
    Hi=Int(Pal2(I)/256)
    Lo=Pal2(I)-256*Hi
    Out #1,Hi
    Out #1,Lo
  Next I
  '
  ' Color cycling info (not needed)
  '
  For I=0 To 89
    Out #1,0
  Next I
  '
  ' Save screen info
  '
  Bput #1,Xbios(3),32000
  '
  Not_neo:
  Close
Return
