$p>
rsc_init
rsc_obj_names
init.s.menu
ON MENU GOSUB call.s.menu
OPENW 0
DEFMOUSE 0
ON ERROR GOSUB fehler
laenge=9.9623189
breite=48.45797
dekl=5
abstand=2.5
lx=100
ly=190
px%=2870/640*lx
py%=2100/380*(380-ly)
e$=CHR$(3)
mez
DO
  ON MENU
LOOP
> PROCEDURE init.s.menu
  LOCAL i%
  DIM t$(24)
  RESTORE roem_zahlen
  FOR i%=1 TO 24
    READ t$(i%)
  NEXT i%
  roem_zahlen:
  DATA I,II,III,IV,V,VI,VII,VIII,IX,X,XI,XII
  DATA I,II,III,IV,V,VI,VII,VIII,IX,X,XI,XII
  LOCAL a$,a%
  MENU KILL
  resto.s.re:
  RESTORE resto.s.re
  '
  ERASE med.s$()
  DIM med.s$(36)
  DATA  Desktop,  Thema Nr. ??????? ,----------------------,  ACC1,  ACC2,  ACC3,  ACC4
  DATA   ACC5,  ACC6,""
  DATA  Eingaben ,  Geogr. L„nge ,  Geogr. Breite,  Wanddeklination ,  Abstand in Minuten
  DATA --------------------------,  mitteleurop„ische Zeit  ,  wahre Ortszeit   ,""
  DATA  Ausgabe ,  Bildschirm,  Plotter,  Drucker [Liste] ,-------------------,""
  DATA  Korrektur ,  Zeigereinsatzpunkt ,---------------------
  DATA   Programmende,---------------------,""
  DATA "",***
  '
  '
  a%=0
  DO
    READ a$
    EXIT IF a$="***"
    med.s$(a%)=a$
    INC a%
  LOOP
  MENU med.s$()
RETURN
> PROCEDURE call.s.menu
  LOCAL a%
  MENU OFF
  a%=MENU(0)
  ON a%-0 GOSUB programminfo,empty.p,empty.p,empty.p,empty.p,empty.p,empty.p
  ON a%-7 GOSUB empty.p
  ON a%-10 GOSUB geogr__l,geogr__b,wanddekl,abstand
  ON a%-14 GOSUB empty.p,mez,woz
  ON a%-19 GOSUB bildschi,plotter,drucker
  ON a%-25 GOSUB zeigereinsatz,empty.p,programmende
RETURN
> PROCEDURE empty.p
  ' Dummy Procedure
RETURN
> PROCEDURE programminfo
  LOCAL a%,a$,b$,c$,d$,e$
  a$="Die deklinierende Sonnenuhr !|Programmiert in GFA-Basic von|Konrad Brendle. Bezahlen wird|sowieso keiner etwas,aber das"
  b$="ist mir|sch...|egal"
  ALERT 1,a$,0,b$,a%
RETURN
> PROCEDURE geogr__l
  eingabe
  LOCAL l$
  l$=STR$(laenge)
  umw(laenge,"Geogr. L„nge:  ")
  PRINT AT(10,5);t$
  umw(breite,"Geogr. Breite: ")
  PRINT AT(10,7);t$
  eingabe
  PRINT "Geographische L„nge [dezimal]:";
  FORM INPUT 10 AS l$
  laenge=VAL(l$)
RETURN
> PROCEDURE geogr__b
  eingabe
  LOCAL b$
  b$=STR$(breite)
  umw(laenge,"Geogr. L„nge:  ")
  PRINT AT(10,5);t$
  umw(breite,"Geogr. Breite: ")
  PRINT AT(10,7);t$
  eingabe
  PRINT "Geographische Breite [dezimal]:";
  FORM INPUT 10 AS b$
  breite=VAL(b$)
RETURN
> PROCEDURE wanddekl
  LOCAL d$
  d$=STR$(dekl)
  eingabe
  PRINT "Wanddeklination :";
  FORM INPUT 6 AS d$
  dekl=VAL(d$)
RETURN
> PROCEDURE bildschi      !Schleife von -150 - +150 Grad
  MENU 20,1
  MENU 21,0
  MENU 22,0
  IF NOT plotter!
    @substilare
  ENDIF
  wechsel%=0
  x=-1
  FOR i=-150 TO 150 STEP abstand
    zw1=DEG(ATN(COS(RAD(breite))/(COS(RAD(dekl))*1/TAN(RAD(i-korr))+SIN(RAD(dekl))*SIN(RAD(breite)))))
    i=INT(1000*i+0.5)/1000
    IF SGN(zw1)=x
      ADD wechsel%,1
      x=-x
    ENDIF
    IF wechsel%>0 AND wechsel%<3
      zeichne_bildschirm(i,zw1,"Schattenlinie um")
      IF drucker!
        druck(i,zw1,"Schattenlinie um")
      ENDIF
    ENDIF
  NEXT i
RETURN
> PROCEDURE plotter
  LOCAL b$,i%
  SGET b$
  ~FORM_CENTER(tree_0.adr%,x%,y%,w%,h%)
  ~OBJC_DRAW(tree_0.adr%,0,5,x%,y%,w%,h%)
  ex_obj%=FORM_DO(tree_0.adr%,0)
  ~OBJC_CHANGE(tree_0.adr%,ex_obj%,0,x%,y%,w%,h%,32,0)
  IF ex_obj%=18
    FOR i%=4 TO 13
      IF BTST(OB_STATE(tree_0.adr%,i%),0)
        speed%=i%-3
        PRINT speed%
      ENDIF
    NEXT i%
    FOR i%=16 TO 17
      IF BTST(OB_STATE(tree_0.adr%,i%),0)
        format%=i%-15
      ENDIF
    NEXT i%
    FOR i%=21 TO 28
      IF BTST(OB_STATE(tree_0.adr%,i%),0)
        pen%=i%-20
      ENDIF
    NEXT i%
    SPUT b$
    IF GEMDOS(17)
      LPRINT "J",pen%;e$
      LPRINT "!",speed%;e$
      IF format%=1
        LPRINT "&100,100,72";e$
      ELSE
        LPRINT "&100,100,100";e$
      ENDIF
      MENU 20,0
      MENU 21,1
      MENU 22,0
      drucker!=FALSE
      plotter!=TRUE
      LPRINT "M0,0";e$
      LPRINT "D 2870,0,2870,2000,0,2000,0,0";e$
      LPRINT "M 200,100";e$
      LPRINT "D 2670,100,2670,1900,200,1900,200,100";e$
      LPRINT "M",px%,py%;e$
      LPRINT "S80";e$
      LPRINT "N15";e$
      LPRINT "S30";e$
      LPRINT "L5";e$
      LPRINT "D",2670,py%;e$
      LPRINT "LP3";e$
      LPRINT "R900";e$
      LPRINT "M130,150";e$
      LPRINT "P";ub$;e$
      LPRINT "L0";e$
      @substilare
      LPRINT "R900";e$
      LPRINT "LP5";e$
      bildschi
      LPRINT "J0";e$
    ELSE
      ALERT 1,"Plotter nicht bereit!",1," OK !",ba%
    ENDIF
  ENDIF
  SPUT b$
  plotter!=FALSE
RETURN
> PROCEDURE drucker
  MENU 20,0
  MENU 21,0
  MENU 22,1
  drucker!=TRUE
  bildschi
  drucker!=FALSE
  plotter!=FALSE
RETURN
> PROCEDURE zeigereinsatz
  LOCAL x,y
  SETMOUSE 50,209
  DO
    x=MAX(MOUSEX,50)
    y=MOUSEY
    PRINT AT(20,10);
    PRINT USING "   Y=###",380-y;
    PRINT USING "   X=###",x
    GRAPHMODE 3
    CIRCLE x,y,4
    LINE x,y,x+50,y
    WHILE MOUSEX=x AND MOUSEY=y AND MOUSEK=0
    WEND
    CIRCLE x,y,4
    LINE x,y,x+50,y
    GRAPHMODE 1
    EXIT IF MOUSEK>0
  LOOP
  IF MOUSEK=2 THEN
    y=190
    x=100
  ENDIF
  CIRCLE x,y,4
  LINE x,y,x+50,y
  LINE x,y+20,x,y-20
  ly=y
  lx=x
  px%=2970/640*lx
  py%=2100/380*(380-ly)
RETURN
> PROCEDURE programmende
  ~RSRC_FREE()
  RESERVE FRE(0)+33000
  EDIT
RETURN
> PROCEDURE fehler
  ON ERROR GOSUB fehler
  IF ERR=0 THEN
    zw1=DEG(ATN(COS(RAD(breite))/(COS(RAD(dekl))*1/TAN(RAD(i-korr+1.0E-09))+SIN(RAD(dekl))*SIN(RAD(breite)))))
    RESUME NEXT
  ELSE
    PRINT ERR$(ERR),ERR
  ENDIF
RETURN
> PROCEDURE druck(i,zw1,x$)
  LOCAL stunden,minuten,us$
  us$=x$+" ##:"
  stunden=INT(i/15)+12
  minuten=FRAC(i/15)*60
  IF minuten<0 THEN
    minuten=minuten+60
  ENDIF
  IF GEMDOS(17)
    LPRINT TAB(10);        !x$;
    LPRINT USING us$,stunden;
    LPRINT USING "##",minuten;
    LPRINT USING "       Winkel in Grad = ###.####   ",zw1
  ELSE
    PRINT AT(10,42);"Na hast'e gar keinen Drucker?"
    PRINT
    PRINT AT(10,44);        !x$;
    PRINT USING us$,stunden;
    PRINT USING "##",minuten;
    PRINT USING "       Winkel in Grad = ###.####   ",zw1
  ENDIF
RETURN
> PROCEDURE zeichne_bildschirm(i,b,c$) !i=Stundenwinkel-90 - +90: b=zifferblattwinkel
  LOCAL x,y,m_x,m_y,t$,s$
  IF i<0 THEN
    m_y=375-ly
  ELSE
    m_y=ly-5
  ENDIF
  GRAPHMODE 3
  DEFTEXT 1,0,0,4
  stunden=INT(i/15)+12
  minuten=FRAC(i/15)*60
  IF minuten<0 THEN
    minuten=minuten+60
  ENDIF
  minuten=INT(10*minuten+0.5)/10
  sek=FRAC(minuten)*60
  t$=STR$(stunden)+":"+STR$(INT(minuten))+":"+STR$(INT(sek))
  IF c$<>"Schattenlinie um"
    DEFLINE 3
    x=m_y/TAN(RAD(b))
    x=ABS(x)
    x=MIN(x,630-lx)
    y=TAN(RAD(b))*x
    PLOT lx,ly-1
    DRAW  TO x+lx,ly-y
    GRAPHMODE 1
    DEFTEXT ,,900
    s$="Substilare bei:"+t$+"  oder Winkel: "+STR$(INT(100*b+0.5)/100)+" Grad"
    IF plotter! AND GEMDOS(17)
      LPRINT "R900";e$
      LPRINT "LP4";e$
      LPRINT "M 180,1050";e$
      LPRINT "P";UPPER$(s$);e$
      LPRINT "R 0";e$
    ENDIF
    TEXT 35,330,s$
    DEFTEXT ,,0
  ELSE
    DEFLINE 1
    x=m_y/TAN(RAD(b))
    x=ABS(x)
    x=MIN(x,630-lx)
    y=TAN(RAD(b))*x
    IF plotter!
      plot(i,b,0)
    ENDIF
    IF i MOD 15=0 THEN
      t$=STR$(stunden)
      IF woz!
        t$=t$(stunden)
      ENDIF
      PLOT lx+0.5*x,ly-0.5*y
      DRAW  TO x+lx,ly-y
      GRAPHMODE 1
      DEFTEXT ,,900
      TEXT lx+0.9*x,ly-0.9*y+8,t$
      DEFTEXT ,,0
    ELSE
      PLOT lx+0.9*x,ly-0.9*y
      DRAW  TO lx+x,ly-y
    ENDIF
  ENDIF
  GRAPHMODE 1
  PRINT AT(10,38);
  PRINT USING "Zeit: ##:",stunden;
  PRINT USING "##",minuten;
  PRINT USING "     Winkel:###.##",b;
RETURN
> PROCEDURE bildschirm    !Beschriftung
  LOCAL a$,b$
  CLS
  GRAPHMODE 3
  DEFFILL 1,2,8
  DEFTEXT 1,0,0,4
  PBOX 1,1,638,379
  DEFFILL 0,1,8
  PBOX 40,23,590,357
  CIRCLE lx,ly-1,4
  LINE lx,ly+20,lx,ly-20
  DEFLINE 4
  LINE lx,ly-1,lx+580,ly-1
  GRAPHMODE 1
  a$="Geogr. Laenge :"+STR$(INT(laenge*100+0.5)/100)+"  Geogr. Breite :"+STR$(INT(breite*100+0.5)/100)+"  Wanddekl. :"+STR$(INT(100*dekl+0.5)/100)
  b$="Aufloesung auf dem Zifferblatt: "+STR$(abstand*4)+" Minuten"
  DEFTEXT ,,900
  TEXT 15,340,a$
  TEXT 25,310,b$
  DEFTEXT 1,1,900,13
  TEXT 15,380,ub$
  DEFTEXT 1,0,0,4
  PRINT AT(10,27);"Stuetzwinkel zwischen Zeiger und";
  PRINT AT(10,29);"Substilare     :    ";
  PRINT USING "###.## Grad",alpha
  IF plotter! AND GEMDOS(17)
    LPRINT "R900";e$
    LPRINT "LP4";e$
    LPRINT "M 60,1050";e$
    LPRINT "P";UPPER$(a$);e$
    LPRINT "M 120,1050";e$
    LPRINT "P";UPPER$(b$);e$
    LPRINT "R 0";e$
  ENDIF
RETURN
> PROCEDURE eingabe
  DEFTEXT 1,0,0,13
  GRAPHMODE 1
  PRINT AT(10,12);
  PRINT SPACE$(55)
  PRINT AT(10,12);
RETURN
> PROCEDURE abstand
  LOCAL a$,ex%
  a$=STR$(abstand*4)
  REPEAT
    eingabe
    PRINT "Abstand in Minuten:";
    FORM INPUT 6 AS a$
    abstand=VAL(a$)
    ex%=60 MOD abstand
  UNTIL abstand<>0 AND ex%=0
  DIV abstand,4
RETURN
> PROCEDURE substilare
  IF dekl=0
    ADD dekl,1.0E-09
  ENDIF
  alpha=DEG(ASIN(COS(RAD(dekl))*COS(RAD(breite))))
  gamma=TAN(RAD(dekl))/SIN(RAD(breite))
  gamma1=DEG(ATN(gamma))
  gamma2=DEG(ATN(COS(RAD(breite))/(COS(RAD(dekl))*1/TAN(RAD(gamma1))+SIN(RAD(dekl))*SIN(RAD(breite)))))
  bildschirm
  '  druck(gamma1,gamma2,"Substilare     ")
  zeichne_bildschirm(gamma1+korr,gamma2,"Substilare     ")
  IF plotter! AND GEMDOS(17)
    LPRINT "L2";e$
    plot(gamma1+korr,gamma2,1)
    LPRINT "L0";e$
  ENDIF
RETURN
> PROCEDURE mez
  MENU 16,1
  MENU 17,0
  ub$=" MEZ"
  woz!=FALSE
  mez!=TRUE
  IF laenge MOD 15>0
    korr=15-laenge MOD 15
  ELSE
    korr=0
  ENDIF
RETURN
> PROCEDURE woz
  MENU 17,1
  MENU 16,0
  ub$=" WOZ"
  woz!=TRUE
  mez!=FALSE
  korr=1.0E-09
RETURN
> PROCEDURE umw(i,i$)
  LOCAL st,m,s,st$,m$,s$
  st=INT(i)
  st$=STR$(st)+" Grad : "
  m=FRAC(i)*60
  m$=STR$(INT(m))+" Minuten : "
  s=INT(FRAC(m)*60*100+0.5)/100
  s$=STR$(INT(s))+" Sekunden"
  t$=st$+m$+s$
  t$=RIGHT$(SPACE$(20)+i$+t$,50)
RETURN
> PROCEDURE rsc_init
  IF EXIST("\SONNEN.UHR\SONNEN_U.RSC")
    RESERVE FRE(0)-33000
    ~RSRC_FREE()
    laden_ok!=RSRC_LOAD("\SONNEN.UHR\SONNEN_U.RSC")
  ELSE
    ALERT 3,"RSC-Datei nicht gefunden!",1,"Abbruch",rueck_1%
    EDIT
    IF NOT laden_ok!
      ALERT 3,"Fehler beim Laden|der RSC-Datei!",1,"Abbruch",rueck_2%
    ENDIF
  ENDIF
RETURN
> PROCEDURE plot(i,b,s%)
  LOCAL x,y,m_x,m_y,t$
  IF GEMDOS(17)
    IF i<0 THEN
      m_y=py%-100
    ELSE
      m_y=1900-py%
    ENDIF
    x=m_y/TAN(RAD(b))
    x=ABS(x)
    x=MIN(x,2670-px%)
    y=TAN(RAD(b))*x
    stunden=INT(i/15)+12
    IF plotter! AND s%=1
      LPRINT "M",px%,py%;e$
      LPRINT "D",x+px%,py%+y;e$
    ENDIF
    IF s%<>1
      IF i MOD 15=0 THEN
        t$=STR$(stunden)
        IF woz!
          t$=t$(stunden)
        ENDIF
        LPRINT "M",px%+0.7*x,py%+0.7*y;e$
        LPRINT "D",x+px%,y+py%;e$
        LPRINT "M",px%+1.04*x,py%+1.04*y;e$
        LPRINT "P";t$;e$
      ELSE
        LPRINT "M",px%+0.9*x,py%+0.9*y;e$
        LPRINT "D",px%+x,py%+y;e$
      ENDIF
    ENDIF
  ELSE
    ALERT 1,"Plotter nicht bereit!",1," OK!",ba%
  ENDIF
RETURN
> PROCEDURE rsc_obj_names
  ~RSRC_GADDR(0,0,tree_0.adr%)
  tree_0%=0
  obj_0.0%=0
  obj_0.1%=1       !Abbruch
  obj_0.2%=2
  obj_0.3%=3
  obj_0.4%=4       !Geschwindigkeit 10%
  obj_0.5%=5       !Geschwindigkeit 20%
  obj_0.6%=6       !Geschwindigkeit 30%
  obj_0.7%=7       !Geschwindigkeit 40%
  obj_0.8%=8       !Geschwindigkeit 50%
  obj_0.9%=9       !Geschwindigkeit 60%
  obj_0.10%=10     !Geschwindigkeit 70%
  obj_0.11%=11     !Geschwindigkeit 80%
  obj_0.12%=12     !Geschwindigkeit 90%
  obj_0.13%=13     !Geschwindigkeit 100%
  obj_0.14%=14
  obj_0.15%=15
  obj_0.16%=16     !Papierformat DIN A3
  obj_0.17%=17     !Papierformat DIN A4
  obj_0.18%=18     !Exbox
  obj_0.19%=19
  obj_0.20%=20
  obj_0.21%=21     !Plotterstift Nr. 1
  obj_0.22%=22     !Plotterstift Nr. 2
  obj_0.23%=23     !Plotterstift Nr. 3
  obj_0.24%=24     !Plotterstift Nr. 4
  obj_0.25%=25     !Plotterstift Nr. 5
  obj_0.26%=26     !Plotterstift Nr. 6
  obj_0.27%=27     !Plotterstift Nr. 7
  obj_0.28%=28     !Plotterstift Nr. 8
RETURN
