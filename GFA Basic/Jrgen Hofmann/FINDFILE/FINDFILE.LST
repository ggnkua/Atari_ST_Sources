' FINDFILE.GFA                                 Jürgen Hofmann
' V1.0                                         Zur Finkenkuhle 26
' 09.01.90                                     3320 Salzgitter 51
' GFA-Basic 3.0                                05341 / 3 64 39
'
dateiname$="*.DOC"                             !Voreinstellung für den Dateinamen
pfad$="E:\"                                    !Voreinstellung für den Suchpfad
~FSETDTA(BASEPAGE+128)
DO
  CLS
  PRINT "Bitte geben Sie den Suchstring ein (z.B. Mit freundlich): ";
  FORM INPUT 19 AS such$
  EXIT IF such$=""
  PRINT "Bitte geben Sie den Dateinamen ein (z.B. *.DOC oder *.*): ";
  FORM INPUT 19 AS dateiname$
  PRINT "Bitte geben Sie den Suchpfad an (z.B. A:\ oder D:\DOKU\): ";
  FORM INPUT 19 AS pfad$
  PRINT
  pfad$=UPPER$(pfad$)
  dateiname$=UPPER$(dateiname$)
  GOSUB suche
LOOP
'
PROCEDURE suche
  LOCAL w&
  e&=FSFIRST(pfad$+dateiname$,&X100111)        !suche nach Dateien (keine Ordner)
  WHILE e&=0                                   !solange noch Dateien vorhanden
    x$=CHAR{BASEPAGE+158}                      !den Namen der gefundenen Datei ermitteln
    PRINT pfad$+x$;                            !gefundenen Suchpfad und Dateinamen ausgeben
    OPEN "I",#1,pfad$+x$                       !... und öffnen
    n&=LOF(#1) DIV 32000
    REPEAT
      IF n&=0
        daten$=INPUT$(LOF(#1) MOD 32000,#1)    !Restdaten in den String einlesen
      ELSE
        daten$=INPUT$(32000,#1)                !Daten in den String einlesen
        DEC n&
      ENDIF
      IF INSTR(daten$,such$)<>0                !ist der Suchstring in der Datei vorhanden?
        PRINT "  --> Suchstring gefunden";
        ALERT 1,"Suchstring gefunden!| |* Bitte wählen Sie *",1,"WEITER|ZEIGE|ABBRUCH",al|
        SELECT al|
        CASE 2                                 !soll die Datei angezeigt werden?
          crsx|=CRSCOL                         !dann Cursor-X-Koordinate merken
          crsy|=CRSLIN                         !     Cursor-Y-Koordinate merken
          SGET screen$                         !Bildschirm retten
          GOSUB zeige_datei
          SPUT screen$                         !Bildschirm restaurieren
          PRINT AT(crsx|,crsy|);               !Cursor auf gemerkte Position setzen
        CASE 3                                 !wurde ABBRUCH angeklickt?
          ALERT 2,"Programm beenden|      oder|  neu starten?",2,"BEENDEN|NEUSTART",al|
          IF al|=1
            SYSTEM                             !Programm verlassen
          ELSE
            RUN                                !Programm neu starten
          ENDIF
        ENDSELECT
      ENDIF
    UNTIL n&=0                                 !am Fileende die Schleife verlassen
    CLOSE #1                                   !Datei schlie×en
    PRINT
    IF ASC(INKEY$)=27
      RUN                                      !Neustart wenn die Esc-Taste gedrückt wurde
    ENDIF
    e&=FSNEXT()
  WEND
  e&=FSFIRST(pfad$+"*.*",&X10000)              !suche nach erstem Ordner
  CLR q&
  WHILE e&=0                                   !solange noch Ordner vorhanden
    IF ASC(INKEY$)=27
      RUN                                      !Neustart wenn die Esc-Taste gedrückt wurde
    ENDIF
    x$=CHAR{BASEPAGE+158}                      !den Namen des gefundenen Ordners ermitteln
    IF BTST(BYTE{BASEPAGE+149},4)              !wenn Bit 4 gesetzt, ist es ein Ordner
      IF x$<>"." AND x$<>".."
        w&=q&
        pfad$=pfad$+x$+"\"
        GOSUB suche
        pfad$=LEFT$(pfad$,RINSTR(LEFT$(pfad$,LEN(pfad$)-1),"\"))
        ~FSFIRST(pfad$+"*.*",&X10000)          !suche nach erstem Ordner
        CLR q&
        WHILE w&<>q&
          ~FSNEXT()
          INC q&
        WEND
      ENDIF
    ENDIF
    e&=FSNEXT()
    INC q&
  WEND
RETURN
'
PROCEDURE zeige_datei
  LOCAL stelle&,merke&
  CLS
  SEEK #1,0
  n&=LOF(#1) DIV 32000
  REPEAT
    IF n&=0
      daten$=INPUT$(LOF(#1) MOD 32000,#1)
    ELSE
      daten$=INPUT$(32000,#1)
      DEC n&
    ENDIF
    merke&=INSTR(daten$,such$)
    ' Ausgabe auf Bildschirm
    stelle&=1
    REPEAT
      CLR lf|
      REPEAT
        IF stelle&=merke&
          PRINT CHR$(27);"p";                  !Inversdarstellung
        ENDIF
        IF stelle&-merke&=LEN(such$)
          IF merke&>0
            PRINT CHR$(27);"q";                !Normaldarstellung
            merke&=INSTR(daten$,such$,stelle&)
          ENDIF
        ENDIF
        IF ASC(MID$(daten$,stelle&,1))<32
          PRINT ".";
        ELSE
          PRINT MID$(daten$,stelle&,1);
        ENDIF
        INC stelle&
        IF CRSCOL=80
          INC lf|
        ENDIF
      UNTIL lf|=24 OR stelle&>LEN(daten$)
      IF n&=0 AND stelle&>LEN(daten$)
        PRINT
        PRINT AT(1,25);"Fileende erreicht";
      ENDIF
      taste|=INP(2)
    UNTIL stelle&>LEN(daten$) OR taste|=27
  UNTIL n&=0 OR taste|=27
  CLR n&
RETURN
