@text_arrays
@make_boxes
@maintain_boxes
> PROCEDURE text_arrays
'
DIM text0$(5)
text0$(0)="This"
text0$(1)="is"
text0$(2)="an"
text0$(3)="example"
text0$(4)="of"
text0$(5)="radio buttons"
RETURN
> PROCEDURE make_boxes
DEFFILL 1,2,4               ! Screen fill pattern
PBOX 0,0,639,399            ! Fill the screen
'
box&=0
x&=109
FOR y&=117 TO 237 STEP 24
DEFFILL 1,1
PBOX x&,y&,x&+375,y&+20
DEFFILL 0,2,8
PBOX x&+1,y&+1,x&+374,y&+19
GRAPHMODE 2
TEXT x&+(375-LEN(text0$(box&))*16)DIV2,y&+16,LEN(text0$(box&))*16,text0$(box&)
GRAPHMODE 1
inc box&
NEXT y&
'
RETURN
> PROCEDURE maintain_boxes
radio_button&=0      ! to change the initial radio button
box&=radio_button&
@radio_button        ! blackens initial radio button
count&=0
RESTORE row1
DO
READ x2&,x1&,y2&,y1&,box&
INC count&
IF MOUSEX<x2& AND MOUSEX>x1& AND MOUSEY<y2& AND MOUSEY>y1&
IF box&<>radio_button&
GRAPHMODE 3
DEFFILL 1,1
PBOX x2&,y2&,x1&,y1&
REPEAT
IF MOUSEK=1
@some_where(box&)
PAUSE 10
ENDIF
UNTIL MOUSEX>x2& OR MOUSEX<x1& OR MOUSEY>y2& OR MOUSEY<y1&
GRAPHMODE 1
IF box&<>radio_button&
DEFFILL 0,2,8
PBOX x2&-1,y2&-1,x1&+1,y1&+1
GRAPHMODE 2
TEXT x1&+(x2&-x1&-LEN(text0$(box&))*16)DIV2,y2&-4,LEN(text0$(box&))*16,text0$(box&)
GRAPHMODE 1
ENDIF
ENDIF
ENDIF
IF count&=6
@select
count&=0
ENDIF
LOOP
row1:
DATA 484,109,137,117,0,484,109,161,141,1,484,109,185,165,2
DATA 484,109,209,189,3,484,109,233,213,4,484,109,257,237,5
RETURN
> PROCEDURE select
SELECT MOUSEX
CASE 0 TO 486
RESTORE row1
DEFAULT
RESTORE row1
ENDSELECT
RETURN
> PROCEDURE some_where(box&)
GRAPHMODE 1
DEFFILL 0,2,8
SELECT radio_button&
CASE 0
PBOX 483,136,110,118
GRAPHMODE 2
TEXT 264,133,64,text0$(0)
CASE 1
PBOX 483,160,110,142
GRAPHMODE 2
TEXT 280,157,32,text0$(1)
CASE 2
PBOX 483,184,110,166
GRAPHMODE 2
TEXT 280,181,32,text0$(2)
CASE 3
PBOX 483,208,110,190
GRAPHMODE 2
TEXT 240,205,112,text0$(3)
CASE 4
PBOX 483,232,110,214
GRAPHMODE 2
TEXT 280,229,32,text0$(4)
CASE 5
PBOX 483,256,110,238
GRAPHMODE 2
TEXT 192,253,208,text0$(5)
ENDSELECT
GRAPHMODE 1
radio_button&=box&
SELECT box&
CASE 0                     ! Box 0
' Do what Box 0 does
CASE 1                     ! Box 1
' Do what Box 1 does
CASE 2                     ! Box 2
' Do what Box 2 does
CASE 3                     ! Box 3
' Do what Box 3 does
CASE 4                     ! Box 4
' Do what Box 4 does
CASE 5                     ! Box 5
' Do what Box 5 does
ENDSELECT
RETURN
> PROCEDURE radio_button
GRAPHMODE 3
DEFFILL 1,1
SELECT radio_button&
CASE 0
PBOX 484,137,109,117
CASE 1
PBOX 484,161,109,141
CASE 2
PBOX 484,185,109,165
CASE 3
PBOX 484,209,109,189
CASE 4
PBOX 484,233,109,213
CASE 5
PBOX 484,257,109,237
ENDSELECT
GRAPHMODE 1
RETURN
