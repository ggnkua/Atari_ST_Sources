@text_arrays
@make_boxes
@maintain_boxes
> PROCEDURE text_arrays
'
DIM text0$(3)
text0$(0)="This"
text0$(1)="is"
text0$(2)="an"
text0$(3)="example."
RETURN
> PROCEDURE make_boxes
DEFFILL 1,2,5               ! Screen fill pattern
PBOX 0,0,639,399            ! Fill the screen
'
box&=0
y&=117
FOR x&=109 TO 418 STEP 103
DEFFILL 1,1
PBOX x&,y&,x&+100,y&+20
DEFFILL 0,2,8
PBOX x&+2,y&+2,x&+98,y&+18
GRAPHMODE 2
TEXT x&+(100-LEN(text0$(box&))*11)DIV2,y&+16,LEN(text0$(box&))*11,text0$(box&)
GRAPHMODE 1
inc box&
NEXT x&
'
RETURN
> PROCEDURE maintain_boxes
count&=0
RESTORE row1
DO
READ x2&,x1&,y2&,y1&,box&
INC count&
IF MOUSEX<x2& AND MOUSEX>x1& AND MOUSEY<y2& AND MOUSEY>y1&
GRAPHMODE 3
DEFFILL 1,1
PBOX x2&-1,y2&-1,x1&+1,y1&+1
REPEAT
IF MOUSEK=1
@some_where(box&)
ENDIF
UNTIL MOUSEX>x2& OR MOUSEX<x1& OR MOUSEY>y2& OR MOUSEY<y1&
GRAPHMODE 1
DEFFILL 0,2,8
PBOX x2&-2,y2&-2,x1&+2,y1&+2
GRAPHMODE 2
TEXT x1&+(x2&-x1&-LEN(text0$(box&))*11)DIV2,y2&-4,LEN(text0$(box&))*11,text0$(box&)
GRAPHMODE 1
ENDIF
IF count&=1
@select
count&=0
ENDIF
LOOP
row1:
DATA 209,109,137,117,0
row2:
DATA 312,212,137,117,1
row3:
DATA 415,315,137,117,2
row4:
DATA 518,418,137,117,3
RETURN
> PROCEDURE select
SELECT MOUSEX
CASE 0 TO 211
RESTORE row1
CASE 212 TO 314
RESTORE row2
CASE 315 TO 417
RESTORE row3
CASE 418 TO 520
RESTORE row4
DEFAULT
RESTORE row4
ENDSELECT
RETURN
> PROCEDURE some_where(box&)
SELECT box&
CASE 0                     ! Box 0
' Do what Box 0 does
CASE 1                     ! Box 1
' Do what Box 1 does
CASE 2                     ! Box 2
' Do what Box 2 does
CASE 3                     ! Box 3
' Do what Box 3 does
ENDSELECT
RETURN
