REM FÅr GFA-Basic 2.xx statt x=Byte{y} x=Peek(y) bzw. Byte{x}=y Poke x,y einsetzen.
FILESELECT "A:\*.*","*.PIC",f$
OPEN "i",#1,f$
fl%=LOF(#1)
kenn$=INPUT$(4,#1) !Kennung siehe unten
CLOSE #1
DIM b%(INT(fl%/4)+1)
start%=V:b%(0)
BLOAD f$,start%
lauf%=start%+4
DEFBYT "a-z"
kb=BYTE{lauf%} !Kennbyte
INC lauf%
pb=BYTE{lauf%} !Packbyte
INC lauf%
sb=BYTE{lauf%} !Spezialbyte
INC lauf%
IF kenn$="pM85" ! Horizontal gepackt
  adr%=XBIOS(3)-1
  @horiz
ELSE IF kenn$="pM86" ! Vertikal gepackt
  @verti
ELSE
  ALERT 1,"Kein STAD-Format!",1,"SORRY",dum
  END
ENDIF
PROCEDURE horiz
  FOR i%=lauf% TO start%+fl%
    n=BYTE{i%}
    IF n=kb
      INC i%
      nn=BYTE{i%}
      FOR i=0 TO nn
        INC adr%
        BYTE{adr%}=pb
      NEXT i
    ELSE IF n=sb
      INC i%
      na=BYTE{i%}
      INC i%
      nn=BYTE{i%}
      FOR i=0 TO nn
        INC adr%
        BYTE{adr%}=na
      NEXT i
    ELSE
      INC adr%
      BYTE{adr%}=n
    ENDIF
  NEXT i%
RETURN
PROCEDURE verti
  FOR i%=lauf% TO start%+fl%
    n=BYTE{i%}
    IF n=kb
      INC i%
      nn=BYTE{i%}
      FOR i=0 TO nn
        @spalte
        BYTE{adr%}=pb
      NEXT i
    ELSE IF n=sb
      INC i%
      na=BYTE{i%}
      INC i%
      nn=BYTE{i%}
      FOR i=0 TO nn
        @spalte
        BYTE{adr%}=na
      NEXT i
    ELSE
      @spalte
      BYTE{adr%}=n
    ENDIF
  NEXT i%
RETURN
PROCEDURE spalte
  IF zeile%>398
    CLR zeile%
    INC spalte%
  ELSE
    INC zeile%
  ENDIF
  adr%=XBIOS(3)+80*(zeile%-1)+spalte%
RETURN
