' Einstellen der Spurwechselzeit der Diskettenlaufwerke unter GFA-Basic
' ---------------------------------------------------------------------
' Henrik Alt, Kirgelweg 25, 7160 Gaildorf, Tel. 07971/7996     7.4.1988
'
' FÅr Atari ST mit TOS vom 6.2.1986 oder Blitter-TOS vom 22.4.1987
'
' Damit lassen sich z.B. mit einem 5.25-Zoll Zweitlaufwerk
' MS-DOS-Disketten lesen und beschreiben, allerdings nicht formatieren.
'
PROCEDURE set_steprate(drive%,rate%)
  ' drive%: Laufwerksnummer , A = 0 , B = 1
  '  rate%: Spurwechselzeit
  '            0 = 6 ms  5.25-Zoll Disketten unter MS-DOS, 40 Spuren
  '            1 =12 ms  unÅblich
  '            2 = 2 ms  unÅblich
  '            3 = 3 ms  TOS-Standardwert, 80 Spuren
  IF LPEEK(&HFC0018)=&H2061986      ! Abfrage auf Datum 6.2.86
    DPOKE &HA08+4*drive%,rate%
  ENDIF
  IF LPEEK(&HFC0018)=&H4221987      ! Abfrage auf Datum 22.4.87
    DPOKE &HA4E+4*drive%,rate%
  ENDIF
RETURN
