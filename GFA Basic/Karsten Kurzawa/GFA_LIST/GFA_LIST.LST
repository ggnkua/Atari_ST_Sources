' GFA_LIST.GFA
'
' Karsten Kurzawa
'
' I April 1988
' U 31.12.1988
'
'
' Dimensionierung der Variablen
'
'
'
' SUCHE
'
DEFMOUSE 2
rsc_datei$="GFA_LIST.RSC"
DEFFILL 1,2,4
PBOX 0,18,640,400
DEFTEXT 1,0,0,13
TEXT 250,15,"Lade RSC-Datei"
IF NOT EXIST(rsc_datei$)
  rsc_datei$=FN suche_datei$(CHR$(65+GEMDOS(25))+":\","GFA_LIST.RSC")
ELSE
  rsc_datei$=DIR$(0)+"\"+rsc_datei$
ENDIF
IF rsc_datei$<>""
  rsc_pfad$=FN filename_to_path$(rsc_datei$)
  CHDIR rsc_pfad$
  '
  '
  ' RSC-File laden
  '
  ~RSRC_FREE()
  RESERVE FRE(0)-40000  ! Speicherplatz für RSC reservieren
  IF RSRC_LOAD(rsc_datei$)=0  ! Fehler beim RSC-File laden
    '
    ' RSC wurde nicht geladen
    '
    ALERT 1,"Fehler beim laden des RSC",1,"Oje",dummy
    ~RSRC_FREE()
    RESERVE  ! Speicherplatz wieder freigeben
    END
  ELSE
    '
    max_lst_zeilen%=10000      ! Wer schreibt grö×ere Programme ???
    DIM lst_zeilen$(max_lst_zeilen%)
    '
    DIM struktur$(24),vorschub$(24)
    '
    '
    ' Angaben für Pfad-Verwaltung
    '
    @fs.init(3)
    @fs.path_init(1,"","LST","")
    @fs.path_init(2,"","FDD","STANDARD.FDD")
    @fs.path_init(3,"","CFG","PRINTER.CFG")
    '
    ' Hintergrund
    '
    DEFMOUSE 2
    pausenmeldung("Menue wird initialisiert",TRUE,17)
    '
    ' GEM-Menue Initialisieren
    '
    DIM m$(50)
    FOR i%=0 TO 50
      READ m$(i%)
      EXIT IF m$(i%)="***"
    NEXT i%
    m$(i%)=""
    m$(i%+1)=""
    m$(0)=CHR$(14)+CHR$(15)  ! Das ATARI-Zeichen
    MENU m$()
    ON MENU GOSUB hauptschleife
    ON ERROR GOSUB fehlerbehandlung
    '    ON BREAK GOSUB ende
    OPENW 0
    '
    DATA Desk, Über den GFA-Lister,------------------------,1,2,3,4,5,6,
    DATA LST-Datei,  ..laden,  ..drucken,---------------------,  Programm beenden,
    DATA Attribute,  Attribute laden,-------------------------,  Zeilennummer,  Struktur-Tiefe
    DATA   Procedure-Verzeichnis,  Sondervorschub,  Hervorhebungen,  Einrückungs-Faktor
    DATA   Zeilenumbruch,  Seiten-Layout,  Überschrift,-------------------------,  Attribute sichern,
    DATA Drucker,  Schriftarten  ,  Seitensteuerung  ,  CFG-Zeichenumwandlung  ,***
    '
    MENU 12,2  ! Drucken ist nicht wählbar da noch nichts geladen
    '
    ' Wenn vorhanden Standard-Einstellungen laden (Datei: STANDARD.FDD)
    '
    pausenmeldung("",FALSE,17)
    DEFMOUSE 0
    einstellung_datei$="\STANDARD.FDD"
    IF NOT EXIST(einstellung_datei$)
      DEFMOUSE 2
      pausenmeldung("Suche STANDARD.FDD",TRUE,17)
      einstellung_datei$=FN suche_datei$(CHR$(GEMDOS(25)+65)+":\","STANDARD.FDD")
      pausenmeldung("",FALSE,17)
      DEFMOUSE 0
    ENDIF
    IF einstellung_datei$<>""
      DEFMOUSE 2
      pausenmeldung(einstellung_datei$,TRUE,17)
      fdd_laden(einstellung_datei$)
      fdd_pfad$=FN filename_to_path$(einstellung_datei$)
      @fs.path_init(2,fdd_pfad$,"FDD","STANDARD.FDD")
      pausenmeldung("",FALSE,17)
      DEFMOUSE 0
    ELSE
      ALERT 1,"Keine Standard-Einstellung| gefunden",1,"Aha",dummy
      DEFMOUSE 2
      pausenmeldung("Standard-Werte initialisieren",TRUE,17)
      ' Standard-Werte initialisieren
      znr_an$=""
      znr_aus$=""
      stf_an$=""
      stf_aus$=""
      stnd_an$=""
      stnd_aus$=""
      strkt_an$=""
      strkt_aus$=""
      ueb_an$=""
      ueb_aus$=""
      bemrk_an$=""
      bemrk_aus$=""
      seitenvorschub$=CHR$(12)
      seiten_init$=""
      struktur$(1)="PROCEDURE"
      struktur$(2)="RETURN"
      struktur$(3)="FUNCTION"
      struktur$(4)="ENDFUNC"
      struktur$(5)="IF"
      struktur$(6)="ELSE"
      struktur$(7)="ENDIF"
      struktur$(8)="WHILE"
      struktur$(9)="WEND"
      struktur$(10)="REPEAT"
      struktur$(11)="UNTIL"
      struktur$(12)="DO"
      struktur$(13)="LOOP"
      struktur$(14)="SELECT"
      struktur$(15)="CASE"
      struktur$(16)="DEFAULT"
      struktur$(17)="ENDSELECT"
      vorschub$(1)="PROCEDURE"
      vorschub$(2)="FUNCTION"
      zeilennummern!=TRUE
      znr_trenn$=":"
      start%=1
      step%=1
      strkt_tiefe!=FALSE
      tiefe_trenn$=">"
      proc_verz!=TRUE
      verz_zeilen!=TRUE
      verz_seiten!=TRUE
      vorschub!=TRUE
      einr_faktor=2.5
      word_wrap!=TRUE
      word_wrap_zeichen$=" ,+-*/);"
      leer_vorn%=5
      spalten%=80
      zeilen_seite%=72
      leer_oben%=2
      leer_unten%=2
      ueb_definit$=""
      cfg_datei$="PRINTER.CFG"
      pausenmeldung("",FALSE,17)
    ENDIF
    IF NOT EXIST(cfg_datei$)
      DEFMOUSE 2
      pausenmeldung("Suche CFG-Datei",TRUE,17)
      cfg_datei$=FN suche_datei$(CHR$(GEMDOS(25)+65)+":\","PRINTER.CFG")
      pausenmeldung("",FALSE,17)
      DEFMOUSE 0
    ENDIF
    IF cfg_datei$<>""
      DEFMOUSE 2
      cfg_pfad$=FN filename_to_path$(cfg_datei$)
      pausenmeldung(cfg_datei$,TRUE,17)
      pt.cfg_load(cfg_datei$)
      datei$=RIGHT$(cfg_datei$,LEN(cfg_datei$)-RINSTR(cfg_datei$,"\"))
      fs.path_init(3,cfg_pfad$,"CFG",datei$)
      pausenmeldung("",FALSE,17)
    ELSE
      ALERT 1,"PRINTER.CFG nicht gefunden",1,"OK",dummy
    ENDIF
    '
    ' Anleitung initialisieren
    '
    hilfe_datei$="\GFA_LIST.TXT"
    IF NOT EXIST(hilfe_datei$)
      DEFMOUSE 2
      pausenmeldung("Suche Hilfstext",TRUE,17)
      hilfe_datei$=FN suche_datei$(CHR$(GEMDOS(25)+65)+":\","GFA_LIST.TXT")
      pausenmeldung("",FALSE,17)
      DEFMOUSE 0
    ENDIF
    IF hilfe_datei$<>""
      DEFMOUSE 2
      pausenmeldung(hilfe_datei$,TRUE,17)
      hilfe_pfad$=FN filename_to_path$(hilfe_datei$)
      CHDIR hilfe_pfad$
      hilfe_datei$=LEFT$(hilfe_datei$,LEN(hilfe_datei$)-4)
      help.init(hilfe_datei$,20)
      pausenmeldung("",FALSE,17)
      DEFMOUSE 0
    ELSE
      ALERT 1,"Hilfstextdatei nicht gefunden",1,"OK",dummy
    ENDIF
    DEFMOUSE 0
    '
    GOSUB prg_info
    GOSUB lst_laden
    '
    ' Hauptprogrammschleife
    '
    DO
      ON MENU
    LOOP
  ENDIF
ELSE
  ALERT 1,"Kein RSC-File gefunden",1,"Oje",dummy
ENDIF
END
> PROCEDURE ersatz_hauptprogramm
  ' Wird benötigt wenn Abbruch beim Druck
  DO
    ON MENU
  LOOP
RETURN
> PROCEDURE hauptschleife
  IF MENU(4)=3 THEN
    prg_info
  ELSE
    IF MENU(4)=4
      ON MENU(0)-10 GOSUB lst_laden,form_druck,dummy,ende
    ELSE
      IF MENU(4)=5 THEN
        ON MENU(0)-16 GOSUB laden,dummy,zeilennummern,strukturtiefe,procverzeichnis,vorschub,hervorhebung,einr_faktor,wordwrap,layout,ueberschrift_defenieren,dummy,sichern
      ELSE
        ON MENU(0)-31 GOSUB schriftart,druckersteuerung,cfg_zeichenwandlung
      ENDIF
    ENDIF
  ENDIF
  MENU OFF
RETURN
'
' --------------- Drucker-Unterroutinen ----------------------------------
'
> PROCEDURE pt.cfg_clear
  IF DIM?(pt.a$())<>0
    ERASE pt.a$(),pt.s$(),pt.t$()
  ENDIF
RETURN
> PROCEDURE pt.cfg_load(cfgname$)
  LOCAL i%,a$,code%
  DIM pt.a$(256)
  DIM pt.s$(52)
  DIM pt.t$(7)
  FOR i%=1 TO 52
    pt.s$(i%)=CHR$(i%)
  NEXT i%
  FOR i%=1 TO 256
    pt.a$(i%)=CHR$(i%-1)
  NEXT i%
  IF EXIST(cfgname$) THEN
    OPEN "I",#80,cfgname$
    CLR i%,a$
    WHILE (NOT EOF(#80)) AND i%<8
      INC i%
      code%=INP(#80)
      a$=a$+CHR$(code%)
    WEND
    IF a$="GFA-CFG:" OR a$="GST-CFG:" THEN
      CLR pt.druckername$
      DO
        code%=INP(#80)
        EXIT IF code%=0
        pt.druckername$=pt.druckername$+CHR$(code%)
      LOOP
      FOR i%=1 TO 6
        pt.t$(i%)=CHR$(INP(#80))
      NEXT i%
      DO
        index%=INP(#80)
        EXIT IF index%=0
        sym%=INP(#80)
        pt.s$(sym%)=""
        i%=2
        WHILE i%<index%
          pt.s$(sym%)=pt.s$(sym%)+CHR$(INP(#80))
          INC i%
        WEND
      LOOP
      DO
        index%=INP(#80)
        EXIT IF index%=0
        sym%=INP(#80)
        pt.a$(sym%+1)=""
        i%=2
        WHILE i%<index%
          pt.a$(sym%+1)=pt.a$(sym%+1)+CHR$(INP(#80))
          INC i%
        WEND
      LOOP
      CLOSE #80
      '
      pt.cfg_load!=TRUE
    ELSE
      ALERT 3,"Dies ist keine CFG-Datei !",1," Hoppla ",dummy%
      pt.cfg_load!=FALSE
    ENDIF
  ELSE
    ALERT 2,"Keine "+cfgname$,1," Wieso ",dummy%
    pt.cfg_load!=FALSE
  ENDIF
RETURN
> PROCEDURE pt.setze_schrift(nr|)
  IF pt.cfg_load!=TRUE
    IF nr|>0 AND nr|<52
      pt.lprint(pt.s$(nr|),FALSE)
    ENDIF
  ENDIF
RETURN
> PROCEDURE pt.lprint(p$,return!)
  LOCAL i%
  ' Normaler LPRINT nur das der Ausgabestatus des Druckers geprüft wird
  IF GEMDOS(17)=FALSE
    ' Manchmal ist der Drucker noch beschäftigt darum einen Moment warten
    i%=1
    DO
      EXIT IF GEMDOS(17)=TRUE
      INC i%
      EXIT IF i%=10000 ! Das mü×te reichen
    LOOP
  ENDIF
  IF GEMDOS(17)=TRUE
    IF return!=TRUE
      LPRINT p$
    ELSE
      LPRINT p$;
    ENDIF
  ELSE
    ERROR 94  ! eigener Fehler (! Drucker nicht bereit !)
    pt.lprint(p$,return!)
  ENDIF
RETURN
> PROCEDURE pt.print(p$,return!)
  LOCAL i%,d$
  IF pt.cfg_load!=TRUE
    d$=""
    FOR i%=1 TO LEN(p$)
      d$=d$+pt.a$(ASC(MID$(p$,i%,1))+1)
    NEXT i%
    IF return!=TRUE  ! Mit Zeilenvorschub
      pt.lprint(d$,TRUE)
    ELSE
      pt.lprint(d$,FALSE)
    ENDIF
  ELSE
    IF return!=TRUE  ! Mit Zeilenvorschub
      pt.lprint(p$,TRUE)
    ELSE
      pt.lprint(p$,FALSE)
    ENDIF
  ENDIF
RETURN
> PROCEDURE pt.leerzeilen(anzahl%)
  LOCAL i%
  FOR i%=1 TO anzahl%
    pt.print("",TRUE)
  NEXT i%
RETURN
'
' --------------- div. Dateiroutinen -------------------------------------
FUNCTION filename_to_path$(filename$)
  IF RINSTR(filename$,"\")=0
    RETURN "\"
  ELSE
    RETURN LEFT$(filename$,RINSTR(filename$,"\"))
  ENDIF
ENDFUNC
FUNCTION suche_datei$(path$,file$)
  ' path$ = Pfad ab dem gesucht wird
  ' file$ = zu suchende Datei
  LOCAL oldpath$,olddrv%
  oldpath$=DIR$(0)
  olddrv%=GEMDOS(25)+1
  IF INSTR(path$,":")
    CHDRIVE ASC(path$)-64
    path$=MID$(path$,INSTR(path$,":")+1)
  ENDIF
  CHDIR path$
  ~FSETDTA(BASEPAGE+128)
  file$=file$+CHR$(0)
  star$="*.*"+CHR$(0)
  drv$=CHR$(GEMDOS(25)+65)+":"
  gefunden$=""
  suche1(file$,gefunden$)
  CHDIR "\"+olddir$
  CHDRIVE olddrv%
  RETURN gefunden$
ENDFUNC
> PROCEDURE suche1(such$,VAR gefunden$)
  ' Prozedur zur Function suche_datei$
  LOCAL w%,x$,t%,e%
  e%=FSFIRST(file$,&H27)
  @getnam(e%,x$,t%)
  WHILE e%=0
    gefunden$=drv$+DIR$(0)+"\"+x$
    EXIT IF gefunden$<>""
    e%=FSNEXT()
    @getnam(e%,x$,t%)
  WEND
  IF gefunden$=""
    e%=FSFIRST(star$,16)
    @getnam(e%,x$,t%)
    q%=0
    WHILE e%=0
      IF t% AND 16
        IF x$<>"." AND x$<>".."
          w%=q%
          CHDIR x$
          suche1(such$,gefunden$)
          CHDIR ".."
          e%=FSFIRST(star$,16)
          @getnam(e%,x$,t%)
          q%=0
          WHILE w%<>q%
            VOID GEMDOS(79)
            INC q%
          WEND
        ENDIF
      ENDIF
      e%=FSNEXT()
      @getnam(e%,x$,t%)
      INC q%
    WEND
  ENDIF
RETURN
> PROCEDURE getnam(rueck%,VAR name$,attribute%)
  ' Prozedur zur Prozedure suche1
  IF rueck%
    LET name$=""
    attribute%=0
  ELSE
    LET name$=CHAR{BASEPAGE+158}
    attribute%=PEEK(BASEPAGE+149)                 !dta+21 Attribute
  ENDIF
RETURN
'
' ---------------------- Standard-Hilfe-Dialoge ---------------------------
'
> PROCEDURE help.init(datei$,kanal%)
  LOCAL i%
  IF EXIST(datei$+".TXT")
    IF EXIST(datei$+".HIF")
      DIM hp.hilf$(29)
      OPEN "I",#kanal%,datei$+".HIF"
      RECALL #kanal%,hp.hilf$(),-1,hp.anz_ueb%
      CLOSE #kanal%
      FOR i%=0 TO 29
        IF LEN(hp.hilf$(i%))<30
          hp.hilf$(i%)=hp.hilf$(i%)+SPACE$(30-LEN(hp.hilf$(i%)))
        ENDIF
      NEXT i%
    ELSE
      ALERT 1,"Hilfs-Informationsdatei|"+datei$+".HIP|nicht gefunden",1,"SCHADE",dummy
    ENDIF
  ELSE
    ALERT 1,"Hilfebeschreibung|"+datei$+".TXT|nicht gefunden",1,"SCHADE",dummy
  ENDIF
RETURN
> PROCEDURE help.exec(datei$,kanal%,rsc_baum&)
  CLOSEW #1
  CLIP OFF
  LOCAL suchwort$,help$,i%,verzeichbaum%,screenbaum%,z%,s%
  LOCAL seite%,anz_seiten%,r%,suchseiten%,beginnseite%,suchseite%
  LOCAL suchbaum%,beginnscreen%,suchscreen%,gefunden%
  LOCAL gefunden!,anfang!,objekt&,gx&,gy&,gw&,gh&,button_exit&,helpscreen&
  LOCAL screen_button&,seitennr&,seitenredraw&,such_button&,suchmodus|,antwort|
  suchwort$=""
  suchmodus|=1
  OPEN "I",#kanal%,datei$+".TXT"
  ~RSRC_GADDR(0,rsc_baum&,verzeichbaum%)
  ~RSRC_GADDR(0,rsc_baum&+1,screenbaum%)
  ~RSRC_GADDR(0,rsc_baum&+2,suchbaum%)
  FOR objekt&=13 TO 22
    CHAR{OB_SPEC(verzeichbaum%,objekt&)}=MID$(hp.hilf$(objekt&-13),11,20)
  NEXT objekt&
  FOR objekt&=34 TO 43
    CHAR{OB_SPEC(verzeichbaum%,objekt&)}=MID$(hp.hilf$(objekt&-34+10),11,20)
  NEXT objekt&
  FOR objekt&=55 TO 64
    CHAR{OB_SPEC(verzeichbaum%,objekt&)}=MID$(hp.hilf$(objekt&-55+20),11,20)
  NEXT objekt&
  ~FORM_CENTER(verzeichbaum%,gx&,gy&,gw&,gh&)
  ~GRAF_GROWBOX(WORK_OUT(0)/2,WORK_OUT(1)/2,0,0,gx&,gy&,gw&,gh&)
  REPEAT
    ~OBJC_DRAW(verzeichbaum%,0,8,0,0,640,400)
    button_exit&=FORM_DO(verzeichbaum%,0)
    ~OBJC_CHANGE(verzeichbaum%,button_exit&,0,0,0,640,400,0,1)
    helpscreen&=-1
    IF button_exit&>=3 AND button_exit&<=12
      helpscreen&=button_exit&-3
    ELSE IF button_exit&>=24 AND button_exit&<=33
      helpscreen&=button_exit&-24+10
    ELSE IF button_exit&>=45 AND button_exit&<=54
      helpscreen&=button_exit&-45+20
    ENDIF
    IF helpscreen&<hp.anz_ueb% AND helpscreen&>=0
      '
      LET seitennr&=11
      LET seitenredraw&=10
      CHAR{OB_SPEC(screenbaum%,1)}=" HILFSTEXT für: "+MID$(hp.hilf$(helpscreen&),11)
      ~FORM_CENTER(screenbaum%,gx&,gy&,gw&,gh&)
      ~OBJC_DRAW(screenbaum%,0,8,0,0,640,400)
      SEEK #kanal%,VAL(LEFT$(hp.hilf$(helpscreen&),5))
      help$=INPUT$(VAL(MID$(hp.hilf$(helpscreen&),6,5)),#kanal%)
      z%=0
      s%=1
      REPEAT
        s%=INSTR(help$,CHR$(13),s%)+1
        INC z%
      UNTIL s%=1
      DEC z%
      seite%=1
      anz_seiten%=(z%-1)/15
      IF (z%-1) MOD 15<>0
        INC anz_seiten%
      ENDIF
      s%=0
      REPEAT
        ~OBJC_DRAW(screenbaum%,8,1,0,0,640,400)
        CHAR{OB_SPEC(screenbaum%,11)}=STR$(seite%,2)
        ~OBJC_DRAW(screenbaum%,10,4,0,0,640,400)
        s%=1
        anfang!=FALSE
        FOR suchseiten%=1 TO seite%
          FOR i%=1 TO 15
            r%=s%
            s%=INSTR(help$,CHR$(13),s%)
            IF s%<>0
              IF MID$(help$,r%,2)<>"~~"
                IF suchseiten%=seite%
                  PRINT AT(2,3+i%);MID$(help$,r%+1,s%-r%+1)
                ENDIF
              ELSE
                DEC i%
              ENDIF
            ELSE
              i%=17
            ENDIF
            INC s%
          NEXT i%
        NEXT suchseiten%
        screen_button&=FORM_DO(screenbaum%,0)
        ~OBJC_CHANGE(screenbaum%,screen_button&,0,0,0,640,400,0,1)
        IF screen_button&=6  ! hfup
          IF seite%>1
            DEC seite%
          ENDIF
        ELSE IF screen_button&=7  ! hfdown
          IF seite%<anz_seiten%
            INC seite%
          ENDIF
        ELSE IF screen_button&=4  ! drucken
          DO
            IF GEMDOS(17)=FALSE
              ALERT 1,"Der Drucker ist nicht bereit",1,"WEITER|ABBRUCH",antwort|
            ELSE
              antwort|=1
            ENDIF
            EXIT IF (antwort|=1 AND GEMDOS(17)=TRUE) OR antwort|=2
          LOOP
          IF antwort|=1
            pt.print("",TRUE)
            pt.print("",TRUE)
            pt.print("     Hilfstext : "+MID$(hp.hilf$(i%),11),TRUE)
            pt.print("",TRUE)
            z%=5
            s%=1
            REPEAT
              r%=s%
              s%=INSTR(help$,CHR$(13),s%)
              IF s%<>0
                IF MID$(help$,r%,2)<>"~~"
                  INC z%
                  pt.print(SPACE$(5)+MID$(help$,r%+1,s%-r%),TRUE)
                  IF z%=60
                    ' Seitenvorschub
                    pt.lprint(CHR$(12),TRUE)
                    z%=0
                  ENDIF
                ENDIF
              ENDIF
              INC s%
            UNTIL s%=1
          ENDIF
        ELSE IF screen_button&=5  ! suchen
          CHAR{{OB_SPEC(suchbaum%,1)}}=suchwort$
          IF suchmodus|=1
            ~OBJC_CHANGE(suchbaum%,4,0,0,0,640,400,1,0)
            ~OBJC_CHANGE(suchbaum%,5,0,0,0,640,400,0,0)
          ELSE
            ~OBJC_CHANGE(suchbaum%,4,0,0,0,640,400,0,0)
            ~OBJC_CHANGE(suchbaum%,5,0,0,0,640,400,1,0)
          ENDIF
          ~FORM_CENTER(suchbaum%,gx&,gy&,gw&,gh&)
          ~OBJC_DRAW(suchbaum%,0,8,0,0,640,400)
          such_button&=FORM_DO(suchbaum%,0)
          IF such_button&=6
            DEFMOUSE 2
            suchwort$=UPPER$(CHAR{{OB_SPEC(suchbaum%,1)}})
            IF OB_STATE(suchbaum%,4)=1  ! von Anfang suchen
              beginnscreen%=0
              beginnseite%=1
              suchmodus|=1
            ELSE
              beginnscreen%=helpscreen&
              beginnseite%=seite%+1
              suchmodus|=2
            ENDIF
            FOR suchscreen%=beginnscreen% TO hp.anz_ueb%
              SEEK #kanal%,VAL(LEFT$(hp.hilf$(suchscreen%),5))
              help$=INPUT$(VAL(MID$(hp.hilf$(suchscreen%),6,5)),#kanal%)
              ' Seiten-Nummer ermitteln
              gefunden%=0
              z%=0
              s%=1
              suchseite%=0
              REPEAT
                r%=s%
                s%=INSTR(help$,CHR$(13),s%)
                IF s%<>0
                  IF MID$(help$,r%,2)<>"~~"
                    INC z%
                    IF z% MOD 15<>0
                      suchseite%=(z%/15)+1
                    ELSE
                      suchseite%=z%/15
                    ENDIF
                    IF suchseite%>=beginnseite%
                      IF INSTR(UPPER$(MID$(help$,r%,s%-r%+1)),suchwort$)<>0
                        gefunden%=suchseite%
                      ENDIF
                    ENDIF
                  ENDIF
                ELSE
                  gefunden%=-1
                ENDIF
                INC s%
              UNTIL gefunden%<>0
              EXIT IF gefunden%<>-1
              beginnseite%=1
            NEXT suchscreen%
            IF gefunden%=-1
              ALERT 1,"Suchbegriff nicht gefunden",1,"SCHADE",dummy
              SEEK #kanal%,VAL(LEFT$(hp.hilf$(helpscreen&),5))
              help$=INPUT$(VAL(MID$(hp.hilf$(helpscreen&),6,5)),#kanal%)
            ELSE
              seite%=gefunden%
              helpscreen&=suchscreen%
              CHAR{OB_SPEC(screenbaum%,1)}=" HILFSTEXT für: "+MID$(hp.hilf$(suchscreen%),11)
              ~OBJC_DRAW(screenbaum%,0,8,0,0,640,400)
            ENDIF
            DEFMOUSE 0
          ENDIF
          ~OBJC_CHANGE(suchbaum%,such_button&,0,0,0,640,400,0,0)
        ENDIF
      UNTIL screen_button&=3
      '
    ELSE IF button_exit&=66
      '
      ALERT 2,"Wirklich alle Hilfstexte|    ausdrucken",1,"JA|NEIN",antwort|
      IF antwort|=1
        DO
          IF GEMDOS(17)=FALSE
            ALERT 1,"Der Drucker ist nicht bereit",1,"WEITER|ABBRUCH",antwort|
          ELSE
            antwort|=1
          ENDIF
          EXIT IF (antwort|=1 AND GEMDOS(17)=TRUE) OR antwort|=2
        LOOP
        IF antwort|=1
          z%=0
          FOR i%=0 TO hp.anz_ueb%-1
            IF z%+5>60
              ' Seitenvorschub
              pt.lprint(CHR$(12),TRUE)
              z%=0
            ENDIF
            pt.print("",TRUE)
            pt.print("",TRUE)
            pt.print("     Hilfstext : "+MID$(hp.hilf$(i%),11),TRUE)
            pt.print("",TRUE)
            ADD z%,5
            SEEK #kanal%,VAL(LEFT$(hp.hilf$(i%),5))
            help$=INPUT$(VAL(MID$(hp.hilf$(i%),6,5)),#kanal%)
            s%=1
            REPEAT
              r%=s%
              s%=INSTR(help$,CHR$(13),s%)
              IF s%<>0
                IF MID$(help$,r%,2)<>"~~"
                  INC z%
                  pt.print(SPACE$(5)+MID$(help$,r%+1,s%-r%),TRUE)
                  IF z%=60
                    ' Seitenvorschub
                    pt.lprint(CHR$(12),FALSE)
                    z%=0
                  ENDIF
                ENDIF
              ENDIF
              INC s%
            UNTIL s%=1
          NEXT i%
        ENDIF
      ELSE
        ALERT 0,"Zum Ausdruck einzelner Hilfstexte|Verzeichnispunkt anwählen und|im Hilfsscreen Druck-Button anklicken",1,"AHA",dummy
      ENDIF
      '
    ELSE IF button_exit&<>65
      ALERT 1,"Nicht defeniert",1,"OHO",dummy
    ENDIF
  UNTIL button_exit&=65
  CLOSE #kanal%
  ~GRAF_SHRINKBOX(WORK_OUT(0)/2,WORK_OUT(1)/2,0,0,gx&,gy&,gw&,gh&)
  IF lst_name$<>""
    OPENW #1,0,39,639,350,&X100010001
    FULLW #1
    TITLEW #1," "+lst_name$+" "
    INFOW #1,"     Gesamt = "+STR$(lst_zeilen%)+" Zeilen"
    redraw_lst_fenster
  ELSE
    DEFFILL 1,2,4
    PBOX 0,0,640,400
  ENDIF
RETURN
'
' --------------------- Fileselect-Routinen --------------------------------
'
> PROCEDURE fs.init(anzahl%)
  DIM fs.pathname$(anzahl%),fs.filename$(anzahl%),fs.f_name$(anzahl%),fs.ext$(anzahl%)
  fs.max%=anzahl%
RETURN
> PROCEDURE fs.path_init(nr%,path$,ext$,file$)
  IF nr%>0 AND nr%<=fs.max%
    fs.pathname$(nr%)=path$
    fs.ext$(nr%)=ext$
    fs.filename$(nr%)=file$
  ELSE
    ALERT 1,"Dieser Pfad wird nicht|verwaltet.",1,"OKAY",dummy
  ENDIF
RETURN
FUNCTION fs.select$(no%,ueb$)
  LOCAL extension$,choice$,index%,length%
  IF fs.pathname$(no%)=""
    fs.pathname$(no%)=CHR$(65+GEMDOS(&H19))+":"+DIR$(0)+"\"
  ENDIF
  IF fs.ext$(no%)=""
    extension$="*"
  ELSE
    extension$=fs.ext$(no%)
  ENDIF
  @fileselect_ueberschrift(ueb$)
  FILESELECT #ueb$,fs.pathname$(no%)+"*."+extension$,fs.filename$(no%),choice$
  IF choice$<>""
    index%=LEN(choice$)
    WHILE MID$(choice$,index%,1)<>"\" AND index%<>0
      DEC index%
    WEND
    fs.pathname$(no%)=LEFT$(choice$,index%)
    fs.filename$(no%)=RIGHT$(choice$,LEN(choice$)-index%)
    IF fs.filename$(no%)<>""
      length%=LEN(fs.filename$(no%))
      index%=INSTR(fs.filename$(no%),".")
      IF index%<>0
        fs.ext$(no%)=RIGHT$(fs.filename$(no%),length%-index%)
        fs.f_name$(no%)=LEFT$(fs.filename$(no%),index%-1)
      ELSE
        fs.f_name$(no%)=fs.filename$(no%)
        IF fs.ext$(no%)<>""
          fs.filename$(no%)=fs.filename$(no%)+"."+fs.ext$(no%)
        ENDIF
      ENDIF
    ELSE
      RETURN ""
    ENDIF
    RETURN fs.pathname$(no%)+fs.filename$(no%)
  ELSE
    RETURN ""
  ENDIF
ENDFUNC
> PROCEDURE fileselect_ueberschrift(text$)
  CLOSEW 0
  DEFFILL 1,0,0
  PBOX 157,19,474,19+21
  BOX 159,19+2,472,19+19
  DEFTEXT 1,0,0,13
  TEXT 190,19+16,text$
  OPENW 0
RETURN
'
' ---------------- aus dem Pull-Down-Menue aufzurufende Routinen -------------
'
> PROCEDURE prg_info
  SGET puffer$
  i.nformat%=10!/* Formula/Dialog */
  w.eiter%=7!/* BUTTON in Baum INFORMAT */
  a.nl%=8!/* BUTTON in Baum INFORMAT */
  ~RSRC_GADDR(0,i.nformat%,i.nformatbaum%)
  ~FORM_CENTER(i.nformatbaum%,fx%,fy%,fw%,fh%)
  ~GRAF_GROWBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  ~OBJC_DRAW(i.nformatbaum%,0,8,0,0,640,400)
  button_exit%=FORM_DO(i.nformatbaum%,0)
  ~OBJC_CHANGE(i.nformatbaum%,button_exit%,0,0,0,640,400,0,1)
  IF button_exit%=a.nl%
    help.exec("GFA_LIST",20,14)  ! Anleitung aufrufen
  ENDIF
  SPUT puffer$
RETURN
'
> PROCEDURE lst_laden
  LOCAL i%
  CLOSEW #1
  REPEAT
    lst_name$=FN fs.select$(1,"Auszudruckende GFA-LST-Datei")
    IF lst_name$<>""
      IF NOT EXIST(lst_name$)
        ALERT 1," Diese LST-Datei | existiert nicht",1,"Oje",dummy
      ELSE
        DEFFILL 1,2,4
        PBOX 0,0,640,400
        pausenmeldung("LST-Datei wird eingelesen",TRUE,17)
        i%=1
        DO
          EXIT IF lst_zeilen$(i%)="" OR i%=max_lst_zeilen%
          lst_zeilen$(i%)=""
          INC i%
        LOOP
        DEFMOUSE 2
        lst_zeilen%=0
        OPEN "I",#1,lst_name$
        REPEAT
          INC lst_zeilen%
          IF lst_zeilen%>max_lst_zeilen%
            ALERT 1,"Die LST-Datei hat mehr als|"+STR$(max_lst_zeilen%)+" Zeilen|und wird auf diese Anzahl|gekürzt",1,"Blöd",dummy
          ENDIF
          EXIT IF lst_zeilen%>max_lst_zeilen%
          LINE INPUT #1,lst_zeilen$(lst_zeilen%)
        UNTIL EOF(#1)
        CLOSE #1
        pausenmeldung("",FALSE,17)
        DEFMOUSE 0
        INFOW #1,"   "
        OPENW #1,0,39,639,350,&X100010001
        FULLW #1
        TITLEW #1," "+lst_name$+" "
        INFOW #1,"     Gesamt = "+STR$(lst_zeilen%)+" Zeilen"
        redraw_lst_fenster
        ~WIND_SET(W_HAND(#1),16,-1,0,0,0)
        ' Folgende Menuetitel sind jetz anwählbar
        MENU 12,3  ! Alles drucken
      ENDIF
    ELSE
      IF lst_name$<>""
        OPENW #1,0,39,639,350,&X100010001
        TITLEW #1," "+lst_name$+" "
        INFOW #1,"     Gesamt = "+STR$(lst_zeilen%)+" Zeilen"
        FULLW #1
        redraw_lst_fenster
      ELSE
        DEFFILL 1,2,4
        PBOX 0,0,640,400
      ENDIF
    ENDIF
  UNTIL lst_name$="" OR EXIST(lst_name$)
RETURN
> PROCEDURE form_druck
  '
  ' Datei drucken
  '
  LOCAL procedure!
  IF ueb_definit$<>""
    anzahl_ueb%=2
  ELSE
    anzahl_ueb%=0
  ENDIF
  '
  ' Anfangsparameter ermitteln
  gedruckt%=0
  IF seiten_init$<>""
    pt.lprint(seiten_init$+CHR$(zeilen_seite%),FALSE)
  ENDIF
  aktuell%=zeilen_seite%+1
  seite%=0
  ueberschrift
  druckpos%=0
  IF zeilennummern!=TRUE
    znr_vorn%=4
    znr%=start%
  ELSE
    znr_vorn%=0
  ENDIF
  IF strkt_tiefe!=TRUE
    ADD znr_vorn%,2
  ENDIF
  verz_proc_name$=""
  verz_von_zeile$=""
  verz_bis_zeile$=""
  verz_von_seite$=""
  verz_bis_seite$=""
  abbruch!=FALSE
  i%=1
  CLS
  DEFMOUSE 2
  FOR zeilen%=1 TO lst_zeilen%
    z$=lst_zeilen$(zeilen%)
    PRINT z$
    INFOW #1,"     Gedruckt = "+STR$(zeilen%)+" von "+STR$(lst_zeilen%)+" Zeilen    (ESC = Abbruch)"
    KEYTEST taste|
    IF taste|=27
      ALERT 2,"Druck abbrechen",1,"JA|NEIN",antwort%
      IF antwort%=1
        abbruch!=TRUE
      ENDIF
    ENDIF
    '
    EXIT IF abbruch!=TRUE
    '
    ' Anteilbalken darstellen
    anteil%=INT((zeilen%/(lst_zeilen%/100)))*10
    ~WIND_SET(W_HAND(#1),16,anteil%,0,0,0)
    '    DEFFILL 1,2,4
    '    PBOX 20,280,20+(anteil%*6),300
    '
    gefunden%=0
    anz_leer%=0
    '
    ' Führende Leerzeichen in der Basic-Zeile ermitteln (Beginn des Befehles)
    WHILE MID$(z$,anz_leer%+1,1)=" "
      ADD anz_leer%,1
    WEND
    '
    ' auf Sondervorschub testen
    IF vorschub!=TRUE
      FOR i%=1 TO 24
        IF MID$(z$,anz_leer%+1,LEN(vorschub$(i%)))=vorschub$(i%)
          ALERT 1,"Vorschub-Befehl|"+vorschub$(i%),1,"OK",dummy
          aktuell%=zeilen_seite%
          ueberschrift
          i%=24
        ENDIF
      NEXT i%
    ENDIF
    '
    ' Eventuellen Procedure oder Function-Namen in Tabelle übernehmen
    IF proc_verz!=TRUE
      IF MID$(z$,anz_leer%+1,9)="PROCEDURE" OR MID$(z$,anz_leer%+1,8)="FUNCTION"
        IF INSTR(z$,"(")=0 THEN
          l%=LEN(z$)-anz_leer%-10
        ELSE
          l%=INSTR(z$,"(")-anz_leer%-11
        ENDIF
        IF MID$(z$,anz_leer%+1,9)="PROCEDURE"
          verz_proc_name$=verz_proc_name$+MID$(z$,anz_leer%+11,l%)+"|"
          LET procedure!=TRUE  ! Wichtig damit RETURN's aus Funktionen
          '                      nicht als Ende einer nicht angefangen
          '                      Procedure erkannt werden
        ELSE
          verz_proc_name$=verz_proc_name$+"FN "+MID$(z$,anz_leer%+10,l%+1)+"|"
          LET procedure!=FALSE
        ENDIF
        verz_von_zeile$=verz_von_zeile$+STR$(znr%)+"|"
        verz_von_seite$=verz_von_seite$+STR$(seite%)+"|"
      ELSE
        IF MID$(z$,anz_leer%+1,6)="RETURN" AND procedure!=TRUE
          verz_bis_zeile$=verz_bis_zeile$+STR$(znr%)+"|"
          verz_bis_seite$=verz_bis_seite$+STR$(seite%)+"|"
          procedure!=FALSE
        ELSE IF MID$(z$,anz_leer%+1,7)="ENDFUNC" AND procedure!=FALSE
          verz_bis_zeile$=verz_bis_zeile$+STR$(znr%)+"|"
          verz_bis_seite$=verz_bis_seite$+STR$(seite%)+"|"
        ENDIF
      ENDIF
    ENDIF
    '
    ' auf Hervorhebung testen
    FOR i%=1 TO 24
      IF struktur$(i%)=MID$(z$,anz_leer%+1,LEN(struktur$(i%)))
        gefunden%=i%
        i%=24
      ENDIF
    NEXT i%
    '
    ' linker Rand
    IF leer_vorn%>0 THEN
      pt.lprint(stnd_an$,FALSE)
      pt.lprint(SPACE$(leer_vorn%),FALSE)
      pt.lprint(stnd_aus$,FALSE)
    ENDIF
    '
    ' Zeilennummern
    pt.lprint(znr_an$,FALSE)
    IF zeilennummern!=TRUE
      pt.print(STR$(znr%,4),FALSE)
      pt.lprint(znr_trenn$,FALSE)
    ENDIF
    ADD znr%,step%
    '
    ' Strukturtiefe (gleich Schriftart wie Zeilennummern!)
    IF strkt_tiefe!=TRUE
      pt.print(STR$(anz_leer% DIV 2,2),FALSE)
      pt.lprint(tiefe_trenn$,FALSE)
    ENDIF
    pt.lprint(znr_aus$,FALSE)
    '
    ' Führende Leerzeichen der Basic-Zeile mit Einrückungs-Faktor
    ' multiplizieren und ausgeben
    IF anz_leer%>0 THEN
      pt.lprint(stnd_an$,FALSE)
      pt.lprint(SPACE$(INT(anz_leer%*einr_faktor)),FALSE)
      pt.lprint(stnd_aus$,FALSE)
    ENDIF
    stelle%=anz_leer%+1
    IF gefunden%<>0 THEN  ! hervorzuhebender Befehl gefunden
      IF struktur$(gefunden%)=MID$(z$,stelle%,LEN(struktur$(gefunden%)))
        ' Hervorzuhebender Befehl steht am Anfang
        pt.lprint(strkt_an$,FALSE)
        pt.print(struktur$(gefunden%),FALSE)
        pt.lprint(strkt_aus$,FALSE)
        komm%=FN finde_kommentar(MID$(z$,stelle%))
        IF komm%=0  ! Kein Kommentar gefunden
          pt.lprint(stnd_an$,FALSE)
          standard_ausgabe(MID$(z$,stelle%+LEN(struktur$(gefunden%))),LEN(struktur$(gefunden%)),stnd_an$,stnd_aus$)
          pt.lprint(stnd_aus$,TRUE)
          druckpos%=0
        ELSE        ! Kommentar gefunden (! Kommentar)
          pt.lprint(stnd_an$,FALSE)
          '
          ' Basic-Befehle ausgeben
          standard_ausgabe(MID$(z$,stelle%+LEN(struktur$(gefunden%)),komm%-LEN(struktur$(gefunden%))),LEN(struktur$(gefunden%)),stnd_an$,stnd_aus$)
          pt.lprint(stnd_aus$,FALSE)
          pt.lprint(bemrk_an$,FALSE)
          '
          ' Kommentar ausgeben
          standard_ausgabe(MID$(z$,stelle%+komm%),druckpos%,bemrk_an$,bemrk_aus$)
          pt.lprint(bemrk_aus$,TRUE)
          druckpos%=0
        ENDIF
      ELSE  ! Hervorzuhebender Befehle steht nicht am Anfang
        '     Nur am Anfang stehende Befehle werden hervorgehoben !!!!
        pt.lprint(stnd_an$,FALSE)
        GOSUB standard_ausgabe(MID$(z$,stelle%),0,stnd_an$,stnd_aus$)
        pt.lprint(stnd_aus$,TRUE)
        druckpos%=0
      ENDIF
    ELSE  ! keinen hervorzuhebenden Befehl gefunden
      IF MID$(z$,stelle%,1)="'" OR MID$(z$,stelle%,3)="REM" OR MID$(z$,stelle%,3)="Rem" THEN
        '
        ' Reine Bemerkungszeile gefunden
        pt.lprint(bemrk_an$,FALSE)
        GOSUB standard_ausgabe(MID$(z$,stelle%),0,bemrk_an$,bemrk_aus$)
        pt.lprint(bemrk_aus$,TRUE)
        druckpos%=0
      ELSE  ! Keine Bemerkungszeile
        komm%=FN finde_kommentar(MID$(z$,stelle%))
        IF komm%=0  ! Kein Kommentar gefunden
          '
          ' Basic-Zeile ausgeben
          pt.lprint(stnd_an$,FALSE)
          GOSUB standard_ausgabe(MID$(z$,stelle%),0,stnd_an$,stnd_aus$)
          pt.lprint(stnd_aus$,TRUE)
          druckpos%=0
        ELSE  ! Kommentar gefunden
          '
          ' Basic-Zeile bis Bemerkung ausgeben
          pt.lprint(stnd_an$,FALSE)
          GOSUB standard_ausgabe(MID$(z$,stelle%,komm%-1),0,stnd_an$,stnd_aus$)
          pt.lprint(stnd_aus$,TRUE)
          '
          ' Bemerkung ausgeben
          pt.lprint(bemrk_an$,FALSE)
          GOSUB standard_ausgabe(MID$(z$,stelle%+komm%),druckpos%,bemrk_an$,bemrk_aus$)
          pt.lprint(bemrk_aus$,TRUE)
          druckpos%=0
        ENDIF
      ENDIF
    ENDIF
  NEXT zeilen%
  IF abbruch!=FALSE  ! Kein Abbruch durch den Benutzer
    pt.lprint(seitenvorschub$,FALSE)
  ENDIF
  ADD seite%,1
  IF proc_verz!=TRUE AND abbruch!=FALSE
    '
    ' Procedore-Verzeichnis wird ausgedruckt
    IF LEN(verz_proc_name$)>0  ! Prozeduren wurden gefunden
      FOR i%=1 TO leer_oben%
        pt.lprint("",TRUE)
      NEXT i%
      pt.print(SPACE$(leer_vorn%)+"VERZEICHNIS von "+lst_name$,TRUE)
      pt.print(SPACE$(leer_vorn%)+"----------------"+STRING$(LEN(lst_name$),"-"),TRUE)
      pt.lprint("",TRUE)
      pt.print(SPACE$(leer_vorn%)+"Name des Unterprg.   ",FALSE)
      IF verz_zeilen!=TRUE  ! Mit Andruck der Listing-Zeilen
        pt.print("   von - bis Zeile   ",FALSE)
      ENDIF
      IF verz_seiten!=TRUE  ! Mit Andruck der Listing-Seiten
        pt.print("   von - bis Seite",FALSE)
      ENDIF
      pt.lprint("",TRUE)
      pt.lprint("",TRUE)
      anz_proc%=0
      '
      ' Anzahl der gedruckten Proceduren/Functionen ermitteln
      FOR i%=1 TO LEN(verz_proc_name$)
        IF MID$(verz_proc_name$,i%,1)="|"  ! '|' = Trenn-Marke
          ADD anz_proc%,1
        ENDIF
      NEXT i%
      '
      ' Procedure/Functionsnamen drucken
      FOR i%=1 TO anz_proc%
        pt.lprint(SPACE$(leer_vorn%),FALSE)
        pt.print(LEFT$(verz_proc_name$,INSTR(verz_proc_name$,"|")-1),FALSE)
        pt.lprint(SPACE$(23-INSTR(verz_proc_name$,"|")+1),FALSE)
        verz_proc_name$=MID$(verz_proc_name$,INSTR(verz_proc_name$,"|")+1)
        IF verz_zeilen!=TRUE  ! mit Listing-Zeilen
          pt.print(STR$(VAL(LEFT$(verz_von_zeile$,INSTR(verz_von_zeile$,"|")-1)),4),FALSE)
          pt.print(" -",FALSE)
          pt.print(STR$(VAL(LEFT$(verz_bis_zeile$,INSTR(verz_bis_zeile$,"|")-1)),4),FALSE)
          pt.lprint("           ",FALSE)
          verz_von_zeile$=MID$(verz_von_zeile$,INSTR(verz_von_zeile$,"|")+1)
          verz_bis_zeile$=MID$(verz_bis_zeile$,INSTR(verz_bis_zeile$,"|")+1)
        ENDIF
        IF verz_seiten!=TRUE  ! mit Listing-Seiten
          pt.print(STR$(VAL(LEFT$(verz_von_seite$,INSTR(verz_von_seite$,"|")-1)),4),FALSE)
          pt.print(" -",FALSE)
          pt.print(STR$(VAL(LEFT$(verz_bis_seite$,INSTR(verz_bis_seite$,"|")-1)),4),FALSE)
          verz_von_seite$=MID$(verz_von_seite$,INSTR(verz_von_seite$,"|")+1)
          verz_bis_seite$=MID$(verz_bis_seite$,INSTR(verz_bis_seite$,"|")+1)
        ENDIF
        pt.lprint("",TRUE)
      NEXT i%
      pt.lprint(seitenvorschub$,TRUE)
    ENDIF
  ENDIF
  DEFMOUSE 0
  INFOW #1,"     Gesamt = "+STR$(lst_zeilen%)+" Zeilen"
  redraw_lst_fenster
RETURN
> PROCEDURE ende
  LOCAL antwort%
  ALERT 1,"Programm beenden",1,"JA|NEIN",antwort%
  IF antwort%=1
    ON ERROR
    MENU KILL
    ~RSRC_FREE()
    RESERVE   ! Speicherplatz wieder freigeben
    END
  ENDIF
RETURN
'
> PROCEDURE laden
  CLOSEW #1
  '  fileselect_ueberschrift("Attribut-Datei laden")
  fdd_datei$=FN fs.select$(2,"Attribut-Datei laden")
  DEFFILL 1,2,4
  PBOX 0,0,640,400
  IF fdd_datei$<>""  ! nicht auf Abbruch geklickt
    IF EXIST(fdd_datei$)
      DEFMOUSE 2
      fdd_laden(fdd_datei$)  ! Attribute laden
      DEFMOUSE 0
    ELSE
      ALERT 1,"Die|"+fdd_datei$+"|existiert nicht",1,"SCHADE",dummy
    ENDIF
  ENDIF
  IF lst_name$<>""
    OPENW #1,0,19,639,350,&X100010001
    TITLEW #1," "+lst_name$+" "
    INFOW #1,"     Gesamt = "+STR$(lst_zeilen%)+" Zeilen"
    FULLW #1
    redraw_lst_fenster
  ELSE
    DEFFILL 1,2,4
    PBOX 0,0,640,400
  ENDIF
RETURN
> PROCEDURE zeilennummern
  SGET puffer$
  z.nr%=0          !/* Formula/Dialog */
  z.nrja%=4        !/* BUTTON in Baum ZNR */
  z.nrnein%=5      !/* BUTTON in Baum ZNR */
  z.nrerste%=6     !/* FTEXT in Baum ZNR */
  z.nrstep%=7      !/* FTEXT in Baum ZNR */
  z.nrok%=8        !/* BUTTON in Baum ZNR */
  z.nrabbr%=9      !/* BUTTON in Baum ZNR */
  z.nrtrenn%=10    !/* FTEXT in Baum ZNR */
  ~RSRC_GADDR(0,z.nr%,z.nrbaum%)
  '
  ' Dialogbox initialisieren
  IF zeilennummern!=TRUE
    ~OBJC_CHANGE(z.nrbaum%,z.nrja%,0,0,0,640,400,1,0)
    ~OBJC_CHANGE(z.nrbaum%,z.nrnein%,0,0,0,640,400,0,0)
  ELSE
    ~OBJC_CHANGE(z.nrbaum%,z.nrja%,0,0,0,640,400,0,0)
    ~OBJC_CHANGE(z.nrbaum%,z.nrnein%,0,0,0,640,400,1,0)
  ENDIF
  CHAR{{OB_SPEC(z.nrbaum%,z.nrerste%)}}=STR$(start%)
  CHAR{{OB_SPEC(z.nrbaum%,z.nrstep%)}}=STR$(step%)
  CHAR{{OB_SPEC(z.nrbaum%,z.nrtrenn%)}}=znr_trenn$
  ~FORM_CENTER(z.nrbaum%,fx%,fy%,fw%,fh%)
  ~GRAF_GROWBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  ~OBJC_DRAW(z.nrbaum%,0,8,0,0,640,400)
  button_exit%=FORM_DO(z.nrbaum%,z.nrerste%)
  ~OBJC_CHANGE(z.nrbaum%,button_exit%,0,0,0,640,400,0,0)
  IF button_exit%=z.nrok%  ! OK-Button
    '
    ' Attribute aus Dialogbox ermitteln
    status%=OB_STATE(z.nrbaum%,z.nrja%)
    IF status%=1 THEN
      zeilennummern!=TRUE
    ELSE
      zeilennummern!=FALSE
    ENDIF
    zahl$=CHAR{{OB_SPEC(z.nrbaum%,z.nrerste%)}}
    start%=VAL(zahl$)
    step$=CHAR{{OB_SPEC(z.nrbaum%,z.nrstep%)}}
    step%=VAL(step$)
    znr_trenn$=CHAR{{OB_SPEC(z.nrbaum%,z.nrtrenn%)}}
  ENDIF
  ~GRAF_SHRINKBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  SPUT puffer$
RETURN
> PROCEDURE strukturtiefe
  SGET puffer$
  s.truktur%=1     !/* Formula/Dialog */
  s.tkja%=4        !/* BUTTON in Baum STRUKTUR */
  s.tknein%=5      !/* BUTTON in Baum STRUKTUR */
  s.tktrenn%=6     !/* FTEXT in Baum STRUKTUR */
  s.tktok%=7       !/* BUTTON in Baum STRUKTUR */
  s.tkrabbr%=8     !/* BUTTON in Baum STRUKTUR */
  ~RSRC_GADDR(0,s.truktur%,s.trukturbaum%)
  '
  ' Dialogbox initialisieren
  IF strkt_tiefe!=TRUE
    ~OBJC_CHANGE(s.trukturbaum%,s.tkja%,0,0,0,640,400,1,0)
    ~OBJC_CHANGE(s.trukturbaum%,s.tknein%,0,0,0,640,400,0,0)
  ELSE
    ~OBJC_CHANGE(s.trukturbaum%,s.tkja%,0,0,0,640,400,0,0)
    ~OBJC_CHANGE(s.trukturbaum%,s.tknein%,0,0,0,640,400,1,0)
  ENDIF
  CHAR{{OB_SPEC(s.trukturbaum%,s.tktrenn%)}}=tiefe_trenn$
  ~FORM_CENTER(s.trukturbaum%,fx%,fy%,fw%,fh%)
  ~GRAF_GROWBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  ~OBJC_DRAW(s.trukturbaum%,0,8,0,0,640,400)
  button_exit%=FORM_DO(s.trukturbaum%,s.tktrenn%)
  ~OBJC_CHANGE(s.trukturbaum%,button_exit%,0,0,0,640,400,0,0)
  IF button_exit%=s.tktok%  ! OK-Button
    '
    ' Attribute aus Dialogbox ermitteln
    status%=OB_STATE(s.trukturbaum%,s.tkja%)
    IF status%=1 THEN
      strkt_tiefe!=TRUE
    ELSE
      strkt_tiefe!=FALSE
    ENDIF
    tiefe_trenn$=CHAR{{OB_SPEC(s.trukturbaum%,s.tktrenn%)}}
  ENDIF
  ~GRAF_SHRINKBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  SPUT puffer$
RETURN
> PROCEDURE procverzeichnis
  SGET puffer$
  v.erzeich%=2     !/* Formula/Dialog */
  v.erzja%=4       !/* BUTTON in Baum VERZEICH */
