  v.erzznr%=6      !/* BUTTON in Baum VERZEICH */
  v.erzseit%=7     !/* BUTTON in Baum VERZEICH */
  v.erzok%=8       !/* BUTTON in Baum VERZEICH */
  v.erzabbr%=9     !/* BUTTON in Baum VERZEICH */
  ~RSRC_GADDR(0,v.erzeich%,v.erzeichbaum%)
  '
  ' Dialogbox initialisieren
  IF proc_verz!=TRUE
    ~OBJC_CHANGE(v.erzeichbaum%,v.erzja%,0,0,0,640,400,1,0)
    ~OBJC_CHANGE(v.erzeichbaum%,v.erznein%,0,0,0,640,400,0,0)
  ELSE
    ~OBJC_CHANGE(v.erzeichbaum%,v.erzja%,0,0,0,640,400,0,0)
    ~OBJC_CHANGE(v.erzeichbaum%,v.erznein%,0,0,0,640,400,1,0)
  ENDIF
  IF verz_zeilen!=TRUE
    ~OBJC_CHANGE(v.erzeichbaum%,v.erzznr%,0,0,0,640,400,1,0)
  ELSE
    ~OBJC_CHANGE(v.erzeichbaum%,v.erzznr%,0,0,0,640,400,0,0)
  ENDIF
  IF verz_seiten!=TRUE
    ~OBJC_CHANGE(v.erzeichbaum%,v.erzseit%,0,0,0,640,400,1,0)
  ELSE
    ~OBJC_CHANGE(v.erzeichbaum%,v.erzseit%,0,0,0,640,400,0,0)
  ENDIF
  ~FORM_CENTER(v.erzeichbaum%,fx%,fy%,fw%,fh%)
  ~GRAF_GROWBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  ~OBJC_DRAW(v.erzeichbaum%,0,8,0,0,640,400)
  button_exit%=FORM_DO(v.erzeichbaum%,0)
  ~OBJC_CHANGE(v.erzeichbaum%,button_exit%,0,0,0,640,400,0,0)
  IF button_exit%=v.erzok%  ! OK-Button
    '
    ' Attribute aus Dialogbox ermitteln
    status%=OB_STATE(v.erzeichbaum%,v.erzja%)
    IF status%=1 THEN
      proc_verz!=TRUE
    ELSE
      proc_verz!=FALSE
    ENDIF
    status%=OB_STATE(v.erzeichbaum%,v.erzznr%)
    IF status%=1
      verz_zeilen!=TRUE
    ELSE
      verz_zeilen!=FALSE
    ENDIF
    status%=OB_STATE(v.erzeichbaum%,v.erzseit%)
    IF status%=1
      verz_seiten!=TRUE
    ELSE
      verz_seiten!=FALSE
    ENDIF
  ENDIF
  ~GRAF_SHRINKBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  SPUT puffer$
RETURN
> PROCEDURE vorschub
  SGET puffer$
  v.orschub%=3     !/* Formula/Dialog */
  v.rsbef01%=4     !/* FTEXT in Baum VORSCHUB */
  v.rsbef24%=27    !/* FTEXT in Baum VORSCHUB */
  v.rsok%=28
  v.rsabbr%=29
  v.orsja%=31
  v.orsnein%=32
  ~RSRC_GADDR(0,v.orschub%,v.orschubbaum%)
  '
  ' Dialogbox ermitteln
  IF vorschub!=TRUE
    ~OBJC_CHANGE(v.orschubbaum%,v.orsja%,0,0,0,640,400,1,0)
    ~OBJC_CHANGE(v.orschubbaum%,v.orsnein%,0,0,0,640,400,0,0)
  ELSE
    ~OBJC_CHANGE(v.orschubbaum%,v.orsja%,0,0,0,640,400,0,0)
    ~OBJC_CHANGE(v.orschubbaum%,v.orsnein%,0,0,0,640,400,1,0)
  ENDIF
  FOR i%=v.rsbef01% TO v.rsbef24%
    CHAR{{OB_SPEC(v.orschubbaum%,i%)}}=vorschub$(i%-v.rsbef01%+1)
  NEXT i%
  ~FORM_CENTER(v.orschubbaum%,fx%,fy%,fw%,fh%)
  ~GRAF_GROWBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  ~OBJC_DRAW(v.orschubbaum%,0,8,0,0,640,400)
  button_exit%=FORM_DO(v.orschubbaum%,v.rsbef01%)
  ~OBJC_CHANGE(v.orschubbaum%,button_exit%,0,0,0,640,400,0,0)
  IF button_exit%=v.rsok%  ! OK-Button
    '
    ' Attribute aus Dialogbox ermitteln
    status%=OB_STATE(v.orschubbaum%,v.orsja%)
    IF status%=1
      vorschub!=TRUE
    ELSE
      vorschub!=FALSE
    ENDIF
    FOR i%=v.rsbef01% TO v.rsbef24%
      a$=CHAR{{OB_SPEC(v.orschubbaum%,i%)}}
      IF a$<>"undef."
        vorschub$(i%-v.rsbef01%+1)=a$
      ENDIF
    NEXT i%
  ENDIF
  ~GRAF_SHRINKBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  SPUT puffer$
RETURN
