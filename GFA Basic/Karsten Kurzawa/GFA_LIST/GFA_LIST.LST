> PROCEDURE layout
  SGET puffer$
  s.eitelay%=5     !/* Formula/Dialog */
  LET zeilen%=2 !/* FTEXT in Baum SEITELAY */
  LET obenleer%=3 !/* FTEXT in Baum SEITELAY */
  LET unteleer%=4 !/* FTEXT in Baum SEITELAY */
  LET anzspalt%=5 !/* FTEXT in Baum SEITELAY */
  LET spltvorn%=6 !/* FTEXT in Baum SEITELAY */
  LET layoutok%=7 !/* BUTTON in Baum SEITELAY */
  LET layoutab%=8 !/* BUTTON in Baum SEITELAY */
  ~RSRC_GADDR(0,s.eitelay%,s.eitelaybaum%)
  '
  ' Dialogbox initialisieren
  CHAR{{OB_SPEC(s.eitelaybaum%,zeilen%)}}=STR$(zeilen_seite%)
  CHAR{{OB_SPEC(s.eitelaybaum%,obenleer%)}}=STR$(leer_oben%)
  CHAR{{OB_SPEC(s.eitelaybaum%,unteleer%)}}=STR$(leer_unten%)
  CHAR{{OB_SPEC(s.eitelaybaum%,anzspalt%)}}=STR$(spalten%)
  CHAR{{OB_SPEC(s.eitelaybaum%,spltvorn%)}}=STR$(leer_vorn%)
  ~FORM_CENTER(s.eitelaybaum%,fx%,fy%,fh%,fw%)
  ~GRAF_GROWBOX(320,200,0,0,fx%,fy%,fh%,fw%)
  ~OBJC_DRAW(s.eitelaybaum%,0,8,0,0,640,400)
  button_exit%=FORM_DO(s.eitelaybaum%,zeilen%)
  ~OBJC_CHANGE(s.eitelaybaum%,button_exit%,0,0,0,640,400,0,1)
  IF button_exit%=layoutok%  ! OK-Button
    '
    ' Attribute aus Dialogbox lesen
    zeilen_seite%=INT(VAL(CHAR{{OB_SPEC(s.eitelaybaum%,zeilen%)}}))
    leer_oben%=INT(VAL(CHAR{{OB_SPEC(s.eitelaybaum%,obenleer%)}}))
    leer_unten%=INT(VAL(CHAR{{OB_SPEC(s.eitelaybaum%,unteleer%)}}))
    spalten%=INT(VAL(CHAR{{OB_SPEC(s.eitelaybaum%,anzspalt%)}}))
    leer_vorn%=INT(VAL(CHAR{{OB_SPEC(s.eitelaybaum%,spltvorn%)}}))
  ENDIF
