> PROCEDURE ueberschrift_defenieren
  SGET puffer$
  u.ebers%=7       !/* Formula/Dialog */
  u.eb1%=2         !/* FTEXT in Baum UEBERS */
  u.eb2%=3         !/* FTEXT in Baum UEBERS */
  u.eb3%=4         !/* FTEXT in Baum UEBERS */
  u.ebok%=7        !/* BUTTON in Baum UEBERS */
  u.ebabbr%=8      !/* BUTTON in Baum UEBERS */
  leer$=""
  ~RSRC_GADDR(0,u.ebers%,u.ebersbaum%)
  '
  ' Dialogbox initialisieren
  CHAR{{OB_SPEC(u.ebersbaum%,u.eb1%)}}=LEFT$(ueb_definit$,65)
  IF LEN(ueb_definit$)>65
    CHAR{{OB_SPEC(u.ebersbaum%,u.eb2%)}}=MID$(ueb_definit$,66,65)
    IF LEN(ueb_definit$)>130
      CHAR{{OB_SPEC(u.ebersbaum%,u.eb3%)}}=MID$(ueb_definit$,131,65)
    ELSE
      CHAR{{OB_SPEC(u.ebersbaum%,u.eb3%)}}=leer$
    ENDIF
  ELSE
    CHAR{{OB_SPEC(u.ebersbaum%,u.eb2%)}}=leer$
    CHAR{{OB_SPEC(u.ebersbaum%,u.eb3%)}}=leer$
  ENDIF
  ~FORM_CENTER(u.ebersbaum%,fx%,fy%,fh%,fw%)
  ~GRAF_GROWBOX(320,200,0,0,fx%,fy%,fh%,fw%)
  ~OBJC_DRAW(u.ebersbaum%,0,8,0,0,640,400)
  button_exit%=FORM_DO(u.ebersbaum%,0)
  ~OBJC_CHANGE(u.ebersbaum%,button_exit%,0,0,0,640,400,0,1)
  IF button_exit%=u.ebok%  ! OK-Button
    '
    ' Attribute aus Dialogbox lesen
    ueb_definit$=CHAR{{OB_SPEC(u.ebersbaum%,u.eb1%)}}
    a$=CHAR{{OB_SPEC(u.ebersbaum%,u.eb2%)}}
    ueb_definit$=ueb_definit$+a$
    a$=CHAR{{OB_SPEC(u.ebersbaum%,u.eb3%)}}
    ueb_definit$=ueb_definit$+a$
  ENDIF
  ~GRAF_SHRINKBOX(320,200,0,0,fx%,fy%,fh%,fw%)
  SPUT puffer$
RETURN
> PROCEDURE sichern
  CLOSEW #1
  '
  ' Attribute schreiben
  fdd_datei$=FN fs.select$(2,"Attribut-Datei sichern")
  DEFFILL 1,2,4
  PBOX 0,0,640,400
  IF fdd_datei$<>""  ! Nicht Abbruch geklickt
    IF EXIST(fdd_datei$)
      ALERT 1,"Diese Datei existiert schon.",1,"OK|BACKUP|ABBRUCH",antwort%
      IF antwort%<>3
        IF antwort%=1
          KILL fdd_datei$
        ELSE
          NAME fdd_datei$ AS LEFT$(fdd_datei$,LEN(fdd_datei$)-3)+"BAK"
        ENDIF
        DEFMOUSE 2
        fdd_schreiben(fdd_datei$)
        DEFMOUSE 0
      ENDIF
    ELSE
      DEFMOUSE 2
      fdd_schreiben(fdd_datei$)
      DEFMOUSE 0
    ENDIF
  ENDIF
  IF lst_name$<>""
    OPENW #1,0,19,639,350,&X100010001
    TITLEW #1," "+lst_name$+" "
    INFOW #1,"     Gesamt = "+STR$(lst_zeilen%)+" Zeilen"
    FULLW #1
    redraw_lst_fenster
  ELSE
    DEFFILL 1,2,4
    PBOX 0,0,640,400
  ENDIF
RETURN
'
> PROCEDURE schriftart
  SGET puffer$
  s.chrift%=8!/* Formula/Dialog */
  z.nran%=5!/* FTEXT in Baum SCHRIFT */
  z.nraus%=6!/* FTEXT in Baum SCHRIFT */
  p.rgtan%=8!/* FTEXT in Baum SCHRIFT */
  p.rgtaus%=9!/* FTEXT in Baum SCHRIFT */
  h.ervan%=11!/* FTEXT in Baum SCHRIFT */
  h.ervaus%=12!/* FTEXT in Baum SCHRIFT */
  b.emrkan%=14!/* FTEXT in Baum SCHRIFT */
  b.emrkaus%=15!/* FTEXT in Baum SCHRIFT */
  s.tdan%=17!/* FTEXT in Baum SCHRIFT */
  s.tdaus%=18!/* FTEXT in Baum SCHRIFT */
  u.eban%=20!/* FTEXT in Baum SCHRIFT */
  u.ebaus%=21!/* FTEXT in Baum SCHRIFT */
  s.chrfok%=22!/* BUTTON in Baum SCHRIFT */
  s.chrfabr%=23!/* BUTTON in Baum SCHRIFT */
  ~RSRC_GADDR(0,s.chrift%,s.chriftbaum%)
  '
  ' Dialogbox initialisieren
  CHAR{{OB_SPEC(s.chriftbaum%,z.nran%)}}=FN ermittle_code$(znr_an$)
  CHAR{{OB_SPEC(s.chriftbaum%,z.nraus%)}}=FN ermittle_code$(znr_aus$)
  CHAR{{OB_SPEC(s.chriftbaum%,p.rgtan%)}}=FN ermittle_code$(stf_an$)
  CHAR{{OB_SPEC(s.chriftbaum%,p.rgtaus%)}}=FN ermittle_code$(stf_aus$)
  CHAR{{OB_SPEC(s.chriftbaum%,h.ervan%)}}=FN ermittle_code$(strkt_an$)
  CHAR{{OB_SPEC(s.chriftbaum%,h.ervaus%)}}=FN ermittle_code$(strkt_aus$)
  CHAR{{OB_SPEC(s.chriftbaum%,b.emrkan%)}}=FN ermittle_code$(bemrk_an$)
  CHAR{{OB_SPEC(s.chriftbaum%,b.emrkaus%)}}=FN ermittle_code$(bemrk_aus$)
  CHAR{{OB_SPEC(s.chriftbaum%,s.tdan%)}}=FN ermittle_code$(stnd_an$)
  CHAR{{OB_SPEC(s.chriftbaum%,s.tdaus%)}}=FN ermittle_code$(stnd_aus$)
  CHAR{{OB_SPEC(s.chriftbaum%,u.eban%)}}=FN ermittle_code$(ueb_an$)
  CHAR{{OB_SPEC(s.chriftbaum%,u.ebaus%)}}=FN ermittle_code$(ueb_aus$)
  ~FORM_CENTER(s.chriftbaum%,fx%,fy%,fh%,fw%)
  ~GRAF_GROWBOX(320,200,0,0,fx%,fy%,fh%,fw%)
  start%=z.nran%
  REPEAT
    ok!=TRUE
    ~OBJC_DRAW(s.chriftbaum%,0,8,0,0,640,400)
    button_exit%=FORM_DO(s.chriftbaum%,start%)
    ~OBJC_CHANGE(s.chriftbaum%,button_exit%,0,0,0,640,400,0,1)
    IF button_exit%=s.chrfok%  ! OK-Button
      '
      ' Druckerschriften aus Dialogbox ermitteln
      znr_an$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,z.nran%)}})
      IF LEFT$(znr_an$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=z.nran%
      ENDIF
      znr_aus$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,z.nraus%)}})
      IF LEFT$(znr_aus$,2)="-1" ! Falscher ASCII-Code
        ok!=FALSE
        start%=z.nraus%
      ENDIF
      stf_an$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,p.rgtan%)}})
      IF LEFT$(stf_an$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=p.rgtan%
      ENDIF
      stf_aus$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,p.rgtaus%)}})
      IF LEFT$(stf_aus$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=p.rgtaus%
      ENDIF
      strkt_an$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,h.ervan%)}})
      IF LEFT$(strkt_an$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=h.ervan%
      ENDIF
      strkt_aus$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,h.ervaus%)}})
      IF LEFT$(strkt_aus$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=h.ervaus%
      ENDIF
      bemrk_an$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,b.emrkan%)}})
      IF LEFT$(bemrk_an$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=b.emrkan%
      ENDIF
      bemrk_aus$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,b.emrkaus%)}})
      IF LEFT$(bemrk_aus$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=b.emrkaus%
      ENDIF
      stnd_an$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,s.tdan%)}})
      IF LEFT$(stnd_an$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=s.tdan%
      ENDIF
      stnd_aus$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,s.tdaus%)}})
      IF LEFT$(stnd_aus$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=s.tdaus%
      ENDIF
      ueb_an$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,u.eban%)}})
      IF LEFT$(ueb_an$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=u.eban%
      ENDIF
      ueb_aus$=FN setze_code$(CHAR{{OB_SPEC(s.chriftbaum%,u.ebaus%)}})
      IF LEFT$(ueb_aus$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=u.ebaus%
      ENDIF
      IF ok!=FALSE
        ALERT 1,"Maximaler ASCII-Code = 255",1,"OK",dummy
      ENDIF
    ENDIF
  UNTIL button_exit%=s.chrfabr% OR ok!=TRUE
  ~GRAF_SHRINKBOX(320,200,0,0,fx%,fy%,fh%,fw%)
  SPUT puffer$
RETURN
> PROCEDURE druckersteuerung
  SGET puffer$
  d.ruckst%=9!/* Formula/Dialog */
  s.eitinit%=2!/* FTEXT in Baum DRUCKST */
  s.eitvors%=3!/* FTEXT in Baum DRUCKST */
  d.ruksok%=4!/* BUTTON in Baum DRUCKST */
  d.ruksabr%=5!/* BUTTON in Baum DRUCKST */
  ~RSRC_GADDR(0,d.ruckst%,d.ruckstbaum%)
  '
  ' Dialogbox initialisieren
  CHAR{{OB_SPEC(d.ruckstbaum%,s.eitinit%)}}=FN ermittle_code$(seiten_init$)
  CHAR{{OB_SPEC(d.ruckstbaum%,s.eitvors%)}}=FN ermittle_code$(seitenvorschub$)
  start%=s.eitinit%
  ~FORM_CENTER(d.ruckstbaum%,fx%,fy%,fw%,fh%)
  ~GRAF_GROWBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  REPEAT
    ok!=TRUE
    ~OBJC_DRAW(d.ruckstbaum%,0,8,0,0,640,400)
    button_exit%=FORM_DO(d.ruckstbaum%,start%)
    ~OBJC_CHANGE(d.ruckstbaum%,button_exit%,0,0,0,640,400,0,1)
    IF button_exit%=d.ruksok%  ! OK-Button
      '
      ' Druckersteuerzeichen aus Dialogbox lesen
      seiten_init$=FN setze_code$(CHAR{{OB_SPEC(d.ruckstbaum%,s.eitinit%)}})
      IF LEFT$(seiten_init$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=s.eitinit%
      ENDIF
      seitenvorschub$=FN setze_code$(CHAR{{OB_SPEC(d.ruckstbaum%,s.eitvors%)}})
      IF LEFT$(seitenvorschub$,2)="-1"  ! Falscher ASCII-Code
        ok!=FALSE
        start%=s.eitvors%
      ENDIF
      IF ok!=FALSE
        ALERT 1,"Maximaler ASCII-Code = 255",1,"OK",dummy
      ENDIF
    ENDIF
  UNTIL button_exit%=d.rucksabr% OR ok!=TRUE
  ~GRAF_SHRINKBOX(320,200,0,0,fx%,fy%,fw%,fh%)
  SPUT puffer$
RETURN
> PROCEDURE cfg_zeichenwandlung
  CLOSEW #1
  REPEAT
    datei$=FN fs.select$(3,"CFG-Druckeranpassung laden")
    IF EXIST(datei$)
      cfg_datei$=datei$
      pt.cfg_clear
      pt.cfg_load(cfg_datei$)
    ENDIF
  UNTIL datei$="" OR EXIST(datei$)
  IF lst_name$<>""
    OPENW #1,0,19,639,350,&X100010001
    TITLEW #1," "+lst_name$+" "
    INFOW #1,"     Gesamt = "+STR$(lst_zeilen%)+" Zeilen"
    FULLW #1
    redraw_lst_fenster
  ELSE
    DEFFILL 1,2,4
    PBOX 0,0,640,400
  ENDIF
RETURN
'
' ------------------ Unterroutinen zu den Hauptprozeduren -------------------
'
> PROCEDURE fdd_schreiben(datei$)
  OPEN "O",#1,datei$
  '
  ' Druckerschriftarten
  schreibe_wert(znr_an$)
  schreibe_wert(znr_aus$)
  schreibe_wert(stf_an$)
  schreibe_wert(stf_aus$)
  schreibe_wert(stnd_an$)
  schreibe_wert(stnd_aus$)
  schreibe_wert(strkt_an$)
  schreibe_wert(strkt_aus$)
  schreibe_wert(ueb_an$)
  schreibe_wert(ueb_aus$)
  schreibe_wert(bemrk_an$)
  schreibe_wert(bemrk_aus$)
  schreibe_wert(seitenvorschub$)
  schreibe_wert(seiten_init$)
  '
  ' Hervorhebungen
  FOR i%=1 TO 24
    PRINT #1,struktur$(i%)
  NEXT i%
  '
  ' Sondervorschub
  FOR i%=1 TO 24
    PRINT #1,vorschub$(i%)
  NEXT i%
  '
  ' Zeilennummern
  PRINT #1,zeilennummern!
  schreibe_wert(znr_trenn$)
  PRINT #1,start%
  PRINT #1,step%
  '
  ' Strukturtiefe
  PRINT #1,strkt_tiefe!
  schreibe_wert(tiefe_trenn$)
  '
  ' Procedure-Verzeichnis
  PRINT #1,proc_verz!
  PRINT #1,verz_zeilen!
  PRINT #1,verz_seiten!
  PRINT #1,vorschub!
  PRINT #1,einr_faktor
  '
  ' Zeilenumbruch
  PRINT #1,word_wrap!
  schreibe_wert(word_wrap_zeichen$)
  '
  ' Seiten-Layout
  PRINT #1,leer_vorn%
  PRINT #1,spalten%
  PRINT #1,zeilen_seite%
  PRINT #1,leer_oben%
  PRINT #1,leer_unten%
  PRINT #1,ueb_definit$
  schreibe_wert(cfg_datei$)
  CLOSE #1
RETURN
> PROCEDURE schreibe_wert(wert$)
  OUT #1,LEN(wert$)
  FOR i%=1 TO LEN(wert$)
    OUT #1,ASC(MID$(wert$,i%,1))
  NEXT i%
RETURN
FUNCTION ermittle_code$(code$)
  '
  ' Aus Druckersteuerzeichen editierbare Zahlen machen
  c$=""
  IF LEN(code$)>0
    FOR i%=1 TO LEN(code$)
      c$=c$+STR$(ASC(MID$(code$,i%,1)))+","
    NEXT i%
    c$=LEFT$(c$,LEN(c$)-1)
  ENDIF
  RETURN c$
ENDFUNC
> PROCEDURE redraw_lst_fenster
  LOCAL i%
  CLS
  FOR i%=1 TO MIN(lst_zeilen%,20)
    PRINT lst_zeilen$(i%)
  NEXT i%
  PRINT lst_zeilen$(i%);
RETURN
FUNCTION setze_code$(code$)
  ' Aus editierten String ein Druckersteuerzeichen machen
  c$=""
  code$=code$+"@"
  IF LEN(code$)>1
    FOR i%=1 TO LEN(code$)
      zahl$=""
      WHILE ASC(MID$(code$,i%,1))>=48 AND ASC(MID$(code$,i%,1))<=57
        zahl$=zahl$+MID$(code$,i%,1)
        ADD i%,1
      WEND
      IF VAL(zahl$)>=0 AND VAL(zahl$)<=255
        c$=c$+CHR$(VAL(zahl$))
      ELSE
        c$="-1"  ! Falscher ASCII-Code
      ENDIF
    NEXT i%
  ENDIF
  RETURN c$
ENDFUNC
> PROCEDURE fdd_laden(datei$)
  ' Attribute lesen
  OPEN "I",#1,datei$
  '
  ' Druckerschriftarten
  znr_an$=FN lese_wert$
  znr_aus$=FN lese_wert$
  stf_an$=FN lese_wert$
  stf_aus$=FN lese_wert$
  stnd_an$=FN lese_wert$
  stnd_aus$=FN lese_wert$
  strkt_an$=FN lese_wert$
  strkt_aus$=FN lese_wert$
  ueb_an$=FN lese_wert$
  ueb_aus$=FN lese_wert$
  bemrk_an$=FN lese_wert$
  bemrk_aus$=FN lese_wert$
  seitenvorschub$=FN lese_wert$
  seiten_init$=FN lese_wert$
  '
  ' Hervorzuhebende Befehle
  FOR i%=1 TO 24
    INPUT #1,struktur$(i%)
  NEXT i%
  '
  ' Sondervorschub
  FOR i%=1 TO 24
    INPUT #1,vorschub$(i%)
  NEXT i%
  '
  ' Zeilennummern
  INPUT #1,zeilennummern!
  znr_trenn$=FN lese_wert$
  INPUT #1,start%
  INPUT #1,step%
  '
  ' Strukturtiefe
  INPUT #1,strkt_tiefe!
  tiefe_trenn$=FN lese_wert$
  '
  ' Procedure-Verzeichnis
  INPUT #1,proc_verz!
  INPUT #1,verz_zeilen!
  INPUT #1,verz_seiten!
  INPUT #1,vorschub!
  INPUT #1,einr_faktor
  '
  ' Zeilenumbruch
  INPUT #1,word_wrap!
  word_wrap_zeichen$=FN lese_wert$
  '
  ' Seiten-Layout
  INPUT #1,leer_vorn%
  INPUT #1,spalten%
  INPUT #1,zeilen_seite%
  INPUT #1,leer_oben%
  INPUT #1,leer_unten%
  INPUT #1,ueb_definit$
  cfg_datei$=FN lese_wert$
  CLOSE #1
RETURN
FUNCTION lese_wert$
  lang%=INP(#1)
  RETURN INPUT$(lang%,#1)
ENDFUNC
> PROCEDURE standard_ausgabe(d$,vorgabe%,stc_an$,stc_aus$)
  ' D$ = zu druckender Text
  ' vorgabe% = schon gedruckte Zeichen in der aktuellen Zeile
  ' stc_an$ = aktuelle Druckerschriftart ein
  ' stc_aus$ = aktuelle Druckerschriftart aus
  '
  lang%=LEN(d$)+vorgabe%  ! Gesamt-Länger ermitteln
  max_lang%=spalten%-leer_vorn%-INT(anz_leer%*einr_faktor)-znr_vorn%-LEN(znr_trenn$)-LEN(tiefe_trenn$)
  IF lang%=<max_lang%  ! Gesamte Zeilenlänge liegt unter der maximalen
    '                   und kann daher direkt ausgedruckt werden
    pt.print(d$,FALSE)
    ADD druckpos%,LEN(d$)
    ADD aktuell%,1
    ueberschrift
  ELSE  ! Gesamte Zeile ist länger als die maximal in einer Zeile möglichen
    WHILE lang%>max_lang%  ! Solange wie die Länger der Zeile grö×er ist
      '                      als die maximale
      IF vorgabe%>0
        IF word_wrap!=TRUE  ! Zeilenumbruch ist an
          ww%=FN wrap_word(LEFT$(d$,max_lang%-vorgabe%))
          pt.print(LEFT$(d$,ww%),TRUE)  ! Text bis Zeilenumbruch drucken
          IF ww%=LEN(d$)
            druckpos%=0
          ELSE
            ADD druckpos%,ww%
          ENDIF
          ADD aktuell%,1
          ueberschrift
          d$=MID$(d$,ww%+1)  ! noch auszudruckender Text
        ELSE  ! ohne Zeilenumbruch
          pt.print(LEFT$(d$,max_lang%-vorgabe%),TRUE)
          IF ww%=LEN(d$)
            druckpos%=0
          ELSE
            ADD druckpos%,ww%
          ENDIF
          ADD aktuell%,1
          ueberschrift
          d$=MID$(d$,max_lang%+1-vorgabe%)  ! noch auszudruckender Text
        ENDIF
        vorgabe%=0
      ELSE
        IF word_wrap!=TRUE  ! Zeilenumbruch ist an
          ww%=FN wrap_word(LEFT$(d$,max_lang%))  ! Zeilenumbruch ermitteln
          pt.print(LEFT$(d$,ww%),TRUE) ! Text bis Zeilenumbruch ausdrucken
          IF ww%=LEN(d$)
            druckpos%=0
          ELSE
            ADD druckpos%,ww%
          ENDIF
          ADD aktuell%,1
          ueberschrift
          d$=MID$(d$,ww%+1)  ! noch auszudruckender Text
        ELSE  ! Zeilenumbruch ist aus
          pt.print(LEFT$(d$,max_lang%),TRUE) ! Text bis maximaler Zeilenlänge ausdrucken
          IF ww%=LEN(d$)
            druckpos%=0
          ELSE
            ADD druckpos%,ww%
          ENDIF
          ADD aktuell%,1
          ueberschrift
          d$=MID$(d$,max_lang%+1)  ! noch auszudruckender Text
        ENDIF
      ENDIF
      lang%=LEN(d$) ! Länge der noch auszudruckende Zeile ermitteln
      leer%=leer_vorn%+INT(anz_leer%*einr_faktor)+znr_vorn%+LEN(znr_trenn$)+LEN(tiefe_trenn$)
      '
      ' Zeilen-Vorlauf
      '
      ' linker Rand
      pt.lprint(stnd_an$,FALSE)
      pt.lprint(SPACE$(leer_vorn%),FALSE)
      pt.lprint(stnd_aus$,FALSE)
      '
      ' Zeilennummern + Strukturtiefe aber ohne Andruck !! nur Leerzeichen !!
      pt.lprint(znr_an$,FALSE)
      pt.lprint(SPACE$(znr_vorn%+LEN(znr_trenn$)+LEN(tiefe_trenn$)),FALSE)
      pt.lprint(znr_aus$,FALSE)
      '
      ' Führende Leerzeichen mit Einrückungsfaktor
      pt.lprint(stnd_an$,FALSE)
      pt.lprint(SPACE$(INT(anz_leer%*einr_faktor)),FALSE)
      pt.lprint(stnd_aus$,FALSE)
      pt.lprint(stc_an$,FALSE)  ! Aktuelle Druckerschriftart wieder an
      ADD druckpos%,leer%
    WEND
    pt.print(d$,FALSE)
    ADD druckpos%,LEN(d$)
    ADD aktuell%,1
    ueberschrift
  ENDIF
RETURN
> PROCEDURE ueberschrift
  '
  ' Testes ob es nötig ist, eine neue Seite anzufangen und die Überschrift
  ' auszudrucken
  IF aktuell%>=zeilen_seite%-leer_oben%-leer_unten%-anzahl_ueb%
    ' Neue Seite ist notwendig
    ADD seite%,1
    IF seite%>1
      '
      ' Erst ab der 2.Seite notwendig
      '
      ' Alle Schriftarten ausschalten
      pt.lprint(stnd_aus$,FALSE)
      pt.lprint(strkt_aus$,FALSE)
      pt.lprint(znr_aus$,FALSE)
      pt.lprint(bemrk_aus$,FALSE)
      pt.lprint(seitenvorschub$,FALSE)
    ENDIF
    '
    ' Leerzeilen oben
    FOR i%=1 TO leer_oben%
      pt.lprint("",TRUE)
    NEXT i%
    IF anzahl_ueb%>0 THEN
      '
      ' linker Rand
      IF leer_vorn%>0 THEN
        pt.lprint(stnd_an$,FALSE)
        pt.lprint(SPACE$(leer_vorn%),FALSE)
        pt.lprint(stnd_aus$,FALSE)
      ENDIF
      pt.lprint(ueb_an$,FALSE)
      '
      ' {LST} durch Dateinamen ersetzen
      s%=INSTR(ueb_definit$,"{LST}")
      IF s%>0
        ueb$=LEFT$(ueb_definit$,s%-1)+lst_name$
        IF LEN(ueb_definit$)>s%+4
          ueb$=ueb$+MID$(ueb_definit$,s%+5)
        ENDIF
      ELSE
        ueb$=ueb_definit$
      ENDIF
      '
      ' {#} durch aktuelle Seitennummer ersetzen
      s%=INSTR(ueb$,"{#}")
      IF s%>0
        IF LEN(ueb$)>s%+2
          ueb$=LEFT$(ueb$,s%-1)+STR$(seite%)+MID$(ueb$,s%+3)
        ELSE
          ueb$=LEFT$(ueb$,s%-1)+STR$(seite%)
        ENDIF
      ENDIF
      '
      ' {D} durch aktuelles Datum ersetzen
      s%=INSTR(ueb$,"{D}")
      IF s%>0
        IF LEN(ueb$)>s%+2
          ueb$=LEFT$(ueb$,s%-1)+DATE$+MID$(ueb$,s%+3)
        ELSE
          ueb$=LEFT$(ueb$,s%-1)+DATE$
        ENDIF
      ENDIF
      pt.print(ueb$,FALSE)
      pt.lprint(ueb_aus$,FALSE)
      FOR i%=1 TO anzahl_ueb%-1
        pt.lprint("",TRUE)
      NEXT i%
    ENDIF
    aktuell%=0
  ENDIF
RETURN
FUNCTION wrap_word(word$)
  '
  ' Zeilenumbruch ermitteln damit keine Wörter getrennt werden
  s%=LEN(word$)
  IF s%>0
    DO
      EXIT IF INSTR(word_wrap_zeichen$,MID$(word$,s%,1))<>0 OR s%=1
      SUB s%,1
    LOOP
    IF s%=1
      RETURN LEN(word$) ! Keine passende Stelle für Word-Wrap gefunden
    ELSE
      RETURN s%
    ENDIF
  ELSE
    ALERT 1,"Fehler in WRAP-WORD",1,"OK",dummy
    RETURN 1
  ENDIF
ENDFUNC
FUNCTION finde_kommentar(basic_zeile$)
  ' Abschlie×enden Kommentar (mit '!') in der Basic-Zeile finden
  LOCAL k%,anz%,i%,pruef%
  such%=2
  WHILE INSTR(basic_zeile$," !",such%)
    k%=INSTR(basic_zeile$," !",such%)
    anz%=0
    FOR i%=such% TO k%-1
      IF MID$(basic_zeile$,i%,1)=CHR$(34)
        ADD anz%,1
      ENDIF
    NEXT i%
    IF anz%>0
      IF ODD(anz%)
        such%=INSTR(basic_zeile$,CHR$(34),k%)+1
        k%=0
      ELSE
        such%=LEN(basic_zeile$)
      ENDIF
    ELSE
      such%=LEN(basic_zeile$)
    ENDIF
  WEND
  RETURN k%
ENDFUNC
'
' ------------------- Standard-Pausenmeldung --------------------------------
'
> PROCEDURE pausenmeldung(meldung$,schalter!,rsc_baum&)
  LOCAL pausenbaum%,gx&,gy&,gw&,gh&
  ~RSRC_GADDR(0,rsc_baum&,pausenbaum%)
  IF schalter!
    CHAR{OB_SPEC(pausenbaum%,2)}=meldung$
    ~FORM_CENTER(pausenbaum%,gx&,gy&,gw&,gh&)
    GET gx&,gy&,gx&+gw&,gy&+gh&,pausenschirm$
    ~GRAF_GROWBOX(320,200,0,0,gx&,gy&,gw&,gh&)
    ~OBJC_DRAW(pausenbaum%,0,8,0,0,640,400)
  ELSE
    ~FORM_CENTER(pausenbaum%,gx&,gy&,gw&,gh&)
    PUT gx&,gy&,pausenschirm$
    ~GRAF_SHRINKBOX(320,200,0,0,gx&,gy&,gw&,gh&)
  ENDIF
RETURN
'
' -------------------------- Fehlerbehandlung ------------------------------
> PROCEDURE fehlerbehandlung
  LOCAL antwort&,fehlertext$
  ON ERROR GOSUB fehlerbehandlung
  IF ERR<>94
    fehlertext$=MID$(ERR$(ERR),5,LEN(ERR$(ERR))-13)
    IF FATAL
      ALERT 1,"Fataler Fehler| |"+fehlertext$,2,"WEITER|ABBRUCH",antwort&
    ELSE
      ALERT 1,"Programm-Fehler aufgetreten| |"+fehlertext$,2,"WEITER|ABBRUCH",antwort&
    ENDIF
    IF antwort&=1
      ALERT 2,"Den gleichen Befehl|oder den nächsten ausführen",2,"GLEICHER|NÄCHSTER",antwort&
      IF antwort&=1
        RESUME
      ELSE
        RESUME NEXT
      ENDIF
    ELSE
      ende
    ENDIF
  ELSE  ! Fehler ist 94 ( Drucker war bei einer Ausgabe nicht bereit )
    ALERT 1,"Drucker nicht bereit",1,"WEITER|ABBRUCH",antwort&
    IF antwort&=1
      RESUME NEXT
    ELSE
      CLOSE
      MENU OFF
      GOSUB ersatz_hauptprogramm
    ENDIF
  ENDIF
RETURN
