' XMAL_RSC.BAS
' Beispielprogramm fÅr die Verwendung von 2 RSC-Dateien in einem BASIC-Programm
'
' Anregung von Dirk Schaun(ST-Computer 9/87)
' Umgesetzt von C in GFA-Basic von Karsten Kurzawa
'
DIM rsc_adr%(2)   ! Adressvariablen fÅr 2 RSC-Dateien
@rsrc_free        ! Speicherplatz freigeben
'
@rsrc_load("A:\TEST1.RSC",1) ! 1.RSC-Datei laden
' ! Achtung ! keine RSRC_FREE aufrufen
@rsrc_load("A:\TEST2.RSC",2) ! 2.RSC-Datei laden
'
' Die folgende Schleife zeichnet jeweils den 0.Dialog der Test-RSC's und fÅhrt
' sie aus
'
FOR i%=1 TO 2
  @set_rsc(i%)                        ! Aktuelle RSC-Nr. setzen
  @rsrc_gaddr(0,0)                    ! Adresse ermitteln
  tree%=LPEEK(ADDROUT)
  @form_center(tree%)                 ! Dialog zentrieren
  @objc_draw(tree%,0,7,0,0,640,400)   ! Dialog zeichnen
  @form_do(tree%,0)                   ! Dialog ausfÅhren
NEXT i%
'
END
'
PROCEDURE rsrc_load(nam$,nr%)
  LOCAL g.lobal%
  ' Erweiterte RSRC_LOAD-Routine
  ' öbergabeparameter:  Nam$ = Pfad und Name der RSC-Datei
  '                     Nr%  = Programmspezifische Nummer der RSC-Datei
  nam$=nam$+CHR$(0)
  LPOKE ADDRIN,VARPTR(nam$)
  GEMSYS 110
  g.lobal%=LPEEK(GB+4)! Holt den Zeiger auf das AES-Globalfeld aus dem AES-
  '                     Parameterblock
  rsc_adr%(nr%)=LPEEK(g.lobal%+10) ! Holt aus dem AES-Globalfeld den Zeiger
  '                                  der auf den Resource-Objektbaum zeigt
RETURN
'
' *****************************************************************************
'
PROCEDURE set_rsc(nr%)
  LOCAL g.lobal%
  ' Diese Prozedur setzt den Zeiger im AES-Globalfeld auf die Adresse der RSC-
  ' Datei mit der programmspezifischen Nummer Nr%
  g.lobal%=LPEEK(GB+4)    ! Holt den Zeiger auf das AES-Globalfeld aus dem AES-
  '                         Parameterblock
  LPOKE g.lobal%+10,rsc_adr%(nr%) ! setzt den Zeiger neu
RETURN
'
' *****************************************************************************
'
PROCEDURE rsrc_free
  GEMSYS 111
RETURN
'
PROCEDURE rsrc_gaddr(type%,index%)
  DPOKE GINTIN,type%
  DPOKE GINTIN+2,index%
  GEMSYS 112
RETURN
'
PROCEDURE form_do(tree%,start%)
  LPOKE ADDRIN,tree%
  DPOKE GINTIN,start%
  GEMSYS 50
RETURN
'
PROCEDURE form_center(tree%)
  LPOKE ADDRIN,tree%
  GEMSYS 54
RETURN
'
PROCEDURE objc_draw(tree%,start%,depth%,x%,y%,b%,h%)
  LPOKE ADDRIN,tree%
  DPOKE GINTIN,start%
  DPOKE GINTIN+2,depth%
  DPOKE GINTIN+4,x%
  DPOKE GINTIN+6,y%
  DPOKE GINTIN+8,b%
  DPOKE GINTIN+10,h%
  GEMSYS 42
RETURN
