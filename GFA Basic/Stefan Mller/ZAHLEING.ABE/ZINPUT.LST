zahl%=255
@zinput(255,2,2,*zahl%)
CLS
PRINT zahl%
PROCEDURE zinput(max%,x%,y%,zeiger%)
  LOCAL f%,z%,key%
  z%=LPEEK(zeiger%)
  PRINT "f";AT(x%,y%);STR$(z%)'"De";
  REPEAT
    key%=INP(2)
    IF key%>=48 AND key%<=57
      SUB key%,48
      f%=z%
      MUL f%,10
      ADD f%,key%
      IF f%<=max%
        z%=f%
      ELSE
        OUT 2,7
      ENDIF
      PRINT "f";AT(x%,y%);STR$(z%)'"De";
    ELSE
      IF key%=8
        DIV z%,10
        PRINT "f";AT(x%,y%);STR$(z%)'"D";
        IF z%=0
          PRINT "D";
        ENDIF
        PRINT "e";
      ENDIF
    ENDIF
  UNTIL key%=13
  *zeiger%=z%
RETURN
