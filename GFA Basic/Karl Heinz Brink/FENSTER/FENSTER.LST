'
' Idee und Programm fÅr die Hohe Auflîsung von Karl Heinz Brink
'
' énderungen fÅr die niedrige und mittlere Auflîsung Karl-Heinz Wallon
'
'
FOR i%=0 TO 200 STEP 20
  t$="Nr:"+STR$(i%)
  @fenster(i%,i%/2,400,80,t$)
NEXT i%
VOID INP(2)
PROCEDURE fenster(x%,y%,breit%,hoch%,ta$)
  LOCAL breit2%
  breit2%=breit%
  breit%=breit%+x%
  hoch%=hoch%+y%
  @form_dial(1,x%,y%,0,0,x%,y%,breit%,hoch%)
  DEFFILL 1,0
  BOX x%,y%,breit%,hoch%
  PBOX x%,y%,breit%-4,hoch%
  PBOX x%,y%,x%+10,y%+10
  DEFFILL 1,2,2
  PBOX x%+11,y%,breit%-10,y%+10
  DEFFILL 1,0
  PBOX breit%-10,y%,breit%,y%+10
  PBOX breit%-10,y%+10,breit%,y%+20
  PBOX breit%-10,y%+20,breit%,hoch%-8
  PBOX breit%-10,hoch%-8,breit%,hoch%+2
  PBOX breit%-10,hoch%+2,breit%,hoch%-8
  PBOX breit%-10,hoch%-20,breit%,hoch%-8
  PBOX x%,hoch%+2,x%+10,hoch%-8
  PBOX x%+10,hoch%+2,breit%-10,hoch%-8
  PBOX breit%-20,hoch%+2,breit%-10,hoch%-8
  TEXT x%+2,y%+8,CHR$(5)
  TEXT breit%-8,y%+8,CHR$(7)
  TEXT breit%-9,hoch%,CHR$(6)
  TEXT breit%-8,y%+18,CHR$(1)
  TEXT breit%-8,hoch%-10,CHR$(2)
  TEXT x%+2,hoch%-1,CHR$(4)
  TEXT breit%-18,hoch%-1,CHR$(3)
  IF breit2%-32>LEN(ta$)*8
    TEXT (x%+(breit2%-(LEN(ta$)*8))/2),y%+8,ta$
  ENDIF
  DEFFILL 1,2,1
  PBOX breit%-10,hoch%-18,breit%,hoch%-48
  PBOX breit%-50,hoch%+2,breit%-20,hoch%-8
  LINE x%,y%+20,breit%,y%+20
  HIDEM
  DEFFILL 1,0,0
  PBOX x%,y%+20,breit%-10,hoch%-8
  SHOWM
RETURN
PROCEDURE cls.fenster(x%,y%,breit%,hoch%)
  breit%=breit%+x%
  hoch%=hoch%+y%
  HIDEM
  COLOR 1
  DEFFILL 1,0,0
  PBOX x%,y%+20,breit%-10,hoch%-8
  DEFFILL 1,0,0
  SHOWM
RETURN
PROCEDURE form_dial(f%,x%,y%,b%,h%,xb%,yb%,bb%,hb%)
  DPOKE GINTIN,f%
  DPOKE GINTIN+2,x%
  DPOKE GINTIN+4,y%
  DPOKE GINTIN+6,b%
  DPOKE GINTIN+8,h%
  DPOKE GINTIN+10,xb%
  DPOKE GINTIN+12,yb%
  DPOKE GINTIN+14,bb%
  DPOKE GINTIN+16,hb%
  GEMSYS 51
RETURN
