' ****************************************
' Name..........................Bit-Muster
' Autor....................Herbert Kreusel
' Sprache.................GFA-Basic V 2,02
' Level..................................1
' Beschreibung......druckt ein Bit-Muster,
' Hilfe beim Erstellen eigener Zeichen und
'    Grafiken für den Drucker STAR NL10
' ****************************************
Lprint Chr$(27);"@";            !Drucker initialisieren
Lprint Chr$(27);"a";Chr$(1);    !Ausdruck zentrieren
Lprint "Bit-Muster"             !Titelzeile
Lprint Chr$(27);"a";Chr$(0);    !Ausdruck linksbündig
Lprint                          !Leerzeile
Lprint Chr$(27);"D";Chr$(2);Chr$(22);Chr$(42);Chr$(62);Chr$;Chr$(0);    !Tabulatoren einstellen
For M%=0 To 63                  !64 Zeilen
  For N%=0 To 3                 !4 Spalten
    I%=M%+N%*64                 !die richtigen Dez-Zahlen errechnen
    A$=Bin$(I%)                 !Dez-Zahlen in Binär-String
    A$=Right$("00000000"+A$,8)  !String auf 8 Stellen bringen
    B$=A$                       !String für Bildschirmausgabe
    For J%=1 To 8
      If Mid$(A$,J%,1)="1"
        Mid$(A$,J%,1)=Chr$(219) !Rechteck für '1' (Drucker)
        Mid$(B$,J%,1)="*"       !Stern für '1' (Bildschirm)
      Else
        Mid$(A$,J%,1)=Chr$(249) !Punkte für '0' (Drucker)
        Mid$(B$,J%,1)="."       !Punkte für '0' (Bildschirm)
      Endif
    Next J%
    Print B$;" = ";I%,          !Bildschirm-Ausgabe
    Lprint Chr$(9);             !Druckkopf zum nächsten Tabulator
    Lprint A$;" = ";I%;         !Drucker-Ausgabe
  Next N%                       !nächste Spalte
  Lprint                        !Zeile auffüllen
  Print                         !"
Next M%                         !nächste Zeile
Lprint Chr$(27);"@";            !alle Drucker-Befehle wieder normal
