' ****************************************
' *              DET_PRG                 *
' ****************************************
'
' Programm zum berechnen von Determinanten vierter Ordnung
' Udo Engelmann, 1987
Deftext 1,4,0,13
Text 100,20,"DETERMINANTEN VIERTER ORDNUNG"
Print
Print
Print "     Bitte geben Sie die Werte der Determinante ein, die so aussieht:"
Print
Print "         | a11  a12  a13  a14 |"
Print "         | a21  a22  a23  a24 |"
Print "         | a31  a32  a33  a34 |"
Print "         | a41  a42  a43  a44 |"
Print
Input " a11= ";A11
Input " a12= ";A12
Input " a13= ";A13
Input " a14= ";A14
Input " a21= ";A21
Input " a22= ";A22
Input " a23= ";A23
Input " a24= ";A24
Input " a31= ";A31
Input " a32= ";A32
Input " a33= ";A33
Input " a34= ";A34
Input " a41= ";A41
Input " a42= ";A42
Input " a43= ";A43
Input " a44= ";A44
A=(A11*A22-A12*A21)*(A33*A44-A34*A43)+(A13*A21-A11*A23)*(A32*A44-A34*A42)
B=(A11*A24-A14*A21)*(A32*A43-A33*A42)+(A12*A23-A13*A22)*(A31*A44-A34*A41)
C=(A14*A22-A12*A24)*(A31*A42-A33*A41)+(A13*A24-A14*A23)*(A31*A42-A32*A41)
Let Endwert=A+B+C
Print "Der Zahlenwert der Determinante betr„gt:       ";Endwert
