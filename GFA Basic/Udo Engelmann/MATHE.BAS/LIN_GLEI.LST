'
' ************************************
' *          LIN_GL_PRG              *
' ************************************
'
' Zur Berechnung eines linearen Gleichungssystems mit 3 Unbekannten
' Udo Engelmann, 1987
'
Print "L I N E A R E S   G L E I C H U N G S S Y S T E M   mit 3 Unbekannten:"
Print
Print "Das Gleichungssystem sieht folgendermaŞen aus:"
Print
Print "  a1 x + b1 y + c1 z = d1"
Print "  a2 x + b2 y + c2 z = d2"
Print "  a3 x + b3 y + c3 z = d3"
Print
Print "Geben Sie nun die Werte der Parameter ein:"
Print
Input "a1=   ";A1
Input "b1=   ";B1
Input "c1=   ";C1
Input "d1=   ";D1
Input "a2=   ";A2
Input "b2=   ";B2
Input "c2=   ";C2
Input "d2=   ";D2
Input "a3=   ";A3
Input "b3=   ";B3
Input "c3=   ";C3
Input "d3=   ";D3
Dx=D1*(B2*C3-B3*C2)-B1*(D2*C3-D3*C2)+C1*(D2*B3-D3*B2)
Dy=A1*(D2*C3-D3*C2)-D1*(A2*C3-A3*C2)+C1*(A2*D3-A3*D2)
Dz=A1*(B2*D3-B3*D2)-B1*(A2*D3-A3*D2)+D1*(A2*B3-A3*B2)
Dd=A1*(B2*C3-B3*C2)-B1*(A2*C3-A3*C2)+C1*(A2*B3-A3*B2)
If Dd=O
  Alert 1,"Achtung !!|Die Determinante wird NULL !",1,"O K|Na ja",B
Endif
If B=1 Or B=2
  Goto 1
Endif
X=Dx/Dd
Y=Dy/Dd
Z=Dz/Dd
Print "Die gesuchten Werte der Gleichung müssen lauten:"
Print
Print "    x = ";Int(X*100+0.5)/100
Print "    y = ";Int(Y*100+0.5)/100
Print "    z = ";Int(Z*100+0.5)/100
End
1:
Print "Leider ist dieses Gleichungssystem nach dieser Methode nicht zu lösen!"
Print
