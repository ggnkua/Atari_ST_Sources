' ******* Trigonometrische Funktionen als Plot *********
'
' Udo Engelmann, 1987
'
'
Text 20,20,"tan(x)"
Text 100,20,"cot(x)"
Text 200,100,"sin(x)"
Text 20,120,"cos(x)"
Line 0,200,640,200
Line 10,0,10,400
For A=110 To 700 Step 100
  Line A,190,A,210
  Line 0,100,20,100
  Line 0,300,20,300
Next A
For B=20 To 700 Step 10
  Line B,195,B,205
Next B
For C=15 To 700 Step 5
  Line C,198,C,202
Next C
For E=10 To 400 Step 10
  Line 5,E,15,E
Next E
For F=5 To 400 Step 5
  Line 8,F,12,F
Next F
Deftext 1,0,0,4
Text 107,220,"1"
Text 207,220,"2"
Text 307,220,"3"
Text 407,220,"4"
Text 507,220,"5"
Text 607,220,"6"
Text 22,95,"1"
Text 22,300,"-1"
Deftext 1,0,0,13
'
' ASCII - Code fÅr das Pi-Zeichen
'
Text 321,190,Chr$(227)
'
' Beginn der Ausrechnungen fÅr 4 Funktionen
'
For X=0 To 7 Step 0.01
  Let Y=Sin(X)
  Draw (10+100*X),(200-100*Y)
Next X
For X=0 To 7 Step 0.01
  Y=Cos(X)
  Draw (10+100*X),(200-100*Y)
Next X
For X=0 To 7 Step 0.01
  Y=Tan(X)
  Draw (10+100*X),(200-100*Y)
Next X
For X=0.001 To 7 Step 0.01
  Y=1/(Tan(X))
  Draw (10+100*X),(200-100*Y)
Next X
