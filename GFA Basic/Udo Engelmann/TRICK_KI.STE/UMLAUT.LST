'
' Umlaute besser ausdrucken
' Verhindert das gestauchte Aussehen der groûen Umlaute gegen¹ber den
' anderen Groûbuchstaben, indem die beiden Punkte extra gedruckt werden.
'
' Die Prozedur ist f¹r den Drucker Star NL-10 ausgelegt. Durch die én-
' derung der Druckercodes kann das Programm bestimmt auch auf andere
' Drucker angepaût werden.
'
' 17.01.1988 von Martin Kellner, Am Stein 9, 8480 Weiden 6
'
Test$="Aaé³OoôîUuö¹"
For I%=1 To Len(Test$)
  T$=Mid$(Test$,I%,1)
  @Druck(T$)
Next I%
Lprint
Edit
'
Procedure Druck(T$)
  If T$="é" Or T$="ô" Or T$="ö"
    If T$="é"
      Lprint "A";
    Endif
    If T$="ô"
      Lprint "O";
    Endif
    If T$="ö"
      Lprint "U";
    Endif
    ' Die beiden Papiertransporte sind einmalige Einstellungen, so daû
    ' der sonstige Zeilenabstand nicht ver³ndert wird!
    Lprint Chr$(8);                  ! Druckkopf eine Position zur¹ck
    Lprint Chr$(27);"j";Chr$(5);     ! Papier um 5/216 Inch r¹ckw³rts
    Lprint Chr$(27);"R";Chr$(1);     ! franz. Zeichensatz
    Lprint Chr$(126);                ! Doppelpunkt ¹ber Buchstaben
    Lprint Chr$(27);"R";Chr$(2);     ! dt. Zeichensatz
    Lprint Chr$(27);"J";Chr$(5);     ! Papier um 5/216 Inch vorw³rts
  Else
    If T$="³"
      Lprint Chr$(123);
    Else
      If T$="î"
        Lprint Chr$(124);
      Else
        If T$="¹"
          Lprint Chr$(125);
        Else
          Lprint T$;
        Endif
      Endif
    Endif
  Endif
Return
