' Beliebige Datumseingabe. Bei Eingabe des derzeitigen Jahrhunderts
' ist nur die Eingabe der letzten beiden Ziffern notwendig.
Dim Wt$(6)
Wt$(0)="Montag"
Wt$(1)="Dienstag"
Wt$(2)="Mittwoch"
Wt$(3)="Donnerstag"
Wt$(4)="Freitag"
Wt$(5)="Samstag"
Wt$(6)="Sonntag"
Ein:
Input "Datum : ",D$
@Wota(D$)
If Not F!
  Print "Der ";D$;" ist ein ";Wt$(Wt%);" in der ";Wo%+1;". Woche"
Endif
Goto Ein
' ------------------------------------------------------------------------------
Procedure Wota(D$)                      ! UP zur Berechnung des Wochentags und
  A=Instr(D$,".")+1                     ! der Woche aus einem beliebigen Datum
  T%=Val(Mid$(D$,1,A-2))
  D$=Mid$(D$,A)
  M%=Val(Left$(D$,2))
  A=Len(D$)-Instr(D$,".")
  If A=2
    J%=1900+Val(Right$(D$,2))
  Else
    J%=Val(Right$(D$,4))
  Endif
  If (J% Mod 4)=0 And ((J% Mod 400)=0 Or (J% Mod 100))
    Montg$="000031060091121152182213244274305335"
    Mt$="312931303130313130313031"
  Else
    Montg$="000031059090120151181212243273304334"
    Mt$="312831303130313130313031"
  Endif
  F!=0
  Mt%=Val(Mid$(Mt$,M%*2-1,2))
  If T%>Mt% Or M%>12
    Print "Datum ist fehlerhaft - Neueingabe"
    F!=-1
    Goto Ex_w
  Endif
  Tg%=Val(Mid$(Montg$,3*M%-2,3))
  I1%=(J%-1)/100
  I2%=(J%-1)/400
  Jt1%=365.25*(J%-1)-I1%+I2%
  Jt%=Jt1%+T%+Tg%-1
  Wt1%=Jt1% Mod 7
  Wt%=Jt% Mod 7
  Wo%=(Tg%+T%+Wt1%-1) Div 7
  If Wt1%>3
    Dec Wo%
  Endif
  Ex_w:
Return
