CLS
DIM acc$(15),acc%(15)               !FÅr max. 15 ACC's dim
~FSETDTA(BASEPAGE+128)
e%=FSFIRST("\*.ACC",-1)             !Hauptverzeichnis nach
DO UNTIL e%
  IF BYTE{BASEPAGE+158}
    INC a%
    acc$(a%)=CHAR{BASEPAGE+158}     !Namen in acc$() 
  ENDIF
  e%=FSNEXT()
LOOP
e%=FSFIRST("\*.ACX",-1)           !Suche nach ACX
DO UNTIL e%
  IF BYTE{BASEPAGE+158}
    INC a%
    acc$(a%)=CHAR{BASEPAGE+158}
  ENDIF
  e%=FSNEXT()
LOOP
IF a%<>0                            !ACCs vorhanden?
  PRINT "ACC Loader (c) 1990 by Martin R. Wollny"
  PRINT "       *** Gfa Club Software ***"
  PRINT
  PRINT a%;" Accessories gefunden"
  PRINT
  FOR b%=1 TO a%
    laenge%=LEN(acc$(b%))             !Extension ab-
    acc2$=LEFT$(acc$(b%),laenge%-4)   !trennen
    PRINT b%;TAB(3);acc2$;
    IF RIGHT$(acc$(b%),3)="ACC"       !gewÑhlt?
      PRINT TAB(19);"gewÑhlt"
      acc%(b%)=1                      !Status speichern
    ELSE
      PRINT
    ENDIF
  NEXT b%
  PRINT
  PRINT "Zur énderung des Status bitte die Nummer des Accessories 

eingeben."
  PRINT "Fertig='+-'"
  b%=CRSLIN-1
  DO
    PRINT AT(0,b%);"       ";TAB(0);
    FORM INPUT 2,a$
    EXIT IF a$="+-"
    auswahl%=VAL(a$)
    IF auswahl%<>0 AND NOT auswahl%>a%  !Status Ñndern
      PRINT AT(20,auswahl%+5);
      IF acc%(auswahl%)=1
        acc%(auswahl%)=0
        PRINT "        "
      ELSE
        acc%(auswahl%)=1
        PRINT "gewÑhlt"
      ENDIF
    ENDIF
  LOOP
  FOR b%=1 TO a%
    IF RIGHT$(acc$(b%),3)="ACC" AND acc%(b%)=0
      new$=LEFT$(acc$(b%),LEN(acc$(b%))-1)+"X"
      RENAME acc$(b%) AS new$
    ENDIF
    IF RIGHT$(acc$(b%),3)="ACX" AND acc%(b%)=1
      new$=LEFT$(acc$(b%),LEN(acc$(b%))-1)+"C"
      RENAME acc$(b%) AS new$
    ENDIF
  NEXT b%
ENDIF
