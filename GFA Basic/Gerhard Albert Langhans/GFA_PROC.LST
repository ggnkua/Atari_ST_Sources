Procedure Pf_menu
  Defmouse String$(74,Mki$(0))
  Deftext 1,4,0,13
  Defline 1,3,0,0
  Box 10,10,630,390
  Line 10,277,630,277
  Text 210,29,Titel$
  Line 10,35,630,35
  Defline 1,1,0,0
  For N=55 To 255 Step 20
    Line 10,N,630,N
  Next N
  Z01$="Pf 1 - Passwort-Schutz (auf diesem Programm ist kein Passwortschutz)"
  Z02$="Pf 2 - Ermitteln eines Wochentags"
  Z03$="Pf 3 - Langhans-Wecker-Company"
  Z04$="Pf 4 - Sechs aus Neunundvierzig"
  Z05$="Pf 5 - Schlu×-Gong"
  Z06$="Pf 6 - Grafik-Demo"
  Z07$="Pf 7 - Laufschrift mit Deftext-Angabe"
  Z08$="Pf 8 - Scroll-Demo 'Rei×verschlu×'"
  Z09$="Pf 9 - Scroll-Demo in Normalschrift"
  Z10$="Pf10 - Jalousie"
  Z11$="Undo - Directory anzeigen"
  Z12$="Help - zurück zum GEM-Desktop"
  Text 20,52,Z01$
  Text 20,72,Z02$
  Text 20,92,Z03$
  Text 20,112,Z04$
  Text 20,132,Z05$
  Text 20,152,Z06$
  Text 20,172,Z07$
  Text 20,192,Z08$
  Text 20,212,Z09$
  Text 20,232,Z10$
  Text 20,252,Z11$
  Text 20,272,Z12$
  Txt1$="Für den GFA-Club über 25 Prozeduren in ein kleines Programm gekleidet,"
  Txt2$="damit der Aufruf in den Club-Nachrichten nicht umsonst war."
  Txt3$="27.12.1987"
  Text 20,320,Txt1$
  Text 20,340,Txt2$
  Text 500,360,Txt3$
  On Menu Key Gosub Tastenmenu
  Do
    On Menu
  Loop
Return
Procedure Tastenmenu
  Taste=Menu(14) Div 256
  On Taste-&H3A Gosub F1,F2,F3,F4,F5,F6,F7,F8,F9,F10
  On Taste-&H60 Gosub Undo,Zurueck_zum_gem
Return
Procedure F1
  Cls
  Start:
  Print At(5,3);"Geben Sie bitte das Passwort ein! ";
  Form Input 4,Pass$   ! 4 Stellen für
  If Pass$="LGHS"      ! Passwort 'LGHS'
    Print At(5,5);"R i c h t i g  !!"
    Void Inp(2)
    Cls
    @Pf_menu
  Endif
  If Pass$<>"LGHS"
    Z%=Z%+1
    Print At(5,5);"Nochmal"
    If Z%=3
      Cls
      Print At(5,5);"Soso, wieder ein Hacker!"
      Void Inp(2)
      Cls
      @Pf_menu
    Else
      Goto Start
    Endif
  Endif
Return
Procedure F2
  Such_datum:
  Cls
  Defmouse String$(74,Mki$(0))
  Print At(3,5);"Geben Sie bitte das Datum ein (TT,MM,JJJJ beachten): ";
  Input D,E,F
  Print
  D=Int(D)
  E=Int(E)
  F=Int(F)
  Dat$=Str$(D)+"."+Str$(E)+"."+Str$(F)
  If F<-5000 Or F<-46
    Print
    Print "  Die Eingabe ";F;" liegt vor der Julianischen Kalenderreform von 46 v. Chr."
    Void Inp(2)
    Goto Such_datum
  Endif
  If F<1582 And E<10 And D<15
    Print
    Print "  vor dem 15. Oktober 1582 galt der Julianische Kalender"
    Juliusflag=1
  Endif
  If F<1582 And E<10 And D<15 Or F=1582 And E<10 And D>4
    Print
    Print "  die Tage 5. bis 14. Oktober 1582 sind gefallen"
  Endif
  A=1
  B=1
  C=2000
  Berechnungstag=A
  If F=C And E=B
    A=D
  Endif
  A=Int(A)
  B=Int(B)
  C=Int(C)
  If B>=1 And B<=13 And C>=1583
    Goto Berechnung
  Endif
  Berechnung:
  Schaltjahr:
  Y=0
  For X=F To C
    If X Mod 4=0
      Y=Y+1
    Endif
    If X Mod 100=0
      Y=Y-1
    Endif
    If X Mod 400=0
      Y=Y+1
    Endif
  Next X
  If Flag=1
    Goto Jahre
  Endif
  Monatsberechnung:
  Restore Monatsberechnung
  Dim G(12)
  For X=1 To 12
    Read G(X)
  Next X
  Data 31,28,31,30,31,30,31,31,30,31,30,31
  If C Mod 4=0 Or F Mod 4=0
    G(2)=28
  Endif
  If C Mod 100=0 Or F Mod 100=0
    G(2)=28
  Endif
  If C Mod 400=0 Or F Mod 400=0
    G(2)=29
  Endif
  If A>=1 And A<=G(B) And D>=1 And D<=G(E)
    Goto Februar
  Endif
  Februar:
  G(2)=28
  Jahre:
  J=365*(C-F)
  If B<>1
    For X=1 To B-1
      H=H+G(X)
    Next X
  Endif
  H=H+A
  If E<>1
    For X=1 To E-1
      K=K+G(X)
    Next X
  Endif
  K=K+D
  L=J+H-K+Y
  If C Mod 4=0 And B<3
    L=L-1
  Endif
  If C Mod 100=0 And B<3
    L=L+1
  Endif
  If C Mod 400=0 And B<3
    L=L-1
  Endif
  If F Mod 4=0 And E>2
    L=L-1
  Endif
  If F Mod 100=0 And E>2
    L=L+1
  Endif
  If F Mod 400=0 And E>2
    L=L-1
  Endif
  If Flag=1
    Goto Wochentagberechnung
  Endif
  If L>=0
    Goto Berechnung_t
  Endif
  Berechnung_t:
  E$=Str$(E)
  D$=Str$(D)
  Y$=E$+D$
  Flag=1
  H=0
  K=0
  A=D
  B=E
  C=F
  D=1
  E=1
  F=1900
  Goto Schaltjahr
  Wochentagberechnung:
  T=L-7*Int(L/7)+1
  Wochentag:
  Restore Wochentag
  If Juliusflag=1
    For X=1 To T
      Read Wt$
    Next X
    Data Montag,Dienstag,Mittwoch
    Data Donnerstag,Freitag,Samstag,Sonntag
  Else
    For X=1 To T
      Read Wt$
    Next X
    Data Dienstag,Mittwoch
    Data Donnerstag,Freitag,Samstag,Sonntag,Montag
  Endif
  Cls
  Print At(5,13);"  Der gesuchte Wochentag für den ";Dat$;" ist ";Wt$
  Void Inp(2)
  Cls
  @Pf_menu
Return
Procedure F3
  Cls
  Do
    @Uhr
    Exit If Inkey$="q"
    Edit
  Loop
Return
Procedure F4
  Cls
  Erase A()
  Erase B()
  Dim A(6),B(7)
  Sound 1,15,8,3
  Wave 1,1,9,65535
  Pause 75
  Schleife:
  Hidem
  L$=" 6  a u s  49 "
  Deftext 1,5,0,32
  Text 200,75,L$
  Print At(32,7);"E n d e  mit 'E'"
  For I=1 To 7
    B_von_i:
    B(I)=1+Int(Rnd*49)
    For J=1 To I-1
      If B(I)=B(J)
        B(I)=1+Int(Rnd*49)
      Endif
    Next J
  Next I
  Richtige=Bed
  For I=1 To 6
    For J=1 To 6
      If A(I)=B(J)
        Richtige=Richtige+1
      Endif
      Exit If A(I)=B(J)
    Next J
  Next I
  For I=1 To 6
    If A(I)=B(7)
      Richtige=Richtige+0.5
    Endif
    Exit If A(I)=B(7)
  Next I
  @Sort
  Print
  Print At(10,20);"                                                            "
  Print At(15,20);" Gewinnzahlen: ";
  For I=1 To 6
    Print B(I);" ";
  Next I
  Print At(50,20);"Zusatzzahl : ";B(7)
  Sound 1,15,10,6
  Wave 1,1,9,30000
  F$=Inkey$
  If F$="e" Or F$="E"
    Void Inp(2)
    Cls
    @Pf_menu
  Else
    Pause 100
    Goto Schleife
  Endif
Return
Procedure F5
  Cls
  Bload "\screen\start.scn",Xbios(2)
  Sound 1,15,1,4,20
  Sound 2,15,4,4,20
  Sound 3,15,8,4,20
  Wave 7,7,0,65535,300
  Wave 0,0
  Cls
  @Pf_menu
Return
Procedure F6
  Cls
  For Punkt=1 To 2
    X=Rnd(1)*640
    Y=Rnd(1)*400
    Schrittweite=Rnd(1)*10+2
    For X1=1 To 640 Step Schrittweite
      Line X,Y,X1,400
      Line X,Y,X1,1
    Next X1
    For Y1=400 To 1 Step -(Schrittweite/2)
      Line X,Y,640,Y1
      Line X,Y,1,Y1
    Next Y1
  Next Punkt
  For I=1 To 10000
  Next I
  Cls
  For X=0 To 640 Step 2
    Line 640-X,400,X,0
  Next X
  For Y=0 To 400 Step 2
    Line 640,400-Y,0,Y
  Next Y
  Cls
  For X=0 To 640 Step 2
    Line 0,0,X,400
    Line 640,400,X,0
  Next X
  Pause 100
  Cls
  @Pf_menu
Return
Procedure F7
  Defmouse String$(74,Mki$(0))
  ' Txt.x%=130
  ' Txt.y%=100
  ' L.txt$="Gerhard Albert Langhans "
  ' @Laufschrift(Txt.x%,Txt.y%,L.txt$)
  @Laufschrift(130,100,"Langhans ")
  Void Inp(2)
  Txt.x%=170
  Txt.y%=150
  L.txt$="Bodelschwinghweg 3 "
  @Laufschrift(Txt.x%,Txt.y%,L.txt$)
  Void Inp(2)
  Cls
  @Pf_menu
Return
Procedure F8
  Cls
  Deftext 1,16,0,32
  Y=200
  T$="S REISSVERSCHLUSS ZU"
  For X=20 To 620 Step 5
    Text X,Y,T$
  Next X
  Deftext 1,4,0,30
  T$="REISSVERSCHLUSS AUF"
  For X=620 To 20 Step -1
    Text X,Y,T$
  Next X
  Void Inp(2)
  Cls
  @Pf_menu
Return
Procedure F9
  A$="Ihre  G l ü c k s z a h l  ist  die"
  A$=A$+" .... "
  Cls
  Repeat
    ' Fensterausschnitt: 13 = Zeile (ypos)
    '                    10 = Zeilenanfang
    '                    A$ = laufender Text
    '                    60 = Textlänge
    @Scroll(13,10,A$,60)
  Until Inkey$<>""
  Cls
  @Pf_menu
Return
Procedure F10
  Cls
  ' Bn$="\screen\fladder.scn"
  Bn$="\screen\old_man.scn"
  ' Bn$="\screen\start.scn"
  Dim Dummy%(32000/4)
  Basis%=Lpeek(Arrptr(Dummy%()))
  Bload Bn$,Basis%
  For J%=0 To 3120 Step 80
    For I%=0 To 28800 Step 3200
      Bmove Basis%+I%+J%,Xbios(2)+I%+J%,80
    Next I%
    Pause 3
  Next J%
  Void Inp(2)
  @Schluss
Return
Procedure Undo
  Cls
  Anzahl=300
  Dim Datei$(Anzahl),Laenge$(Anzahl),Uhr$(Anzahl),Datum$(Anzahl),Ordner$(Anzahl)
  Dim Stack$(100)
  Laufwerk$="A"
  Datei=0
  A$="*.*"
  @Directory(Laufwerk$)
  @Anzeigen
  Void Inp(2)
  Cls
  @Pf_menu
Return
Procedure Schluss
  Color 1
  For I%=0 To 320
    Box I%,I%,639-I%,399-I%/320*200
  Next I%
  Deffill 0,2,8
  Pbox 0,0,639,399
  @Pf_menu
Return
Procedure Laufschrift(Txt.x%,Txt.y%,L.txt$)
  Cls
  B.txt$=""
  Do
    Deftext 1,4,0,32
    Taste$=Inkey$
    L.txt$=Right$(L.txt$,Len(L.txt$)-1)+Left$(L.txt$)
    B.txt$=L.txt$
    Text Txt.x%,Txt.y%,B.txt$
    Inc Txt.cnt%
    If Txt.cnt%=Len(L.txt$)
      Txt.cnt%=0
    Endif
    Pause 5
    If Mousek<>0 Or Taste$=Chr$(13)
      L.flag%=1
    Endif
    '   Exit If Txt.cnt%=0 And L.flag%=1
    Exit If L.flag%=1
  Loop
  L.flag%=0
Return
Procedure Scroll(Xpos,Ypos,Satz$,Ausschnitt)
  Local I
  If Ausschnitt>79-Xpos
    Ausschnitt=79-Xpos
  Endif
  A$=Space$(Ausschnitt)+A$
  For I=1 To Len(A$)
    Print At(Ypos,Xpos);Mid$(A$,I,Ausschnitt)
    Pause 10
  Next I
Return
Procedure Uhr
  Local M_x%,M_y%,Size%,Uhrx,Uhry,Sek,Min,Std,T%,Dd$,K%
  Deffill ,0,0
  Get 530,20,630,120,Dd$
  M_x%=320
  M_y%=200
  Size%=150
  Pbox M_x%-Size%,M_y%-Size%,M_x%+Size%,M_y%+Size%
  L1$="L W C"
  L2$="Langhans Wecker Company"
  Deftext 1,4,0,13
  Text 295,100,L1$
  Deftext 1,5,0,4
  Text 250,120,L2$
  A12$="12"
  A3$="3"
  A6$="6"
  A9$="9"
  A15$="15"
  A18$="18"
  A21$="21"
  A24$="24"
  Deftext 1,4,0,13
  If Time$<"12:00:00"
    Text 308,70,A12$
    Text 315,340,A6$
    Text 180,205,A9$
    Text 450,205,A3$
  Endif
  If Time$>"12:00:00"
    Text 308,70,A24$
    Text 312,340,A18$
    Text 180,205,A21$
    Text 442,205,A15$
  Endif
  Text Pos*7.9,300,Wt$
  Text 280,320,Date$
  For I=1 To 12
    Uhrx=Sin(2*Pi*I/12)
    Uhry=Cos(2*Pi*I/12)
    Line M_x%+(Size%-7)*Uhrx,M_y%+(Size%-7)*Uhry,M_x%+(Size%-2)*Uhrx,M_y%+(Size%-2)*Uhry
  Next I
  Graphmode 3
  Repeat
    Sek=Val(Mid$(Time$,7))*Pi/30
    Min=Val(Mid$(Time$,4))*Pi/30+Sek/60
    Std=Val(Time$)*Pi/6+Min/12
    Defline 1,3
    Line M_x%,M_y%,M_x%+Size%/2*Sin(Std),M_y%-Size%/2*Cos(Std)
    Line M_x%,M_y%,M_x%+(Size%-Size%/10)*Sin(Min),M_y%-(Size%-Size%/10)*Cos(Min)
    Defline 1,1
    Line M_x%,M_y%,M_x%+Size%*Sin(Sek),M_y%-Size%*Cos(Sek)
    T%=Timer
    Repeat
      K%=Mousek+Len(Inkey$)
    Until T%+400=Timer Or K%
    Defline 1,3
    Line M_x%,M_y%,M_x%+Size%/2*Sin(Std),M_y%-Size%/2*Cos(Std)
    Line M_x%,M_y%,M_x%+(Size%-Size%/10)*Sin(Min),M_y%-(Size%-Size%/10)*Cos(Min)
    Defline 1,1
    Line M_x%,M_y%,M_x%+Size%*Sin(Sek),M_y%-Size%*Cos(Sek)
  Until K%
  Put 530,20,Dd$
  Graphmode 1
Return
Procedure Sort
  Flag=0
  For I=0 To 5
    If B(I)>B(I+1)
      Swap B(I),B(I+1)
      Flag=1
    Endif
  Next I
  If Flag=1
    @Sort
  Endif
Return
Procedure Anzeigen
  If Datei>0
    Print
    Print Diskname$
    Print
    For L=1 To Datei
      Print " ";Datei$(L);" ";Laenge$(L);" ";Datum$(L);" ";Uhr$(L);" ";Ordner$(L)
      If L=20 Or L=40 Or L=60 Or L=80 Or L=100 Or L=120 Or L=140 Or L=160
        Void Inp(2)
      Endif
    Next L
  Endif
Return
Procedure Directory(Laufwerk$)
  Local A,L,Dta,Stack,Attribut,Fehler
  Local Joker$,Datei$,Laenge$,Uhr$,Datum$,Ordner1$,Ordner2$
  Joker$=A$
  Dta=Gemdos(47)
  Poke Dta+30,0
  Chdrive (Asc(Laufwerk$)-64)
  Chdir "\"
  Void Gemdos(78,L:Varptr(Joker$),8)
  @Dta_auslesen
  Diskname$=Datei$+" Diskette mit  "+Str$(Dfree(0))+" Bytes frei"
  Do
    @Datei_auslesen
    Exit If Stack=0
    Chdir Stack$(Stack)
  Loop
Return
Procedure Datei_auslesen
  Ordner1$=String$(30," ")
  Ordner2$=Stack$(Stack)
  Lset Ordner1$=Ordner2$
  If Stack>0
    Dec Stack
  Endif
  Fehler=Gemdos(78,L:Varptr(Joker$),1+2+4+8+16+32)
  If Fehler=0
    @Dta_auslesen
    Do
      If Attribut=16
        If Right$(Datei$)<>"."
          Inc Stack
          Stack$(Stack)=Ordner2$+"\"+Datei$
        Endif
      Else
        Inc Datei
        While Len(Datei$)<12
          Datei$=Datei$+" "
        Wend
        Datei$(Datei)=Datei$
        Laenge$(Datei)=Laenge$
        Uhr$(Datei)=Uhr$
        Datum$(Datei)=Datum$
        Ordner$(Datei)=Ordner1$
      Endif
      Fehler=Gemdos(79)
      Exit If Fehler<>0
      @Dta_auslesen
    Loop
  Endif
Return
Procedure Dta_auslesen
  Datei$=""
  For L=1 To 14
    A=Peek(Dta+29+L)
    Exit If A=0
    Datei$=Datei$+Chr$(A)
  Next L
  Laenge$="      "
  Rset Laenge$=Str$(Lpeek(Dta+26))
  A=Dpeek(Dta+22)
  Uhr$="00:00:00"
  H$=Str$((A And &X1111100000000000)/2048)
  Mid$(Uhr$,3-Len(H$))=H$
  H$=Str$((A And &X11111100000)/32)
  Mid$(Uhr$,6-Len(H$))=H$
  H$=Str$((A And &X11111)*2)
  Mid$(Uhr$,9-Len(H$))=H$
  A=Dpeek(Dta+24)
  Datum$="00.00."
  H$=Str$(A And &X11111)
  Mid$(Datum$,3-Len(H$))=H$
  H$=Str$((A And &X111100000)/32)
  Mid$(Datum$,6-Len(H$))=H$
  Datum$=Datum$+Str$(((A And &X1111111000000000)/512)+1980)
  Attribut=Peek(Dta+21)
Return
Procedure Zurueck_zum_gem
  Color 1
  For I%=0 To 320
    Box I%,I%,639-I%,399-I%/320*200
  Next I%
  Deffill 0,2,8
  Pbox 0,0,639,399
  Edit
Return
