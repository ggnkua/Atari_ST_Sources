'
' ------------------------------------------------------------------------------
' -          Initialisierung der Variablen und Aufbau des Menü-Feldes          -
' ------------------------------------------------------------------------------
IF XBIOS(4)=0
  ALERT 3,"|Bitte benutzen Sie die| MITTLERE-Auflösung!",1," ENDE ",ta%
  QUIT
ENDIF
CLEAR
DIM def_farben%(3)
FOR i%=0 TO 3
  def_farben%(i%)=XBIOS(7,i%,-1)
NEXT i%
res%=3-XBIOS(4)
IF res%=2
  SETCOLOR 0,0,0,0
  SETCOLOR 1,7,7,0
  SETCOLOR 2,7,1,0
  SETCOLOR 3,0,4,7
  norm%=6
  small%=4
  med%=11
  big%=14
ELSE
  SETCOLOR 0,7,7,7
  SETCOLOR 1,0,0,0
  norm%=13
  small%=6
  med%=20
  big%=26
ENDIF
col0%=0
col1%=1
col2%=2
col3%=3
OPENW 0,0,0
CLS
HIDEM
CLR eintraege%
maxmenue%=50
felder%=1
ins!=TRUE
datei_flag!=FALSE
inf$="einfügen überschr."
boot_sect$=CHR$(0)+CHR$(0)+"format"+CHR$(188)+CHR$(165)+CHR$(165)+CHR$(0)+CHR$(2)+CHR$(2)+CHR$(1)+CHR$(0)+CHR$(2)+CHR$(112)+CHR$(0)+CHR$(208)+CHR$(2)+CHR$(248)+CHR$(5)+CHR$(0)+CHR$(9)+CHR$(0)+CHR$(1)+CHR$(0)+CHR$(0)+CHR$(0)+STRING$(482,"N")
LET hex$="ABCDEF0123456789"
LET dec$=" 0123456789"
DIM m$(maxmenue%),drucker$(26),feld_name$(9),feld_laenge%(9),app_feld_laenge%(9),feld$(81),xpos%(82),ypos%(82),laenge%(81),ok$(81),in$(81)
FOR i%=0 TO maxmenue%
  READ m$(i%)
  EXIT IF m$(i%)="MENU END"
NEXT i%
m$(i%)=""
DATA INFO,  Über Datei-STar,----------------------,ACC_1,ACC_2,ACC_3,ACC_4,ACC_5,ACC_6,""
DATA DISK,  Datei laden,  Datei speichern,  Datei anhängen,-------------------,  Zeige Disk-Info,-------------------,  Datei löschen,  Disk formatieren,""
DATA DATEI,  Daten eingeben,  Daten ausgeben,---------------------,  Eintrag suchen,  Eintrag ändern,---------------------,  Daten sortieren,---------------------,  Eintrag löschen,  Neue Datei anlegen,""
DATA NAMEN,  Internen Namen ändern ,  Feld-Namen ändern,""
DATA DRUCKER,  Druckeranpassung eingeben,-----------------------------,  Druckeranpassung laden,  Druckeranpassung speichern,""
DATA ENDE,  Zurück zum Desktop ,""
DATA "MENU END"
ARRAYFILL feld_laenge%(),1
id1$="Datei von Datei-STar"
id2$="Ende der Infodatei für Datenfiles"
id3$="Druckeranpassung von Datei-STar"
id4$="Ende der Druckeranpassungsdatei"
m1$="linke Maustaste  anhalten     rechte Maustaste  Abbruch"
m2$="             weiter mit Mausklick oder Taste             "
int_name$="Unbenannt"
filename$=""
path$="\DAT-STAR\"
file$="DAT-STAR.CON"
MENU m$()
MENU 12,2
MENU 13,2
MENU 21,2
MENU 22,2
MENU 24,2
MENU 25,2
MENU 27,2
MENU 29,2
MENU 33,2
MENU 34,2
DEFFILL 1,2,4
PBOX -1,18 DIV res%,640,400 DIV res%
DEFFILL 0,0
' ---------- Laden der Druckeranpassungstabelle --------------------------------
IF EXIST(path$+file$)
  OPEN "I",#1,path$+file$
  ok!=TRUE
ELSE
  IF EXIST(file$)
    OPEN "I",#1,file$
    ok!=TRUE
  ELSE
    ok!=FALSE
    ALERT 3,"    H A L T    | | Wo ist das Druckeran-|passungsfile?|",1," WEITER ",ta%
  ENDIF
ENDIF
IF ok!=TRUE
  INPUT #1,id$
  IF id$=id3$
    FOR i%=0 TO 26
      INPUT #1,drucker$(i%)
    NEXT i%
    CLOSE #1
  ELSE
    ALERT 2,"|Das Anpassungsfile ist|im falschen Datenformat!|",1," WEITER ",ta%
    CLOSE #1
  ENDIF
ELSE
  drucker$(0)="nicht installiert"
ENDIF
CLOSEW 0
DEFTEXT col1%,0,0,small%
TEXT 395,10 DIV res%,drucker$(0)
OPENW 0,0,0
SHOWM
DEFMOUSE 3
' ------------------------------------------------------------------------------
' -          Abfrage des Menüs und Sprung zu den Unterprogrammen               -
' ------------------------------------------------------------------------------
ON MENU  GOSUB menue_select
ON BREAK CONT
ON ERROR GOSUB fehler
DO
  ON MENU
  ON BREAK CONT
  ON ERROR GOSUB fehler
LOOP
' ------------------------------------------------------------------------------
PROCEDURE menue_select
  LOCAL ok!,b$,c$,i%,j%,ta%,ausg$,ladende%
  MENU OFF
  DEFMOUSE 3
  CLOSE #1
  ' ----------------------------------------------------------------------------
  ' -          Info ausgeben                                                   -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Über Datei-STar"
    GET 100,100 DIV res%,540,300 DIV res%,b$
    DEFFILL 0,0
    @graf_growbox(100,100,440,200,40,18)
    PBOX 100,100 DIV res%,540,300 DIV res%
    FOR i%=0 TO 1
      BOX 100+(i%*2),(100+(i%*2)) DIV res%,540-(i%*2),(300-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT col2%,16+(ABS(res%=2)),0,big%
    TEXT 220,140 DIV res%,200,"Datei-STar"
    IF res%=1
      DEFTEXT col1%,4,0,small%
      TEXT 384,120 DIV res%,"V1.5"
    ENDIF
    FOR i%=0 TO 1
      RBOX 205+i%,(110+i%) DIV res%,430-i%,(147-i%) DIV res%
    NEXT i%
    DEFTEXT col2%,16,0,norm%
    TEXT 113,180 DIV res%,415,"Ein Produkt des Äktiesend-ATARI-Computer-Clubs"
    TEXT 207,200 DIV res%,"Į Roland Szkudlarek"
    DEFTEXT col3%,13,0,norm%
    TEXT 120,230 DIV res%,"Im Vertrieb von:"
    DEFTEXT col3%,1,0,norm%
    TEXT 270,230 DIV res%,"Äktiesend-ATARI-Computer-Club"
    DEFTEXT col1%,0,0,norm%
    TEXT 208,256 DIV res%,"geschrieben in GfA-BASIC"
    FOR i%=0 TO 2
      BOX 270+i%,(266+i%) DIV res%,370-i%,(293-i%) DIV res%
    NEXT i%
    TEXT 296,286 DIV res%,48,"WEITER"
    REPEAT
      MOUSE mx%,my%,mk%
      IF (NOT (mx%>99 AND mx%<541) AND (my%>99 DIV res% AND my%<301 DIV res%)) AND (mk%=1)
        OUT 2,7
      ENDIF
    UNTIL ((mx%>272 AND mx%<368) AND (my%>(267 DIV res%) AND my%<(291 DIV res%)) AND (mk%=1)) OR (INKEY$=CHR$(13))
    PUT 100,100 DIV res%,b$
    @graf_shrinkbox(100,100,440,200,40,18)
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Datei laden                                                     -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Datei laden"
    IF datei_flag!=TRUE
      ALERT 2,"Das Laden einer neuen Datei|bewirkt das Löschen der|im Speicher befindlichen!| |Wollen Sie das?",2,"JA| NEIN ",ta%
      IF ta%=2
        GOTO label_1
      ENDIF
    ENDIF
    GET 157,31 DIV res%,480,53 DIV res%,w$
    DEFFILL 0,0
    @graf_growbox(157,31,323,22,86,18)
    PBOX 157,31 DIV res%,480,53 DIV res%
    FOR i%=0 TO 1
      BOX 157+(i%*2),(31+(i%*2)) DIV res%,480-(i%*2),(53-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT 1,0,0,norm%
    TEXT 272,47 DIV res%,"Datei laden"
    @graf_growbox(157,52,323,314,86,18)
    FILESELECT "A:\*.DAT","",file$
    @graf_shrinkbox(157,52,323,314,86,18)
    PUT 157,31 DIV res%,w$
    @graf_shrinkbox(157,31,323,22,86,18)
    IF file$<>"" AND EXIST(file$)
      DEFMOUSE 2
      filename$=file$
      OPEN "I",#1,filename$
      LINE INPUT #1,id$
      IF id$=id1$
        LINE INPUT #1,int_name$
        INPUT #1,eintraege%
        INPUT #1,felder%
        FOR i%=1 TO felder%
          INPUT #1,feld_laenge%(i%)
          LINE INPUT #1,feld_name$(i%)
        NEXT i%
        datei_flag!=TRUE
        CLR feld%
        FOR i%=1 TO felder%
          feld%=feld%+feld_laenge%(i%)
        NEXT i%
        maxeintrag%=FRE(0) DIV feld%
        IF maxeintrag%*felder%>32766
          maxeintrag%=32766 DIV felder%
        ENDIF
        ERASE datei$()
        DIM datei$(felder%,maxeintrag%)
        ladende%=eintraege%
        IF eintraege%>maxeintrag%
          ALERT 3,"Die zu Ladende% Datei ist|zu gro×!|Trotzdem laden?",1,"JA| NEIN ",ta%
          IF ta%=1
            ladende%=maxeintrag%
          ELSE
            CLR ladende%
          ENDIF
        ENDIF
        IF ladende%>0
          LINE INPUT #1,dummy$
          GET 30,183 DIV res%,610,206 DIV res%,b$
          DEFFILL 0,0
          @graf_growbox(30,183,580,23,86,18)
          PBOX 30,183 DIV res%,610,206 DIV res%
          COLOR col3%
          FOR j%=0 TO 1
            BOX 30+(j%*2),(183+(j%*2)) DIV res%,610-(j%*2),(206-(j%*2)) DIV res%
          NEXT j%
          COLOR col1%
          DEFTEXT col3%,1,0,norm%
          TEXT 200,200 DIV res%,180,"Ich lade Datensatz #"
          FOR i%=1 TO ladende%
            TEXT 392,200 DIV res%,STRING$(5-LEN(STR$(i%)),"0")+STR$(i%)
            k%=0
            WHILE k%<felder%
              INC k%
              LINE INPUT #1,datei$(k%,i%)
            WEND
          NEXT i%
          PUT 30,183 DIV res%,b$
          @graf_shrinkbox(30,183,580,23,86,18)
          MENU 12,3
          MENU 13,3
          MENU 21,3
          MENU 22,3
          MENU 24,3
          MENU 25,3
          MENU 27,3
          MENU 29,3
          MENU 33,3
          MENU 34,3
        ENDIF
        CLOSE #1
      ELSE
        ALERT 2,"|Dies ist kein Datei-STar|Daten-File",1,"ABBRUCH",ta%
      ENDIF
    ENDIF
    DEFMOUSE 3
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Datei speichern                                                 -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Datei speichern"
    GET 157,31 DIV res%,480,53 DIV res%,w$
    DEFFILL 0,0
    @graf_growbox(157,31,323,22,86,18)
    PBOX 157,31 DIV res%,480,53 DIV res%
    FOR i%=0 TO 1
      BOX 157+(i%*2),(31+(i%*2)) DIV res%,480-(i%*2),(53-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT 1,0,0,norm%
    TEXT 256,47 DIV res%,"Datei speichern"
    @graf_growbox(157,52,323,314,86,18)
    FILESELECT "A:\*.DAT",filename$,file$
    @graf_shrinkbox(157,52,323,314,86,18)
    PUT 157,31 DIV res%,w$
    @graf_shrinkbox(157,31,323,22,86,18)
    IF file$<>"" AND RIGHT$(file$,4)=".DAT"
      DEFMOUSE 2
      OPEN "O",#1,file$
      PRINT #1,id1$
      PRINT #1,int_name$
      PRINT #1,eintraege%
      PRINT #1,felder%
      FOR j%=1 TO felder%
        PRINT #1,feld_laenge%(j%)
        PRINT #1,feld_name$(j%)
      NEXT j%
      PRINT #1,"--------------------------------------------------------------------------------"
      GET 30,183 DIV res%,610,206 DIV res%,b$
      DEFFILL 0,0
      @graf_growbox(30,183,580,23,86,18)
      PBOX 30,183 DIV res%,610,206 DIV res%
      COLOR col3%
      FOR j%=0 TO 1
        BOX 30+(j%*2),(183+(j%*2)) DIV res%,610-(j%*2),(206-(j%*2)) DIV res%
      NEXT j%
      COLOR col1%
      DEFTEXT col3%,1,0,norm%
      TEXT 180,200 DIV res%,180,"Ich speichere Datensatz #"
      FOR i%=1 TO eintraege%
        TEXT 412,200 DIV res%,STRING$(5-LEN(STR$(i%)),"0")+STR$(i%)
        k%=0
        WHILE k%<felder%
          INC k%
          PRINT #1,datei$(k%,i%)
        WEND
      NEXT i%
      PUT 30,183 DIV res%,b$
      @graf_shrinkbox(30,183,580,23,86,18)
      CLOSE #1
    ENDIF
    DEFMOUSE 3
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Datei anhängen                                                  -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Datei anhängen"
    ERASE app_feld_laenge%()
    DIM app_feld_laenge%(9)
    GET 157,31 DIV res%,480,53 DIV res%,w$
    DEFFILL 0,0
    @graf_growbox(157,31,323,22,86,18)
    PBOX 157,31 DIV res%,480,53 DIV res%
    FOR i%=0 TO 1
      BOX 157+(i%*2),(31+(i%*2)) DIV res%,480-(i%*2),(53-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT 1,0,0,norm%
    TEXT 260,47 DIV res%,"Datei anhängen"
    @graf_growbox(157,52,323,314,86,18)
    FILESELECT "A:\*.DAT","",file$
    @graf_shrinkbox(157,52,323,314,86,18)
    PUT 157,31 DIV res%,w$
    @graf_shrinkbox(157,31,323,22,86,18)
    IF file$<>"" AND EXIST(file$)
      DEFMOUSE 2
      OPEN "I",#2,file$
      LINE INPUT #2,id$
      IF id$=id1$
        LINE INPUT #2,dummy$
        INPUT #2,app_eintraege%
        INPUT #2,app_felder%
        IF app_felder%=felder%
          app_flag!=TRUE
          FOR i%=1 TO felder%
            INPUT #2,app_feld_laenge%(i%)
            LINE INPUT #2,dummy$
          NEXT i%
          FOR i%=1 TO felder%
            IF app_feld_laenge%(i%)<>feld_laenge%(i%)
              app_flag!=FALSE
            ENDIF
          NEXT i%
        ELSE
          app_flag!=FALSE
        ENDIF
      ENDIF
      IF app_flag!=FALSE
        ALERT 3,"|Das Datenformat der beiden|Dateien stimmt nicht|überein!",1,"ABBRUCH",ta%
      ELSE
        IF eintraege%+app_eintraege%>maxeintrag%
          ALERT 2,"|Die anzuhängende Datei|ist zu lang!|Trotzdem laden?",1,"JA| NEIN ",ta%
          IF ta%=1
            app_eintraege%=maxeintrag%-eintraege%
          ELSE
            CLR app_eintraege%
          ENDIF
        ENDIF
        IF app_eintraege%>0
          LINE INPUT #2,dummy$
          GET 30,183 DIV res%,610,206 DIV res%,b$
          DEFFILL 0,0
          @graf_growbox(30,183,580,23,86,18)
          PBOX 30,183 DIV res%,610,206 DIV res%
          COLOR col3%
          FOR j%=0 TO 1
            BOX 30+(j%*2),(183+(j%*2)) DIV res%,610-(j%*2),(206-(j%*2)) DIV res%
          NEXT j%
          COLOR col1%
          DEFTEXT col3%,1,0,norm%
          TEXT 200,200 DIV res%,180,"Ich lade Datensatz #"
          FOR i%=1 TO app_eintraege%
            TEXT 392,200 DIV res%,STRING$(5-LEN(STR$(i%+eintraege%)),"0")+STR$(i%+eintraege%)
            k%=0
            WHILE k%<felder%
              INC k%
              LINE INPUT #2,datei$(k%,i%+eintraege%)
            WEND
          NEXT i%
          PUT 30,183 DIV res%,b$
          @graf_shrinkbox(30,183,580,23,86,18)
          CLOSE #2
          ADD eintraege%,app_eintraege%
        ENDIF
      ENDIF
    ENDIF
    DEFMOUSE 3
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Zeige Disk_Info                                                 -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Zeige Disk-Info"
    DEFMOUSE 2
    ta%=DFREE(0)
    ALERT 1,"   DISK-INFO | |Die Diskette hat noch|"+STR$(ta%)+" Bytes frei.",1," WEITER ",ta%
    DEFMOUSE 3
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Datei löschen                                                   -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Datei löschen"
    REPEAT
      GET 157,31 DIV res%,480,53 DIV res%,w$
      DEFFILL 0,0
      @graf_growbox(157,31,323,22,86,18)
      PBOX 157,31 DIV res%,480,53 DIV res%
      FOR i%=0 TO 1
        BOX 157+(i%*2),(31+(i%*2)) DIV res%,480-(i%*2),(53-(i%*2)) DIV res%
      NEXT i%
      DEFTEXT 1,0,0,norm%
      TEXT 264,47 DIV res%,"Datei löschen"
      @graf_growbox(157,52,323,314,86,18)
      FILESELECT "\*.*","",file$
      @graf_shrinkbox(157,52,323,314,86,18)
      PUT 157,31 DIV res%,w$
      @graf_shrinkbox(157,31,323,22,86,18)
      DEFMOUSE 2
      IF file$<>"" AND EXIST(file$)
        KILL file$
      ELSE
        file$=""
      ENDIF
    UNTIL files$=""
    DEFMOUSE 3
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Disk formatieren                                                -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Disk formatieren"
    ALERT 3,"DISK FORMATIEREN| |Welches Laufwerk soll|angesprochen werden?|",1,"A|B|ABBRUCH",ta%
    IF ta%<>3
      frm_drive%=ta%-1
      ALERT 3,"Wie soll die Disk|formatiert werden ?",3,"360KB|720KB|ABBRUCH",ta%
      buf$=STRING$(8192,CHR$(0))
      IF ta%<>3
        IF ta%=1
          sides%=0
        ELSE
          sides%=1
        ENDIF
        ALERT 3,"Legen Sie die zu for-|matierende Diskette in|Laufwerk "+CHR$(65+frm_drive%),0,"OK|ABBRUCH",ta%
        IF ta%=1
          HIDEM
          GET 200,150 DIV res%,440,250 DIV res%,b$
          DEFFILL 0,0
          @graf_growbox(200,150,240,100,86,18)
          PBOX 200,150 DIV res%,440,250 DIV res%
          FOR i%=0 TO 1
            BOX 200+(i%*2),(150+(i%*2)) DIV res%,440-(i%*2),(250-(i%*2)) DIV res%
          NEXT i%
          DEFTEXT col1%,17,0,norm%
          TEXT 210,170 DIV res%,"Formatieren von Disk "+CHR$(65+frm_drive%)
          DEFTEXT col2%,1,0,norm%
          TEXT 250,200 DIV res%,"Seite:"
          TEXT 250,220 DIV res%,"Track:"
          DEFTEXT col1%,0,0,small%
          TEXT 263,245 DIV res%,"Bitte warten Sie"
          DEFTEXT col3%,0,0,norm%
          FOR track%=0 TO 79
            FOR side%=0 TO sides%
              TEXT 315,200 DIV res%," "+STR$(side%+1)
              TEXT 315,220 DIV res%,SPACE$(ABS(track%<10))+STR$(track%)
              ta%=ASC(INKEY$)
              EXIT IF ta%=27
              VOID XBIOS(10,L:VARPTR(buf$),L:filler,frm_drive%,9,track%,side%,1,L:&H87654321,0)
            NEXT side%
            EXIT IF ta%=27
          NEXT track%
          IF ta%=27
            GOTO label_1
            PUT 200,150 DIV res%,b$
            @graf_shrinkbox(200,150,240,100,86,18)
            SHOWM
          ENDIF
          PUT 200,150 DIV res%,b$
          @graf_shrinkbox(200,150,240,100,86,18)
          SHOWM
          DEFMOUSE 2
          IF sides%=0
            MID$(boot_sect$,20,1)=CHR$(208)
            MID$(boot_sect$,21,1)=CHR$(2)
          ELSE
            MID$(boot_sect$,20,1)=CHR$(160)
            MID$(boot_sect$,21,1)=CHR$(5)
          ENDIF
          MID$(boot_sect$,27)=CHR$(sides%+1)
          buf2$=STRING$(512,CHR$(0))
          VOID XBIOS(9,L:VARPTR(boot_sect$),L:VARPTR(buf2$),frm_drive%,1,0,0,1)
          buf$=CHR$(&HF7)+CHR$(&HFF)+CHR$(&HFF)+STRING$(509,CHR$(0))
          ta%=XBIOS(9,L:VARPTR(buf$),L:VARPTR(buf2$),frm_drive%,2,0,0,1)
          ta%=XBIOS(9,L:VARPTR(buf$),L:VARPTR(buf2$),frm_drive%,7,0,0,1)
          ALERT 1,"DISK FORMATIERT| |Auf der Diskette sind|"+STR$(DFREE(frm_drive%+1))+" Bytes frei.",1,"   OK   ",ta%
        ENDIF
      ENDIF
    ENDIF
    DEFMOUSE 3
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Daten eingeben                                                  -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Daten eingeben"
    GET 0,0,639,399 DIV res%,b$
    GET 215,364 DIV res%,425,394 DIV res%,c$
    @graf_growbox(215,364,90,30,140,18)
    PBOX 215,364 DIV res%,305,394 DIV res%
    @graf_growbox(335,364,90,30,140,18)
    PBOX 335,364 DIV res%,425,394 DIV res%
    FOR j%=0 TO 1
      FOR i%=0 TO 2
        BOX (215+i%)+(j%*120),(364+i%) DIV res%,(305-i%)+(j%*120),(394-i%) DIV res%
      NEXT i%
    NEXT j%
    DEFTEXT col1%,16,0,norm%
    TEXT 252,385 DIV res%,"OK"
    TEXT 347,385 DIV res%,"ABBRUCH"
    TITLEW 1," Eingabe "
    info$="    Eintrag: 00000/00000    einfügen    Name: "+int_name$
    hilf$="00000"
    hilf$=RIGHT$(hilf$,5-LEN(STR$(maxeintrag%)))+STR$(maxeintrag%)
    MID$(info$,20,5)=hilf$
    INFOW 1,info$
    @graf_growbox(1,18,638,358,140,18)
    OPENW 1,639,340 DIV res%
    CLS
    DEFTEXT col2%,1,0,norm%
    FOR i%=1 TO felder%
      TEXT 5,(35+(i%*25)) DIV res%,144,feld_name$(i%)
      LINE 150,(39+(i%*25)) DIV res%,150+(feld_laenge%(i%)*8),(39+(i%*25)) DIV res%
    NEXT i%
    REPEAT
      INC eintraege%
      IF eintraege%>maxeintrag%
        ALERT 2,"| |Die Datei ist voll!",1,"ABBRUCH",ta%
        GOTO label_2
      ENDIF
      hilf$="00000"
      hilf$=RIGHT$(hilf$,5-LEN(STR$(eintraege%)))+STR$(eintraege%)
      MID$(info$,14,5)=hilf$
      INFOW 1,info$
      DEFTEXT col3%,0,0,norm%
      FOR i%=1 TO felder%
        TEXT 150,(35+(i%*25)) DIV res%,SPACE$(feld_laenge%(i%))
        TEXT 150,(35+(i%*25)) DIV res%,datei$(i%,eintraege%)
        xpos%(i%)=150
        ypos%(i%)=(35+(i%*25)) DIV res%
        laenge%(i%)=feld_laenge%(i%)
        ok$(i%)=""
        feld$(i%)=datei$(i%,eintrage)
      NEXT i%
      @eingabe(felder%,215,310 DIV res%,302,336 DIV res%,343,310 DIV res%,425,336 DIV res%)
      IF eingabe_status%=0
        FOR i%=1 TO felder%
          datei$(i%,eintraege%)=feld$(i%)
        NEXT i%
      ENDIF
    UNTIL eingabe_status%=1
    DEC eintraege%
    label_2:
    CLOSEW 1
    OPENW 0,0,0
    @graf_shrinkbox(1,18,638,358,140,18)
    PUT 0,0,b$
    PUT 215,364 DIV res%,c$
    @graf_shrinkbox(215,364,90,30,140,18)
    @graf_shrinkbox(335,364,90,30,140,18)
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Daten ausgeben                                                  -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Daten ausgeben"
    IF eintraege%=0
      GOTO label_1
    ENDIF
    GET 80,45 DIV res%,560,335 DIV res%,b$
    DEFFILL 0,0
    GET 215,364 DIV res%,425,394 DIV res%,c$
    @graf_growbox(215,364,90,30,140,18)
    PBOX 215,364 DIV res%,305,394 DIV res%
    @graf_growbox(335,364,90,30,140,18)
    PBOX 335,364 DIV res%,425,394 DIV res%
    FOR j%=0 TO 1
      FOR i%=0 TO 2
        BOX (215+i%)+(j%*120),(364+i%) DIV res%,(305-i%)+(j%*120),(394-i%) DIV res%
      NEXT i%
    NEXT j%
    DEFTEXT col1%,16,0,norm%
    TEXT 252,385 DIV res%,"OK"
    TEXT 347,385 DIV res%,"ABBRUCH"
    @graf_growbox(80,45,480,290,140,18)
    PBOX 80,45 DIV res%,560,335 DIV res%
    FOR i%=0 TO 1
      BOX 80+(i%*2),(45+(i%*2)) DIV res%,560-(i%*2),(335-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT col2%,5,0,med%
    TEXT 190,80 DIV res%,260,"Daten-Ausgabe"
    RBOX 180,57 DIV res%,460,87 DIV res%
    DEFTEXT col3%,17,0,norm%
    TEXT 100,130 DIV res%,150,"mit Numerierung"
    TEXT 100,165 DIV res%,120,"Ausgabegerät"
    TEXT 100,200 DIV res%,"pro Feld neue Zeile"
    TEXT 100,235 DIV res%,80,"Druckart"
    TEXT 100,305 DIV res%,180,"Datensätze trennen"
    CLR feld%
    FOR i%=1 TO felder%
      ADD feld%,feld_laenge%(i%)
    NEXT i%
    DEFTEXT col1%,1,0,norm%
    GRAPHMODE 1
    z_nr!=TRUE
    drucker!=FALSE
    IF feld%>78-(3*felder%)-(LEN(STR$(eintraege%)))
      fld!=TRUE
    ELSE
      fld!=FALSE
    ENDIF
    elite!=FALSE
    normal%=1
    trenn!=FALSE
    TEXT 300,130 DIV res%,"   Ja        Nein"
    TEXT 305,165 DIV res%,"Monitor    Drucker"
    TEXT 300,200 DIV res%,"   Ja        Nein"
    TEXT 300,235 DIV res%,"  Pica"
    TEXT 400,235 DIV res%,"Elite"
    TEXT 300,270 DIV res%," normal      fett        NLQ"
    TEXT 300,305 DIV res%,"   Ja        Nein"
    FOR i%=0 TO 5
      FOR j%=0 TO 1
        BOX 294,(115+(i%*35)) DIV res%,372,(134+(i%*35)) DIV res%
        BOX 382,(115+(i%*35)) DIV res%,460,(134+(i%*35)) DIV res%
      NEXT j%
    NEXT i%
    BOX 470,255 DIV res%,548,274 DIV res%
    ok%=1
    GRAPHMODE 3
    DEFFILL 1,1
    PBOX 295,116 DIV res%,371,133 DIV res%
    PBOX 295,151 DIV res%,371,168 DIV res%
    IF fld!=FALSE
      PBOX 383,186 DIV res%,459,203 DIV res%
    ELSE
      PBOX 295,186 DIV res%,371,203 DIV res%
    ENDIF
    PBOX 295,221 DIV res%,371,238 DIV res%
    PBOX 295,256 DIV res%,371,273 DIV res%
    PBOX 383,291 DIV res%,459,308 DIV res%
    REPEAT
      MOUSE mx%,my%,mk%
      IF mk%=1
        IF (mx%>215 AND mx%<302) AND (my%>(365 DIV res%) AND my%<(393 DIV res%))
          ok%=TRUE
        ENDIF
        IF (mx%>343 AND mx%<425) AND (my%>(365 DIV res%) AND my%<(393 DIV res%))
          ok%=FALSE
        ENDIF
        IF (mx%>294 AND mx%<372)
          IF (my%>(115 DIV res%) AND my%<(134 DIV res%)) AND (z_nr!=FALSE)
            z_nr!=TRUE
            PBOX 383,116 DIV res%,459,133 DIV res%
            PBOX 295,116 DIV res%,371,133 DIV res%
          ENDIF
          IF (my%>(151 DIV res%) AND my%<(168 DIV res%)) AND (drucker!=TRUE)
            IF (feld%>78-(3*felder%)-ABS(LEN(STR$(eintraege%))*z_nr!=TRUE) AND (fld!=FALSE))
              fld!=TRUE
              PBOX 383,186 DIV res%,459,203 DIV res%
              PBOX 295,186 DIV res%,371,203 DIV res%
            ENDIF
            drucker!=FALSE
            PBOX 383,151 DIV res%,459,168 DIV res%
            PBOX 295,151 DIV res%,371,168 DIV res%
          ENDIF
          IF (my%>(185 DIV res%) AND my%<(203 DIV res%)) AND (fld!=FALSE)
            fld!=TRUE
            PBOX 383,186 DIV res%,459,203 DIV res%
            PBOX 295,186 DIV res%,371,203 DIV res%
          ENDIF
          IF (my%>(221 DIV res%) AND my%<(238 DIV res%)) AND (elite!=TRUE)
            elite!=FALSE
            PBOX 383,221 DIV res%,459,238 DIV res%
            PBOX 295,221 DIV res%,371,238 DIV res%
          ENDIF
          IF (my%>(256 DIV res%) AND my%<(273 DIV res%)) AND (normal%<>1)
            PBOX 383-((normal%=3)*88),256 DIV res%,459-((normal%=3)*88),273 DIV res%
            PBOX 295,256 DIV res%,371,273 DIV res%
            normal%=1
          ENDIF
          IF (my%>(290 DIV res%) AND my%<(308 DIV res%)) AND (trenn!=FALSE)
            trenn!=TRUE
            PBOX 383,291 DIV res%,459,308 DIV res%
            PBOX 295,291 DIV res%,371,308 DIV res%
          ENDIF
        ENDIF
        IF (mx%>382 AND mx%<460)
          IF (my%>(115 DIV res%) AND my%<(133 DIV res%)) AND (z_nr!=TRUE)
            z_nr!=FALSE
            PBOX 383,116 DIV res%,459,133 DIV res%
            PBOX 295,116 DIV res%,371,133 DIV res%
          ENDIF
          IF (my%>(151 DIV res%) AND my%<(168 DIV res%)) AND (drucker!=FALSE)
            drucker!=TRUE
            PBOX 383,151 DIV res%,459,168 DIV res%
            PBOX 295,151 DIV res%,371,168 DIV res%
          ENDIF
          IF (my%>(185 DIV res%) AND my%<(203 DIV res%)) AND (fld!=TRUE)
            IF (feld%<=78-(3*felder%)-ABS(LEN(STR$(eintraege%))*z_nr!=TRUE) OR (drucker!=TRUE))
              fld!=FALSE
              PBOX 383,186 DIV res%,459,203 DIV res%
              PBOX 295,186 DIV res%,371,203 DIV res%
            ENDIF
          ENDIF
          IF (my%>(221 DIV res%) AND my%<(238 DIV res%)) AND (elite!=FALSE)
            elite!=TRUE
            PBOX 383,221 DIV res%,459,238 DIV res%
            PBOX 295,221 DIV res%,371,238 DIV res%
          ENDIF
          IF (my%>(256 DIV res%) AND my%<(273 DIV res%)) AND (normal%<>2)
            PBOX 295-((normal%=3)*176),256 DIV res%,371-((normal%=3)*176),273 DIV res%
            PBOX 383,256 DIV res%,459,273 DIV res%
            normal%=2
          ENDIF
          IF (my%>(290 DIV res%) AND my%<(308 DIV res%)) AND (trenn!=TRUE)
            trenn!=FALSE
            PBOX 383,291 DIV res%,459,308 DIV res%
            PBOX 295,291 DIV res%,371,308 DIV res%
          ENDIF
        ENDIF
        IF (mx%>471 AND mx%<547) AND (my%>(256 DIV res%) AND my%<(273 DIV res%)) AND (normal%<>3)
          PBOX 295-((normal%=2)*88),256 DIV res%,371-((normal%=2)*88),273 DIV res%
          PBOX 471,256 DIV res%,547,273 DIV res%
          normal%=3
        ENDIF
      ENDIF
    UNTIL ok%=TRUE OR ok%=FALSE
    GRAPHMODE 1
    PUT 80,45 DIV res%,b$
    @graf_shrinkbox(80,45,480,290,140,18)
    PUT 215,364 DIV res%,c$
    @graf_shrinkbox(215,364,90,30,140,18)
    @graf_shrinkbox(335,364,90,30,140,18)
    DEFFILL 0,0
    IF ok%=TRUE
      HIDEM
      IF drucker!=TRUE
        OUT 0,0
        WHILE OUT?(0)=FALSE
          ALERT 1,"|Der Drucker ist nicht bereit!| |Schalten Sie ihn ein!",1,"OK|ABBRUCH",ta%
          IF ta%=2
            m$(MENU(0))=""
            GOTO label_1
          ENDIF
        WEND
        GET 180,150 DIV res%,460,250 DIV res%,b$
        GET 0,270 DIV res%,639,292 DIV res%,c$
        @graf_growbox(180,150,280,100,140,18)
        PBOX 180,150 DIV res%,460,250 DIV res%
        FOR i%=0 TO 1
          BOX 180+(i%*2),(150+(i%*2)) DIV res%,460-(i%*2),(250-(i%*2)) DIV res%
        NEXT i%
        DEFTEXT col1%,17,0,norm%
        TEXT 195,170 DIV res%,"Bitte warten - ich drucke"
        DEFTEXT col3%,5,0,norm%
        TEXT 200,210 DIV res%,240,int_name$
        DEFTEXT col2%,1,0,norm%
        TEXT 250,235 DIV res%,"Datensatz:"
        @graf_growbox(0,270,640,22,140,18)
        PBOX 0,270 DIV res%,639,292 DIV res%
        FOR i%=0 TO 1
          BOX i%*2,(270+(i%*2)) DIV res%,639-(i%*2),(292-(i%*2)) DIV res%
        NEXT i%
        DEFTEXT col2%,1,0,norm%
        TEXT 80,286 DIV res%,480,m1$
        LPRINT drucker$(26);drucker$(25);
        LPRINT drucker$(20+ABS(elite!=TRUE)*4);
        LPRINT SPACE$(5);
        @drucke(int_name$)
        LPRINT drucker$(26)
        LPRINT drucker$(16+normal%+ABS(elite!=TRUE)*4);
        FOR i%=1 TO eintraege%
          TEXT 340,235 DIV res%,SPACE$(LEN(STR$(eintraege%))-LEN(STR$(i%)))+STR$(i%)
          IF MOUSEK=1
            TEXT 80,286 DIV res%,480,m2$
            PAUSE 20
            REPEAT
            UNTIL (MOUSEK=1) OR (LEN(INKEY$))
            TEXT 80,286 DIV res%,480,m1$
          ENDIF
          EXIT IF MOUSEK=2
          IF z_nr!=TRUE
            hilf$=STRING$(LEN(STR$(eintraege%)),"0")
            hilf$=RIGHT$(hilf$,LEN(hilf$)-LEN(STR$(i%)))+STR$(i%)
            ausg$=hilf$+"  "
          ELSE
            ausg$=""
          ENDIF
          FOR j%=1 TO felder%
            IF fld!=FALSE
              ausg$=ausg$+datei$(j%,i%)+"  "
            ELSE
              IF j%=1
                ausg$=ausg$+datei$(j%,i%)
              ELSE
                ausg$=SPACE$(ABS(z_nr!=TRUE)*LEN(STR$(eintraege%))+3)+"  "+datei$(j%,i%)+CHR$(10)
              ENDIF
              @drucke(ausg$)
            ENDIF
          NEXT j%
          IF fld!=FALSE
            @drucke(ausg$)
          ENDIF
          IF trenn!=TRUE
            LPRINT STRING$(80+ABS(elite!=TRUE)*16,"-")
          ENDIF
        NEXT i%
        LPRINT drucker$(26)
        PUT 0,270 DIV res%,c$
        @graf_shrinkbox(0,270,640,22,140,18)
        PUT 180,150 DIV res%,b$
        @graf_shrinkbox(180,150,280,100,140,18)
      ELSE
        GET 0,0,639,376 DIV res%,c$
        GET 0,377 DIV res%,639,399 DIV res%,b$
        @graf_growbox(0,377,640,22,140,18)
        PBOX 0,377 DIV res%,639,399 DIV res%
        FOR i%=0 TO 1
          BOX (i%*2),(377+(i%*2)) DIV res%,639-(i%*2),(399-(i%*2)) DIV res%
        NEXT i%
        DEFTEXT col2%,1,0,norm%
        TEXT 80,393 DIV res%,480,m1$
        TITLEW 1," Ausgabe "
        INFOW 1,""
        @graf_growbox(1,18,638,375,140,18)
        OPENW 1,639,375 DIV res%
        CLS
        DEFTEXT col3%,0,0,norm%
        FOR k%=1 TO eintraege%
          IF MOUSEK=1
            CLOSEW 0
            DEFTEXT col2%,1,0,norm%
            TEXT 80,393 DIV res%,480,m2$
            PAUSE 20
            REPEAT
            UNTIL (MOUSEK=1) OR (LEN(INKEY$))
            TEXT 80,393 DIV res%,480,m1$
            OPENW 1
            DEFTEXT col3%,0,0,norm%
          ENDIF
          EXIT IF MOUSEK=2
          IF z_nr!=TRUE
            hilf$=STRING$(LEN(STR$(eintraege%)),"0")
            hilf$=RIGHT$(hilf$,LEN(hilf$)-LEN(STR$(k%)))+STR$(k%)
            ausg$=" "+hilf$+"   "
          ELSE
            ausg$=" "
          ENDIF
          FOR i%=1 TO felder%
            ausg$=ausg$+datei$(i%,k%)
            IF fld!=TRUE
              ausg$=ausg$+CHR$(13)+CHR$(10)
              IF i%<felder%
                ausg$=ausg$+" "+SPACE$(ABS(z_nr!=TRUE)*(LEN(hilf$)+3))
              ENDIF
            ELSE
              IF i%<felder%
                ausg$=ausg$+"   "
              ELSE
                IF (k%<eintraege%) OR (trenn!=TRUE)
                  ausg$=ausg$+CHR$(10)+CHR$(13)
                ENDIF
              ENDIF
            ENDIF
          NEXT i%
          IF trenn!=TRUE
            ausg$=ausg$+STRING$(79,"-")
            IF k%<eintraege%
              ausg$=ausg$+CHR$(10)+CHR$(13)
            ENDIF
          ENDIF
          PRINT ausg$;
        NEXT k%
        DEFTEXT col2%,1,0,norm%
        CLOSEW 0
        TEXT 80,393 DIV res%,480,m2$
        REPEAT
        UNTIL (MOUSEK<>0) OR (INKEY$<>"")
        CLOSEW 1
        OPENW 0,0,0
        PUT 0,0,c$
        @graf_shrinkbox(1,18,638,375,140,18)
        PUT 0,377 DIV res%,b$
        @graf_shrinkbox(0,377,640,22,140,18)
      ENDIF
    ENDIF
    SHOWM
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Eintrag suchen                                                  -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Eintrag suchen"
    @aend_loesch_feld("Eintrag suchen","Suchen in Feld:","was suchen?",1)
    PUT 100,50 DIV res%,b$
    @graf_shrinkbox(100,50,440,300,140,18)
    PUT 215,364 DIV res%,c$
    @graf_shrinkbox(215,364,90,30,140,18)
    @graf_shrinkbox(335,364,90,30,140,18)
    IF eingabe_status%=0
      start%=1
      search$=feld$(1)
      REPEAT
        @search(search$,worin%,start%)
        IF gefunden>0
          GET 0,360 DIV res%,639,399 DIV res%,b$
          DEFFILL 0,0
          @graf_growbox(0,360,640,39,140,18)
          PBOX 0,360 DIV res%,639,399 DIV res%
          FOR i%=0 TO 1
            BOX 1+(i%*2),(360+(i%*2)) DIV res%,638-(i%*2),(398-(i%*2)) DIV res%
          NEXT i%
          DEFTEXT col1%,1,0,norm%
          TEXT 195,385 DIV res%,250,"Weiter suchen?      JA    NEIN"
          BOX 349,369 DIV res%,397,390 DIV res%
          BOX 404,369 DIV res%,451,390 DIV res%
          @ausgabe(gefunden," Eintrag suchen ")
          REPEAT
            ok!=FALSE
            MOUSE mx%,my%,mk%
            IF mk%=1 AND (my%>(312 DIV res%) AND my%<(334 DIV res%))
              IF (mx%>347 AND mx%<396)
                ok!=TRUE
                INC gefunden
                start%=gefunden
              ENDIF
              IF (mx%>401 AND mx%<450)
                CLR gefunden
                ok!=TRUE
              ENDIF
            ENDIF
          UNTIL ok!=TRUE
        ENDIF
        CLOSEW 1
        OPENW 0,0,0
        DEFFILL 1,2,4
        PBOX -1,18 DIV res%,640,400 DIV res%
        @graf_shrinkbox(1,18,638,340,140,18)
        @graf_shrinkbox(0,360,640,39,140,18)
        DEFFILL 0,0
      UNTIL gefunden=0
    ENDIF
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Eintrag ändern                                                  -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Eintrag ändern"
    @aend_loesch_feld("Eintrag ändern","Ändern in Feld:","was ändern?",1)
    PUT 100,50 DIV res%,b$
    @graf_shrinkbox(100,50,440,300,140,18)
    PUT 215,364 DIV res%,c$
    @graf_shrinkbox(215,364,90,30,140,18)
    @graf_shrinkbox(335,364,90,30,140,18)
    IF eingabe_status%=0
      start%=1
      search$=feld$(1)
      GET 0,360 DIV res%,639,400 DIV res%,b$
      REPEAT
        @search(search$,worin%,start%)
        IF gefunden<>0
          DEFFILL 0,0
          @graf_growbox(0,360,640,39,140,18)
          PBOX 0,360 DIV res%,639,399 DIV res%
          FOR i%=0 TO 1
            BOX 1+(i%*2),(360+(i%*2)) DIV res%,638-(i%*2),(398-(i%*2)) DIV res%
          NEXT i%
          DEFTEXT col1%,1,0,norm%
          TEXT 105,385 DIV res%,430,"Diesen Eintrag ändern?       JA       NEIN    ABBRUCH"
          BOX 317,369 DIV res%,385,390 DIV res%
          BOX 393,369 DIV res%,465,390 DIV res%
          BOX 473,369 DIV res%,542,390 DIV res%
          @ausgabe(gefunden," Eintrag ändern ")
          REPEAT
            ok!=FALSE
            MOUSE mx%,my%,mk%
            IF mk%=1 AND (my%>(312 DIV res%) AND my%<(334 DIV res%))
              IF (mx%>316 AND mx%<386)
                ok!=TRUE
                OPENW 0,0,0
                PUT 0,360 DIV res%,b$
                @graf_shrinkbox(0,360,640,39,140,18)
                GET 215,364 DIV res%,425,394 DIV res%,c$
                @graf_growbox(215,364,90,30,140,18)
                PBOX 215,364 DIV res%,305,394 DIV res%
                @graf_growbox(335,364,90,30,140,18)
                PBOX 335,364 DIV res%,425,394 DIV res%
                FOR j%=0 TO 1
                  FOR i%=0 TO 2
                    BOX (215+i%)+(j%*120),(364+i%) DIV res%,(305-i%)+(j%*120),(394-i%) DIV res%
                  NEXT i%
                NEXT j%
                DEFTEXT col1%,16,0,norm%
                TEXT 252,385 DIV res%,"OK"
                TEXT 347,385 DIV res%,"ABBRUCH"
                FOR i%=1 TO felder%
                  ok$(i%)=""
                  feld$(i%)=datei$(i%,gefunden)
                  xpos%(i%)=150
                  ypos%(i%)=(35+(i%*25)) DIV res%
                  laenge%(i%)=feld_laenge%(i%)
                NEXT i%
                OPENW 1
                @eingabe(felder%,215,310 DIV res%,302,336 DIV res%,343,310 DIV res%,425,336 DIV res%)
                IF eingabe_status%=0
                  FOR i%=1 TO felder%
                    datei$(i%,gefunden)=feld$(i%)
                  NEXT i%
                ENDIF
                INC start%
                CLOSEW 1
                OPENW 0,0,0
                DEFFILL 1,2,4
                PBOX -1,18 DIV res%,640,359 DIV res%
                PUT 215,364 DIV res%,c$
                @graf_shrinkbox(215,364,90,30,140,18)
                @graf_shrinkbox(335,364,90,30,140,18)
              ENDIF
              IF (mx%>392 AND mx%<466)
                INC gefunden
                start%=gefunden
                ok!=TRUE
                CLOSEW 1
                OPENW 0,0,0
                DEFFILL 1,2,4
                PBOX -1,18 DIV res%,640,360 DIV res%
                DEFFILL 0,0
                @graf_shrinkbox(0,18,640,340,140,18)
                @graf_shrinkbox(0,360,640,39,140,18)
              ENDIF
              PUT 0,360 DIV res%,b$
              IF (mx%>472 AND mx%<543)
                ok!=TRUE
                CLOSEW 1
                OPENW 0,0,0
                DEFFILL 1,2,4
                PBOX -1,18 DIV res%,640,360 DIV res%
                @graf_shrinkbox(1,18,638,340,140,18)
                PBOX -1,18 DIV res%,640,400 DIV res%
                @graf_shrinkbox(0,360,640,39,140,18)
                DEFFILL 0,0
                CLR gefunden
              ENDIF
            ENDIF
          UNTIL ok!=TRUE
        ENDIF
      UNTIL gefunden=0
    ENDIF
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Daten sortieren                                                 -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Daten sortieren"
    @aend_loesch_feld("Daten sortieren","Sortieren nach Feld:","",0)
    PUT 100,50 DIV res%,b$
    @graf_shrinkbox(100,50,440,300,140,18)
    PUT 215,364 DIV res%,c$
    @graf_shrinkbox(215,364,90,30,140,18)
    @graf_shrinkbox(335,364,90,30,140,18)
    GET 200,160 DIV res%,440,240 DIV res%,b$
    @graf_growbox(200,160,240,80,140,18)
    PBOX 200,160 DIV res%,440,240 DIV res%
    FOR i%=0 TO 1
      BOX 200+(i%*2),(160+(i%*2)) DIV res%,440-(i%*2),(240-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT col3%,1,0,norm%
    IF eingabe_status%=0
      TEXT 245,180 DIV res%,150,"Einen Augenblick!"
      DEFTEXT col3%,4,0,norm%
      TEXT 245,205 DIV res%,153,"Ich sortiere nach"
      DEFTEXT col2%,17,0,norm%
      TEXT 230,232 DIV res%,180,feld_name$(worin%)
      DEFTEXT col1%,0,0,norm%
      @sort(worin%)
      PUT 200,160 DIV res%,b$
      @graf_shrinkbox(200,160,240,80,140,18)
    ENDIF
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Eintrag löschen                                                 -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Eintrag löschen"
    @aend_loesch_feld("Eintrag löschen","Löschen in Feld:","was löschen?",1)
    PUT 100,50 DIV res%,b$
    @graf_shrinkbox(100,50,440,300,140,18)
    PUT 215,364 DIV res%,c$
    @graf_shrinkbox(215,364,90,30,140,18)
    @graf_shrinkbox(335,364,90,30,140,18)
    IF eingabe_status%=0
      search$=feld$(1)
      start%=1
      REPEAT
        @search(search$,worin%,start%)
        IF gefunden<>0
          GET 0,360 DIV res%,639,399 DIV res%,b$
          DEFFILL 0,0
          @graf_growbox(0,360,640,39,140,18)
          PBOX 0,360 DIV res%,639,399 DIV res%
          FOR i%=0 TO 1
            BOX 1+(i%*2),(360+(i%*2)) DIV res%,638-(i%*2),(398-(i%*2)) DIV res%
          NEXT i%
          DEFTEXT col1%,1,0,norm%
          TEXT 105,385 DIV res%,430,"Diesen Eintrag löschen?      JA       NEIN    ABBRUCH"
          BOX 317,369 DIV res%,385,390 DIV res%
          BOX 393,369 DIV res%,465,390 DIV res%
          BOX 473,369 DIV res%,542,390 DIV res%
          @ausgabe(gefunden," Eintrag löschen ")
          REPEAT
            ok!=FALSE
            MOUSE mx%,my%,mk%
            IF mk%=1 AND (my%>(312 DIV res%) AND my%<(334 DIV res%))
              IF (mx%>316 AND mx%<386)
                ok!=TRUE
                FOR i%=gefunden TO eintraege%-1
                  FOR j%=1 TO felder%
                    datei$(j%,i%)=datei$(j%,i%+1)
                  NEXT j%
                NEXT i%
                DEC eintraege%
                start%=gefunden
              ENDIF
              IF (mx%>392 AND mx%<466)
                INC gefunden
                start%=gefunden
                ok!=TRUE
              ENDIF
              IF (mx%>472 AND mx%<543)
                ok!=TRUE
                CLR gefunden
              ENDIF
            ENDIF
          UNTIL ok!=TRUE
        ENDIF
        CLOSEW 1
        OPENW 0,0,0
        PUT 0,360 DIV res%,b$
        DEFFILL 1,2,4
        PBOX -1,18 DIV res%,640,400 DIV res%
        @graf_shrinkbox(1,18,638,340,140,18)
        @graf_shrinkbox(0,360,640,39,140,18)
        DEFFILL 0,0
      UNTIL gefunden=0
    ENDIF
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Neue Datei anlegen                                              -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Neue Datei anlegen"
    IF datei_flag!=TRUE
      ALERT 3,"Das Anlegen einer neuen|Datei löscht die Alte!|Trotzdem anlegen?",2,"JA| NEIN ",ta%
      IF ta%=2
        m$(MENU(0))=""
        GOTO label_1
      ELSE
        datei_flag!=FALSE
      ENDIF
    ENDIF
    hilf%=felder%
    hilf$=int_name$
    GET 100,45 DIV res%,540,355 DIV res%,b$
    DEFFILL 0,0
    @graf_growbox(100,45,450,310,140,18)
    PBOX 100,45 DIV res%,540,355 DIV res%
    FOR i%=0 TO 1
      BOX 100+(i%*2),(45+(i%*2)) DIV res%,540-(i%*2),(355-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT col2%,5,0,med%
    TEXT 170,80 DIV res%,300,"Neue Datei anlegen"
    RBOX 160,57 DIV res%,480,87 DIV res%
    DEFTEXT col1%,1,0,norm%
    TEXT 120,145 DIV res%,"Anzahl der Datenfelder:"
    DEFTEXT col2%,0,0,norm%
    TEXT 320,145 DIV res%,felder%
    DEFTEXT col1%,0,0,norm%
    TEXT 350,145 DIV res%,CHR$(2)+" "+CHR$(1)+"    OK"
    BOX 347,132 DIV res%,360,147 DIV res%
    BOX 363,132 DIV res%,376,147 DIV res%
    BOX 397,132 DIV res%,429,147 DIV res%
    DEFTEXT col2%,0,0,norm%
    REPEAT
      MOUSE mx%,my%,mk%
      IF (my%>(132 DIV res%) AND my%<(147 DIV res%))
        IF (mx%>347 AND mx%<360) AND mk%=1
          hilf%=hilf%+1
          PAUSE 8
          IF hilf%>9
            hilf%=1
          ENDIF
          TEXT 320,145 DIV res%,hilf%
        ENDIF
        IF (mx%>363 AND mx%<376) AND mk%=1
          hilf%=hilf%-1
          PAUSE 8
          IF hilf%<1
            hilf%=9
          ENDIF
          TEXT 320,145 DIV res%,hilf%
        ENDIF
      ENDIF
    UNTIL (mx%>395 AND mx%<427) AND (my%>(132 DIV res%) AND my%<(147 DIV res%)) AND (mk%=1)
    PBOX 347,132 DIV res%,429,147 DIV res%
    DEFTEXT col2%,1,0,norm%
    TEXT 120,120 DIV res%,"Interner Name:"
    DEFTEXT col3%,0,0,norm%
    TEXT 240,120 DIV res%,int_name$
    LINE 240,124 DIV res%,480,124 DIV res%
    GET 215,364 DIV res%,425,394 DIV res%,c$
    @graf_growbox(215,364,90,30,140,18)
    PBOX 215,364 DIV res%,305,394 DIV res%
    @graf_growbox(335,364,90,30,140,18)
    PBOX 335,364 DIV res%,425,394 DIV res%
    FOR j%=0 TO 1
      FOR i%=0 TO 2
        BOX (215+i%)+(j%*120),(364+i%) DIV res%,(305-i%)+(j%*120),(394-i%) DIV res%
      NEXT i%
    NEXT j%
    DEFTEXT col1%,16,0,norm%
    TEXT 252,385 DIV res%,"OK"
    TEXT 347,385 DIV res%,"ABBRUCH"
    FOR i%=1 TO hilf%
      DEFTEXT col2%,1,0,norm%
      TEXT 140,(180+(i%-1)*20) DIV res%,"Feld "+STR$(i%)+"   Name:                      Länge:  "
      DEFTEXT col3%,0,0,norm%
      TEXT 270,(180+(i%-1)*20) DIV res%,feld_name$(i%)
      hilf$="00"
      hilf$=LEFT$(hilf$,(2-LEN(STR$(feld_laenge%(i%)))))+STR$(feld_laenge%(i%))
      TEXT 490,(180+(i%-1)*20) DIV res%,hilf$
      LINE 270,(184+(i%-1)*20) DIV res%,414,(184+(i%-1)*20) DIV res%
      LINE 490,(184+(i%-1)*20) DIV res%,506,(184+(i%-1)*20) DIV res%
    NEXT i%
    FOR i%=1 TO 9
      feld$(i%*2)=feld_name$(i%)
      hilf$="00"
      hilf$=LEFT$(hilf$,(2-LEN(STR$(feld_laenge%(i%)))))+STR$(feld_laenge%(i%))
      feld$(i%*2+1)=hilf$
    NEXT i%
    hilf$=int_name$
    feld$(1)=hilf$
    ok$(1)=""
    FOR i%=1 TO 9
      ok$(i%*2)=""
      ok$(i%*2+1)=dec$
    NEXT i%
    xpos%(1)=240
    ypos%(1)=120 DIV res%
    laenge%(1)=30
    FOR i%=1 TO 9
      xpos%(i%*2)=270
      laenge%(i%*2)=18
      xpos%(i%*2+1)=490
      laenge%(i%*2+1)=2
    NEXT i%
    j%=0
    FOR i%=2 TO 19
      j%=j%-(i% MOD 2=0)
      ypos%(i%)=(160+j%*20) DIV res%
    NEXT i%
    @eingabe(1+(hilf%*2),215,365 DIV res%,302,393 DIV res%,343,365 DIV res%,425,393 DIV res%)
    IF eingabe_status%=0
      CLR eintraege%
      felder%=hilf%
      int_name$=feld$(1)
      CLR j%
      FOR i%=2 TO 18 STEP 2
        INC j%
        feld_name$(j%)=feld$(i%)
      NEXT i%
      CLR j%
      FOR i%=3 TO 19 STEP 2
        INC j%
        feld_laenge%(j%)=VAL(feld$(i%))
        IF feld_laenge%(j%)>60
          feld_laenge%(j%)=60
        ENDIF
      NEXT i%
      datei_flag!=TRUE
      CLR feld%
      FOR i%=1 TO felder%
        feld%=feld%+feld_laenge%(i%)
      NEXT i%
      IF feld%<1
        feld%=1
      ENDIF
      maxeintrag%=FRE(0) DIV feld%
      IF maxeintrag%*felder%>32766
        maxeintrag%=32766 DIV felder%
      ENDIF
      ERASE datei$()
      dummy%=FRE(0)
      DIM datei$(felder%,maxeintrag%)
      ALERT 1,"|Sie haben Platz für|"+STR$(maxeintrag%)+" Einträge!",1," OK ",ta%
      MENU 12,3
      MENU 13,3
      MENU 21,3
      MENU 22,3
      MENU 24,3
      MENU 25,3
      MENU 27,3
      MENU 29,3
      MENU 33,3
      MENU 34,3
    ENDIF
    PUT 215,364 DIV res%,c$
    @graf_shrinkbox(215,364,90,30,140,18)
    @graf_shrinkbox(335,364,90,30,140,18)
    IF eingabe_status%=0
      GET 230,160 DIV res%,410,220 DIV res%,c$
      @graf_growbox(230,160,180,60,140,18)
      DEFFILL 1,0
      PBOX 230,160 DIV res%,410,220 DIV res%
      BOX 232,162 DIV res%,408,218 DIV res%
      DEFTEXT col2%,1,0,norm%
      TEXT 256,186 DIV res%,128,"Einen Augenblick"
      TEXT 236,210 DIV res%,168,"Ich initialisiere ..."
      DEFMOUSE 2
      FOR i%=1 TO maxeintrag%
        FOR j%=1 TO felder%
          datei$(j%,i%)=" "
        NEXT j%
      NEXT i%
      CLR eintrage%
      PUT 230,160 DIV res%,c$
      @graf_shrinkbox(230,160,180,60,140,18)
    ENDIF
    PUT 100,45 DIV res%,b$
    @graf_shrinkbox(100,45,450,310,140,18)
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Internen Namen ändern                                           -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Internen Namen ändern "
    GET 100,155 DIV res%,540,230 DIV res%,b$
    @graf_growbox(100,155,440,75,195,18)
    PBOX 100,155 DIV res%,540,230 DIV res%
    FOR i%=0 TO 1
      BOX 100+(i%*2),(155+(i%*2)) DIV res%,540-(i%*2),(230-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT col2%,16,0,norm%
    TEXT 120,180 DIV res%,"Wie lautet der neue interne Name?"
    DEFTEXT col3%,0,0,norm%
    TEXT 140,220 DIV res%,int_name$
    LINE 140,224 DIV res%,380,224 DIV res%
    GET 215,264 DIV res%,425,294 DIV res%,c$
    @graf_growbox(215,264,90,30,140,18)
    PBOX 215,264 DIV res%,305,294 DIV res%
    @graf_growbox(335,264,90,30,140,18)
    PBOX 335,264 DIV res%,425,294 DIV res%
    FOR j%=0 TO 1
      FOR i%=0 TO 2
        BOX (215+i%)+(j%*120),(264+i%) DIV res%,(305-i%)+(j%*120),(294-i%) DIV res%
      NEXT i%
    NEXT j%
    DEFTEXT col1%,16,0,norm%
    TEXT 252,285 DIV res%,"OK"
    TEXT 347,285 DIV res%,"ABBRUCH"
    feld$(1)=int_name$
    xpos%(1)=140
    ypos%(1)=220 DIV res%
    laenge%(1)=30
    @eingabe(1,215,265 DIV res%,302,293 DIV res%,343,265 DIV res%,425,293 DIV res%)
    IF eingabe_status%=0
      int_name$=feld$(1)
    ENDIF
    PUT 100,155 DIV res%,b$
    @graf_shrinkbox(100,155,440,75,195,18)
    PUT 215,264 DIV res%,c$
    @graf_shrinkbox(215,264,90,30,195,18)
    @graf_shrinkbox(335,264,90,30,195,18)
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Feld-Namen ändern                                               -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Feld-Namen ändern"
    GET 100,80 DIV res%,540,320 DIV res%,b$
    @graf_growbox(100,80,440,240,195,18)
    PBOX 100,80 DIV res%,540,320 DIV res%
    FOR i%=0 TO 1
      BOX 100+(i%*2),(80+(i%*2)) DIV res%,540-(i%*2),(320-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT col2%,16,0,norm%
    TEXT 140,100 DIV res%,"Wie lauten die neuen Feld-Namen?"
    DEFTEXT col2%,1,0,norm%
    FOR i%=1 TO felder%
      TEXT 170,(110+(i%*20)) DIV res%,"Feld "+STR$(i%)+" "
    NEXT i%
    DEFTEXT col3%,0,0,norm%
    FOR i%=1 TO felder%
      TEXT 250,(110+(i%*20)) DIV res%,feld_name$(i%)
      LINE 250,(114+(i%*20)) DIV res%,394,(114+(i%*20)) DIV res%
    NEXT i%
    GET 215,364 DIV res%,425,394 DIV res%,c$
    @graf_growbox(215,364,90,30,195,18)
    PBOX 215,364 DIV res%,305,394 DIV res%
    @graf_growbox(335,364,90,30,195,18)
    PBOX 335,364 DIV res%,425,394 DIV res%
    FOR j%=0 TO 1
      FOR i%=0 TO 2
        BOX (215+i%)+(j%*120),(364+i%) DIV res%,(305-i%)+(j%*120),(394-i%) DIV res%
      NEXT i%
    NEXT j%
    DEFTEXT col1%,16,0,norm%
    TEXT 252,385 DIV res%,"OK"
    TEXT 347,385 DIV res%,"ABBRUCH"
    FOR i%=1 TO felder%
      ok$(i%)=""
      feld$(i%)=feld_name$(i%)
      xpos%(i%)=250
      ypos%(i%)=(110+(i%*20)) DIV res%
      laenge%(i%)=18
    NEXT i%
    @eingabe(felder%,215,365 DIV res%,302,393 DIV res%,343,365 DIV res%,425,393 DIV res%)
    IF eingabe_status%=0
      FOR i%=1 TO felder%
        feld_name$(i%)=feld$(i%)
      NEXT i%
    ENDIF
    PUT 100,80 DIV res%,b$
    @graf_shrinkbox(100,80,440,240,195,18)
    PUT 215,364 DIV res%,c$
    @graf_shrinkbox(215,364,90,30,195,18)
    @graf_shrinkbox(335,364,90,30,195,18)
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Druckeranpassung eingeben                                       -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Druckeranpassung eingeben"
    GET 215,364 DIV res%,425,394 DIV res%,c$
    GET 20,30 DIV res%,620,350 DIV res%,b$
    @graf_growbox(20,30,600,320,260,18)
    PBOX 20,30 DIV res%,620,350 DIV res%
    @graf_growbox(215,364,90,30,260,18)
    PBOX 215,364 DIV res%,305,394 DIV res%
    @graf_growbox(335,364,90,30,260,18)
    PBOX 335,364 DIV res%,425,394 DIV res%
    FOR j%=0 TO 1
      FOR i%=0 TO 2
        BOX (215+i%)+(j%*120),(364+i%) DIV res%,(305-i%)+(j%*120),(394-i%) DIV res%
      NEXT i%
      BOX 20+(j%*2),(30+(j%*2)) DIV res%,620-(j%*2),(350-(j%*2)) DIV res%
    NEXT j%
    DEFTEXT col2%,5,0,med%
    TEXT 200,60 DIV res%,240,"Druckeranpassung"
    RBOX 190,39 DIV res%,450,67 DIV res%
    DEFTEXT col1%,16,0,norm%
    TEXT 252,385 DIV res%,"OK"
    TEXT 347,385 DIV res%,"ABBRUCH"
    DEFTEXT col2%,16,0,norm%
    TEXT 50,100 DIV res%,"Name des Druckers:"
    TEXT 100,135 DIV res%,"ä :                     Ä :"
    TEXT 100,160 DIV res%,"ö :                     Ö :"
    TEXT 100,185 DIV res%,"ü :                     Ü :"
    TEXT 100,210 DIV res%,"× :                     ▌ :"
    TEXT 100,245 DIV res%,"| :                     ~ :"
    TEXT 100,270 DIV res%,"[ :                     ] :"
    TEXT 100,295 DIV res%,"{ :                     } :"
    TEXT 100,320 DIV res%,"@ :                     \ :"
    LINE 235,104 DIV res%,475,104 DIV res%
    xpos%(1)=235
    ypos%(1)=100 DIV res%
    ok$(1)=""
    laenge%(1)=30
    feld$(1)=drucker$(0)
    DEFTEXT col3%,0,0,norm%
    TEXT 235,100 DIV res%,drucker$(0)
    FOR j%=0 TO 7
      FOR k%=0 TO 1
        FOR i%=0 TO 4
          LINE 139+(ABS(k%=1)*240)+(i%*24),(139+(j%*25)+(ABS(j%>3)*10)) DIV res%,155+(ABS(k%=1)*240)+(i%*24),(139+(j%*25)+(ABS(j%>3)*10)) DIV res%
        NEXT i%
      NEXT k%
    NEXT j%
    FOR k%=1 TO 16
      FOR j%=1 TO 5
        feld$((k%-1)*5+j%+1)=HEX$(ASC(MID$(drucker$(k%),j%,1)))
      NEXT j%
    NEXT k%
    CLR zaehler%,zaehler2%,zaehler3%
    FOR i%=1 TO 80
      INC zaehler%
      IF zaehler%>5
        zaehler%=1
        zaehler2%=1-zaehler2%
        INC zaehler3%
      ENDIF
      IF LEN(feld$(i%+1))=1
        feld$(i%+1)="0"+feld$(i%+1)
      ENDIF
      ok$(i%+1)=hex$
      laenge%(i%+1)=2
      xpos%(i%+1)=139+(zaehler%-1)*24+zaehler2%*240
      ypos%(i%+1)=(135+ABS(i%>40)*10+(i% DIV 10)*25+(i% MOD 10=0)*25) DIV res%
      TEXT xpos%(i%+1),(ypos%(i%+1)),feld$(i%+1)
    NEXT i%
    DEFTEXT col3%,0,0,norm%
    @eingabe(81,215,365 DIV res%,302,393 DIV res%,343,365 DIV res%,425,393 DIV res%)
    IF eingabe_status%=0
      drucker$(0)=feld$(1)
      DEFTEXT col1%,0,0,small%
      CLOSEW 0
      TEXT 395,10 DIV res%,drucker$(0)
      OPENW 0,0,0
      hilf$=""
      FOR i%=2 TO 81
        hilf$=hilf$+CHR$(VAL("&h"+feld$(i%)))
      NEXT i%
      FOR k%=1 TO 16
        drucker$(k%)=MID$(hilf$,(k%-1)*5+1,5)
      NEXT k%
      PBOX 50,70 DIV res%,600,340 DIV res%
      DEFTEXT col2%,16,0,norm%
      TEXT 100,100 DIV res%,"Pica Normalschrift         :"
      TEXT 100,125 DIV res%,"Pica Fettschryft           :"
      TEXT 100,150 DIV res%,"Pica NLQ ein               :"
      TEXT 100,175 DIV res%,"Pica NLQ Breitschrift      :"
      TEXT 100,200 DIV res%,"Elite Normalschrift        :"
      TEXT 100,225 DIV res%,"Elite Fettschrift          :"
      TEXT 100,250 DIV res%,"Elite NLQ ein              :"
      TEXT 100,275 DIV res%,"Elite NLQ Breitschrift     :"
      TEXT 100,300 DIV res%,"Vorschub über Perforamtion :"
      TEXT 100,325 DIV res%,"Drucker Initialisierung    :"
      DEFTEXT col3%,0,0,norm%
      FOR j%=1 TO 10
        FOR i%=1 TO 6
          LINE 386+(i%-1)*24,(104+(j%-1)*25) DIV res%,402+(i%-1)*24,(104+(j%-1)*25) DIV res%
        NEXT i%
      NEXT j%
      FOR i%=1 TO 81
        feld$(i%)=""
      NEXT i%
      FOR k%=0 TO 9
        FOR j%=1 TO 6
          feld$(k%*6+j%)=HEX$(ASC(MID$(drucker$(k%+17),j%,1)))
        NEXT j%
      NEXT k%
      CLR zaehler%
      FOR i%=1 TO 60
        INC zaehler%
        IF zaehler%>6
          zaehler%=1
        ENDIF
        ypos%(i%)=(100+(i% DIV 6)*25+(i% MOD 6=0)*25) DIV res%
        xpos%(i%)=362+zaehler%*24
        ok$(i%)=hex$
        laenge%(i%)=2
        IF LEN(feld$(i%))=1
          feld$(i%)="0"+feld$(i%)
        ENDIF
        TEXT xpos%(i%),ypos%(i%),feld$(i%)
      NEXT i%
      @eingabe(60,215,365 DIV res%,302,393 DIV res%,343,365 DIV res%,425,393 DIV res%)
      IF eingabe_status%=0
        CLR hilf$
        FOR i%=1 TO 60
          hilf$=hilf$+CHR$(VAL("&h"+feld$(i%)))
        NEXT i%
        FOR i%=1 TO 10
          drucker$(i%+16)=MID$(hilf$,(i%-1)*6+1,6)
        NEXT i%
      ENDIF
    ENDIF
    PUT 215,364 DIV res%,c$
    @graf_shrinkbox(215,364,90,30,260,18)
    @graf_shrinkbox(335,364,90,30,260,18)
    PUT 20,30 DIV res%,b$
    @graf_shrinkbox(20,30,600,320,260,18)
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Druckeranpassung laden                                          -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Druckeranpassung laden"
    GET 157,31 DIV res%,480,53 DIV res%,w$
    DEFFILL 0,0
    @graf_growbox(157,31,323,22,260,18)
    PBOX 157,31 DIV res%,480,53 DIV res%
    FOR i%=0 TO 1
      BOX 157+(i%*2),(31+(i%*2)) DIV res%,480-(i%*2),(53-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT 1,0,0,norm%
    TEXT 228,47 DIV res%,"Druckeranpassung laden"
    @graf_growbox(157,52,323,314,260,18)
    FILESELECT "\*.CON","",file$
    @graf_shrinkbox(157,52,323,314,260,18)
    PUT 157,31 DIV res%,w$
    @graf_shrinkbox(157,31,323,22,260,18)
    IF file$<>"" AND RIGHT$(file$,4)=".CON" AND EXIST(file$)
      DEFMOUSE 2
      OPEN "I",#2,file$
      INPUT #2,a$
      IF a$=id3$
        FOR i%=0 TO 26
          INPUT #2,drucker$(i%)
        NEXT i%
        CLOSE #2
      ELSE
        ALERT 2,"Dies ist kein Drucker-|anpassungsfile!",1,"ABBRUCH",ta%
      ENDIF
    ENDIF
    DEFMOUSE 3
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Druckeranpassung speichern                                      -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Druckeranpassung speichern"
    GET 157,31 DIV res%,480,53 DIV res%,w$
    DEFFILL 0,0
    @graf_growbox(157,31,323,22,260,18)
    PBOX 157,31 DIV res%,480,53 DIV res%
    FOR i%=0 TO 1
      BOX 157+(i%*2),(31+(i%*2)) DIV res%,480-(i%*2),(53-(i%*2)) DIV res%
    NEXT i%
    DEFTEXT 1,0,0,norm%
    TEXT 216,47 DIV res%,"Druckeranpassung speichern"
    @graf_growbox(157,52,323,314,260,18)
    FILESELECT "\*.CON","",file$
    @graf_shrinkbox(157,52,323,314,260,18)
    PUT 157,31 DIV res%,w$
    @graf_shrinkbox(157,31,323,22,260,18)
    IF file$<>"" AND RIGHT$(file$,4)=".CON"
      DEFMOUSE 2
      OPEN "O",#2,file$
      PRINT #2,id3$
      FOR i%=0 TO 26
        PRINT #2,drucker$(i%)
      NEXT i%
      PRINT #2,id4$
      CLOSE #2
    ENDIF
    DEFMOUSE 3
  ENDIF
  ' ----------------------------------------------------------------------------
  ' -          Zurück zum Desktop                                              -
  ' ----------------------------------------------------------------------------
  IF m$(MENU(0))="  Zurück zum Desktop "
    ALERT 3,"|Wollen Sie das Programm|wirklich verlassen?",2,"JA| NEIN ",ta%
    IF ta%=1
      ERASE datei$()
      MENU KILL
      FOR i%=0 TO 3
        VOID XBIOS(7,i%,def_farben%(i%))
      NEXT i%
      QUIT
    ENDIF
  ENDIF
  DEFMOUSE 3
  label_1:
RETURN
' ------------------------------------------------------------------------------
' -          Drucken                                                           -
' ------------------------------------------------------------------------------
PROCEDURE drucke(druck$)
  LOCAL i%,char$
  FOR i%=1 TO LEN(druck$)
    char$=MID$(druck$,i%,1)
    IF char$="ä" OR char$="Ä" OR char$="ö" OR char$="Ö" OR char$="ü" OR char$="Ü" OR char$="×" OR char$="▌" OR char$="|" OR char$="~" OR char$="[" OR char$="]" OR char$="{" OR char$="}" OR char$="@" OR char$="\"
      IF char$="ä"
        LPRINT drucker$(1);
      ENDIF
      IF char$="Ä"
        LPRINT drucker$(2);
      ENDIF
      IF char$="ö"
        LPRINT drucker$(3);
      ENDIF
      IF char$="Ö"
        LPRINT drucker$(4);
      ENDIF
      IF char$="ü"
        LPRINT drucker$(5);
      ENDIF
      IF char$="Ü"
        LPRINT drucker$(6);
      ENDIF
      IF char$="×"
        LPRINT drucker$(7);
      ENDIF
      IF char$="▌"
        LPRINT drucker$(8);
      ENDIF
      IF char$="|"
        LPRINT drucker$(9);
      ENDIF
      IF char$="~"
        LPRINT drucker$(10);
      ENDIF
      IF char$="["
        LPRINT drucker$(11);
      ENDIF
      IF char$="]"
        LPRINT drucker$(12);
      ENDIF
      IF char$="{"
        LPRINT drucker$(13);
      ENDIF
      IF char$="}"
        LPRINT drucker$(14)
      ENDIF
      IF char$="@"
        LPRINT drucker$(15);
      ENDIF
      IF char$="\"
        LPRINT drucker$(16);
      ENDIF
    ELSE
      LPRINT char$;
    ENDIF
  NEXT i%
  LPRINT
RETURN
' ------------------------------------------------------------------------------
' -          Maske für Ändern, Löschen, Suchen und Sortieren                   -
' ------------------------------------------------------------------------------
PROCEDURE aend_loesch_feld(s1$,s2$,s3$,was%)
  LOCAL lng%,i%,j%
  eingabe_status%=-1
  DEFFILL 0,0
  GET 100,50 DIV res%,540,350 DIV res%,b$
  @graf_growbox(100,50,440,300,140,18)
  PBOX 100,50 DIV res%,540,350 DIV res%
  FOR i%=0 TO 1
    BOX 100+(i%*2),(50+(i%*2)) DIV res%,540-(i%*2),(350-(i%*2)) DIV res%
  NEXT i%
  GET 215,364 DIV res%,425,394 DIV res%,c$
  @graf_growbox(215,364,90,30,140,18)
  PBOX 215,364 DIV res%,305,394 DIV res%
  @graf_growbox(335,364,90,30,140,18)
  PBOX 335,364 DIV res%,425,394 DIV res%
  FOR j%=0 TO 1
    FOR i%=0 TO 2
      BOX (215+i%)+(j%*120),(364+i%) DIV res%,(305-i%)+(j%*120),(394-i%) DIV res%
    NEXT i%
  NEXT j%
  DEFTEXT col1%,16,0,norm%
  TEXT 252,385 DIV res%,"OK"
  TEXT 347,385 DIV res%,"ABBRUCH"
  DEFTEXT col2%,5,0,med%
  TEXT 200,80 DIV res%,240,s1$
  RBOX 190,57 DIV res%,450,87 DIV res%
  DEFTEXT col2%,1,0,norm%
  TEXT 120,123 DIV res%,s2$
  DEFTEXT col1%,0,0,norm%
  FOR i%=1 TO felder%
    BOX 298,(108+((i%-1)*25)) DIV res%,462,(127+((i%-1)*25)) DIV res%
    TEXT 308,(123+((i%-1)*25)) DIV res%,feld_name$(i%)
  NEXT i%
  DEFFILL 1,1
  worin%=1
  GRAPHMODE 3
  PBOX 299,109 DIV res%,461,126 DIV res%
  REPEAT
    MOUSE mx%,my%,mk%
    IF mk%=1 AND (mx%>298 AND mx%<462)
      FOR i%=1 TO felder%
        IF (my%>((108+((i%-1)*25)) DIV res%) AND my%<(127+((i%-1)*25)) DIV res%) AND (i%<>worin%)
          PBOX 299,(109+((worin%-1)*25)) DIV res%,461,(126+((worin%-1)*25)) DIV res%
          worin%=i%
          PBOX 299,(109+((worin%-1)*25)) DIV res%,461,(126+((worin%-1)*25)) DIV res%
        ENDIF
      NEXT i%
    ENDIF
    IF (my%>(364 DIV res%) AND my%<(394 DIV res%)) AND mk%=1
      IF (mx%>215 AND mx%<305)
        eingabe_status%=0
      ENDIF
      IF (mx%>335 AND mx%<425)
        eingabe_status%=1
      ENDIF
    ENDIF
  UNTIL eingabe_status%<>-1
  DEFFILL 0,0
  GRAPHMODE 1
  IF eingabe_status%=0
    PBOX 110,128 DIV res%,530,345 DIV res%
    IF was%=1
      PBOX 299,109 DIV res%,461,126 DIV res%
      BOX 298,108 DIV res%,462,127 DIV res%
      DEFTEXT col3%,0,0,norm%
      TEXT 308,123 DIV res%,feld_name$(worin%)
      DEFTEXT col1%,1,0,norm%
      TEXT 120,180 DIV res%,s3$
      DEFTEXT col3%,0,0,norm%
      lng%=feld_laenge%(worin%)*8
      IF lng%>35*8
        lng%=35*8
      ENDIF
      LINE 240,184 DIV res%,240+(lng%),184 DIV res%
      feld$(1)=""
      ok$(1)=""
      xpos%(1)=240
      ypos%(1)=180 DIV res%
      laenge%(1)=lng% DIV 8
      laenge%(i%)=0
      @eingabe(1,215,365 DIV res%,302,393 DIV res%,343,365 DIV res%,425,393 DIV res%)
    ENDIF
  ENDIF
RETURN
' ------------------------------------------------------------------------------
' -          Sortieralgorithmus Bubblesort                                     -
' ------------------------------------------------------------------------------
PROCEDURE sort(wonach%)
  LOCAL i%,j%,k%
  FOR i%=eintraege%-1 DOWNTO 1
    FOR j%=1 TO i%
      IF UPPER$(datei$(wonach%,j%))>UPPER$(datei$(wonach%,j%+1))
        FOR k%=1 TO felder%
          SWAP datei$(k%,j%),datei$(k%,j%+1)
        NEXT k%
      ENDIF
    NEXT j%
  NEXT i%
RETURN
' ------------------------------------------------------------------------------
' -          Suchen eines Eintrages                                            -
' ------------------------------------------------------------------------------
PROCEDURE search(was$,worin%,start%)
  LOCAL i%,fin%
  CLR gefunden
  fin%=LEN(was$)
  FOR i%=LEN(was$) DOWNTO 1
    IF MID$(was$,i%,1)=" "
      fin%=i%-1
      was$=LEFT$(was$,fin%)
    ENDIF
  NEXT i%
  i%=start%
  WHILE i%<=eintraege%
    IF LEFT$(datei$(worin%,i%),fin%)=was$
      gefunden=i%
    ENDIF
    EXIT IF gefunden>0
    INC i%
  WEND
RETURN
' ------------------------------------------------------------------------------
' -          Ausgabe eines Eintrages nach suchen, ...                          -
' ------------------------------------------------------------------------------
PROCEDURE ausgabe(nr%,t$)
  LOCAL i%,j%
  TITLEW 1,t$
  info$="     Eintrag No.: 00000     einfügen     Name: "+int_name$
  INFOW 1,info$
  @graf_growbox(1,18,638,340,140,18)
  OPENW 1,639,340 DIV res%
  CLS
  DEFTEXT col2%,1,0,norm%
  FOR i%=1 TO felder%
    TEXT 5,(35+(i%*25)) DIV res%,144,feld_name$(i%)
    LINE 150,(39+(i%*25)) DIV res%,150+(feld_laenge%(i%)*8),(39+(i%*25)) DIV res%
  NEXT i%
  hilf$="00000"
  hilf$=RIGHT$(hilf$,5-LEN(STR$(nr%)))+STR$(nr%)
  MID$(info$,18,5)=hilf$
  INFOW 1,info$
  DEFTEXT col3%,0,0,norm%
  FOR i%=1 TO felder%
    TEXT 150,(35+(i%*25)) DIV res%,SPACE$(feld_laenge%(i%))
    TEXT 150,(35+(i%*25)) DIV res%,datei$(i%,nr%)
  NEXT i%
RETURN
' ------------------------------------------------------------------------------
' -          Eingaberoutine                                                    -
' ------------------------------------------------------------------------------
PROCEDURE eingabe(anz_feld%,mx1%,my1%,mx2%,my2%,mx3%,my3%,mx4%,my4%)
  LOCAL i%,j%,ta$,zeile%,spalte%,ok!
  DEFTEXT col3%,0,0,norm%
  FOR i%=1 TO 81
    in$(i%)=feld$(i%)
    IF LEN(in$(i%))<>laenge%(i%)
      FOR j%=LEN(in$(i%))+1 TO laenge%(i%)
        in$(i%)=in$(i%)+" "
      NEXT j%
    ENDIF
    IF ok$(i%)=""
      ok$(i%)=" ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789äÄöÖüÜ×▌,.-;:_<>[]{}@\+*~|#^'`?=)(/&%$▌!"""
    ENDIF
  NEXT i%
  spalte%=1
  zeile%=1
  eingabe_status%=0
  @cursor(col3%,1,1)
  ' ---------- Tastaturabfrage -------------------------------------------------
  taste:
  REPEAT
    ta$=INKEY$
    IF (ta$>="a" AND ta$<="z") AND ok$(zeile%)=hex$
      ta$=CHR$(ASC(ta$)-32)
    ENDIF
    MOUSE mx%,my%,mk%
    IF (mx%>=mx1% AND mx%<=mx2%) AND (my%>=my1% AND my%<=my2%) AND mk%=1
      eingabe_status%=0
      GOTO eingabe_ende
    ENDIF
    IF (mx%>=mx3% AND mx%<=mx4%) AND (my%>=my3% AND my%<=my4%) AND mk%=1
      eingabe_status%=1
      GOTO eingabe_ende
    ENDIF
  UNTIL ta$<>""
  ' ---------- Bei TAB fünf Zeichen nach rechts --------------------------------
  IF LEFT$(ta$,1)=CHR$(9)
    @cursor(0,spalte%,zeile%)
    ADD spalte%,5
    IF spalte%>laenge%(zeile%)
      spalte%=laenge%(zeile%)
    ENDIF
    @cursor(col3%,spalte%,zeile%)
    GOTO taste
  ENDIF
  ' ---------- Bei ESC Eingaberoutine verlassen mit Text-Übernahme -------------
  IF LEFT$(ta$,1)=CHR$(27)
    eingabe_status%=0
    GOTO eingabe_ende
  ENDIF
  ' ---------- Bei UNDO Eingaberoutine verlassen ohne Übernahme der Texte ------
  IF (ASC(LEFT$(ta$,1))=0) AND (ASC(RIGHT$(ta$,1))=97)
    eingabe_status%=1
    GOTO eingabe_ende
  ENDIF
  ' ---------- Bei HELP umschalten zwischen Einfüge- und Überschreibmodus ------
  IF (ASC(LEFT$(ta$,1))=0) AND (ASC(RIGHT$(ta$,1))=98)
    IF ins!=FALSE
      ins!=TRUE
    ELSE
      ins!=FALSE
    ENDIF
    MID$(info$,29,9)=MID$(inf$,1+(9*ABS(ins!=FALSE)),9)
    INFOW 1,info$
  ENDIF
  ' ---------- Bei RETURN in die nächste Zeile springen ------------------------
  IF LEFT$(ta$)=CHR$(13)
    @cursor(0,spalte%,zeile%)
    spalte%=1
    INC zeile%
    IF zeile%>anz_feld%
      eingabe_status%=0
      GOTO eingabe_ende
    ENDIF
    @cursor(col3%,spalte%,zeile%)
    GOTO taste
  ENDIF
  ' ---------- eine Zeile hoch springen ----------------------------------------
  IF (ASC(LEFT$(ta$,1))=0) AND (ASC(RIGHT$(ta$,1))=72)
    @cursor(0,spalte%,zeile%)
    DEC zeile%
    IF zeile%<1
      zeile%=anz_feld%
    ENDIF
    IF spalte%>laenge%(zeile%)
      spalte%=laenge%(zeile%)
    ENDIF
    @cursor(col3%,spalte%,zeile%)
    GOTO taste
  ENDIF
  ' ---------- eine Zeile runter springen --------------------------------------
  IF (ASC(LEFT$(ta$,1))=0) AND (ASC(RIGHT$(ta$,1))=80)
    @cursor(0,spalte%,zeile%)
    INC zeile%
    IF zeile%>anz_feld%
      zeile%=1
    ENDIF
    IF spalte%>laenge%(zeile%)
      spalte%=laenge%(zeile%)
    ENDIF
    @cursor(col3%,spalte%,zeile%)
    GOTO taste
  ENDIF
  ' ---------- Cursor eine Spalte nach links bewegen ---------------------------
  IF (ASC(LEFT$(ta$,1))=0) AND (ASC(RIGHT$(ta$,1))=75)
    @cursor(0,spalte%,zeile%)
    DEC spalte%
    IF spalte%<1
      spalte%=laenge%(zeile%)
    ENDIF
    @cursor(col3%,spalte%,zeile%)
    GOTO taste
  ENDIF
  ' ---------- Cursor eine Spalte nach rechts bewegen --------------------------
  IF (ASC(LEFT$(ta$,1))=0) AND (ASC(RIGHT$(ta$,1))=77)
    @cursor(0,spalte%,zeile%)
    INC spalte%
    IF spalte%>laenge%(zeile%)
      spalte%=1
    ENDIF
    @cursor(col3%,spalte%,zeile%)
    GOTO taste
  ENDIF
  ' ---------- Cursor in Home-Position -----------------------------------------
  IF (ASC(LEFT$(ta$,1))=0) AND (ASC(RIGHT$(ta$,1))=71)
    @cursor(0,spalte%,zeile%)
    spalte%=1
    zeile%=1
    @cursor(col3%,spalte%,zeile%)
    GOTO taste
  ENDIF
  ' ---------- Die gesamte Eingabe löschen -------------------------------------
  IF (ASC(LEFT$(ta$,1))=0) AND (ASC(RIGHT$(ta$,1))=119)
    @cursor(0,spalte%,zeile%)
    FOR i%=1 TO anz_feld%
      in$(i%)=SPACE$(laenge%(i%))
      TEXT xpos%(i%),ypos%(i%),in$(i%)
    NEXT i%
    spalte%=1
    zeile%=1
    @cursor(col3%,spalte%,zeile%)
    GOTO taste
  ENDIF
  ' ---------- Leerzeichen einfügen --------------------------------------------
  IF (ASC(LEFT$(ta$,1))=0) AND (ASC(RIGHT$(ta$,1))=82)
    in$(zeile%)=LEFT$(in$(zeile%),spalte%-1)+" "+MID$(in$(zeile%),spalte%,laenge%(zeile%)-spalte%)
    TEXT xpos%(zeile%),ypos%(zeile%),in$(zeile%)
    GOTO taste
  ENDIF
  ' ---------- Zeichen unter dem Cursor löschen und den Rest einziehen ---------
  IF LEFT$(ta$)=CHR$(127)
    in$(zeile%)=LEFT$(in$(zeile%),spalte%-1)+RIGHT$(in$(zeile%),laenge%(zeile%)-spalte%)+" "
    TEXT xpos%(zeile%),ypos%(zeile%),in$(zeile%)
    GOTO taste
  ENDIF
  ' ---------- Zeichen links vom Cursor löschen und den Rest nachziehen --------
  IF LEFT$(ta$)=CHR$(8)
    IF spalte%-1<1
      OUT 2,7
      GOTO taste
    ELSE
      @cursor(0,spalte%,zeile%)
      in$(zeile%)=LEFT$(in$(zeile%),spalte%-2)+RIGHT$(in$(zeile%),laenge%(zeile%)-spalte%+1)+" "
      DEC spalte%
      TEXT xpos%(zeile%),ypos%(zeile%),in$(zeile%)
      @cursor(col3%,spalte%,zeile%)
    ENDIF
    GOTO taste
  ENDIF
  ' ---------- Überprüfung ob gültiges Zeichen ---------------------------------
  i%=1
  ok!=FALSE
  WHILE (i%<LEN(ok$(zeile%))+1)
    IF ta$=MID$(ok$(zeile%),i%,1)
      ok!=TRUE
      @cursor(0,spalte%,zeile%)
      in$(zeile%)=LEFT$(in$(zeile%),spalte%-1)+ta$+MID$(in$(zeile%),spalte%+ABS(ins!=FALSE),laenge%(zeile%)-spalte%)
    ENDIF
    INC i%
  WEND
  IF ok!=TRUE
    INC spalte%
    IF spalte%>laenge%(zeile%)
      spalte%=laenge%(zeile%)
    ENDIF
    DEFTEXT col3%,0,0,norm%
    TEXT xpos%(zeile%),ypos%(zeile%),LEFT$(in$(zeile%),laenge%(zeile%))
    @cursor(col3%,spalte%,zeile%)
  ENDIF
  GOTO taste
  ' ---------- Beenden der Eingaberoutine mit/ohne Textübernahme ---------------
  eingabe_ende:
  IF eingabe_status%=0
    FOR i%=1 TO anz_feld%
      feld$(i%)=LEFT$(in$(i%),laenge%(i%))
    NEXT i%
  ENDIF
  @cursor(0,spalte%,zeile%)
RETURN
' ------------------------------------------------------------------------------
' -          Cursor zeichnen oder löschen                                      -
' ------------------------------------------------------------------------------
PROCEDURE cursor(cur_farbe%,sp%,ze%)
  COLOR cur_farbe%
  LINE xpos%(ze%)+(sp%*8)-8,ypos%(ze%)+3,xpos%(ze%)+(sp%*8),ypos%(ze%)+3
  COLOR col1%
RETURN
' ------------------------------------------------------------------------------
' -           sich vergrö×ernde Box zeichenen                                  -
' ------------------------------------------------------------------------------
PROCEDURE graf_growbox(x_alt%,y_alt%,w_alt%,h_alt%,x_neu%,y_neu%)
  DPOKE GINTIN,x_neu%
  DPOKE GINTIN+2,y_neu% DIV res%
  DPOKE GINTIN+4,16
  DPOKE GINTIN+6,16 DIV res%
  DPOKE GINTIN+8,x_alt%
  DPOKE GINTIN+10,y_alt% DIV res%
  DPOKE GINTIN+12,w_alt%
  DPOKE GINTIN+14,h_alt% DIV res%
  GEMSYS (73)
RETURN
' ------------------------------------------------------------------------------
' -           sich verkleinernde Box zeichnen                                  -
' ------------------------------------------------------------------------------
PROCEDURE graf_shrinkbox(x_alt%,y_alt%,w_alt%,h_alt%,x_neu%,y_neu%)
  DPOKE GINTIN,x_neu%
  DPOKE GINTIN+2,y_neu% DIV res%
  DPOKE GINTIN+4,16
  DPOKE GINTIN+6,16 DIV res%
  DPOKE GINTIN+8,x_alt%
  DPOKE GINTIN+10,y_alt% DIV res%
  DPOKE GINTIN+12,w_alt%
  DPOKE GINTIN+14,h_alt% DIV res%
  GEMSYS (74)
RETURN
' ******************************************************************************
