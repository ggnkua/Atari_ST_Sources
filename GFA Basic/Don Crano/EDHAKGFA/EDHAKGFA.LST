' Edhak.ACC calling routines..                     by Don Crano        10/10/92
'
CLS
RESERVE -100000
DIM pipebuff&(8),m$(10)
adr%=MALLOC(60000)                !Reserve a storage area for the buffer
IF adr%<=0                        !If not enough memory, lets not bomb the Sys
  PRINT " Not enough memory availible to run this Demo"
  PAUSE 1000
  EDIT
ENDIF
PRINT " Make sure you have EDHAK v2.3x or newer installed as EDHAK.ACC"
PRINT " Enter the text you want to send to EDHAK.ACC......."
PRINT " Enter Alternate a to send your text to EdHak......."
PRINT "------------------------------------------------------------------------"
PRINT
@text_edit                         !Enter something to send Edhak
BMOVE V:test$,adr%,lng%            !Send our text to the buffer we made
SGET screen$                       !Save the screen
@ed_send                           !Send a message and the buffer to Edhak
~EVNT_MESAG(V:pipebuff&(0))        !Look for a message on the Gem Pipe
IF pipebuff&(0)=17236              !Is that message from Edhak
  SPUT screen$                     !Send the screen back for cleanup
  @read_message                    !Lets go get the message
ENDIF
~MFREE(adr%)
PRINT
PRINT
INPUT "Run again  Y/N ",a$
a$=UPPER$(a$)
IF a$="Y"
  RUN
ENDIF
EDIT
'     ******************* Send the message/s and buffer *******************
PROCEDURE ed_send
  call_ap_id%=APPL_INIT()           !Get this Applications ID
  ap_id%=APPL_FIND("EDHAK   ")      !Get Edhak's ID
  IF ap_id%<0                       !Is Edhak installed as an ACC
    PRINT " Edhak not found "
  ELSE
    pipebuff&(0)=40                 !GemBase   Open this ACC
    pipebuff&(1)=call_ap_id%        !Send our ID
    pipebuff&(2)=16                 !Read all 16 bytes of this message
    pipebuff&(5)=17236              !Edhak's magic number
    pipebuff&(6)=2                  !Pass buffer adr/size info
    result%=APPL_WRITE(ap_id%,16,V:pipebuff&(0)) !Gem call, send the message
    '
    ' ********************* Sending second message **********************
    '
    pipebuff&(0)=0                   ! 0= half window   1= Full window
    pipebuff&(1)=1                   ! 0=don't load     1= Load
    pipebuff&(2)=WORD(SWAP(adr%))    !High word adr of our buffer
    pipebuff&(3)=WORD(adr%)          !Low word adr of our buffer
    pipebuff&(4)=WORD(SWAP(lng%))    !High word of lenght of our used buff
    pipebuff&(5)=WORD(lng%)          !Low word of lenght of our used buff
    pipebuff&(6)=WORD(SWAP(60000))  !High word of our total buff size
    pipebuff&(7)=WORD(60000)        !Low word of our total buff size
    result%=APPL_WRITE(ap_id%,16,V:pipebuff&(0))  !Gem call, send message
  ENDIF
RETURN
'     *******************  Read the incoming message   ********************
PROCEDURE read_message
  lng%=(WORD(pipebuff&(3))*&H10000)+(WORD(pipebuff&(4)))!Lenght of incoming data
  test$=SPACE$(lng%)                       !Setup a string to that lenght
  BMOVE adr%,V:test$,lng%                !Move the data Buff to string
  PRINT
  PRINT
  PRINT " Now this is the text that EdHak just sent back to your application.."
  PRINT "-----------------------------------------------------------------------"
  PRINT
  PRINT test$
  pipebuff&(0)=0
RETURN
'     *****************  Our quick and dirty text editor  *****************
PROCEDURE text_edit
  HIDEM
  PRINT CHR$(27)+"e";
  DO
    KEYGET get.code%
    ABSOLUTE ascii|,V:get.code%+3 ! ASCII-code of key
    '
    EXIT IF HEX$(get.code%,6)="1E0000"
    IF ascii|<127
      IF ascii|=13
        PRINT CHR$(ascii|);
        PRINT CHR$(10);
        test$=test$+CHR$(13)+CHR$(10)
      ELSE
        PRINT CHR$(ascii|);
        IF ascii|=8
          PRINT CHR$(27)+"K";
          test$=LEFT$(test$,(LEN(test$)-1))
        ELSE
          test$=test$+CHR$(ascii|)
        ENDIF
      ENDIF
    ENDIF
  LOOP
  PRINT CHR$(27)+"f";
  SHOWM
  {XBIOS(14,1)+6}=0               ! empty keyboard-buffer before leaving
  lng%=LEN(test$)
RETURN
