         ?             list commands available
         bell          beep
         bye,exit      exit from shell or shell script
         cd            set current directory
                       ( with no argument, display current directory )
         del,era,rm    delete file
         copy          copy file
         d,dir,ls      display directory contents
                       ( with no argument, current directory )
         echo          argument "on" or "off"; specify whether command
                       lines in scripts should show on the screen
         log           "on" or "off" ; whether names of programs entered
                       should appear on screen
         md            create new directory
         path          define discs &/or directories to be searched for
                       programs to be executed. Use ";" as separator.
         pause         wait for keypress
         pdir          list directory to printer
         print         list file to printer
         ren           rename file
         rd            delete directory ( must be empty )
