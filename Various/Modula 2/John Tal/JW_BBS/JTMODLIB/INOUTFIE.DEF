DEFINITION MODULE InOutField;

(*
    Emulation of IBM System 23 Datamaster Fields statements

    This type of Screen I/O was one of IBM's first attempts at full
    screen processing on a micro.

    See System 23 Basic Reference Manual for more thorough descr.


    Provides clean, logical-handling of data for input by user

    Author: J. Tal/02-03-1986
    Last Edit: 04-16-1986

    Format for ScreenControl

        'aa,bb,c d,ee,ff'
                                 a = 2 digit,left-zero padded Y position
                                 b = 2 digit,left-zero padded X position
                                 c = Type of Data
                                              C = character
                                              N = Numeric (not supported)
                                 d = Width of field
                                 e = Control attributes
                                              N = normal
                                              B = blinking
                                              H = highlight
                                              R = reverse
                                              U = underline
                                 f = Post-operation attribute (not supported)

      OutField('01,01,C 40,R,A','This data must be no shorter than 40 ch');

*)


EXPORT QUALIFIED
  OutField, InField;

PROCEDURE OutField( ScreenControl,ShowData : ARRAY OF CHAR);

PROCEDURE InField(ScreenControl : ARRAY OF CHAR; VAR FieldData : ARRAY OF CHAR;
                  VAR FieldNumber : INTEGER);


END InOutField.
