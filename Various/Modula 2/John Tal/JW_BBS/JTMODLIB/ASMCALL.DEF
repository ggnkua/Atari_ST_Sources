DEFINITION MODULE AsmCall;


(*

   Author: J. Tal
           Rollins Medical/Dental Systems   Southfield, MI  48075
           (313) 423-7200

   Date: 02/28/86


   Procedure to CALL assembly language subroutines that have been loaded
   into memory and terminated and stayed resident.

   The example here was developed to use with FABS of Computer Control
   Systems, Largo, Florida.   FABS is a routine for handling keyed files.
   FABS loads and writes it load segment into a file called FSEG.

   In this example the value of FSEG is read and used for the variable
   SEGMENT of this call.

   The entry point into this routine is OFFSET, which is the entry for
   compiled BASIC to pass 4 byte string descriptors.

   The code presented in AsmCall could be modified for most any application.

*)


PROCEDURE AsmCall(CMND : ARRAY OF CHAR; VAR ERRF,RECNO,ADRKEY : CARDINAL;
                   OFFSET,SEGMENT : CARDINAL);




END AsmCall.