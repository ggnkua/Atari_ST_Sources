library "gemvdi","xbios","bios","gemdos"
defint a-z
rem $option y
const numitems=9,charsperline=10,amount=2
dim shared source(10),dest(10),xy(7),movexy(7),mparam(5),mvec(1),sizes(100)
dim shared cols(15),charset(16033),piccy(16033),file$(9)

mouse -1
origrez=fngetrez
if origrez=2 then
	rez=2
else
	rez=1
end if
if origrez=1 then screen 0

txtwidth=32*rez : txtheight=12*rez

if rez=1 then
	x1=2:y1=188:x2=319:y2=200
else
	x1=40:y1=376:x2=600:y2=400
end if

for blank=0 to 15
	palette blank,0
next
for blank&=fnlogbase& to fnlogbase&+32000 step 4
	pokel blank&,0
next

if rez=1 then
	coltxt varptr(charset(0))
	colpic varptr(piccy(0))
	end if
if rez=2 then
	monotxt varptr(charset(0))
	monopic varptr(piccy(0))
	end if

fontsize varptr(sizes(0))

for conv=0 to 95
	sizes(conv)=((sizes(conv)\amount))*rez
next
sizes(60)=21*rez
sizes(92)=31*rez
sizes(62)=30*rez
sizes(94)=27*rez
sizes(59)=7*rez

restore filenames
for getfiles=1 to numitems
	read file$(getfiles)
next

keyvalue=0:altvalue=0:maddr&=0
disable

blockmove varptr(piccy(0))+2,varptr(cols(0)),32
setpalette cols()
blockmove varptr(charset(0))+34,varptr(charset(0)),32000
blockmove varptr(piccy(0))+34,varptr(piccy(0)),32000

'  init source MFDB
sourcemfdb&=varptr(source(0))
pokel sourcemfdb&,varptr(charset(0))
source(2)=320*rez
source(3)=200*rez
source(4)=20*rez
source(5)=0
if rez=1 then
	source(6)=4
else
	source(6)=1
end if

'  init destination MFDB
destmfdb&=varptr(dest(0))
pokel destmfdb&,FNphysbase&
dest(2)=320*rez
dest(3)=200*rez
dest(4)=20*rez
dest(5)=0
if rez=1 then
	dest(6)=4
else
	dest(6)=1
end if

text$=""
gettext

textlen=len(text$)
dim shared msg(((textlen+20)\2)+1)
ptr&=varptr(msg(0))
for conv=1 to textlen
	pokeb ptr&,asc((mid$(text$,conv,1)))-32
	incr ptr&
next
text$=""

movexy(0)=x1
movexy(1)=y1
movexy(2)=x2
movexy(3)=y2
movexy(4)=movexy(0)-amount
movexy(5)=movexy(1)
movexy(6)=movexy(2)-amount
movexy(7)=movexy(3)

xy(4)=x2-3
xy(5)=y1
xy(6)=x2-2
xy(7)=y2

pic_switch 1,varptr(piccy(0))
do
	ptr&=varptr(msg(0))
	for char=0 to textlen-1
		charnum=peekb(ptr&)
		wide=sizes(charnum)
		xy(1)=txtheight*(charnum\charsperline)
		xy(3)=xy(1)+txtheight
		xy(0)=txtwidth*fnmod(charnum,charsperline)
		xy(2)=xy(0)+amount
		for pix=0 to wide
			vsync
			vro_cpyfm 3,xy(),sourcemfdb&,destmfdb&
			vro_cpyfm 3,movexy(),destmfdb&,destmfdb&
			xy(0)=xy(0)+amount
			xy(2)=xy(2)+amount
		next
		key$=ucase$(inkey$)
		incr ptr&
		if key$="0" then
			stack&=fnsuper&(0)
			pokeb &hff820a,peekb(&hff820a) xor 2
			stack&=fnsuper&(stack&)
			end if
		if key$>="1" and key$<="9" then exit for
	next
loop until key$>="1" and key$<="9"
pic_switch 0,varptr(piccy(0))
exists=fexists(file$(val(key$)))
enable
if origrez=1 then screen 1
palette
if not(exists) then beep : system
chain file$(val(key$))

def fnmod(first,second)
fnmod=first-((first\second)*second)
end def

