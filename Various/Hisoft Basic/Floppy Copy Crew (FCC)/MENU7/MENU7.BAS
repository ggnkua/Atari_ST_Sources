library "gemvdi","xbios","bios","gemdos"
defint a-z
rem $option y
dim shared source(10),dest(10),xy(7),movexy(7),mparam(5),mvec(1),sizes(100)
dim shared cols(15),charset(16033),piccy(16033)

mouse -1
rez=1
origrez=fngetrez
if origrez=2 then
	window open 2,"",0,0,0,0,0
	window fullw
	cls
	print space$(20);"Sorry this Menu Dosn't work in High Res"
	print
	print space$(19);"But then again nor does GFA RAYTRACE 2.0!!"
	while inkey$=""
	wend
	system
end if

if origrez=1 then screen 0

txtwidth=32
txtheight=12

for blank=0 to 15
	palette blank,0
next
for blank&=fnphysbase& to fnphysbase&+32000 step 4
	pokel blank&,0
next

colfnt varptr(charset(0))
colpic varptr(piccy(0))

blockmove varptr(piccy(0))+2,varptr(cols(0)),32
setpalette cols()
blockmove varptr(charset(0))+34,varptr(charset(0)),32000
blockmove varptr(piccy(0))+34,varptr(piccy(0)),32000

pic_switch 1

fontsize varptr(sizes(0))
for conv=0 to 95
	sizes(conv)=((sizes(conv)\2))
next
sizes(60)=21
sizes(92)=31
sizes(62)=30
sizes(94)=27
sizes(59)=7

keyvalue=0:altvalue=0:maddr&=0
disable

'  init source MFDB
sourcemfdb&=varptr(source(0))
pokel sourcemfdb&,varptr(charset(0))
source(2)=320
source(3)=200
source(4)=20
source(5)=0
source(6)=4

'  init destination MFDB
destmfdb&=varptr(dest(0))
pokel destmfdb&,FNphysbase&
blockmove sourcemfdb&+4,destmfdb&+4,10

text$=""
gettext

textlen=len(text$)
dim shared msg(((textlen+20)\2)+1)
ptr&=varptr(msg(0))
for conv=1 to textlen
	pokeb ptr&,asc((mid$(text$,conv,1)))-32
	incr ptr&
next
text$=""

movexy(0)=2
movexy(1)=188
movexy(2)=319
movexy(3)=200
movexy(4)=0
movexy(5)=188
movexy(6)=317
movexy(7)=200

xy(4)=316
xy(5)=188
xy(6)=317
xy(7)=200

do
	ptr&=varptr(msg(0))
	for char=0 to textlen-1
		charnum=peekb(ptr&)
		wide=sizes(charnum)
		xy(1)=txtheight*(charnum\10)
		xy(3)=xy(1)+txtheight
		xy(0)=txtwidth*(charnum MOD 10)
		xy(2)=xy(0)+2
		for pix=0 to wide
			vsync
			vro_cpyfm 3,xy(),sourcemfdb&,destmfdb&
			vro_cpyfm 3,movexy(),destmfdb&,destmfdb&
			xy(0)=xy(0)+2
			xy(2)=xy(2)+2
		next
		key$=ucase$(inkey$)
		incr ptr&
		if key$="0" then
			stack&=fnsuper&(0)
			pokeb &hff820a,peekb(&hff820a) xor 2
			stack&=fnsuper&(stack&)
		end if
		if key$="1" then exit for
	next
loop until key$="1"
pic_switch 0
exists=fexists("RAYTRACE.PRG")
enable
if origrez=1 then screen 1
palette
if not(exists) then beep : system
chain "RAYTRACE.PRG"

