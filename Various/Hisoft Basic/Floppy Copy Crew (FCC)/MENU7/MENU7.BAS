sub disable
shared keyvalue,altvalue,maddr&
local stack&
stack&=fnsuper&(0)
keyvalue=peekb(&h484)
pokeb &h484,keyvalue and &h1111100
altvalue=peekw(&h4ee)
pokew &h4ee,1
maddr&=fnkbdvbase&
maddr&=peekl(maddr&+16)
pokew varptr(mvec(0)),20085
pokeb varptr(mparam(0))+1,255
initmous 0,varptr(mparam(0)),varptr(mvec(0))
stack&=fnsuper&(stack&)
end sub

sub enable
shared keyvalue,altvalue,maddr&,origrez
local xmax,ymax,stack&,dummy
stack&=fnsuper&(0)
pokeb &h484,keyvalue
pokew &h4ee,altvalue
pokel varptr(mparam(0)),65537
ymax=199
xmax=(320+(320*origrez)-1)
pokew varptr(mparam(0))+4,xmax
pokew varptr(mparam(0))+6,ymax
pokew varptr(mparam(0))+8,1
pokeb varptr(mparam(0))+10,1
initmous 1,varptr(mparam(0)),maddr&
pokel &h4da,0
stack&=fnsuper&(stack&)
dummy=FNgiaccess(0&,136&)
dummy=FNgiaccess(0&,137&)
dummy=FNgiaccess(0&,138&)
end sub 

SUB pic_switch(inout)
LOCAL addres&,step_rate,endpass,start,wait,x,y
	addres&=varptr(piccy(0))
	step_rate=1
	if inout=0 then
	  pokel addres&,0
	  pokel addres&+4,0
	end if
	for x=0 to 160 step 8
		if step_rate=1 then
			step_rate=-1 : start=199 : endpass=0
		else
			step_rate=1 : start=0 : endpass=199
		end if
		for y=start to endpass step step_rate
			for wait=1 to (ABS(start-endpass)\6)
			next wait
			blockmove addres&+(((y*160)+x)*inout),FNphysbase&+(y*160)+x,8
		next y
	next x
END SUB

sub decrunch(addr&,nummain&,numbytes&,crunchflag&)
local item&,trans&,howmany&,depack&
for trans&=1 to nummain&
	read item&
	if item&=crunchflag& then
		read howmany&,item&
		for depack&=addr& to addr&+(4*howmany&) step 4
			pokel depack&,item&
		next
		addr&=addr&+(4*howmany&)
	else
		pokel addr&,item& : addr&=addr&+4
	end if
next
for trans&=1 to numbytes&
	read item&
	pokeb addr&,item&
	incr addr&
next
end sub
 
sub fontsize(addr&) ' 190 bytes.
restore fontsize_data
decrunch addr&, 44, 2, 0
end sub
