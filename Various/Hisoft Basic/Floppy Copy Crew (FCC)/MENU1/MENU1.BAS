library "gemvdi","xbios","bios" 
defint a-z
rem $option y
const numitems=23
window open 2,"Menu 1",0,0,1,1,0
rez=fngetrez
dim shared source(10),dest(10),xy(7),movexy(7),megacol(4,4),startfix(7)
dim shared cols(15),file$(25),charset(6000),piccy(16033),sample(6000),code(1400)

if inkey$="!" then system ' back door getout

' clear k/b buffer
do
loop until inkey$=""

mouse -1 : window fullw
if rez=0 then 
	?"Please run in medium or hi-rez..!"
	for wait=1 to 100:vsync:next
	system
	end if

if rez=1 then x1=2:y1=185:x2=319:y2=200:height=14
if rez=2 then x1=4:y1=369:x2=636:y2=400:height=28
if rez=1 then screen 0
blit=FNblitmode(-1)
dummy=FNblitmode(blit and &b1111111111111110)
cls

keyvalue=0 : altvalue=0
disable

bascode varptr(code(0))
sam3210 varptr(sample(0))

if rez=1 then
	colourtext varptr(charset(0))
	colourpic varptr(piccy(0))
	end if
if rez=2 then
	monotext varptr(charset(0))
	monopicture varptr(piccy(0))
	end if

' back door getout
if inkey$="!" then
	enable
	system
	end if

setcolor

restore filenames
for numnames=0 to numitems-1
	read file$(numnames)
next

'  init source MFDB
sourcemfdb&=varptr(source(0))
pokel sourcemfdb&,varptr(charset(0))
source(2)=320*rez
source(3)=200*rez
source(4)=20*rez
source(5)=0
source(6)=(-4*(rez=1))+(-1*(rez=2))

'  init destination MFDB
destmfdb&=varptr(dest(0))
pokel destmfdb&,FNphysbase&
dest(2)=320*rez
dest(3)=200*rez
dest(4)=20*rez
dest(5)=0
dest(6)=(-4*(rez=1))+(-1*(rez=2))

settext

textlen=len(text$)
dim shared msg(((textlen+20)\2)+1)
ptr&=varptr(msg(0))
for conv=1 to textlen
	pokeb ptr&,asc((mid$(text$,conv,1)))-32
	incr ptr&
next
text$=""

movexy(0)=x1
movexy(1)=y1-1
movexy(2)=x2
movexy(3)=y2-1
movexy(4)=movexy(0)-(2*rez)
movexy(5)=movexy(1)
movexy(6)=movexy(2)-(2*rez)
movexy(7)=movexy(3)

xy(4)=x2-2
xy(5)=y1+1
xy(6)=x2
xy(7)=y2

col1=&h112
col2=&h223
col3=&h334
col4=&h445

megacol(1,1)=col1:megacol(1,2)=col2:megacol(1,3)=col3:megacol(1,4)=col4
megacol(2,1)=col4:megacol(2,2)=col1:megacol(2,3)=col2:megacol(2,4)=col3
megacol(3,1)=col3:megacol(3,2)=col4:megacol(3,3)=col1:megacol(3,4)=col2
megacol(4,1)=col2:megacol(4,2)=col3:megacol(4,3)=col4:megacol(4,4)=col1

pic_switch
if rez=1 then call start
txtwidth=rez*16
howmany=7
if rez=1 then howmuch=2 else howmuch=4
last$=chr$(asc("A")+numitems)
do
ptr&=varptr(msg(0))
colswitch=1
for char=0 to textlen-1
	charnum=peekb(ptr&)
	xy(1)=txtwidth*(charnum\20)
	xy(3)=xy(1)+txtwidth
	xy(0)=txtwidth*fnmod(charnum,20)
	xy(2)=xy(0)+howmuch
	for pix=0 to howmany
		if rez=1 then call movecols
		vsync
		vro_cpyfm 3,movexy(),destmfdb&,destmfdb&
		vro_cpyfm 3,xy(),sourcemfdb&,destmfdb&
		xy(0)=xy(0)+howmuch
		xy(2)=xy(2)+howmuch
	next
	key$=ucase$(inkey$)
getout:
	incr ptr&
	if key$>="A" and key$<last$ then exit for
next
loop until key$>="A" and key$<last$
replay
picout

if rez=1 then screen 1
palette
keyitem=asc(key$)-asc("A")
enable
if not(fexists(file$(keyitem))) then system
dummy=FNblitmode(blit)
chain file$(keyitem)



def fnmod(first,second)
fnmod=first-((first\second)*second)
end def

sub setcolor
shared rez
local col
for col=0 to 15
	if rez=1 then cols(col)=piccy(col+1) else cols(col)=piccy(col+1)
next
setpalette cols()
end sub

sub movecols
shared colswitch
palette 9,megacol(1,colswitch)
palette 12,megacol(2,colswitch)
palette 14,megacol(3,colswitch)
palette 15,megacol(4,colswitch)
incr colswitch
if colswitch=4 then colswitch=1
end sub

sub start
shared destmfdb&,sourcemfdb&,y1
static count
startfix(0)=0
startfix(1)=0
startfix(2)=15
startfix(3)=15
startfix(5)=y1-1
startfix(7)=y1+14
for count=0 to 19
startfix(4)=(16*count)-1
startfix(6)=14+(16*count)
vro_cpyfm 3,startfix(),sourcemfdb&,destmfdb&
next
end sub

sub picout
shared rez
local blank&,base&,n,wait,size
size=(160\rez)
base&=fnlogbase&
for blank=0 to size-1 step 4
	pokel base&+blank,&hffffffff*(rez-1)
next
for n=0 to (200*rez)-1 step 2
	for wait=1 to 150
	next
	blockmove base&,base&+(n*size),size
	blockmove base&,(base&+32000-size)-(n*size),size
next
end sub

sub pic_switch
shared rez
local pic&,scr&,n,m,rate,max,inc
	rate=160\rez
	max=(200*rez)-1
	inc=2*rez
	pic&=varptr(piccy(17))
	scr&=fnlogbase&
	for n=0 to max
	for m=n to max step inc
	blockmove pic&+(n*rate),scr&+(m*rate),rate
	next
	next
end sub

sub disable
shared keyvalue,altvalue
def seg=&h484
keyvalue=peek(0)
poke 0,keyvalue and &h11111000
def seg=0
altvalue=peek(&h4ee)
poke &h4ee,1
end sub

sub enable
shared keyvalue,altvalue
def seg=&h484
poke 0,keyvalue
def seg=0
poke &h4ee,altvalue
end sub

