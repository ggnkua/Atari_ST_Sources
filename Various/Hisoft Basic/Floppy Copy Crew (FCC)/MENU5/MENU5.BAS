filenames:
data "ZZ_ROUGH.PRG","ART_DIR.PRG","FILM_DIR.PRG","NEOCHROM.PRG","QPAINT2.PRG","GFARTIST.PRG","IFF_CONV.PRG","PICSW7.PRG","PBX_SHOW.PRG"

sub disable
shared keyvalue,altvalue,maddr&
local stack&
stack&=fnsuper&(0)
keyvalue=peekb(&h484)
pokeb &h484,keyvalue and &h1111100
altvalue=peekw(&h4ee)
pokew &h4ee,1
maddr&=fnkbdvbase&
maddr&=peekl(maddr&+16)
pokew varptr(mvec(0)),20085
pokeb varptr(mparam(0))+1,255
initmous 0,varptr(mparam(0)),varptr(mvec(0))
stack&=fnsuper&(stack&)
end sub

sub enable
shared keyvalue,altvalue,maddr&,origrez
local xmax,ymax,stack&
stack&=fnsuper&(0)
pokeb &h484,keyvalue
pokew &h4ee,altvalue
pokeb varptr(mparam(0)),0
pokeb varptr(mparam(0))+1,1
pokeb varptr(mparam(0))+2,1
pokeb varptr(mparam(0))+3,1
if origrez=0 then
	xmax=319
	ymax=199
	end if
if origrez=1 then
	xmax=639
	ymax=199
	end if
if origrez=2 then
	xmax=639
	ymax=399
	end if
pokew varptr(mparam(0))+4,xmax
pokew varptr(mparam(0))+6,ymax
pokew varptr(mparam(0))+8,1
pokeb varptr(mparam(0))+10,1
initmous 1,varptr(mparam(0)),maddr&
pokel &h4da,0
beep
stack&=fnsuper&(stack&)
end sub 

SUB pic_switch(inout,addres&)
shared rez
LOCAL colum,lines,n,slow
	if inout=0 then
		for n=0 to 159
			pokeb addres&+n,0
		next n
	end if
		for lines=0 to 39
			for n=0 to 190 step 40
				blockmove addres&+((((lines+n)*160))*inout),FNlogbase&+((n+lines)*160),160
				for slow=1 to 350
				next slow
			next n
		next lines
END SUB

sub decrunch(addr&,nummain&,numbytes&,crunchflag&)
local item&,trans&,howmany&,depack&
for trans&=1 to nummain&
	read item&
	if item&=crunchflag& then
		read howmany&,item&
		for depack&=addr& to addr&+(4*howmany&) step 4
			pokel depack&,item&
		next
		addr&=addr&+(4*howmany&)
	else
		pokel addr&,item& : addr&=addr&+4
	end if
next
for trans&=1 to numbytes&
	read item&
	pokeb addr&,item&
	incr addr&
next
end sub
 
 
sub fontsize(addr&) ' 190 bytes.
restore fontsize_data
decrunch addr&, 44, 2, 0
end sub
